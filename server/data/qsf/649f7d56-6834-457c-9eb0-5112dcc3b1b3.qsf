        <SG _S="11" N="InsertWaferMap">
          <QY P="MsSql" Q="INSERT INTO QWMSWAFMAP (&#xD;&#xA;   FACTORY,&#xD;&#xA;   LOT_ID,&#xD;&#xA;   WAFER_ID,&#xD;&#xA;   DEVICE_ID,&#xD;&#xA;   REFERENCE_DIE,&#xD;&#xA;   DIE_SIZE_X,&#xD;&#xA;   DIE_SIZE_Y,&#xD;&#xA;   COLS,&#xD;&#xA;   ROWS,&#xD;&#xA;   MAP_FILE_NAME,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   CUS_ID,&#xD;&#xA;   GOOD_QTY,&#xD;&#xA;   BAD_QTY,&#xD;&#xA;   FLAT_ZONE,&#xD;&#xA;   BIN_1_QTY,&#xD;&#xA;   BIN_2_QTY,&#xD;&#xA;   BIN_3_QTY,&#xD;&#xA;   BIN_4_QTY,&#xD;&#xA;   BIN_5_QTY,&#xD;&#xA;   BIN_6_QTY,&#xD;&#xA;   BIN_7_QTY,&#xD;&#xA;   BIN_8_QTY,&#xD;&#xA;   BIN_9_QTY,&#xD;&#xA;   BIN_10_QTY,&#xD;&#xA;   BIN_D_QTY,   &#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   CREATE_USER_ID&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @lot_id,&#xD;&#xA;   @wafer_id,&#xD;&#xA;   @device_id,&#xD;&#xA;   @reference_die,&#xD;&#xA;   @die_size_x,&#xD;&#xA;   @die_size_y,&#xD;&#xA;   @cols,&#xD;&#xA;   @rows,&#xD;&#xA;   @map_file_name,&#xD;&#xA;   @hist_seq,&#xD;&#xA;   @cus_id,&#xD;&#xA;   @good_qty,&#xD;&#xA;   @bad_qty,&#xD;&#xA;   @flat_zone,&#xD;&#xA;   @bin_1_qty,&#xD;&#xA;   @bin_2_qty,&#xD;&#xA;   @bin_3_qty,&#xD;&#xA;   @bin_4_qty,&#xD;&#xA;   @bin_5_qty,&#xD;&#xA;   @bin_6_qty,&#xD;&#xA;   @bin_7_qty,&#xD;&#xA;   @bin_8_qty,&#xD;&#xA;   @bin_9_qty,&#xD;&#xA;   @bin_10_qty,&#xD;&#xA;   @bin_d_qty,&#xD;&#xA;   @create_time,&#xD;&#xA;   @create_user_id&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="lot_id" />
            <QP N="wafer_id" />
            <QP N="device_id" />
            <QP N="reference_die" />
            <QP N="die_size_x" />
            <QP N="die_size_y" />
            <QP N="cols" />
            <QP N="rows" />
            <QP N="map_file_name" />
            <QP N="hist_seq" />
