  <S _RK="649f7d56-6834-457c-9eb0-5112dcc3b1b3" _S="0" N="LinkOnWMLoader" D="LinkOn WMS Map Loader">
    <M _S="1" N="MapCollection">
      <F _S="2" N="Collection">
        <SG _S="3" N="HasSupplierParser">
          <QY P="MsSql" Q="SELECT PSR_NAME&#xD;&#xA;  FROM QWMSSPLMAP&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND SPL_NAME = @spl_name&#xD;&#xA;   AND MAP_TYPE = @map_type">
