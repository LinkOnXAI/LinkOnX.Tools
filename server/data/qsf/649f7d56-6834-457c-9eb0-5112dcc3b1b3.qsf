            <QP N="wafer_id" />
            <QP N="map_seq" />
            <QP N="hist_seq" />
            <QP N="cols" />
            <QP N="rows" />
            <QP N="bin_info" />
            <QP N="bin_1_qty" />
            <QP N="bin_2_qty" />
