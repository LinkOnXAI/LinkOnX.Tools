            <QP N="map_type" />
          </QY>
          <QY P="Oracle" Q="SELECT PSR_NAME&#xD;&#xA;  FROM QWMSSPLMAP&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND SPL_NAME = @spl_name&#xD;&#xA;   AND MAP_TYPE = @map_type" />
