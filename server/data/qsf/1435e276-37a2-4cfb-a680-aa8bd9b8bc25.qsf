6,&#xD;&#xA;   @evt_h_17,&#xD;&#xA;   @evt_d_17,&#xD;&#xA;   @evt_h_18,&#xD;&#xA;   @evt_d_18,&#xD;&#xA;   @evt_h_19,&#xD;&#xA;   @evt_d_19,&#xD;&#xA;   @evt_h_20,&#xD;&#xA;   @evt_d_20,&#xD;&#xA;   @tran_user_id,&#xD;&#xA;   @tran_comment)">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="last_hist_seq" />
            <QP N="event_id" />
            <QP N="tran_time" />
            <QP N="SYSTEM" />
            <QP N="evt_h_1" />
            <QP N="evt_d_1" />
            <QP N="evt_h_2" />
            <QP N="evt_d_2" />
            <QP N="evt_h_3" />
            <QP N="evt_d_3" />
            <QP N="evt_h_4" />
            <QP N="evt_d_4" />
            <QP N="evt_h_5" />
            <QP N="evt_d_5" />
            <QP N="evt_h_6" />
            <QP N="evt_d_6" />
            <QP N="evt_h_7" />
            <QP N="evt_d_7" />
            <QP N="evt_h_8" />
            <QP N="evt_d_8" />
            <QP N="evt_h_9" />
            <QP N="evt_d_9" />
            <QP N="evt_h_10" />
            <QP N="evt_d_10" />
            <QP N="evt_h_11" />
            <QP N="evt_d_11" />
            <QP N="evt_h_12" />
            <QP N="evt_d_12" />
            <QP N="evt_h_13" />
            <QP N="evt_d_13" />
