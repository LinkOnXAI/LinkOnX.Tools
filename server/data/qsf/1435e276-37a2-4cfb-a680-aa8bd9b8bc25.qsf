    <M _S="211" N="Command">
      <F _S="886" N="EapBatchModification">
        <SG _S="890" N="SearchEap">
          <QY P="SQLite" Q="SELECT *&#xD;&#xA;  FROM (&#xD;&#xA;       SELECT A.EAP, B.MODEL, B.MDL_VER, B.LIBRARY, B.LIB_VER,  B.EAP_SCHEMA&#xD;&#xA;         FROM QRASEAPDEF A&#xD;&#xA;    LEFT JOIN QRASEAPATR B&#xD;&#xA;           ON A.FACTORY       = B.FACTORY&#xD;&#xA;          AND A.EAP           = B.EAP&#xD;&#xA;        WHERE A.FACTORY       = @factory&#xD;&#xA;          AND A.DELETE_FLAG   = 'N'&#xD;&#xA;          AND B.ATTR_CATEGORY = 'Setup'&#xD;&#xA;          AND B.MODEL         = IFNULL(@searchMdl, B.MODEL)&#xD;&#xA;          AND B.LIBRARY         = IFNULL(@searchLib, B.LIBRARY)&#xD;&#xA;       ) C&#xD;&#xA; ??CONDITION??&#xD;&#xA; ORDER BY EAP">
            <QP N="factory" />
            <QP N="searchMdl" />
            <QP N="searchLib" />
          </QY>
