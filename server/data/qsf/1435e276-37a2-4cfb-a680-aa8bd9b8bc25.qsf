          </QY>
        </SG>
        <SG _S="2760" N="UpdateEquipment">
          <QY P="SQLite" Q="UPDATE QRASEQPDEF SET&#xD;&#xA;   EQP_DESC        = @eqp_desc,&#xD;&#xA;   IP_ADDRESS      = @ip_address,&#xD;&#xA;   TYPE            = @type,&#xD;&#xA;   DELETE_FLAG     = @delete_flag,&#xD;&#xA;   UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;   UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EQP_NAME    = @eqp_name">
            <QP N="eqp_desc" />
            <QP N="ip_address" />
            <QP N="type" />
            <QP N="delete_flag" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="3147" N="UpdateEquipmentStatus">
          <QY P="SQLite" Q="UPDATE QRASEQPSTS SET&#xD;&#xA;   LAST_EVENT_ID   = @last_event_id,&#xD;&#xA;   LAST_EVENT_TIME = @last_event_time,&#xD;&#xA;   LAST_HIST_SEQ   =@last_hist_seq,&#xD;&#xA;   UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;   UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EQP_NAME    = @eqp_name">
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="last_hist_seq" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="2761" N="UpdateEquipmentForNewEq">
          <QY P="SQLite" Q="UPDATE QRASEQPDEF SET&#xD;&#xA;   EQP_DESC        = @eqp_desc,&#xD;&#xA;   IP_ADDRESS      = @ip_address,&#xD;&#xA;   EAP             = @eap,&#xD;&#xA;   TYPE            = @type,&#xD;&#xA;   DELETE_FLAG     = @delete_flag,&#xD;&#xA;   UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;   UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EQP_NAME    = @eqp_name">
            <QP N="eqp_desc" />
            <QP N="ip_address" />
            <QP N="eap" />
            <QP N="type" />
            <QP N="delete_flag" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="3148" N="UpdateEquipmentStatusForNewEq">
          <QY P="SQLite" Q="UPDATE QRASEQPSTS SET   &#xD;&#xA;   COMM_STATE      = @comm_state,&#xD;&#xA;   CTRL_MODE       = @ctrl_mode,&#xD;&#xA;   PROC_STATE       = @proc_state,&#xD;&#xA;   LAST_EVENT_ID   = @last_event_id,&#xD;&#xA;   LAST_EVENT_TIME = @last_event_time,&#xD;&#xA;   LAST_HIST_SEQ   = @last_his_seq,&#xD;&#xA;   UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;   UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EQP_NAME    = @eqp_name">
            <QP N="comm_state" />
            <QP N="ctrl_mode" />
            <QP N="proc_state" />
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="last_his_seq" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="2762" N="DeleteEquipment">
          <QY P="SQLite" Q="UPDATE QRASEQPDEF SET&#xD;&#xA;   DELETE_FLAG     = @delete_flag,&#xD;&#xA;   UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;   UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EQP_NAME    = @eqp_name">
            <QP N="delete_flag" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
      </F>
      <F _S="212" N="Eap">
        <SG _S="579" N="EapCount">
          <QY P="SQLite" Q="SELECT COUNT(EAP) AS CNT &#xD;&#xA;  FROM QRASEAPDEF &#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND DELETE_FLAG &lt;&gt; 'Y'">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3728" N="HasPackageVer">
          <QY P="SQLite" Q="SELECT PACKAGE&#xD;&#xA;  FROM QSYSPKGVER&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND PACKAGE = @package&#xD;&#xA;   AND PKG_VER = @pkg_ver">
            <QP N="factory" />
            <QP N="package" />
            <QP N="pkg_ver" />
          </QY>
        </SG>
        <SG _S="3374" N="HasEapAtr">
          <QY P="SQLite" Q="SELECT EAP, MODEL, MDL_VER, LIBRARY, LIB_VER, EAP_SCHEMA&#xD;&#xA;  FROM QRASEAPATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP           = @eap&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
          </QY>
        </SG>
        <SG _S="3733" N="HasEapAtrByPkg">
          <QY P="SQLite" Q="SELECT EAP, PACKAGE, PKG_VER, MODEL, MDL_VER, LIBRARY, LIB_VER, EAP_SCHEMA&#xD;&#xA;  FROM QRASEAPATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP           = @eap&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
          </QY>
        </SG>
        <SG _S="579" N="HasEap">
          <QY P="SQLite" Q="SELECT A.EAP, A.EAP_TYPE, A.SERVER, A.STEP, A.UP_DOWN, A.STATUS,&#xD;&#xA;       A.DELETE_FLAG, A.NEED_ACTION, A.NEXT_NEED_ACTION, ALARM,&#xD;&#xA;       B.PACKAGE, B.PKG_VER, B.MODEL, B.MDL_VER, B.LIBRARY, B.LIB_VER,&#xD;&#xA;       B.EAP_SCHEMA&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B&#xD;&#xA;    ON A.FACTORY        = B.FACTORY&#xD;&#xA;   AND A.EAP            = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY  = @attr_category&#xD;&#xA; WHERE A.FACTORY        = @factory&#xD;&#xA;   AND A.EAP            = @eap">
            <QP N="attr_category" />
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="583" N="HasModelVer">
          <QY P="SQLite" Q="SELECT MODEL&#xD;&#xA;  FROM QSYSMDLVER&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND MODEL  = @model&#xD;&#xA;   AND MDL_VER = @mdl_ver">
            <QP N="factory" />
            <QP N="model" />
            <QP N="mdl_ver" />
          </QY>
        </SG>
        <SG _S="3694" N="HasLibraryVer">
          <QY P="SQLite" Q="SELECT LIBRARY &#xD;&#xA;  FROM QSYSLIBVER&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND LIBRARY  = @library&#xD;&#xA;   AND LIB_VER  = @lib_ver">
            <QP N="factory" />
            <QP N="library" />
            <QP N="lib_ver" />
          </QY>
        </SG>
        <SG _S="3119" N="HasDuplicateOfEquipmentName">
          <QY P="SQLite" Q="SELECT EAP&#xD;&#xA;  FROM QRASEAPCFG&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP          &lt;&gt; @eap&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category&#xD;&#xA;   AND OBJ_TYPE      = @obj_type&#xD;&#xA;   AND KEY_NAME      = @eqp_name_key&#xD;&#xA;   AND DATA          = @eqp_name">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
            <QP N="obj_type" />
            <QP N="eqp_name_key" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="2224" N="HasEapEquipment">
          <QY P="SQLite" Q="SELECT EQP_DESC&#xD;&#xA;  FROM QRASEQPDEF&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND EQP_NAME     = @eqp_name&#xD;&#xA;   AND DELETE_FLAG  = 'N'">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="307" N="HasEapEquipmentAtr">
          <QY P="SQLite" Q="SELECT EQP_NAME&#xD;&#xA;  FROM QRASEQPATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP           = @eap&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category&#xD;&#xA; ORDER BY EQP_SEQ">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
          </QY>
        </SG>
        <SG _S="219" N="ListEap">
          <QY P="SQLite" Q="SELECT A.EAP, A.EAP_DESC, A.STEP,  B.MODEL, B.MDL_VER, B.LIBRARY, B.LIB_VER&#xD;&#xA;FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = @attr_category&#xD;&#xA; WHERE A.FACTORY       = @factory   &#xD;&#xA;   AND A.DELETE_FLAG   = 'N'&#xD;&#xA; ORDER BY A.EAP">
            <QP N="attr_category" />
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="541" N="SearchEap">
          <QY P="SQLite" Q="SELECT A.EAP, A.EAP_DESC, A.STEP, B.MODEL, B.MDL_VER,  B.LIBRARY, B.LIB_VER&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = @attr_category&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.EAP           = @eap&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="attr_category" />
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="3740" N="SearchEapByPkg">
          <QY P="SQLite" Q="SELECT A.EAP, A.EAP_DESC, A.STEP, B.PACKAGE, B.PKG_VER,  B.MODEL, B.MDL_VER,  B.LIBRARY, B.LIB_VER&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = @attr_category&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.EAP           = @eap&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="attr_category" />
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="279" N="InsertEap">
          <QY P="SQLite" Q="INSERT INTO QRASEAPDEF (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EAP,&#xD;&#xA;   EAP_DESC,  &#xD;&#xA;   STEP,&#xD;&#xA;   UP_DOWN,&#xD;&#xA;   STATUS,&#xD;&#xA;   NEED_ACTION,&#xD;&#xA;   NEXT_NEED_ACTION,&#xD;&#xA;   ALARM,&#xD;&#xA;   LAST_EVENT_ID,&#xD;&#xA;   LAST_EVENT_TIME,&#xD;&#xA;   LAST_HIST_SEQ,&#xD;&#xA;   DELETE_FLAG,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @eap,&#xD;&#xA;   @eap_desc,&#xD;&#xA;   @step,&#xD;&#xA;   @up_down,&#xD;&#xA;   @status,&#xD;&#xA;   @need_action,&#xD;&#xA;   @next_need_action,&#xD;&#xA;   @alarm,&#xD;&#xA;   @last_event_id,&#xD;&#xA;   @last_event_time,&#xD;&#xA;   @last_hist_seq,&#xD;&#xA;   @delete_flag,   &#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="eap_desc" />
            <QP N="step" />
            <QP N="up_down" />
            <QP N="status" />
            <QP N="need_action" />
            <QP N="next_need_action" />
            <QP N="alarm" />
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="last_hist_seq" />
            <QP N="delete_flag" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="281" N="InsertEapAtr">
          <QY P="SQLite" Q="INSERT INTO QRASEAPATR (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EAP,&#xD;&#xA;   ATTR_CATEGORY,&#xD;&#xA;   MODEL,&#xD;&#xA;   MDL_VER,&#xD;&#xA;   LIBRARY, &#xD;&#xA;   LIB_VER,&#xD;&#xA;   EAP_SCHEMA,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @eap,&#xD;&#xA;   @attr_category,&#xD;&#xA;   @model,&#xD;&#xA;   @mdl_ver,&#xD;&#xA;   @library,&#xD;&#xA;   @lib_ver,&#xD;&#xA;   @eap_schema,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
            <QP N="model" />
            <QP N="mdl_ver" />
            <QP N="library" />
            <QP N="lib_ver" />
            <QP N="eap_schema" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="3731" N="InsertEapAtrByPkg">
          <QY P="SQLite" Q="INSERT INTO QRASEAPATR (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EAP,&#xD;&#xA;   ATTR_CATEGORY,&#xD;&#xA;   PACKAGE,&#xD;&#xA;   PKG_VER,&#xD;&#xA;   MODEL,&#xD;&#xA;   MDL_VER,&#xD;&#xA;   LIBRARY, &#xD;&#xA;   LIB_VER,&#xD;&#xA;   EAP_SCHEMA,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @eap,&#xD;&#xA;   @attr_category,&#xD;&#xA;   @package,   &#xD;&#xA;   @pkg_ver,&#xD;&#xA;   @model,&#xD;&#xA;   @mdl_ver,&#xD;&#xA;   @library,&#xD;&#xA;   @lib_ver,&#xD;&#xA;   @eap_schema,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
            <QP N="package" />
            <QP N="pkg_ver" />
            <QP N="model" />
            <QP N="mdl_ver" />
            <QP N="library" />
            <QP N="lib_ver" />
            <QP N="eap_schema" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="3120" N="InsertEapConfig">
          <QY P="SQLite" Q="INSERT INTO QRASEAPCFG (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EAP,&#xD;&#xA;   ATTR_CATEGORY,&#xD;&#xA;   OBJ_TYPE,&#xD;&#xA;   OBJ_NAME,&#xD;&#xA;   KEY_SEQ,&#xD;&#xA;   KEY_NAME,&#xD;&#xA;   DATA,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @eap,&#xD;&#xA;   @attr_category,&#xD;&#xA;   @obj_type,&#xD;&#xA;   @obj_name,&#xD;&#xA;   @key_seq,&#xD;&#xA;   @key_name,&#xD;&#xA;   @data,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
            <QP N="obj_type" />
            <QP N="obj_name" />
            <QP N="key_seq" />
            <QP N="key_name" />
            <QP N="data" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
