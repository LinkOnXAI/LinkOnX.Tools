          <QY P="SQLite" Q="UPDATE QRASEAPDEF SET&#xD;&#xA;  LAST_EVENT_ID   = @last_event_id,&#xD;&#xA;  LAST_EVENT_TIME = @last_event_time,&#xD;&#xA;  LAST_HIST_SEQ   = @hist_seq,&#xD;&#xA;  UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;  UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EAP     = @eap">
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="hist_seq" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
      </F>
      <F _S="1960" N="EapReload">
        <SG _S="1961" N="HasEap">
          <QY P="SQLite" Q="SELECT UP_DOWN, STATUS, NEED_ACTION, RELOAD_CNT&#xD;&#xA;  FROM QRASEAPDEF  &#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND EAP          = @eap&#xD;&#xA;   AND DELETE_FLAG  = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="1962" N="HasEapAtr">
          <QY P="SQLite" Q="SELECT EAP, MODEL, MDL_VER, LIBRARY, LIB_VER&#xD;&#xA;  FROM QRASEAPATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP           = @eap&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
          </QY>
        </SG>
        <SG _S="1970" N="UpdateEap">
          <QY P="SQLite" Q="UPDATE QRASEAPDEF SET&#xD;&#xA;  LAST_EVENT_ID   = @last_event_id,&#xD;&#xA;  LAST_EVENT_TIME = @last_event_time,&#xD;&#xA;  LAST_HIST_SEQ   = @hist_seq,&#xD;&#xA;  UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;  UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EAP     = @eap">
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="hist_seq" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
      </F>
      <F _S="463" N="EapRestart">
        <SG _S="468" N="HasEap">
          <QY P="SQLite" Q="SELECT EAP, UP_DOWN, STATUS&#xD;&#xA;  FROM QRASEAPDEF  &#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND EAP          = @eap&#xD;&#xA;   AND DELETE_FLAG  = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="469" N="HasEapAtr">
          <QY P="SQLite" Q="SELECT EAP, MODEL, MDL_VER, LIBRARY, LIB_VER,  EAP_SCHEMA&#xD;&#xA;  FROM QRASEAPATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP           = @eap&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
          </QY>
        </SG>
        <SG _S="3737" N="HasEapAtrByPkg">
          <QY P="SQLite" Q="SELECT EAP, PACKAGE, PKG_VER, MODEL, MDL_VER, LIBRARY, LIB_VER, EAP_SCHEMA&#xD;&#xA;  FROM QRASEAPATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP           = @eap&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
          </QY>
        </SG>
        <SG _S="3133" N="HasDuplicateOfEquipmentName">
          <QY P="SQLite" Q="SELECT EAP&#xD;&#xA;  FROM QRASEAPCFG&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP          &lt;&gt; @eap&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category&#xD;&#xA;   AND OBJ_TYPE      = @obj_type&#xD;&#xA;   AND KEY_NAME      = @eqp_name_key&#xD;&#xA;   AND DATA          = @eqp_name">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
            <QP N="obj_type" />
            <QP N="eqp_name_key" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="826" N="UpdateEap">
          <QY P="SQLite" Q="UPDATE QRASEAPDEF SET&#xD;&#xA;  LAST_EVENT_ID   = @last_event_id,&#xD;&#xA;  LAST_EVENT_TIME = @last_event_time,&#xD;&#xA;  LAST_HIST_SEQ   = @hist_seq,&#xD;&#xA;  UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;  UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EAP     = @eap">
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="hist_seq" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
      </F>
      <F _S="3081" N="ApplicationAlarmClear">
        <SG _S="3083" N="HasEquipment">
          <QY P="SQLite" Q="SELECT EQP_NAME, EAP &#xD;&#xA;  FROM QRASEQPDEF &#xD;&#xA; WHERE FACTORY  = @factory &#xD;&#xA;   AND EQP_NAME = @eqp_name">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="3091" N="UpdateEquipment">
          <QY P="SQLite" Q="UPDATE QRASEQPDEF SET&#xD;&#xA;   LAST_HIST_SEQ   = LAST_HIST_SEQ + 1,&#xD;&#xA;   LAST_EVENT_ID   = @last_event_id,&#xD;&#xA;   LAST_EVENT_TIME = @last_event_time,&#xD;&#xA;   UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;   UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EQP_NAME = @eqp_name">
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="3089" N="HasAlarmStatus">
          <QY P="SQLite" Q="SELECT EQP_NAME, SET_TIME&#xD;&#xA; FROM QSYSAPPALS&#xD;&#xA;WHERE FACTORY = @factory&#xD;&#xA;     AND HIST_SEQ = @hist_seq">
            <QP N="factory" />
            <QP N="hist_seq" />
          </QY>
        </SG>
        <SG _S="3082" N="SelectAlarmList">
          <QY P="SQLite" Q="SELECT EQP_NAME, SET_TIME, HIST_SEQ, ALARM_ID, ALARM_TEXT&#xD;&#xA; FROM QSYSAPPALS&#xD;&#xA;WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3084" N="InsertEquipmentHis">
          <QY P="SQLite" Q="INSERT INTO QRASEQPHIS (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   EVENT_ID,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   SYSTEM,&#xD;&#xA;   MDLN,&#xD;&#xA;   SOFTREV,&#xD;&#xA;   CTRL_MODE,&#xD;&#xA;   PRI_STATE,&#xD;&#xA;   STATE,&#xD;&#xA;   EQP_ME,&#xD;&#xA;   EVENT_DEFINE,&#xD;&#xA;   EQP_RCP_ID,&#xD;&#xA;   EAP,&#xD;&#xA;   EAP_EVENT_ID,      &#xD;&#xA;   EVT_H_1,&#xD;&#xA;   EVT_D_1,   &#xD;&#xA;   EVT_H_2,&#xD;&#xA;   EVT_D_2,&#xD;&#xA;   EVT_H_3,&#xD;&#xA;   EVT_D_3,&#xD;&#xA;   EVT_H_4,&#xD;&#xA;   EVT_D_4,&#xD;&#xA;   EVT_H_5,&#xD;&#xA;   EVT_D_5,&#xD;&#xA;   EVT_H_6,&#xD;&#xA;   EVT_D_6,&#xD;&#xA;   EVT_H_7,&#xD;&#xA;   EVT_D_7,&#xD;&#xA;   EVT_H_8,&#xD;&#xA;   EVT_D_8,&#xD;&#xA;   EVT_H_9,&#xD;&#xA;   EVT_D_9,&#xD;&#xA;   EVT_H_10,&#xD;&#xA;   EVT_D_10,&#xD;&#xA;   EVT_H_11,&#xD;&#xA;   EVT_D_11,   &#xD;&#xA;   EVT_H_12,&#xD;&#xA;   EVT_D_12,&#xD;&#xA;   EVT_H_13,&#xD;&#xA;   EVT_D_13,&#xD;&#xA;   EVT_H_14,&#xD;&#xA;   EVT_D_14,&#xD;&#xA;   EVT_H_15,&#xD;&#xA;   EVT_D_15,&#xD;&#xA;   EVT_H_16,&#xD;&#xA;   EVT_D_16,&#xD;&#xA;   EVT_H_17,&#xD;&#xA;   EVT_D_17,&#xD;&#xA;   EVT_H_18,&#xD;&#xA;   EVT_D_18,&#xD;&#xA;   EVT_H_19,&#xD;&#xA;   EVT_D_19,&#xD;&#xA;   EVT_H_20,&#xD;&#xA;   EVT_D_20,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT      &#xD;&#xA;) &#xD;&#xA;SELECT &#xD;&#xA;   FACTORY,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   LAST_HIST_SEQ,&#xD;&#xA;   @event_id,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @SYSTEM,&#xD;&#xA;   MDLN,&#xD;&#xA;   SOFTREV,&#xD;&#xA;   CTRL_MODE,&#xD;&#xA;   PRI_STATE,&#xD;&#xA;   STATE,&#xD;&#xA;   EQP_ME,&#xD;&#xA;   EVENT_DEFINE,&#xD;&#xA;   EQP_RCP_ID,&#xD;&#xA;   @eap,&#xD;&#xA;   @eap_event_id,&#xD;&#xA;   @evt_h_1,&#xD;&#xA;   @evt_d_1,   &#xD;&#xA;   @evt_h_2,&#xD;&#xA;   @evt_d_2,&#xD;&#xA;   @evt_h_3,&#xD;&#xA;   @evt_d_3,&#xD;&#xA;   @evt_h_4,&#xD;&#xA;   @evt_d_4,&#xD;&#xA;   @evt_h_5,&#xD;&#xA;   @evt_d_5,&#xD;&#xA;   @evt_h_6,&#xD;&#xA;   @evt_d_6,&#xD;&#xA;   @evt_h_7,&#xD;&#xA;   @evt_d_7,&#xD;&#xA;   @evt_h_8,&#xD;&#xA;   @evt_d_8,&#xD;&#xA;   @evt_h_9,&#xD;&#xA;   @evt_d_9,&#xD;&#xA;   @evt_h_10,&#xD;&#xA;   @evt_d_10,&#xD;&#xA;   @evt_h_11,&#xD;&#xA;   @evt_d_11,   &#xD;&#xA;   @evt_h_12,&#xD;&#xA;   @evt_d_12,&#xD;&#xA;   @evt_h_13,&#xD;&#xA;   @evt_d_13,&#xD;&#xA;   @evt_h_14,&#xD;&#xA;   @evt_d_14,&#xD;&#xA;   @evt_h_15,&#xD;&#xA;   @evt_d_15,&#xD;&#xA;   @evt_h_16,&#xD;&#xA;   @evt_d_16,&#xD;&#xA;   @evt_h_17,&#xD;&#xA;   @evt_d_17,&#xD;&#xA;   @evt_h_18,&#xD;&#xA;   @evt_d_18,&#xD;&#xA;   @evt_h_19,&#xD;&#xA;   @evt_d_19,&#xD;&#xA;   @evt_h_20,&#xD;&#xA;   @evt_d_20,&#xD;&#xA;   @tran_user_id,&#xD;&#xA;   @tran_comment&#xD;&#xA;  FROM QRASEQPDEF &#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EQP_NAME = @eqp_name">
            <QP N="event_id" />
            <QP N="tran_time" />
            <QP N="system" />
            <QP N="eap" />
            <QP N="eap_event_id" />
            <QP N="evt_h_1" />
            <QP N="evt_d_1" />
            <QP N="evt_h_2" />
            <QP N="evt_d_2" />
            <QP N="evt_h_3" />
            <QP N="evt_d_3" />
            <QP N="evt_h_4" />
            <QP N="evt_d_4" />
            <QP N="evt_h_5" />
            <QP N="evt_d_5" />
            <QP N="evt_h_6" />
            <QP N="evt_d_6" />
            <QP N="evt_h_7" />
            <QP N="evt_d_7" />
            <QP N="evt_h_8" />
            <QP N="evt_d_8" />
            <QP N="evt_h_9" />
            <QP N="evt_d_9" />
            <QP N="evt_h_10" />
            <QP N="evt_d_10" />
            <QP N="evt_h_11" />
            <QP N="evt_d_11" />
            <QP N="evt_h_12" />
            <QP N="evt_d_12" />
            <QP N="evt_h_13" />
            <QP N="evt_d_13" />
            <QP N="evt_h_14" />
            <QP N="evt_d_14" />
            <QP N="evt_h_15" />
            <QP N="evt_d_15" />
            <QP N="evt_h_16" />
            <QP N="evt_d_16" />
            <QP N="evt_h_17" />
            <QP N="evt_d_17" />
            <QP N="evt_h_18" />
            <QP N="evt_d_18" />
            <QP N="evt_h_19" />
            <QP N="evt_d_19" />
            <QP N="evt_h_20" />
            <QP N="evt_d_20" />
            <QP N="tran_user_id" />
            <QP N="tran_comment" />
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="3087" N="InsertApplicationAlarmHis">
          <QY P="SQLite" Q="INSERT INTO QSYSAPPALH (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   SET_TIME,&#xD;&#xA;   CLEAR_TIME,&#xD;&#xA;   CLEAR_COMMENT,&#xD;&#xA;   ALARM_ID,&#xD;&#xA;   ALARM_TEXT,&#xD;&#xA;   DURATION,&#xD;&#xA;   SUM_DATE,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_TIME&#xD;&#xA;)&#xD;&#xA;SELECT&#xD;&#xA;   FACTORY,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   SET_TIME,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @clear_comment,&#xD;&#xA;   ALARM_ID,&#xD;&#xA;   ALARM_TEXT,&#xD;&#xA;   @duration,&#xD;&#xA;   @sum_date,&#xD;&#xA;   @tran_user_id,&#xD;&#xA;   @tran_time&#xD;&#xA;  FROM QSYSAPPALS&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND HIST_SEQ = @hist_seq">
            <QP N="tran_time" />
            <QP N="clear_comment" />
            <QP N="duration" />
            <QP N="sum_date" />
            <QP N="tran_user_id" />
            <QP N="factory" />
            <QP N="hist_seq" />
          </QY>
        </SG>
        <SG _S="3088" N="DeleteApplicationAlarmStatus">
          <QY P="SQLite" Q="DELETE FROM QSYSAPPALS&#xD;&#xA;WHERE FACTORY = @factory&#xD;&#xA;     AND HIST_SEQ = @hist_seq">
            <QP N="factory" />
            <QP N="hist_seq" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="688" N="View">
      <F _S="2583" N="EapSchemaSearch">
        <SG _S="2584" N="SearchEap">
          <QY P="SQLite" Q="SELECT EAP&#xD;&#xA;  FROM QRASEAPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EAP         = @eap&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="3139" N="SearchEapAtr">
          <QY P="SQLite" Q="SELECT EAP_SCHEMA&#xD;&#xA;  FROM QRASEAPATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP           = @eap&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
          </QY>
        </SG>
        <SG _S="3141" N="SearchConnectorSts">
          <QY P="SQLite" Q="SELECT CNT_SEQ, CNT_NAME, STATE&#xD;&#xA;  FROM QRASCNTSTS&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EAP     = @eap">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="3140" N="SearchEquipment">
          <QY P="SQLite" Q="SELECT EQP_NAME, COMM_STATE, CTRL_MODE&#xD;&#xA;  FROM QRASEQPSTS&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EQP_NAME IN&#xD;&#xA;       (&#xD;&#xA;SELECT DATA&#xD;&#xA;  FROM QRASEAPCFG&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP           = @eap&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category&#xD;&#xA;   AND OBJ_TYPE      = @obj_type&#xD;&#xA;   AND KEY_NAME      = @key_eqp_name&#xD;&#xA;       )">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
            <QP N="obj_type" />
            <QP N="key_eqp_name" />
          </QY>
        </SG>
      </F>
      <F _S="2560" N="EapViewer">
        <SG _S="2563" N="ListModel">
          <QY P="SQLite" Q="SELECT A.MODEL, A.MDL_DESC, B.MDL_VER, B.MDL_VER_DESC, B.MDL_RELEASE&#xD;&#xA;  FROM QSYSMDLDEF A&#xD;&#xA;  LEFT JOIN QSYSMDLVER B&#xD;&#xA;    ON A.FACTORY = B.FACTORY&#xD;&#xA;   AND A.MODEL   = B.MODEL&#xD;&#xA; WHERE A.FACTORY = @factory&#xD;&#xA; ORDER BY A.MODEL, B.MDL_VER DESC">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="2565" N="ListEap">
          <QY P="SQLite" Q="SELECT A.EAP, A.EAP_DESC, A.STEP, A.UP_DOWN, A.STATUS, A.RELOAD_CNT, A.ALARM, A.NEED_ACTION, A.NEXT_NEED_ACTION,       &#xD;&#xA;       IFNULL(B.MODEL, 'N/A') SET_MODEL, IFNULL(B.MDL_VER, 0) SET_MDL_VER, IFNULL(C.MODEL, 'N/A') REL_MODEL, IFNULL(C.MDL_VER, 0) REL_MDL_VER, IFNULL(D.MODEL, 'N/A') APL_MODEL, IFNULL(D.MDL_VER, 0) APL_MDL_VER,&#xD;&#xA;       IFNULL(B.LIBRARY, 'N/A') SET_LIBRARY, IFNULL(B.LIB_VER, 0) SET_LIB_VER, IFNULL(C.LIBRARY, 'N/A') REL_LIBRARY, IFNULL(C.LIB_VER, 0) REL_LIB_VER, IFNULL(D.LIBRARY, 'N/A') APL_LIBRARY, IFNULL(D.LIB_VER, 0) APL_LIB_VER&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP           = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP           = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'    &#xD;&#xA;   AND (&#xD;&#xA;       (B.MODEL        = IFNULL(@model, B.MODEL) AND B.MDL_VER = IFNULL(@mdl_ver, B.MDL_VER))&#xD;&#xA;    OR (C.MODEL        = IFNULL(@model, C.MODEL) AND C.MDL_VER = IFNULL(@mdl_ver, C.MDL_VER))&#xD;&#xA;    OR (D.MODEL        = IFNULL(@model, D.MODEL) AND D.MDL_VER = IFNULL(@mdl_ver, D.MDL_VER))&#xD;&#xA;       )   &#xD;&#xA; ORDER BY A.EAP">
            <QP N="factory" />
            <QP N="model" />
            <QP N="mdl_ver" />
          </QY>
        </SG>
        <SG _S="2566" N="SearchEap">
          <QY P="SQLite" Q="SELECT B.MODEL&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.EAP           LIKE @eap&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'&#xD;&#xA; ORDER BY B.MODEL">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="3094" N="SearchEapByEquipment">
          <QY P="SQLite" Q="SELECT A.EAP&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA;  LEFT JOIN QRASEQPDEF C&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = C.EAP   &#xD;&#xA;   AND C.DELETE_FLAG &lt;&gt; 'Y'&#xD;&#xA;  LEFT JOIN QRASEQPATR D&#xD;&#xA;    ON C.FACTORY       = D.FACTORY&#xD;&#xA;   AND C.EQP_NAME      = D.EQP_NAME   &#xD;&#xA; WHERE A.FACTORY       = @factory &#xD;&#xA;   AND B.ATTR_CATEGORY = 'Applied' &#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'     &#xD;&#xA;   AND C.EQP_NAME      LIKE @eqp_name&#xD;&#xA;   AND A.EAP NOT LIKE '%_ST'&#xD;&#xA;   AND A.DELETE_FLAG   &lt;&gt; 'Y'">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="2567" N="SearchEapForUpdate">
          <QY P="SQLite" Q="SELECT A.EAP, A.EAP_DESC, A.STEP, B.MODEL, B.MDL_VER, B.LIBRARY, B.LIB_VER&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = @attr_category&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.EAP           = @eap&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="attr_category" />
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="2568" N="SearchEapForClone">
          <QY P="SQLite" Q="SELECT A.STEP, B.MODEL, B.MDL_VER, B.LIBRARY, B.LIB_VER&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = @attr_category&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.EAP           = @eap&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="attr_category" />
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
      </F>
      <F _S="2600" N="EapLogList">
        <SG _S="2602" N="HasEap">
          <QY P="SQLite" Q="SELECT UP_DOWN, STATUS&#xD;&#xA;  FROM QRASEAPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EAP         = @eap&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="3312" N="RemoteCommand">
      <F _S="3313" N="EquipmentEventDefineRequest">
        <SG _S="3314" N="HasEap">
          <QY P="SQLite" Q="SELECT UP_DOWN, STATUS    &#xD;&#xA;  FROM QRASEAPDEF  &#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EAP         = @eap&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="3315" N="HasEapAtr">
          <QY P="SQLite" Q="SELECT EAP&#xD;&#xA;  FROM QRASEAPATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP           = @eap&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
          </QY>
        </SG>
        <SG _S="3316" N="HasEapEquipment">
          <QY P="SQLite" Q="SELECT EQP_NAME&#xD;&#xA;  FROM QRASEQPATR &#xD;&#xA;WHERE FACTORY       = @factory&#xD;&#xA;  AND EAP           = @eap&#xD;&#xA;  AND EQP_NAME      = @eqp_name&#xD;&#xA;  AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="eqp_name" />
            <QP N="attr_category" />
          </QY>
        </SG>
        <SG _S="3317" N="InsertEapHistory">
          <QY P="SQLite" Q="INSERT INTO QRASEAPHIS (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EAP,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   EVENT_ID,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   SERVER,&#xD;&#xA;   STEP,&#xD;&#xA;   UP_DOWN,&#xD;&#xA;   STATUS,&#xD;&#xA;   NEED_ACTION,&#xD;&#xA;   NEXT_NEED_ACTION,&#xD;&#xA;   SET_PACKAGE,&#xD;&#xA;   SET_PKG_VER,&#xD;&#xA;   REL_PACKAGE,&#xD;&#xA;   REL_PKG_VER,&#xD;&#xA;   APL_PACKAGE,&#xD;&#xA;   APL_PKG_VER,   &#xD;&#xA;   SET_MEL,&#xD;&#xA;   SET_MDL_VER,&#xD;&#xA;   REL_MEL,&#xD;&#xA;   REL_MDL_VER,&#xD;&#xA;   APL_MEL,&#xD;&#xA;   APL_MDL_VER,   &#xD;&#xA;   SET_USED_COM,&#xD;&#xA;   SET_COMPONENT,&#xD;&#xA;   SET_COM_VER,   &#xD;&#xA;   REL_USED_COM,&#xD;&#xA;   REL_COMPONENT,&#xD;&#xA;   REL_COM_VER,   &#xD;&#xA;   APL_USED_COM,&#xD;&#xA;   APL_COMPONENT,&#xD;&#xA;   APL_COM_VER,   &#xD;&#xA;   EVT_H_1,&#xD;&#xA;   EVT_D_1,   &#xD;&#xA;   EVT_H_2,&#xD;&#xA;   EVT_D_2,&#xD;&#xA;   EVT_H_3,&#xD;&#xA;   EVT_D_3,&#xD;&#xA;   EVT_H_4,&#xD;&#xA;   EVT_D_4,&#xD;&#xA;   EVT_H_5,&#xD;&#xA;   EVT_D_5,&#xD;&#xA;   EVT_H_6,&#xD;&#xA;   EVT_D_6,&#xD;&#xA;   EVT_H_7,&#xD;&#xA;   EVT_D_7,&#xD;&#xA;   EVT_H_8,&#xD;&#xA;   EVT_D_8,&#xD;&#xA;   EVT_H_9,&#xD;&#xA;   EVT_D_9,&#xD;&#xA;   EVT_H_10,&#xD;&#xA;   EVT_D_10,&#xD;&#xA;   EVT_H_11,&#xD;&#xA;   EVT_D_11,   &#xD;&#xA;   EVT_H_12,&#xD;&#xA;   EVT_D_12,&#xD;&#xA;   EVT_H_13,&#xD;&#xA;   EVT_D_13,&#xD;&#xA;   EVT_H_14,&#xD;&#xA;   EVT_D_14,&#xD;&#xA;   EVT_H_15,&#xD;&#xA;   EVT_D_15,&#xD;&#xA;   EVT_H_16,&#xD;&#xA;   EVT_D_16,&#xD;&#xA;   EVT_H_17,&#xD;&#xA;   EVT_D_17,&#xD;&#xA;   EVT_H_18,&#xD;&#xA;   EVT_D_18,&#xD;&#xA;   EVT_H_19,&#xD;&#xA;   EVT_D_19,&#xD;&#xA;   EVT_H_20,&#xD;&#xA;   EVT_D_20,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT      &#xD;&#xA;) &#xD;&#xA;SELECT &#xD;&#xA;   A.FACTORY,&#xD;&#xA;   A.EAP,&#xD;&#xA;   A.LAST_HIST_SEQ,&#xD;&#xA;   @event_id,&#xD;&#xA;   @tran_time,&#xD;&#xA;   A.SERVER,&#xD;&#xA;   A.STEP,&#xD;&#xA;   A.UP_DOWN,&#xD;&#xA;   A.STATUS,&#xD;&#xA;   A.NEED_ACTION,&#xD;&#xA;   A.NEXT_NEED_ACTION,   &#xD;&#xA;   NVL(B.PACKAGE, ' '),&#xD;&#xA;   NVL(B.PKG_VER, 0),&#xD;&#xA;   NVL(C.PACKAGE, ' '),&#xD;&#xA;   NVL(C.PKG_VER, 0),&#xD;&#xA;   NVL(D.PACKAGE, ' '),&#xD;&#xA;   NVL(D.PKG_VER, 0),   &#xD;&#xA;   NVL(B.MEL, ' '),&#xD;&#xA;   NVL(B.MDL_VER, 0),&#xD;&#xA;   NVL(C.MEL, ' '),&#xD;&#xA;   NVL(C.MDL_VER, 0),&#xD;&#xA;   NVL(D.MEL, ' '),&#xD;&#xA;   NVL(D.MDL_VER, 0),   &#xD;&#xA;   NVL(B.USED_COM, 'No'),&#xD;&#xA;   NVL(B.COMPONENT, ' '),&#xD;&#xA;   NVL(B.COM_VER, 0),&#xD;&#xA;   NVL(C.USED_COM, 'No'),&#xD;&#xA;   NVL(C.COMPONENT, ' '),&#xD;&#xA;   NVL(C.COM_VER, 0),&#xD;&#xA;   NVL(D.USED_COM, 'No'),&#xD;&#xA;   NVL(D.COMPONENT, ' '),&#xD;&#xA;   NVL(D.COM_VER, 0),&#xD;&#xA;   @evt_h_1,&#xD;&#xA;   @evt_d_1,   &#xD;&#xA;   @evt_h_2,&#xD;&#xA;   @evt_d_2,&#xD;&#xA;   @evt_h_3,&#xD;&#xA;   @evt_d_3,&#xD;&#xA;   @evt_h_4,&#xD;&#xA;   @evt_d_4,&#xD;&#xA;   @evt_h_5,&#xD;&#xA;   @evt_d_5,&#xD;&#xA;   @evt_h_6,&#xD;&#xA;   @evt_d_6,&#xD;&#xA;   @evt_h_7,&#xD;&#xA;   @evt_d_7,&#xD;&#xA;   @evt_h_8,&#xD;&#xA;   @evt_d_8,&#xD;&#xA;   @evt_h_9,&#xD;&#xA;   @evt_d_9,&#xD;&#xA;   @evt_h_10,&#xD;&#xA;   @evt_d_10,&#xD;&#xA;   @evt_h_11,&#xD;&#xA;   @evt_d_11,   &#xD;&#xA;   @evt_h_12,&#xD;&#xA;   @evt_d_12,&#xD;&#xA;   @evt_h_13,&#xD;&#xA;   @evt_d_13,&#xD;&#xA;   @evt_h_14,&#xD;&#xA;   @evt_d_14,&#xD;&#xA;   @evt_h_15,&#xD;&#xA;   @evt_d_15,&#xD;&#xA;   @evt_h_16,&#xD;&#xA;   @evt_d_16,&#xD;&#xA;   @evt_h_17,&#xD;&#xA;   @evt_d_17,&#xD;&#xA;   @evt_h_18,&#xD;&#xA;   @evt_d_18,&#xD;&#xA;   @evt_h_19,&#xD;&#xA;   @evt_d_19,&#xD;&#xA;   @evt_h_20,&#xD;&#xA;   @evt_d_20,&#xD;&#xA;   @tran_user_id,&#xD;&#xA;   @tran_comment&#xD;&#xA;  FROM QRASEAPDEF A  &#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C&#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP           = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D&#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP           = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.EAP         = @eap">
            <QP N="event_id" />
            <QP N="tran_time" />
            <QP N="evt_h_1" />
            <QP N="evt_d_1" />
            <QP N="evt_h_2" />
            <QP N="evt_d_2" />
            <QP N="evt_h_3" />
            <QP N="evt_d_3" />
            <QP N="evt_h_4" />
            <QP N="evt_d_4" />
            <QP N="evt_h_5" />
            <QP N="evt_d_5" />
            <QP N="evt_h_6" />
            <QP N="evt_d_6" />
            <QP N="evt_h_7" />
            <QP N="evt_d_7" />
            <QP N="evt_h_8" />
            <QP N="evt_d_8" />
            <QP N="evt_h_9" />
            <QP N="evt_d_9" />
