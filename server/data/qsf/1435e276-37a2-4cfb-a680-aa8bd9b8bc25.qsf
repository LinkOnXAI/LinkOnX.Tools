            <QP N="tran_user_id" />
            <QP N="tran_comment" />
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="3318" N="InsertEapIeh" D="2017.07.17 by spike.lee">
          <QY P="SQLite" Q="INSERT INTO QRASEAPIEH (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EAP,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   EVENT_ID,&#xD;&#xA;   TRAN_DATE,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   SERVER,&#xD;&#xA;   STEP,&#xD;&#xA;   UP_DOWN,&#xD;&#xA;   STATUS,&#xD;&#xA;   NEED_ACTION,&#xD;&#xA;   NEXT_NEED_ACTION,&#xD;&#xA;   SET_PACKAGE,&#xD;&#xA;   SET_PKG_VER,&#xD;&#xA;   REL_PACKAGE,&#xD;&#xA;   REL_PKG_VER,&#xD;&#xA;   APL_PACKAGE,&#xD;&#xA;   APL_PKG_VER,   &#xD;&#xA;   SET_MEL,&#xD;&#xA;   SET_MDL_VER,&#xD;&#xA;   REL_MEL,&#xD;&#xA;   REL_MDL_VER,&#xD;&#xA;   APL_MEL,&#xD;&#xA;   APL_MDL_VER,   &#xD;&#xA;   SET_USED_COM,&#xD;&#xA;   SET_COMPONENT,&#xD;&#xA;   SET_COM_VER,   &#xD;&#xA;   REL_USED_COM,&#xD;&#xA;   REL_COMPONENT,&#xD;&#xA;   REL_COM_VER,   &#xD;&#xA;   APL_USED_COM,&#xD;&#xA;   APL_COMPONENT,&#xD;&#xA;   APL_COM_VER,   &#xD;&#xA;   EVT_H_1,&#xD;&#xA;   EVT_D_1,   &#xD;&#xA;   EVT_H_2,&#xD;&#xA;   EVT_D_2,&#xD;&#xA;   EVT_H_3,&#xD;&#xA;   EVT_D_3,&#xD;&#xA;   EVT_H_4,&#xD;&#xA;   EVT_D_4,&#xD;&#xA;   EVT_H_5,&#xD;&#xA;   EVT_D_5,&#xD;&#xA;   EVT_H_6,&#xD;&#xA;   EVT_D_6,&#xD;&#xA;   EVT_H_7,&#xD;&#xA;   EVT_D_7,&#xD;&#xA;   EVT_H_8,&#xD;&#xA;   EVT_D_8,&#xD;&#xA;   EVT_H_9,&#xD;&#xA;   EVT_D_9,&#xD;&#xA;   EVT_H_10,&#xD;&#xA;   EVT_D_10,&#xD;&#xA;   EVT_H_11,&#xD;&#xA;   EVT_D_11,   &#xD;&#xA;   EVT_H_12,&#xD;&#xA;   EVT_D_12,&#xD;&#xA;   EVT_H_13,&#xD;&#xA;   EVT_D_13,&#xD;&#xA;   EVT_H_14,&#xD;&#xA;   EVT_D_14,&#xD;&#xA;   EVT_H_15,&#xD;&#xA;   EVT_D_15,&#xD;&#xA;   EVT_H_16,&#xD;&#xA;   EVT_D_16,&#xD;&#xA;   EVT_H_17,&#xD;&#xA;   EVT_D_17,&#xD;&#xA;   EVT_H_18,&#xD;&#xA;   EVT_D_18,&#xD;&#xA;   EVT_H_19,&#xD;&#xA;   EVT_D_19,&#xD;&#xA;   EVT_H_20,&#xD;&#xA;   EVT_D_20,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT      &#xD;&#xA;) &#xD;&#xA;SELECT &#xD;&#xA;   A.FACTORY,&#xD;&#xA;   A.EAP,&#xD;&#xA;   A.LAST_HIST_SEQ,&#xD;&#xA;   @event_id,&#xD;&#xA;   @tran_date,&#xD;&#xA;   @tran_time,&#xD;&#xA;   A.SERVER,&#xD;&#xA;   A.STEP,&#xD;&#xA;   A.UP_DOWN,&#xD;&#xA;   A.STATUS,&#xD;&#xA;   A.NEED_ACTION,&#xD;&#xA;   A.NEXT_NEED_ACTION,   &#xD;&#xA;   NVL(B.PACKAGE, ' '),&#xD;&#xA;   NVL(B.PKG_VER, 0),&#xD;&#xA;   NVL(C.PACKAGE, ' '),&#xD;&#xA;   NVL(C.PKG_VER, 0),&#xD;&#xA;   NVL(D.PACKAGE, ' '),&#xD;&#xA;   NVL(D.PKG_VER, 0),   &#xD;&#xA;   NVL(B.MEL, ' '),&#xD;&#xA;   NVL(B.MDL_VER, 0),&#xD;&#xA;   NVL(C.MEL, ' '),&#xD;&#xA;   NVL(C.MDL_VER, 0),&#xD;&#xA;   NVL(D.MEL, ' '),&#xD;&#xA;   NVL(D.MDL_VER, 0),   &#xD;&#xA;   NVL(B.USED_COM, 'No'),&#xD;&#xA;   NVL(B.COMPONENT, ' '),&#xD;&#xA;   NVL(B.COM_VER, 0),&#xD;&#xA;   NVL(C.USED_COM, 'No'),&#xD;&#xA;   NVL(C.COMPONENT, ' '),&#xD;&#xA;   NVL(C.COM_VER, 0),&#xD;&#xA;   NVL(D.USED_COM, 'No'),&#xD;&#xA;   NVL(D.COMPONENT, ' '),&#xD;&#xA;   NVL(D.COM_VER, 0),&#xD;&#xA;   @evt_h_1,&#xD;&#xA;   @evt_d_1,   &#xD;&#xA;   @evt_h_2,&#xD;&#xA;   @evt_d_2,&#xD;&#xA;   @evt_h_3,&#xD;&#xA;   @evt_d_3,&#xD;&#xA;   @evt_h_4,&#xD;&#xA;   @evt_d_4,&#xD;&#xA;   @evt_h_5,&#xD;&#xA;   @evt_d_5,&#xD;&#xA;   @evt_h_6,&#xD;&#xA;   @evt_d_6,&#xD;&#xA;   @evt_h_7,&#xD;&#xA;   @evt_d_7,&#xD;&#xA;   @evt_h_8,&#xD;&#xA;   @evt_d_8,&#xD;&#xA;   @evt_h_9,&#xD;&#xA;   @evt_d_9,&#xD;&#xA;   @evt_h_10,&#xD;&#xA;   @evt_d_10,&#xD;&#xA;   @evt_h_11,&#xD;&#xA;   @evt_d_11,   &#xD;&#xA;   @evt_h_12,&#xD;&#xA;   @evt_d_12,&#xD;&#xA;   @evt_h_13,&#xD;&#xA;   @evt_d_13,&#xD;&#xA;   @evt_h_14,&#xD;&#xA;   @evt_d_14,&#xD;&#xA;   @evt_h_15,&#xD;&#xA;   @evt_d_15,&#xD;&#xA;   @evt_h_16,&#xD;&#xA;   @evt_d_16,&#xD;&#xA;   @evt_h_17,&#xD;&#xA;   @evt_d_17,&#xD;&#xA;   @evt_h_18,&#xD;&#xA;   @evt_d_18,&#xD;&#xA;   @evt_h_19,&#xD;&#xA;   @evt_d_19,&#xD;&#xA;   @evt_h_20,&#xD;&#xA;   @evt_d_20,&#xD;&#xA;   @tran_user_id,&#xD;&#xA;   @tran_comment&#xD;&#xA;  FROM QRASEAPDEF A  &#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C&#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP           = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D&#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP           = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.EAP         = @eap">
            <QP N="event_id" />
            <QP N="tran_date" />
            <QP N="tran_time" />
            <QP N="evt_h_1" />
            <QP N="evt_d_1" />
