    <M _S="100" N="Common">
      <F _S="483" N="EapSchemaSearch">
        <SG _S="489" N="SearchEap">
          <QY P="SQLite" Q="SELECT EAP_TYPE&#xD;&#xA;  FROM QRASEAPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EAP         = @eap&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
      </F>
      <F _S="3627" N="EventSearch">
        <SG _S="3629" N="SearchEapEvent">
          <QY P="SQLite" Q="SELECT EVENT_DESC,&#xD;&#xA;       DATA_1_PRT, DATA_2_PRT, DATA_3_PRT, DATA_4_PRT, DATA_5_PRT,&#xD;&#xA;       DATA_6_PRT, DATA_7_PRT, DATA_8_PRT, DATA_9_PRT, DATA_10_PRT,    &#xD;&#xA;       DATA_11_PRT, DATA_12_PRT, DATA_13_PRT, DATA_14_PRT, DATA_15_PRT,&#xD;&#xA;       DATA_16_PRT, DATA_17_PRT, DATA_18_PRT, DATA_19_PRT, DATA_20_PRT,&#xD;&#xA;       ALT_COMMENT&#xD;&#xA;  FROM QRASEAPEVT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EVENT_ID = @event_id">
            <QP N="factory" />
            <QP N="event_id" />
          </QY>
        </SG>
        <SG _S="3673" N="SearchEquipmentEvent">
          <QY P="SQLite" Q="SELECT EVENT_DESC,&#xD;&#xA;       DATA_1_PRT, DATA_2_PRT, DATA_3_PRT, DATA_4_PRT, DATA_5_PRT,&#xD;&#xA;       DATA_6_PRT, DATA_7_PRT, DATA_8_PRT, DATA_9_PRT, DATA_10_PRT,    &#xD;&#xA;       DATA_11_PRT, DATA_12_PRT, DATA_13_PRT, DATA_14_PRT, DATA_15_PRT,&#xD;&#xA;       DATA_16_PRT, DATA_17_PRT, DATA_18_PRT, DATA_19_PRT, DATA_20_PRT,&#xD;&#xA;       ALT_COMMENT&#xD;&#xA;  FROM QRASEQPEVT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EVENT_ID = @event_id">
            <QP N="factory" />
            <QP N="event_id" />
          </QY>
        </SG>
      </F>
      <F _S="3678" N="EapAlarmSet">
        <SG _S="3680" N="SearchEap">
          <QY P="SQLite" Q="SELECT UP_DOWN, STATUS, ALARM&#xD;&#xA;  FROM QRASEAPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EAP         = @eap&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="3681" N="SearchConnectorState">
          <QY P="SQLite" Q="SELECT CNT_NAME&#xD;&#xA;  FROM QRASCNTSTS&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EAP     = @eap&#xD;&#xA;   AND STATE  &lt;&gt; @state">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="state" />
          </QY>
        </SG>
        <SG _S="3682" N="UpdateEap">
          <QY P="SQLite" Q="UPDATE QRASEAPDEF SET  &#xD;&#xA;  ALARM = @alarm  &#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EAP     = @eap">
            <QP N="alarm" />
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
      </F>
      <F _S="1100" N="EapFilePack">
        <SG _S="1102" N="HasModelVer">
          <QY P="SQLite" Q="SELECT MDL_VER_PATH, MDL_RELEASE&#xD;&#xA;  FROM QSYSMDLVER  &#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND MODEL  = @model&#xD;&#xA;   AND MDL_VER = @mdl_ver">
            <QP N="factory" />
            <QP N="model" />
            <QP N="mdl_ver" />
          </QY>
        </SG>
        <SG _S="3735" N="HasPackageVer">
          <QY P="SQLite" Q="SELECT PKG_VER_PATH, PKG_RELEASE&#xD;&#xA;  FROM QSYSPKGVER  &#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND PACKAGE = @package&#xD;&#xA;   AND PKG_VER = @pkg_ver">
            <QP N="factory" />
            <QP N="package" />
            <QP N="pkg_ver" />
          </QY>
        </SG>
        <SG _S="1103" N="HasLibraryVer">
          <QY P="SQLite" Q="SELECT LIB_VER_PATH, LIB_RELEASE&#xD;&#xA;  FROM QSYSLIBVER&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND LIBRARY  = @library&#xD;&#xA;   AND LIB_VER  = @lib_ver">
            <QP N="factory" />
            <QP N="library" />
            <QP N="lib_ver" />
          </QY>
        </SG>
      </F>
      <F _S="3188" N="EapHistory">
        <SG _S="3189" N="SelectEapHistorySeq">
          <QY P="SQLite" Q="SELECT NEXT VALUE FOR SEQ_EAP_HIS" />
        </SG>
        <SG _S="3369" N="SelectEapInfoForHistory">
          <QY P="SQLite" Q="SELECT &#xD;&#xA;   A.FACTORY,&#xD;&#xA;   A.EAP,   &#xD;&#xA;   A.STEP,&#xD;&#xA;   A.ALARM,&#xD;&#xA;   A.UP_DOWN,&#xD;&#xA;   A.STATUS,&#xD;&#xA;   A.NEED_ACTION,&#xD;&#xA;   A.NEXT_NEED_ACTION,   &#xD;&#xA;   A.RELOAD_CNT,&#xD;&#xA;   A.DELETE_FLAG,&#xD;&#xA;   IFNULL(B.MODEL, ' ') AS SET_MDL,&#xD;&#xA;   IFNULL(B.MDL_VER, 0) AS SET_MDL_VER,&#xD;&#xA;   IFNULL(C.MODEL, ' ') AS REL_MDL,&#xD;&#xA;   IFNULL(C.MDL_VER, 0) AS REL_MDL_VER,&#xD;&#xA;   IFNULL(D.MODEL, ' ') AS APL_MDL,&#xD;&#xA;   IFNULL(D.MDL_VER, 0) AS APL_MDL_VER,&#xD;&#xA;   IFNULL(B.LIBRARY, ' ') AS SET_LIB,&#xD;&#xA;   IFNULL(B.LIB_VER, 0) AS SET_LIB_VER,&#xD;&#xA;   IFNULL(C.LIBRARY, ' ') AS REL_LIB,&#xD;&#xA;   IFNULL(C.LIB_VER, 0) AS REL_LIB_VER,&#xD;&#xA;   IFNULL(D.LIBRARY, ' ') AS APL_LIB,&#xD;&#xA;   IFNULL(D.LIB_VER, 0) AS APL_LIB_VER&#xD;&#xA;  FROM QRASEAPDEF A  &#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C&#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP           = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D&#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP           = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.EAP         = @eap">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="3729" N="SelectEapInfoForHistoryByPkg">
          <QY P="SQLite" Q="SELECT &#xD;&#xA;   A.FACTORY,&#xD;&#xA;   A.EAP,   &#xD;&#xA;   A.STEP,&#xD;&#xA;   A.ALARM,&#xD;&#xA;   A.UP_DOWN,&#xD;&#xA;   A.STATUS,&#xD;&#xA;   A.NEED_ACTION,&#xD;&#xA;   A.NEXT_NEED_ACTION,   &#xD;&#xA;   A.RELOAD_CNT,&#xD;&#xA;   A.DELETE_FLAG,&#xD;&#xA;   IFNULL(B.PACKAGE, ' ') AS SET_PKG,&#xD;&#xA;   IFNULL(B.PKG_VER, 0) AS SET_PKG_VER,&#xD;&#xA;   IFNULL(C.PACKAGE, ' ') AS REL_PKG,&#xD;&#xA;   IFNULL(C.PKG_VER, 0) AS REL_PKG_VER,&#xD;&#xA;   IFNULL(D.PACKAGE, ' ') AS APL_PKG,&#xD;&#xA;   IFNULL(D.PKG_VER, 0) AS APL_PKG_VER,   &#xD;&#xA;   IFNULL(B.MODEL, ' ') AS SET_MDL,&#xD;&#xA;   IFNULL(B.MDL_VER, 0) AS SET_MDL_VER,&#xD;&#xA;   IFNULL(C.MODEL, ' ') AS REL_MDL,&#xD;&#xA;   IFNULL(C.MDL_VER, 0) AS REL_MDL_VER,&#xD;&#xA;   IFNULL(D.MODEL, ' ') AS APL_MDL,&#xD;&#xA;   IFNULL(D.MDL_VER, 0) AS APL_MDL_VER,&#xD;&#xA;   IFNULL(B.LIBRARY, ' ') AS SET_LIB,&#xD;&#xA;   IFNULL(B.LIB_VER, 0) AS SET_LIB_VER,&#xD;&#xA;   IFNULL(C.LIBRARY, ' ') AS REL_LIB,&#xD;&#xA;   IFNULL(C.LIB_VER, 0) AS REL_LIB_VER,&#xD;&#xA;   IFNULL(D.LIBRARY, ' ') AS APL_LIB,&#xD;&#xA;   IFNULL(D.LIB_VER, 0) AS APL_LIB_VER&#xD;&#xA;  FROM QRASEAPDEF A  &#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C&#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP           = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D&#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP           = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.EAP         = @eap">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
