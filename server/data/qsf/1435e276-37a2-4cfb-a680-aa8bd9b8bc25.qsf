          </QY>
        </SG>
        <SG _S="3361" N="UpdateEapEquipment">
          <QY P="SQLite" Q="UPDATE QRASEQPDEF SET&#xD;&#xA;   EAP             = @eap,&#xD;&#xA;   UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;   UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EQP_NAME = @eqp_name">
            <QP N="eap" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="3358" N="UpdateEapEquipmentStatus">
          <QY P="SQLite" Q="UPDATE QRASEQPSTS SET&#xD;&#xA;   LAST_HIST_SEQ   = @last_his_seq,&#xD;&#xA;   LAST_EVENT_ID   = @last_event_id,&#xD;&#xA;   LAST_EVENT_TIME = @last_event_time,&#xD;&#xA;   UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;   UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EQP_NAME = @eqp_name">
            <QP N="last_his_seq" />
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="199" N="Report">
      <F _S="236" N="ModelList">
        <SG _S="243" N="ListModel">
          <QY P="SQLite" Q="SELECT A.MODEL, A.MDL_DESC, A.MDL_TYPE, ISNULL(DATA.SET_COUNT, 0), ISNULL(DATA.REL_COUNT, 0), ISNULL(DATA.APP_COUNT, 0), A.REL_MDL_VER, A.LAST_MDL_VER, A.CREATE_USER_ID, A.CREATE_TIME, A.UPDATE_USER_ID, A.UPDATE_TIME&#xD;&#xA;  FROM QSYSMDLDEF A&#xD;&#xA;  LEFT JOIN (  &#xD;&#xA;SELECT B.FACTORY, B.MODEL,  SUM(B.SETUP) AS SET_COUNT, SUM(B.RELEASED) AS REL_COUNT, SUM(B.APPLIED) AS APP_COUNT &#xD;&#xA;  FROM (&#xD;&#xA;SELECT FACTORY, MODEL,&#xD;&#xA;  CASE WHEN ATTR_CATEGORY='Setup' THEN 1 ELSE 0 END AS SETUP,&#xD;&#xA;  CASE WHEN ATTR_CATEGORY='Released' THEN 1 ELSE 0 END AS RELEASED,&#xD;&#xA;  CASE WHEN ATTR_CATEGORY='Applied' THEN 1 ELSE 0 END AS APPLIED&#xD;&#xA;  FROM QRASEAPATR) B&#xD;&#xA; GROUP BY B.FACTORY, B.MODEL) DATA&#xD;&#xA;    ON A.FACTORY = DATA.FACTORY&#xD;&#xA;   AND A.MODEL   = DATA.MODEL&#xD;&#xA; WHERE A.FACTORY = @factory&#xD;&#xA; ORDER BY A.MODEL">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="244" N="ListModelVer">
          <QY P="SQLite" Q="SELECT A.MDL_VER, A.MDL_VER_DESC, ISNULL(SET_COUNT, 0), ISNULL(REL_COUNT, 0), ISNULL(APP_COUNT, 0), A.MDL_VER_PATH, A.MDL_COMMENT, A.MDL_RELEASE,&#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME, A.UPDATE_USER_ID, A.UPDATE_TIME &#xD;&#xA;  FROM QSYSMDLVER A&#xD;&#xA;  LEFT JOIN(&#xD;&#xA;SELECT A.FACTORY, A.MODEL, A.MDL_VER, SUM(A.SETUP) AS SET_COUNT, SUM(A.RELEASED) AS REL_COUNT, SUM(A.APPLIED) AS APP_COUNT&#xD;&#xA;  FROM (   &#xD;&#xA;SELECT FACTORY, MODEL, MDL_VER,  &#xD;&#xA;  CASE WHEN ATTR_CATEGORY='Setup' THEN 1 ELSE 0 END AS SETUP,&#xD;&#xA;  CASE WHEN ATTR_CATEGORY='Released' THEN 1 ELSE 0 END AS RELEASED,&#xD;&#xA;  CASE WHEN ATTR_CATEGORY='Applied' THEN 1 ELSE 0 END AS APPLIED&#xD;&#xA;  FROM QRASEAPATR &#xD;&#xA; ) A&#xD;&#xA; GROUP BY FACTORY, MODEL, MDL_VER&#xD;&#xA;  ) DATA&#xD;&#xA;    ON A.FACTORY  = DATA.FACTORY&#xD;&#xA;   AND A.MODEL    = DATA.MODEL&#xD;&#xA;   AND A.MDL_VER  = DATA.MDL_VER&#xD;&#xA; WHERE A.FACTORY  = @factory&#xD;&#xA;   AND A.MODEL    = @model&#xD;&#xA; ORDER BY A.MDL_VER DESC">
            <QP N="factory" />
            <QP N="model" />
          </QY>
        </SG>
        <SG _S="599" N="ListEap">
          <QY P="SQLite" Q="SELECT A.EAP, A.EAP_DESC, A.EAP_TYPE, A.OPER_ME, A.SERVER, A.STEP, A.UP_DOWN, A.STATUS, A.RELOAD_CNT,&#xD;&#xA;       ISNULL(B.PACKAGE, 'N/A') SET_PACKAGE,  ISNULL(B.PKG_VER, 0) SET_PKG_VER, ISNULL(C.PACKAGE, 'N/A') REL_PACKAGE, ISNULL(C.PKG_VER, 0) REL_PKG_VER, ISNULL(D.PACKAGE, 'N/A') APL_PACKAGE, ISNULL(D.PKG_VER, 0) APL_PKG_VER,&#xD;&#xA;       ISNULL(B.MODEL, 'N/A') SET_MODEL, ISNULL(B.MDL_VER, 0) SET_MDL_VER, ISNULL(C.MODEL, 'N/A') REL_MODEL, ISNULL(C.MDL_VER, 0) REL_MDL_VER, ISNULL(D.MODEL, 'N/A') APL_MODEL, ISNULL(D.MDL_VER, 0) APL_MDL_VER, &#xD;&#xA;       ISNULL(B.USED_COM, 'N/A') SET_USED_COM, ISNULL(B.COMPONENT, 'N/A') SET_COMPONENT, ISNULL(B.COM_VER, 0) SET_COM_VER, ISNULL(C.USED_COM, 'N/A') REL_USED_COM, ISNULL(C.COMPONENT, 'N/A') REL_COMPONENT, ISNULL(C.COM_VER, 0) REL_COM_VER, ISNULL(D.USED_COM, 'N/A') APL_USED_COM, ISNULL(D.COMPONENT, 'N/A') APL_COMPONENT, ISNULL(D.COM_VER, 0) APL_COM_VER,&#xD;&#xA;       A.NEED_ACTION, A.NEXT_NEED_ACTION, A.LAST_EVENT_TIME, A.LAST_EVENT_ID,&#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME, A.UPDATE_USER_ID, A.UPDATE_TIME&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP              = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP              = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP              = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND B.MODEL            = @model&#xD;&#xA;   AND B.MDL_VER         = @mdl_ver&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'   &#xD;&#xA; ORDER BY EAP">
            <QP N="factory" />
            <QP N="model" />
            <QP N="mdl_ver" />
          </QY>
        </SG>
        <SG _S="600" N="SearchEap">
          <QY P="SQLite" Q="SELECT A.EAP, A.EAP_DESC, &#xD;&#xA;       A.EAP_TYPE, A.OPER_ME, A.SERVER, &#xD;&#xA;       A.UP_DOWN, A.STATUS, A.STEP, &#xD;&#xA;       A.NEED_ACTION, A.NEXT_NEED_ACTION, A.RELOAD_CNT,&#xD;&#xA;       ISNULL(B.PACKAGE, 'N/A') SET_PACKAGE, ISNULL(B.PKG_VER, 0) SET_PKG_VER, ISNULL(B.MODEL, 'N/A') SET_MODEL, ISNULL(B.MDL_VER, 0) SET_MDL_VER, ISNULL(B.USED_COM, 'N/A') SET_USED_COM, ISNULL(B.COMPONENT, 'N/A') SET_COMPONENT, ISNULL(B.COM_VER, 0) SET_COM_VER,&#xD;&#xA;       ISNULL(C.PACKAGE, 'N/A') REL_PACKAGE, ISNULL(C.PKG_VER, 0) REL_PKG_VER, ISNULL(C.MODEL, 'N/A') REL_MODEL, ISNULL(C.MDL_VER, 0) REL_MDL_VER, ISNULL(C.USED_COM, 'N/A') REL_USED_COM, ISNULL(C.COMPONENT, 'N/A') REL_COMPONENT, ISNULL(C.COM_VER, 0) REL_COM_VER,&#xD;&#xA;       ISNULL(D.PACKAGE, 'N/A') APL_PACKAGE, ISNULL(D.PKG_VER, 0) APL_PKG_VER, ISNULL(D.MODEL, 'N/A') APL_MODEL, ISNULL(D.MDL_VER, 0) APL_MDL_VER, ISNULL(D.USED_COM, 'N/A') APL_USED_COM, ISNULL(D.COMPONENT, 'N/A') APL_COMPONENT, ISNULL(D.COM_VER, 0) APL_COM_VER,&#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME,&#xD;&#xA;       A.UPDATE_USER_ID, A.UPDATE_TIME,&#xD;&#xA;       A.LAST_EVENT_TIME, A.LAST_EVENT_ID&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP              = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP              = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP              = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.EAP                 = @eap&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="2702" N="SearchModelSheet">
          <QY P="SQLite" Q="SELECT &#xD;&#xA;  SHT_CONTENTS_01,&#xD;&#xA;  SHT_CONTENTS_02,&#xD;&#xA;  SHT_CONTENTS_03,&#xD;&#xA;  SHT_CONTENTS_04,&#xD;&#xA;  SHT_CONTENTS_05,&#xD;&#xA;  SHT_CONTENTS_06,&#xD;&#xA;  SHT_CONTENTS_07,&#xD;&#xA;  SHT_CONTENTS_08,&#xD;&#xA;  SHT_CONTENTS_09,&#xD;&#xA;  SHT_CONTENTS_10,&#xD;&#xA;  SHT_CONTENTS_11,&#xD;&#xA;  SHT_CONTENTS_12,&#xD;&#xA;  SHT_CONTENTS_13,&#xD;&#xA;  SHT_CONTENTS_14,&#xD;&#xA;  SHT_CONTENTS_15,&#xD;&#xA;  SHT_CONTENTS_16,&#xD;&#xA;  SHT_CONTENTS_17,&#xD;&#xA;  SHT_CONTENTS_18,&#xD;&#xA;  SHT_CONTENTS_19,&#xD;&#xA;  SHT_CONTENTS_20&#xD;&#xA;  FROM QSMDLSHT&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND MODEL  = @model">
            <QP N="factory" />
            <QP N="model" />
          </QY>
        </SG>
      </F>
      <F _S="237" N="ModelStatus">
        <SG _S="595" N="ListModelVer">
          <QY P="SQLite" Q="SELECT MDL_VER, MDL_VER_DESC, MDL_RELEASE &#xD;&#xA;  FROM QSYSMDLVER&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND MODEL  = @model&#xD;&#xA; ORDER BY MDL_VER DESC">
            <QP N="factory" />
            <QP N="model" />
          </QY>
        </SG>
        <SG _S="596" N="SearchModel">
          <QY P="SQLite" Q="SELECT A.MODEL, A.MDL_DESC, A.MDL_TYPE,&#xD;&#xA;       A.REL_MDL_VER, A.LAST_MDL_VER,&#xD;&#xA;       B.MDL_VER, B.MDL_RELEASE, B.MDL_VER_DESC,&#xD;&#xA;       B.MDL_VER_PATH, B.MDL_COMMENT,&#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME,&#xD;&#xA;       A.UPDATE_USER_ID, A.UPDATE_TIME&#xD;&#xA;  FROM QSYSMDLDEF A&#xD;&#xA; INNER JOIN QSYSMDLVER B&#xD;&#xA;    ON A.FACTORY = B.FACTORY&#xD;&#xA;   AND A.MODEL   = B.MODEL&#xD;&#xA; WHERE A.FACTORY = @factory &#xD;&#xA;   AND A.MODEL   = @model&#xD;&#xA;   AND B.MDL_VER = @mdl_ver">
            <QP N="factory" />
            <QP N="model" />
            <QP N="mdl_ver" />
          </QY>
        </SG>
        <SG _S="597" N="ListEap">
          <QY P="SQLite" Q="SELECT A.EAP, A.EAP_DESC, A.EAP_TYPE, A.OPER_ME, A.SERVER, A.STEP, A.UP_DOWN, A.STATUS, A.RELOAD_CNT,&#xD;&#xA;       ISNULL(B.PACKAGE, 'N/A') SET_PACKAGE,  ISNULL(B.PKG_VER, 0) SET_PKG_VER, ISNULL(C.PACKAGE, 'N/A') REL_PACKAGE, ISNULL(C.PKG_VER, 0) REL_PKG_VER, ISNULL(D.PACKAGE, 'N/A') APL_PACKAGE, ISNULL(D.PKG_VER, 0) APL_PKG_VER,&#xD;&#xA;       ISNULL(B.MODEL, 'N/A') SET_MODEL, ISNULL(B.MDL_VER, 0) SET_MDL_VER, ISNULL(C.MODEL, 'N/A') REL_MODEL, ISNULL(C.MDL_VER, 0) REL_MDL_VER, ISNULL(D.MODEL, 'N/A') APL_MODEL, ISNULL(D.MDL_VER, 0) APL_MDL_VER, &#xD;&#xA;       ISNULL(B.USED_COM, 'N/A') SET_USED_COM, ISNULL(B.COMPONENT, 'N/A') SET_COMPONENT, ISNULL(B.COM_VER, 0) SET_COM_VER, ISNULL(C.USED_COM, 'N/A') REL_USED_COM, ISNULL(C.COMPONENT, 'N/A') REL_COMPONENT, ISNULL(C.COM_VER, 0) REL_COM_VER, ISNULL(D.USED_COM, 'N/A') APL_USED_COM, ISNULL(D.COMPONENT, 'N/A') APL_COMPONENT, ISNULL(D.COM_VER, 0) APL_COM_VER,&#xD;&#xA;       A.NEED_ACTION, A.NEXT_NEED_ACTION, A.LAST_EVENT_TIME, A.LAST_EVENT_ID,&#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME, A.UPDATE_USER_ID, A.UPDATE_TIME&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP              = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP              = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP              = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND B.MODEL             = @model&#xD;&#xA;   AND B.MDL_VER         = @mdl_ver&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'   &#xD;&#xA; ORDER BY EAP">
            <QP N="factory" />
            <QP N="model" />
            <QP N="mdl_ver" />
          </QY>
        </SG>
        <SG _S="598" N="SearchEap">
          <QY P="SQLite" Q="SELECT A.EAP, A.EAP_DESC, &#xD;&#xA;       A.EAP_TYPE, A.OPER_ME, A.SERVER, &#xD;&#xA;       A.UP_DOWN, A.STATUS, A.STEP, &#xD;&#xA;       A.NEED_ACTION, A.NEXT_NEED_ACTION, A.RELOAD_CNT,&#xD;&#xA;       ISNULL(B.PACKAGE, 'N/A') SET_PACKAGE, ISNULL(B.PKG_VER, 0) SET_PKG_VER, ISNULL(B.MODEL, 'N/A') SET_MODEL, ISNULL(B.MDL_VER, 0) SET_MDL_VER, ISNULL(B.USED_COM, 'N/A') SET_USED_COM, ISNULL(B.COMPONENT, 'N/A') SET_COMPONENT, ISNULL(B.COM_VER, 0) SET_COM_VER,&#xD;&#xA;       ISNULL(C.PACKAGE, 'N/A') REL_PACKAGE, ISNULL(C.PKG_VER, 0) REL_PKG_VER, ISNULL(C.MODEL, 'N/A') REL_MODEL, ISNULL(C.MDL_VER, 0) REL_MDL_VER, ISNULL(C.USED_COM, 'N/A') REL_USED_COM, ISNULL(C.COMPONENT, 'N/A') REL_COMPONENT, ISNULL(C.COM_VER, 0) REL_COM_VER,&#xD;&#xA;       ISNULL(D.PACKAGE, 'N/A') APL_PACKAGE, ISNULL(D.PKG_VER, 0) APL_PKG_VER, ISNULL(D.MODEL, 'N/A') APL_MODEL, ISNULL(D.MDL_VER, 0) APL_MDL_VER, ISNULL(D.USED_COM, 'N/A') APL_USED_COM, ISNULL(D.COMPONENT, 'N/A') APL_COMPONENT, ISNULL(D.COM_VER, 0) APL_COM_VER,&#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME,&#xD;&#xA;       A.UPDATE_USER_ID, A.UPDATE_TIME,&#xD;&#xA;       A.LAST_EVENT_TIME, A.LAST_EVENT_ID&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP              = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP              = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP              = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.EAP                 = @eap&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="2703" N="SearchModelSheet">
          <QY P="SQLite" Q="SELECT &#xD;&#xA;  SHT_CONTENTS_01,&#xD;&#xA;  SHT_CONTENTS_02,&#xD;&#xA;  SHT_CONTENTS_03,&#xD;&#xA;  SHT_CONTENTS_04,&#xD;&#xA;  SHT_CONTENTS_05,&#xD;&#xA;  SHT_CONTENTS_06,&#xD;&#xA;  SHT_CONTENTS_07,&#xD;&#xA;  SHT_CONTENTS_08,&#xD;&#xA;  SHT_CONTENTS_09,&#xD;&#xA;  SHT_CONTENTS_10,&#xD;&#xA;  SHT_CONTENTS_11,&#xD;&#xA;  SHT_CONTENTS_12,&#xD;&#xA;  SHT_CONTENTS_13,&#xD;&#xA;  SHT_CONTENTS_14,&#xD;&#xA;  SHT_CONTENTS_15,&#xD;&#xA;  SHT_CONTENTS_16,&#xD;&#xA;  SHT_CONTENTS_17,&#xD;&#xA;  SHT_CONTENTS_18,&#xD;&#xA;  SHT_CONTENTS_19,&#xD;&#xA;  SHT_CONTENTS_20&#xD;&#xA;  FROM QSMDLSHT&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND MODEL  = @model">
            <QP N="factory" />
            <QP N="model" />
          </QY>
        </SG>
      </F>
      <F _S="378" N="EapList">
        <SG _S="379" N="ListEap">
          <QY P="SQLite" Q="SELECT A.EAP, A.EAP_DESC, A.STEP, A.UP_DOWN, A.STATUS, A.RELOAD_CNT,&#xD;&#xA;       IFNULL(B.MODEL, 'N/A') SET_MODEL, IFNULL(B.MDL_VER, 0) SET_MDL_VER, IFNULL(C.MODEL, 'N/A') REL_MODEL, IFNULL(C.MDL_VER, 0) REL_MDL_VER, IFNULL(D.MODEL, 'N/A') APL_MODEL, IFNULL(D.MDL_VER, 0) APL_MDL_VER,        &#xD;&#xA;       A.NEED_ACTION, A.NEXT_NEED_ACTION, A.LAST_EVENT_TIME, A.LAST_EVENT_ID,&#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME, A.UPDATE_USER_ID, A.UPDATE_TIME&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY              = B.FACTORY&#xD;&#xA;   AND A.EAP                     = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C &#xD;&#xA;    ON A.FACTORY              = C.FACTORY&#xD;&#xA;   AND A.EAP                     = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D &#xD;&#xA;    ON A.FACTORY              = D.FACTORY&#xD;&#xA;   AND A.EAP                     = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY           = @factory&#xD;&#xA;   AND B.MODEL                 = IFNULL(@model, B.MODEL)&#xD;&#xA;   AND A.DELETE_FLAG        = 'N'&#xD;&#xA; ORDER BY A.EAP">
            <QP N="factory" />
            <QP N="model" />
          </QY>
        </SG>
        <SG _S="624" N="SearchEap">
          <QY P="SQLite" Q="SELECT A.EAP, A.EAP_DESC, &#xD;&#xA;       A.UP_DOWN, A.STATUS, A.STEP,&#xD;&#xA;       A.NEED_ACTION, A.NEXT_NEED_ACTION, A.RELOAD_CNT,&#xD;&#xA;       IFNULL(B.MODEL, 'N/A') SET_MODEL, IFNULL(B.MDL_VER, 0) SET_MDL_VER, &#xD;&#xA;       IFNULL(C.MODEL, 'N/A') REL_MODEL, IFNULL(C.MDL_VER, 0) REL_MDL_VER, &#xD;&#xA;       IFNULL(D.MODEL, 'N/A') APL_MODEL, IFNULL(D.MDL_VER, 0) APL_MDL_VER,&#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME,&#xD;&#xA;       A.UPDATE_USER_ID, A.UPDATE_TIME,&#xD;&#xA;       A.LAST_EVENT_TIME, A.LAST_EVENT_ID&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP           = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP           = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.EAP           = @eap&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
      </F>
      <F _S="380" N="EapStatus">
        <SG _S="945" N="HasEap">
          <QY P="SQLite" Q="SELECT *&#xD;&#xA;  FROM QRASEAPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EAP= ISNULL(@eap, EAP)">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="381" N="SearchEap">
          <QY P="SQLite" Q="SELECT A.EAP, A.EAP_DESC, &#xD;&#xA;       A.UP_DOWN, A.STATUS, A.STEP,&#xD;&#xA;       A.NEED_ACTION, A.NEXT_NEED_ACTION, A.RELOAD_CNT,&#xD;&#xA;       IFNULL(B.MODEL, 'N/A') SET_MODEL, IFNULL(B.MDL_VER, 0) SET_MDL_VER, &#xD;&#xA;       IFNULL(C.MODEL, 'N/A') REL_MODEL, IFNULL(C.MDL_VER, 0) REL_MDL_VER, &#xD;&#xA;       IFNULL(D.MODEL, 'N/A') APL_MODEL, IFNULL(D.MDL_VER, 0) APL_MDL_VER,&#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME,&#xD;&#xA;       A.UPDATE_USER_ID, A.UPDATE_TIME,&#xD;&#xA;       A.LAST_EVENT_TIME, A.LAST_EVENT_ID&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP           = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP           = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.EAP           = @eap&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
      </F>
      <F _S="842" N="EapHistory">
        <SG _S="845" N="SearchEapHistory">
          <QY P="SQLite" Q="SELECT TRAN_TIME, EAP, EVENT_ID, STEP, &#xD;&#xA;       UP_DOWN, STATUS, NEED_ACTION, NEXT_NEED_ACTION, TRAN_USER_ID,&#xD;&#xA;       SET_MODEL, SET_MDL_VER, REL_MODEL, REL_MDL_VER, APL_MODEL, APL_MDL_VER,&#xD;&#xA;       EVT_H_1, EVT_D_1, EVT_H_2, EVT_D_2, EVT_H_3, EVT_D_3, EVT_H_4, EVT_D_4, EVT_H_5, EVT_D_5, &#xD;&#xA;       EVT_H_6, EVT_D_6, EVT_H_7, EVT_D_7, EVT_H_8, EVT_D_8, EVT_H_9, EVT_D_9, EVT_H_10, EVT_D_10, &#xD;&#xA;       EVT_H_11, EVT_D_11, EVT_H_12, EVT_D_12, EVT_H_13, EVT_D_13, EVT_H_14, EVT_D_14, EVT_H_15, EVT_D_15, &#xD;&#xA;       EVT_H_16, EVT_D_16, EVT_H_17, EVT_D_17, EVT_H_18, EVT_D_18, EVT_H_19, EVT_D_19, EVT_H_20, EVT_D_20,&#xD;&#xA;       TRAN_COMMENT&#xD;&#xA;  FROM QRASEAPHIS&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND EAP          = IFNULL(@eap, EAP)&#xD;&#xA;   AND TRAN_TIME &gt;= @tran_from_time&#xD;&#xA;   AND TRAN_TIME &lt;= IFNULL(@tran_to_time, TRAN_TIME)&#xD;&#xA; ORDER BY TRAN_TIME DESC">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
      </F>
      <F _S="2729" N="EapNeedActionList">
        <SG _S="2737" N="ListEap">
          <QY P="SQLite" Q="SELECT A.EAP, A.EAP_DESC, A.STEP, A.UP_DOWN, A.STATUS, A.RELOAD_CNT, A.ALARM, A.NEED_ACTION, A.NEXT_NEED_ACTION,&#xD;&#xA;       IFNULL(B.MODEL, 'N/A') SET_MODEL, IFNULL(B.MDL_VER, 0) SET_MDL_VER, IFNULL(C.MODEL, 'N/A') REL_MODEL, IFNULL(C.MDL_VER, 0) REL_MDL_VER, IFNULL(D.MODEL, 'N/A') APL_MODEL, IFNULL(D.MDL_VER, 0) APL_MDL_VER&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP           = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP           = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.DELETE_FLAG = 'N'    &#xD;&#xA;   AND A.NEED_ACTION = @need_action  &#xD;&#xA; ORDER BY A.EAP">
            <QP N="factory" />
            <QP N="need_action" />
          </QY>
        </SG>
      </F>
      <F _S="876" N="EquipmentList">
        <SG _S="882" N="ListEquipment">
          <QY P="SQLite" Q="SELECT A.EQP_NAME, A.EQP_DESC, A.TYPE, A.AREA, A.LINE,ISNULL(A.CTRL_MODE,'N/A') CTRL_MODE, ISNULL(A.PRI_STATE,'N/A') PRI_STATE, ISNULL(A.STATE,'N/A') STATE,&#xD;&#xA;       C.EAP, ISNULL(A.MDLN,'N/A') MDLN, ISNULL( A.SOFTREV,'N/A') SOFTREV, ISNULL( A.EVENT_DEFINE,'N/A') EVENT_DEFINE, A.EQP_RCP_ID,&#xD;&#xA;       C.SERVER, C.STEP, C.UP_DOWN, C.STATUS, C.RELOAD_CNT, &#xD;&#xA;       ISNULL(D.PACKAGE, 'N/A'), ISNULL(D.PKG_VER, 0),&#xD;&#xA;       ISNULL(D.MODEL, 'N/A'), ISNULL(D.MDL_VER, 0), &#xD;&#xA;       ISNULL(D.USED_COM, 'N/A'), ISNULL(D.COMPONENT, 'N/A'), ISNULL(D.COM_VER, 0), &#xD;&#xA;       C.NEED_ACTION, C.NEXT_NEED_ACTION, &#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME,&#xD;&#xA;       A.UPDATE_USER_ID, A.UPDATE_TIME,&#xD;&#xA;       A.LAST_EVENT_ID, A.LAST_EVENT_TIME &#xD;&#xA;  FROM QRASEQPDEF  A &#xD;&#xA;  LEFT JOIN  QRASEQPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EQP_NAME      = B.EQP_NAME&#xD;&#xA;   AND B.ATTR_CATEGORY = @category&#xD;&#xA;  LEFT JOIN QRASEAPDEF C&#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND B.EAP           = C.EAP&#xD;&#xA;  LEFT JOIN QRASEAPATR D&#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND B.EAP           = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = @category   &#xD;&#xA; WHERE A.FACTORY       = @factory &#xD;&#xA;   AND A.TYPE          = ISNULL(@type, A.TYPE)&#xD;&#xA;   AND A.AREA          = ISNULL(@area, A.AREA)&#xD;&#xA;   AND A.LINE          = ISNULL(@line, A.LINE)&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'&#xD;&#xA; ORDER BY A.EQP_NAME">
            <QP N="category" />
            <QP N="factory" />
            <QP N="type" />
            <QP N="area" />
            <QP N="line" />
          </QY>
        </SG>
        <SG _S="884" N="SearchEquipment">
          <QY P="SQLite" Q="SELECT A.EQP_NAME, A.EQP_DESC, A.TYPE, A.AREA, A.LINE, ISNULL(A.CTRL_MODE,'N/A'), ISNULL(A.PRI_STATE,'N/A'), ISNULL(A.STATE,'N/A'),&#xD;&#xA;       ISNULL(A.MDLN,'N/A'), ISNULL( A.SOFTREV,'N/A'), ISNULL( A.EVENT_DEFINE,'N/A'),  A.EQP_RCP_ID,&#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME,  &#xD;&#xA;       A.UPDATE_USER_ID, A.UPDATE_TIME, &#xD;&#xA;       A.LAST_EVENT_TIME, A.LAST_EVENT_ID,&#xD;&#xA;       C.EAP, C.EAP_DESC, C.EAP_TYPE, &#xD;&#xA;       C.SERVER, C.UP_DOWN,  C.STATUS, C.STEP, C.NEED_ACTION, C.NEXT_NEED_ACTION, &#xD;&#xA;       ISNULL(D.PACKAGE, 'N/A'), ISNULL(D.PKG_VER, 0),&#xD;&#xA;       ISNULL(D.MODEL, 'N/A'), ISNULL(D.MDL_VER, 0), &#xD;&#xA;       ISNULL(D.USED_COM, 'N/A'), ISNULL(D.COMPONENT, 'N/A'), ISNULL(D.COM_VER, 0),        &#xD;&#xA;       C.RELOAD_CNT,&#xD;&#xA;       C.CREATE_USER_ID, C.CREATE_TIME,&#xD;&#xA;       C.UPDATE_USER_ID, C.UPDATE_TIME,&#xD;&#xA;       C.LAST_EVENT_TIME, C.LAST_EVENT_ID&#xD;&#xA;  FROM QRASEQPDEF  A &#xD;&#xA;  LEFT JOIN  QRASEQPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EQP_NAME      = B.EQP_NAME&#xD;&#xA;   AND B.ATTR_CATEGORY = @category&#xD;&#xA;  LEFT JOIN QRASEAPDEF C&#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND B.EAP           = C.EAP&#xD;&#xA;  LEFT JOIN QRASEAPATR D&#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND B.EAP           = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = @category   &#xD;&#xA; WHERE A.FACTORY       = @factory &#xD;&#xA;   AND A.EQP_NAME      = @eqpName&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="category" />
            <QP N="factory" />
            <QP N="eqpName" />
          </QY>
        </SG>
      </F>
      <F _S="3076" N="AlarmStatus">
        <SG _S="3077" N="SearchAlarmStatus">
          <QY P="SQLite" Q="SELECT EQP_NAME, SET_TIME, ALARM_ID, ALARM_TEXT&#xD;&#xA; FROM QRASEQPALS&#xD;&#xA;WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="2724" N="EquipmentStatus">
        <SG _S="2725" N="HasEquipment">
          <QY P="SQLite" Q="SELECT EQP_NAME &#xD;&#xA;  FROM QRASEQPDEF &#xD;&#xA; WHERE FACTORY  = @factory &#xD;&#xA;   AND EQP_NAME = @eqp_name">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="2727" N="SearchEquipment">
          <QY P="SQLite" Q="SELECT EQP_NAME, EQP_DESC, ISNULL(EQP_RCP_ID, 'N/A'),&#xD;&#xA;       TYPE, AREA, LINE, &#xD;&#xA;       ISNULL(CTRL_MODE,'N/A'), ISNULL(PRI_STATE,'N/A'), ISNULL(STATE,'N/A'),&#xD;&#xA;       ISNULL(MDLN,'N/A'), ISNULL(SOFTREV,'N/A'), ISNULL(EVENT_DEFINE,'N/A'), &#xD;&#xA;       CREATE_USER_ID, CREATE_TIME, UPDATE_USER_ID, UPDATE_TIME, &#xD;&#xA;       LAST_EVENT_TIME, LAST_EVENT_ID&#xD;&#xA;  FROM QRASEQPDEF &#xD;&#xA; WHERE FACTORY  = @factory &#xD;&#xA;   AND EQP_NAME = @eqp_name">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="2728" N="SearchEap">
          <QY P="SQLite" Q="SELECT A.EAP, B.EAP_DESC, B.EAP_TYPE,&#xD;&#xA;       B.SERVER, B.UP_DOWN, B.STATUS,&#xD;&#xA;       B.STEP, B.NEED_ACTION, B.NEXT_NEED_ACTION,&#xD;&#xA;       ISNULL(C.PACKAGE, 'N/A'), ISNULL(C.PKG_VER, 0), ISNULL(C.MODEL, 'N/A'), ISNULL(C.MDL_VER, 0), ISNULL(C.USED_COM, 'N/A'), ISNULL(C.COMPONENT, 'N/A'), ISNULL(C.COM_VER, 0),&#xD;&#xA;       B.RELOAD_CNT, B.CREATE_USER_ID, B.CREATE_TIME, B.UPDATE_USER_ID, B.UPDATE_TIME,&#xD;&#xA;       B.LAST_EVENT_TIME, B.LAST_EVENT_ID&#xD;&#xA;  FROM QRASEQPATR A&#xD;&#xA;  LEFT JOIN QRASEAPDEF B&#xD;&#xA;    ON A.FACTORY = B.FACTORY&#xD;&#xA;   AND A.EAP     = B.EAP&#xD;&#xA;  LEFT JOIN QRASEAPATR C&#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP           = C.EAP&#xD;&#xA;   AND A.ATTR_CATEGORY = C.ATTR_CATEGORY&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.EQP_NAME      = @eqp_name&#xD;&#xA;   AND A.ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="attr_category" />
          </QY>
        </SG>
      </F>
      <F _S="1463" N="EquipmentHistory">
        <SG _S="2822" N="SearchEquipmentHistory">
          <QY P="SQLite" Q="SELECT  TRAN_TIME, EQP_NAME, SYSTEM, EVENT_ID, EAP, COMM_STATE, CTRL_MODE, EAP_EVENT_ID, TRAN_USER_ID,&#xD;&#xA;        EVT_H_1, EVT_D_1, EVT_H_2, EVT_D_2, EVT_H_3, EVT_D_3, EVT_H_4, EVT_D_4, EVT_H_5, EVT_D_5, &#xD;&#xA;        EVT_H_6, EVT_D_6, EVT_H_7, EVT_D_7, EVT_H_8, EVT_D_8, EVT_H_9, EVT_D_9, EVT_H_10, EVT_D_10, &#xD;&#xA;        EVT_H_11, EVT_D_11, EVT_H_12, EVT_D_12, EVT_H_13, EVT_D_13, EVT_H_14, EVT_D_14, EVT_H_15, EVT_D_15, &#xD;&#xA;        EVT_H_16, EVT_D_16, EVT_H_17, EVT_D_17, EVT_H_18, EVT_D_18, EVT_H_19, EVT_D_19, EVT_H_20, EVT_D_20,&#xD;&#xA;        TRAN_COMMENT&#xD;&#xA;   FROM QRASEQPHIS&#xD;&#xA;  WHERE FACTORY      = @factory&#xD;&#xA;    AND EQP_NAME     = ISNULL(@eqp_name, EQP_NAME)&#xD;&#xA;   AND TRAN_TIME &gt;= @tran_from_time&#xD;&#xA;   AND TRAN_TIME &lt;= ISNULL(@tran_to_time, TRAN_TIME)&#xD;&#xA; ORDER BY TRAN_TIME">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="411" N="EapTransaction">
      <F _S="8095" N="EquipmentEvent">
        <SG _S="8096" N="SearchEap">
          <QY P="SQLite" Q="SELECT EAP&#xD;&#xA;  FROM QRASEAPDEF  &#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EAP         = @eap&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="8097" N="SearchEquipment">
          <QY P="SQLite" Q="SELECT A.EQP_NAME, B.COMM_STATE, B.CTRL_MODE&#xD;&#xA;  FROM QRASEQPDEF A&#xD;&#xA;  	LEFT JOIN QRASEQPSTS B&#xD;&#xA;  	ON A.EQP_NAME = B.EQP_NAME&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.EQP_NAME = @eqp_name&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="8099" N="InsertEquipmentHis">
          <QY P="SQLite" Q="INSERT INTO QRASEQPHIS (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   EVENT_ID,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   SYSTEM,&#xD;&#xA;   COMM_STATE,&#xD;&#xA;   CTRL_MODE,&#xD;&#xA;   EAP,&#xD;&#xA;   EAP_EVENT_ID,      &#xD;&#xA;   EVT_H_1,&#xD;&#xA;   EVT_D_1,   &#xD;&#xA;   EVT_H_2,&#xD;&#xA;   EVT_D_2,&#xD;&#xA;   EVT_H_3,&#xD;&#xA;   EVT_D_3,&#xD;&#xA;   EVT_H_4,&#xD;&#xA;   EVT_D_4,&#xD;&#xA;   EVT_H_5,&#xD;&#xA;   EVT_D_5,&#xD;&#xA;   EVT_H_6,&#xD;&#xA;   EVT_D_6,&#xD;&#xA;   EVT_H_7,&#xD;&#xA;   EVT_D_7,&#xD;&#xA;   EVT_H_8,&#xD;&#xA;   EVT_D_8,&#xD;&#xA;   EVT_H_9,&#xD;&#xA;   EVT_D_9,&#xD;&#xA;   EVT_H_10,&#xD;&#xA;   EVT_D_10,&#xD;&#xA;   EVT_H_11,&#xD;&#xA;   EVT_D_11,   &#xD;&#xA;   EVT_H_12,&#xD;&#xA;   EVT_D_12,&#xD;&#xA;   EVT_H_13,&#xD;&#xA;   EVT_D_13,&#xD;&#xA;   EVT_H_14,&#xD;&#xA;   EVT_D_14,&#xD;&#xA;   EVT_H_15,&#xD;&#xA;   EVT_D_15,&#xD;&#xA;   EVT_H_16,&#xD;&#xA;   EVT_D_16,&#xD;&#xA;   EVT_H_17,&#xD;&#xA;   EVT_D_17,&#xD;&#xA;   EVT_H_18,&#xD;&#xA;   EVT_D_18,&#xD;&#xA;   EVT_H_19,&#xD;&#xA;   EVT_D_19,&#xD;&#xA;   EVT_H_20,&#xD;&#xA;   EVT_D_20,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT      &#xD;&#xA;) &#xD;&#xA;VALUES( &#xD;&#xA;   @factory,&#xD;&#xA;   @eqp_name,&#xD;&#xA;   @last_his_seq,&#xD;&#xA;   @event_id,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @SYSTEM,&#xD;&#xA;   @comm_state,&#xD;&#xA;   @ctrl_mode,&#xD;&#xA;   @eap,&#xD;&#xA;   @eap_event_id,&#xD;&#xA;   @evt_h_1,&#xD;&#xA;   @evt_d_1,   &#xD;&#xA;   @evt_h_2,&#xD;&#xA;   @evt_d_2,&#xD;&#xA;   @evt_h_3,&#xD;&#xA;   @evt_d_3,&#xD;&#xA;   @evt_h_4,&#xD;&#xA;   @evt_d_4,&#xD;&#xA;   @evt_h_5,&#xD;&#xA;   @evt_d_5,&#xD;&#xA;   @evt_h_6,&#xD;&#xA;   @evt_d_6,&#xD;&#xA;   @evt_h_7,&#xD;&#xA;   @evt_d_7,&#xD;&#xA;   @evt_h_8,&#xD;&#xA;   @evt_d_8,&#xD;&#xA;   @evt_h_9,&#xD;&#xA;   @evt_d_9,&#xD;&#xA;   @evt_h_10,&#xD;&#xA;   @evt_d_10,&#xD;&#xA;   @evt_h_11,&#xD;&#xA;   @evt_d_11,   &#xD;&#xA;   @evt_h_12,&#xD;&#xA;   @ev