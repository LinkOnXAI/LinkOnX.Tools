            <QP N="evt_h_17" />
            <QP N="evt_d_17" />
            <QP N="evt_h_18" />
            <QP N="evt_d_18" />
            <QP N="evt_h_19" />
            <QP N="evt_d_19" />
            <QP N="evt_h_20" />
            <QP N="evt_d_20" />
            <QP N="tran_user_id" />
            <QP N="tran_comment" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="3279" N="Inquiry">
      <F _S="3281" N="ModelVerSchema">
        <SG _S="3282" N="HasModelVer">
          <QY P="SQLite" Q="SELECT MODEL, MDL_SCHEMA&#xD;&#xA;  FROM QSYSMDLVER&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND MODEL  = @model&#xD;&#xA;   AND MDL_VER = @mdl_ver">
            <QP N="factory" />
            <QP N="model" />
            <QP N="mdl_ver" />
          </QY>
        </SG>
      </F>
      <F _S="3363" N="EapModelerFile">
        <SG _S="3364" N="HasFactory">
          <QY P="SQLite" Q="SELECT FACTORY, EAP_RELOAD_LIMIT&#xD;&#xA;  FROM QSYSFACDEF&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3366" N="HasEap">
          <QY P="SQLite" Q="SELECT EAP_TYPE, UP_DOWN, SERVER, STATUS&#xD;&#xA;  FROM QRASEAPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EAP         = @eap&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="486" N="Dialog">
      <F _S="2933" N="ModelSelector">
        <SG _S="2938" N="ListModel">
          <QY P="SQLite" Q="SELECT MODEL, MDL_DESC, REL_MDL_VER, LAST_MDL_VER&#xD;&#xA;  FROM QSYSMDLDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY MODEL">
            <QP P="factory" />
          </QY>
        </SG>
      </F>
      <F _S="565" N="ModelVerSelector">
        <SG _S="566" N="ListModel">
          <QY P="SQLite" Q="SELECT MODEL, MDL_DESC, REL_MDL_VER, LAST_MDL_VER&#xD;&#xA;  FROM QSYSMDLDEF&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA; ORDER BY MODEL">
            <QP P="factory" />
          </QY>
        </SG>
        <SG _S="567" N="ListModelVer">
          <QY P="SQLite" Q="SELECT MDL_VER, MDL_VER_DESC, MDL_RELEASE, MDL_COMMENT&#xD;&#xA;  FROM QSYSMDLVER&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND MODEL   = @model&#xD;&#xA; ORDER BY MDL_VER DESC">
            <QP P="factory" />
            <QP P="model" />
          </QY>
        </SG>
      </F>
      <F _S="3695" N="LibrarySelector">
        <SG _S="3697" N="ListLibrary">
          <QY P="SQLite" Q="SELECT LIBRARY, LIB_DESC, REL_LIB_VER, LAST_LIB_VER&#xD;&#xA;  FROM QSYSLIBDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY LIBRARY">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="3696" N="LibraryVerSelector">
        <SG _S="3698" N="ListLibraryVer">
          <QY P="SQLite" Q="SELECT LIB_VER, LIB_VER_DESC, LIB_RELEASE, LIB_COMMENT&#xD;&#xA;  FROM QSYSLIBVER&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND LIBRARY  = @library&#xD;&#xA; ORDER BY LIB_VER DESC">
            <QP N="factory" />
            <QP N="library" />
          </QY>
        </SG>
        <SG _S="3699" N="ListLibrary">
          <QY P="SQLite" Q="SELECT LIBRARY, LIB_DESC, REL_LIB_VER, LAST_LIB_VER&#xD;&#xA;  FROM QSYSLIBDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY LIBRARY">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="544" N="EapWizard">
        <SG _S="549" N="HasModelVer">
          <QY P="SQLite" Q="SELECT MODEL, MDL_SCHEMA&#xD;&#xA;  FROM QSYSMDLVER&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND MODEL  = @model&#xD;&#xA;   AND MDL_VER = @mdl_ver">
            <QP N="factory" />
            <QP N="model" />
            <QP N="mdl_ver" />
          </QY>
        </SG>
        <SG _S="3117" N="HasEapAtr">
          <QY P="SQLite" Q="SELECT EAP_SCHEMA&#xD;&#xA;  FROM QRASEAPATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP           = @eap&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
          </QY>
        </SG>
      </F>
      <F _S="609" N="EapSelector">
        <SG _S="615" N="ListModel">
          <QY P="SQLite" Q="SELECT A.MODEL, A.MDL_DESC, B.MDL_VER, B.MDL_VER_DESC, B.MDL_RELEASE&#xD;&#xA;  FROM QSYSMDLDEF A&#xD;&#xA;  LEFT JOIN QSYSMDLVER B&#xD;&#xA;    ON A.FACTORY = B.FACTORY&#xD;&#xA;   AND A.MODEL   = B.MODEL&#xD;&#xA; WHERE A.FACTORY = @factory&#xD;&#xA; ORDER BY A.MODEL, B.MDL_VER DESC">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="616" N="ListEap">
          <QY P="SQLite" Q="SELECT A.EAP, A.EAP_DESC, A.STEP, A.UP_DOWN, A.STATUS, A.NEED_ACTION, A.NEXT_NEED_ACTION, IFNULL(B.MODEL, 'N/A') AS MODEL, IFNULL(B.MDL_VER, 0) AS MDL_VER&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP           = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP           = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.DELETE_FLAG   = 'N' &#xD;&#xA;   AND (&#xD;&#xA;       (B.MODEL        = IFNULL(@model, B.MODEL) AND B.MDL_VER = IFNULL(@mdl_ver, B.MDL_VER))&#xD;&#xA;    OR (C.MODEL        = IFNULL(@model, C.MODEL) AND C.MDL_VER = IFNULL(@mdl_ver, C.MDL_VER))&#xD;&#xA;    OR (D.MODEL        = IFNULL(@model, D.MODEL) AND D.MDL_VER = IFNULL(@mdl_ver, D.MDL_VER))&#xD;&#xA;       )&#xD;&#xA; ORDER BY A.EAP">
            <QP N="factory" />
            <QP N="model" />
            <QP N="mdl_ver" />
          </QY>
        </SG>
        <SG _S="2908" N="ListAllEap">
          <QY P="SQLite" Q="SELECT EAP, EAP_DESC, UP_DOWN, STATUS, DELETE_FLAG&#xD;&#xA;  FROM QRASEAPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND DELETE_FLAG = IFNULL(@delete_flag, DELETE_FLAG)&#xD;&#xA; ORDER BY EAP">
            <QP N="factory" />
            <QP N="delete_flag" />
          </QY>
        </SG>
        <SG _S="1378" N="SearchEap">
          <QY P="SQLite" Q="SELECT B.MODEL&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'&#xD;&#xA;   AND A.EAP           LIKE @eap&#xD;&#xA; ORDER BY B.MODEL">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
      </F>
      <F _S="2213" N="EquipmentSelector_Bak">
        <SG _S="2214" N="ListEquipmentType">
          <QY P="SQLite" Q="SELECT TYPE, TYPE_DESC&#xD;&#xA;  FROM QRASEQPTYP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY TYPE">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="2220" N="ListEquipment">
          <QY P="SQLite" Q="SELECT A.EQP_NAME, B.EQP_DESC, A.CTRL_MODE, A.MDLN, A.SOFTREV,&#xD;&#xA;        ISNULL(C.EAP,'N/A'), ISNULL(C.SERVER,'N/A'), ISNULL(C.UP_DOWN,'N/A'), ISNULL(C.STATUS, 'N/A'),&#xD;&#xA;        D.PACKAGE, D.PKG_VER, D.MODEL, D.MDL_VER, D.USED_COM, D.COMPONENT, D.COM_VER, A.CMF_5 AS PLC_IP_ADDRESS&#xD;&#xA;  FROM QRASEQPDEF A&#xD;&#xA;  LEFT JOIN QRASEQPATR B&#xD;&#xA;   ON A.FACTORY  = B.FACTORY&#xD;&#xA;  AND A.EQP_NAME = B.EQP_NAME&#xD;&#xA;  AND B.ATTR_CATEGORY = 'Applied'&#xD;&#xA; LEFT JOIN QRASEAPDEF C&#xD;&#xA;   ON A.FACTORY = C.FACTORY&#xD;&#xA;  AND B.EAP     = C.EAP&#xD;&#xA; LEFT JOIN QRASEAPATR D&#xD;&#xA;   ON A.FACTORY = D.FACTORY&#xD;&#xA;  AND B.EAP     = D.EAP&#xD;&#xA;  AND D.ATTR_CATEGORY = 'Applied'&#xD;&#xA;WHERE A.FACTORY = @factory&#xD;&#xA;  AND (A.TYPE         = @type OR&#xD;&#xA;        A.AREA        = @area OR&#xD;&#xA;        A.LINE        = @line)&#xD;&#xA;  AND A.DELETE_FLAG   &lt;&gt; 'Y'&#xD;&#xA;ORDER BY A.EQP_NAME">
            <QP N="factory" />
            <QP N="type" />
            <QP N="area" />
            <QP N="line" />
          </QY>
        </SG>
        <SG _S="2856" N="ListAllEquipment">
          <QY P="SQLite" Q="SELECT EQP_NAME, EQP_DESC, CTRL_MODE, DELETE_FLAG&#xD;&#xA;  FROM QRASEQPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND DELETE_FLAG = ISNULL(@delete_flag, DELETE_FLAG)&#xD;&#xA; ORDER BY EQP_NAME">
            <QP N="factory" />
            <QP N="delete_flag" />
          </QY>
        </SG>
        <SG _S="2223" N="SearchEquipment">
          <QY P="SQLite" Q="SELECT A.TYPE, A.AREA, A.LINE&#xD;&#xA;  FROM QRASEQPDEF A&#xD;&#xA;  LEFT JOIN QRASEQPATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EQP_NAME      = B.EQP_NAME&#xD;&#xA;  LEFT JOIN QRASEAPDEF C&#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND B.EAP           = C.EAP&#xD;&#xA;  LEFT JOIN QRASEAPATR D&#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND B.EAP           = D.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = D.ATTR_CATEGORY &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Applied'&#xD;&#xA;   AND A.EQP_NAME      LIKE @eqpName&#xD;&#xA;   AND A.DELETE_FLAG   &lt;&gt; 'Y'&#xD;&#xA; ORDER BY &#xD;&#xA; (CASE @target&#xD;&#xA;  WHEN 'Type'  THEN A.TYPE&#xD;&#xA;  WHEN 'Area'  THEN A.AREA&#xD;&#xA;  WHEN 'Line'  THEN A.LINE&#xD;&#xA;   END)">
            <QP N="factory" />
            <QP N="eqpName" />
            <QP N="target" />
          </QY>
        </SG>
      </F>
      <F _S="3107" N="EquipmentSelector">
        <SG _S="3111" N="ListEquipment">
          <QY P="SQLite" Q="SELECT EQP_NAME, EQP_DESC, DELETE_FLAG, IP_ADDRESS&#xD;&#xA;  FROM QRASEQPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND DELETE_FLAG = IFNULL(@delete_flag, DELETE_FLAG)&#xD;&#xA; ORDER BY EQP_NAME">
            <QP N="factory" />
            <QP N="delete_flag" />
          </QY>
        </SG>
      </F>
      <F _S="3359" N="EquipmentEapSelector">
        <SG _S="3360" N="ListEquipment">
          <QY P="SQLite" Q="SELECT D.EQP_NAME, F.EAP, D.EQP_DESC, D.DELETE_FLAG&#xD;&#xA;FROM QRASEQPDEF D&#xD;&#xA;LEFT JOIN QRASEAPCFG F ON    &#xD;&#xA;	F.OBJ_TYPE = 'CONTROLLER'&#xD;&#xA;	AND F.ATTR_CATEGORY = 'Applied'&#xD;&#xA;	AND F.DATA = D.EQP_NAME&#xD;&#xA; WHERE D.FACTORY = @factory &#xD;&#xA;       AND D.DELETE_FLAG = ISNULL(@delete_flag, D.DELETE_FLAG)&#xD;&#xA;	AND F.EAP IS NOT NULL&#xD;&#xA; ORDER BY D.EQP_NAME;">
            <QP N="factory" />
            <QP N="delete_flag" />
          </QY>
        </SG>
      </F>
      <F _S="2194" N="EquipmentTypeSelector">
        <SG _S="2197" N="ListEquipmentType">
          <QY P="SQLite" Q="SELECT TYPE, TYPE_DESC&#xD;&#xA;  FROM QRASEQPTYP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY TYPE">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="2786" N="EapNameSelector">
        <SG _S="2788" N="ListEquipment">
          <QY P="SQLite" Q="SELECT EQP_NAME, EQP_DESC&#xD;&#xA;  FROM QRASEQPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND DELETE_FLAG = ISNULL(@delete_flag, DELETE_FLAG)&#xD;&#xA; ORDER BY EQP_NAME">
            <QP N="factory" />
            <QP N="delete_flag" />
          </QY>
        </SG>
      </F>
      <F _S="3384" N="CustomRemoteCommandSelector">
        <SG _S="3385" N="ListCustomRemoteCommand">
          <QY P="SQLite" Q="SELECT COMMAND, CMD_DESC, CREATE_TIME&#xD;&#xA;  FROM QRASCUSRCM&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY COMMAND&#xD;&#xA;">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="3724" N="PackageVerSelector">
        <SG _S="3726" N="ListPackage">
          <QY P="SQLite" Q="SELECT PACKAGE, PKG_DESC, REL_PKG_VER, LAST_PKG_VER&#xD;&#xA;  FROM QSYSPKGDEF&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA; ORDER BY PACKAGE">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3727" N="ListPackageVer">
          <QY P="SQLite" Q="SELECT PKG_VER, PKG_VER_DESC, PKG_RELEASE, PKG_COMMENT&#xD;&#xA;  FROM QSYSPKGVER&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND PACKAGE = @package&#xD;&#xA; ORDER BY PKG_VER DESC">
            <QP N="factory" />
            <QP N="package" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="14" N="Setup">
      <F _S="15" N="EquipmentType">
        <SG _S="17" N="HasEquipmentType">
          <QY P="SQLite" Q="SELECT TYPE&#xD;&#xA;  FROM QRASEQPTYP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE    = @type">
            <QP N="factory" />
            <QP N="type" />
          </QY>
        </SG>
        <SG _S="18" N="ListEquipmentType">
          <QY P="SQLite" Q="SELECT TYPE, TYPE_DESC&#xD;&#xA;  FROM QRASEQPTYP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY TYPE">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="19" N="SearchEquipmentType">
          <QY P="SQLite" Q="SELECT TYPE, TYPE_DESC&#xD;&#xA;  FROM QRASEQPTYP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE    = @type">
            <QP N="factory" />
            <QP N="type" />
          </QY>
        </SG>
        <SG _S="20" N="InsertEquipmentType">
          <QY P="SQLite" Q="INSERT INTO QRASEQPTYP (&#xD;&#xA;	FACTORY,&#xD;&#xA;	TYPE,&#xD;&#xA;	TYPE_DESC,&#xD;&#xA;	CREATE_USER_ID,&#xD;&#xA;	CREATE_TIME,&#xD;&#xA;	UPDATE_USER_ID,&#xD;&#xA;	UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;	@factory,&#xD;&#xA;	@type,&#xD;&#xA;	@type_desc,&#xD;&#xA;	@create_user_id,&#xD;&#xA;	@create_time,&#xD;&#xA;	@update_user_id,&#xD;&#xA;	@update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="type" />
            <QP N="type_desc" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="21" N="UpdateEquipmentType">
          <QY P="SQLite" Q="UPDATE QRASEQPTYP SET&#xD;&#xA;    TYPE_DESC      =@type_desc,&#xD;&#xA;    UPDATE_USER_ID =@update_user_id,&#xD;&#xA;    UPDATE_TIME    =@update_time&#xD;&#xA; WHERE FACTORY     =@factory&#xD;&#xA;   AND TYPE        =@type">
            <QP N="type_desc" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="type" />
          </QY>
        </SG>
        <SG _S="22" N="DeleteEquipmentType">
          <QY P="SQLite" Q="DELETE &#xD;&#xA;  FROM QRASEQPTYP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE    = @type">
            <QP N="factory" />
            <QP N="type" />
          </QY>
        </SG>
        <SG _S="23" N="CountEquipment">
          <QY P="SQLite" Q="SELECT EQP_NAME&#xD;&#xA;  FROM QRASEQPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="type" />
          </QY>
        </SG>
      </F>
      <F _S="3155" N="PlugInDriver">
        <SG _S="3156" N="HasPlugInDriver">
          <QY P="SQLite" Q="SELECT DRIVER&#xD;&#xA;  FROM QSYSPIDDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND DRIVER  = @driver">
            <QP N="factory" />
            <QP N="driver" />
          </QY>
        </SG>
        <SG _S="3157" N="ListPlugInDriver">
          <QY P="SQLite" Q="SELECT DRIVER, DRV_VER, DRV_DESC&#xD;&#xA;  FROM QSYSPIDDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY DRIVER">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3158" N="SearchPlugInDriver">
          <QY P="SQLite" Q="SELECT DRIVER, DRV_VER, DRV_DESC, DRV_COMMENT&#xD;&#xA;  FROM QSYSPIDDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND DRIVER  = @driver">
            <QP N="factory" />
            <QP N="driver" />
          </QY>
        </SG>
        <SG _S="3159" N="InsertPlugInDriver">
          <QY P="SQLite" Q="INSERT INTO QSYSPIDDEF (&#xD;&#xA;	FACTORY,&#xD;&#xA;	DRIVER,&#xD;&#xA;	DRV_VER,&#xD;&#xA;	DRV_DESC,	&#xD;&#xA;	DRV_COMMENT,&#xD;&#xA;	CREATE_USER_ID,&#xD;&#xA;	CREATE_TIME,&#xD;&#xA;	UPDATE_USER_ID,&#xD;&#xA;	UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;	@factory,&#xD;&#xA;	@driver,&#xD;&#xA;	@drv_ver,&#xD;&#xA;	@drv_desc,&#xD;&#xA;	@drv_comment,&#xD;&#xA;	@create_user_id,&#xD;&#xA;	@create_time,&#xD;&#xA;	@update_user_id,&#xD;&#xA;	@update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="driver" />
            <QP N="drv_ver" />
            <QP N="drv_desc" />
            <QP N="drv_comment" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="3160" N="UpdatePlugInDriver">
          <QY P="SQLite" Q="UPDATE QSYSPIDDEF SET&#xD;&#xA;  DRV_DESC       =@drv_desc,&#xD;&#xA;  DRV_COMMENT    =@drv_comment,&#xD;&#xA;  UPDATE_USER_ID =@update_user_id,&#xD;&#xA;  UPDATE_TIME    =@update_time&#xD;&#xA; WHERE FACTORY   =@factory&#xD;&#xA;   AND DRIVER    =@driver">
            <QP N="drv_desc" />
            <QP N="drv_comment" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="driver" />
          </QY>
        </SG>
        <SG _S="3161" N="DeletePlugInDriver">
          <QY P="SQLite" Q="DELETE &#xD;&#xA;  FROM QSYSPIDDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND DRIVER  = @driver">
            <QP N="factory" />
            <QP N="driver" />
          </QY>
        </SG>
      </F>
      <F _S="72" N="Model">
        <SG _S="522" N="HasModel">
          <QY P="SQLite" Q="SELECT REL_MDL_VER, LAST_MDL_VER&#xD;&#xA;  FROM QSYSMDLDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND MODEL = @model">
            <QP N="factory" />
            <QP N="model" />
          </QY>
        </SG>
        <SG _S="73" N="ListModel">
          <QY P="SQLite" Q="SELECT MODEL, MDL_DESC, REL_MDL_VER, LAST_MDL_VER&#xD;&#xA;  FROM QSYSMDLDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY MODEL">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="74" N="SearchModel">
          <QY P="SQLite" Q="SELECT MODEL, MDL_DESC, REL_MDL_VER, LAST_MDL_VER&#xD;&#xA;  FROM QSYSMDLDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND MODEL = @model">
            <QP N="factory" />
            <QP N="model" />
          </QY>
        </SG>
        <SG _S="75" N="InsertModel">
          <QY P="SQLite" Q="INSERT INTO QSYSMDLDEF (&#xD;&#xA;   FACTORY,&#xD;&#xA;   MODEL,&#xD;&#xA;   MDL_DESC,&#xD;&#xA;   REL_MDL_VER,&#xD;&#xA;   LAST_MDL_VER,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @model,&#xD;&#xA;   @mdl_desc,&#xD;&#xA;   @rel_mdl_ver,&#xD;&#xA;   @last_mdl_ver,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="model" />
            <QP N="mdl_desc" />
            <QP N="rel_mdl_ver" />
            <QP N="last_mdl_ver" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="76" N="UpdateModel">
          <QY P="SQLite" Q="UPDATE QSYSMDLDEF SET&#xD;&#xA;  MDL_DESC       = @mdl_desc,&#xD;&#xA;  UPDATE_USER_ID = @update_user_id,&#xD;&#xA;  UPDATE_TIME    = @update_time&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND MODEL  = @model">
            <QP N="mdl_desc" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="model" />
          </QY>
