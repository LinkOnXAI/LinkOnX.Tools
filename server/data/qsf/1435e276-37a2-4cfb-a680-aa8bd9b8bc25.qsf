      <F _S="795" N="EapDataPush">
        <SG _S="796" N="SearchEap">
          <QY P="SQLite" Q="SELECT A.EAP, A.EAP_DESC, A.STEP, A.UP_DOWN, A.STATUS, A.RELOAD_CNT, A.NEED_ACTION, A.NEXT_NEED_ACTION, ALARM,       &#xD;&#xA;       IFNULL(B.MODEL, 'N/A') SET_MODEL, IFNULL(B.MDL_VER, 0) SET_MDL_VER, IFNULL(C.MODEL, 'N/A') REL_MODEL, IFNULL(C.MDL_VER, 0) REL_MDL_VER, IFNULL(D.MODEL, 'N/A') APL_MODEL, IFNULL(D.MDL_VER, 0) APL_MDL_VER,  &#xD;&#xA;       IFNULL(B.LIBRARY, 'N/A') SET_LIBRARY, IFNULL(B.LIB_VER, 0) SET_LIB_VER, IFNULL(C.LIBRARY, 'N/A') REL_LIBRARY, IFNULL(C.LIB_VER, 0) REL_LIB_VER, IFNULL(D.LIBRARY, 'N/A') APL_LIBRARY, IFNULL(D.LIB_VER, 0) APL_LIB_VER,&#xD;&#xA;       A.LAST_EVENT_ID,&#xD;&#xA;       D.EAP_SCHEMA&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP           = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP           = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.EAP           = @eap&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="3150" N="SearchConnectorSts">
          <QY P="SQLite" Q="SELECT CNT_SEQ, CNT_NAME, STATE&#xD;&#xA;  FROM QRASCNTSTS&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EAP     = @eap">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="3151" N="SearchEquipment">
          <QY P="SQLite" Q="SELECT EQP_NAME, COMM_STATE, CTRL_MODE&#xD;&#xA;  FROM QRASEQPSTS&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EQP_NAME IN&#xD;&#xA;       (&#xD;&#xA;SELECT DATA&#xD;&#xA;  FROM QRASEAPCFG&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP           = @eap&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category&#xD;&#xA;   AND KEY_NAME      = @key_eqp_name&#xD;&#xA;       )">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
            <QP N="key_eqp_name" />
          </QY>
        </SG>
      </F>
      <F _S="2435" N="EquipmentDataPush" D="cleanup needed">
        <SG _S="2436" N="SearchEquipment">
          <QY P="SQLite" Q="SELECT A.EQP_NAME, A.EQP_DESC, ISNULL(C.SERVER, 'N/A') SERVER, ISNULL(C.EAP, 'N/A') EAP, ISNULL(C.UP_DOWN, 'N/A') UP_DOWN, ISNULL(C.STATUS, 'N/A') STATUS,&#xD;&#xA;       A.TYPE, A.AREA, A.LINE, A.MDLN, A.SOFTREV, A.CTRL_MODE, A.PRI_STATE, A.STATE, A.ALARM, A.EVENT_DEFINE&#xD;&#xA;  FROM QRASEQPDEF A&#xD;&#xA;  LEFT JOIN QRASEQPATR B&#xD;&#xA;    ON A.FACTORY         = B.FACTORY&#xD;&#xA;   AND A.EQP_NAME        = B.EQP_NAME&#xD;&#xA;   AND B.ATTR_CATEGORY   = @attr_category&#xD;&#xA;  LEFT JOIN QRASEAPDEF C&#xD;&#xA;    ON A.FACTORY         = C.FACTORY&#xD;&#xA;   AND B.EAP             = C.EAP&#xD;&#xA; WHERE A.FACTORY         = @factory&#xD;&#xA;   AND A.EQP_NAME        = @eqp_name&#xD;&#xA;   AND A.DELETE_FLAG     = 'N'">
            <QP N="attr_category" />
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="1419" N="DataPurge">
      <F _S="1420" N="DataPurge">
        <SG _S="1424" N="DeleteEapHistory" UMG="No">
          <QY P="MsSql" />
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" Q="DELETE FROM QRASEAPHIS WHERE FACTORY = @factory AND TRAN_TIME &lt; @tran_time">
            <QP N="factory" />
            <QP N="tran_time" />
          </QY>
        </SG>
        <SG _S="1505" N="DeleteEquipmentHistory" UMG="No">
          <QY P="MsSql" />
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" Q="DELETE FROM QRASEQPHIS WHERE FACTORY = @factory AND TRAN_TIME &lt; @tran_time">
            <QP N="factory" />
            <QP N="tran_time" />
          </QY>
        </SG>
      </F>
    </M>
  </S>
</Q>