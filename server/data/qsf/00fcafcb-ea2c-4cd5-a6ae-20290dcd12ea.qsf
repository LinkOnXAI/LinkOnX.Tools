          <QY P="MsSql" Q="SELECT  * &#xD;&#xA;  FROM QEESEQPSTS&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EQP_NAME = @eqp_name">
            <QP N="factory" />
