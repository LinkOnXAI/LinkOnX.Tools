      <F _S="3188" N="SndHistory">
        <SG _S="3189" N="SelectSndHistorySeq">
          <QY P="MsSql" Q="SELECT NEXT VALUE FOR SEQ_SVS_NODE_HIS" />
        </SG>
        <SG _S="3369" N="SelectSndInfoForHistory">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;   A.FACTORY,&#xD;&#xA;   A.SVS_NODE,   &#xD;&#xA;   A.CONTAINER,&#xD;&#xA;   A.SVS_NODE_GROUP,&#xD;&#xA;   A.STEP,&#xD;&#xA;   A.ALARM,&#xD;&#xA;   A.UP_DOWN,&#xD;&#xA;   A.STATUS,&#xD;&#xA;   A.NEED_ACTION,&#xD;&#xA;   A.NEXT_NEED_ACTION,   &#xD;&#xA;   A.RELOAD_CNT,&#xD;&#xA;   A.DELETE_FLAG,&#xD;&#xA;   ISNULL(B.MODEL, ' ') AS SET_MODEL,&#xD;&#xA;   ISNULL(B.MODEL_VER, 0) AS SET_MODEL_VER,&#xD;&#xA;   ISNULL(C.MODEL, ' ') AS REL_MODEL,&#xD;&#xA;   ISNULL(C.MODEL_VER, 0) AS REL_MODEL_VER,&#xD;&#xA;   ISNULL(D.MODEL, ' ') AS APL_MODEL,&#xD;&#xA;   ISNULL(D.MODEL_VER, 0) AS APL_MODEL_VER&#xD;&#xA;  FROM QEESSNDDEF A  &#xD;&#xA;  WITH (NOLOCK)&#xD;&#xA;  LEFT JOIN QEESSNDATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = B.SVS_NODE&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QEESSNDATR C&#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = C.SVS_NODE&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QEESSNDATR D&#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = D.SVS_NODE&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.SVS_NODE         = @svs_node">
            <QP N="factory" />
            <QP N="svs_node" />
          </QY>
        </SG>
        <SG _S="3370" N="InsertSndHistory">
