          <QY P="MsSql" Q="INSERT INTO QSYSAPPALH (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   SET_TIME,&#xD;&#xA;   CLEAR_TIME,&#xD;&#xA;   CLEAR_COMMENT,&#xD;&#xA;   ALARM_ID,&#xD;&#xA;   ALARM_TEXT,&#xD;&#xA;   DURATION,&#xD;&#xA;   SUM_DATE,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_TIME&#xD;&#xA;)&#xD;&#xA;SELECT&#xD;&#xA;   FACTORY,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   SET_TIME,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @clear_comment,&#xD;&#xA;   ALARM_ID,&#xD;&#xA;   ALARM_TEXT,&#xD;&#xA;   @duration,&#xD;&#xA;   @sum_date,&#xD;&#xA;   @tran_user_id,&#xD;&#xA;   @tran_time&#xD;&#xA;  FROM QSYSAPPALS&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND HIST_SEQ = @hist_seq">
            <QP N="tran_time" />
            <QP N="clear_comment" />
            <QP N="duration" />
            <QP N="sum_date" />
            <QP N="tran_user_id" />
            <QP N="factory" />
            <QP N="hist_seq" />
          </QY>
        </SG>
        <SG _S="3088" N="DeleteApplicationAlarmStatus">
          <QY P="MsSql" Q="DELETE FROM QSYSAPPALS&#xD;&#xA;WHERE FACTORY = @factory&#xD;&#xA;     AND HIST_SEQ = @hist_seq">
            <QP N="factory" />
