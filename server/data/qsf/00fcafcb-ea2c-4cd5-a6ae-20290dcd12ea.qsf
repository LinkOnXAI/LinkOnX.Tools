      <F _S="3607" N="EquipmentEventFlow">
        <SG _S="3608" N="ListLine">
          <QY P="MsSql" Q="SELECT LINE_NAME, LINE_DESC&#xD;&#xA;  FROM QEESLINDEF&#xD;&#xA; WHERE FACTORY     = @factory &#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY LINE_NAME">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3620" N="HasEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME&#xD;&#xA;  FROM QEESEQPDEF&#xD;&#xA; WHERE FACTORY  = @factory &#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND DELETE_FLAG != 'Y'">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="3612" N="ListEquipmentEvent">
          <QY P="MsSql" Q="SELECT EFL.EVENT_SEQ, EFL.EVENT_ID, EVT.EVENT_DESC, &#xD;&#xA;       EFL.USED_CONDITION, EFL.CONDITION_NAME, EFL.USED_TIMEOUT, EFL.TIMEOUT&#xD;&#xA;  FROM QEESEQPEFL EFL&#xD;&#xA;  LEFT JOIN QEESEQPEVT EVT&#xD;&#xA;    ON EFL.FACTORY  = EVT.FACTORY&#xD;&#xA;   AND EFL.EVENT_ID = EVT.EVENT_ID&#xD;&#xA; WHERE EFL.FACTORY  = @factory &#xD;&#xA;   AND EFL.EQP_NAME = @eqp_name&#xD;&#xA; ORDER BY EFL.EVENT_SEQ ASC">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="3826" N="ListEquipment">
          <QY P="MsSql" Q="SELECT R.SEQ, R.EQP_NAME, E.EQP_DESC, E.EQP_TYPE&#xD;&#xA;  FROM QEESLINEQP R&#xD;&#xA;  LEFT JOIN QEESEQPDEF E&#xD;&#xA;    ON R.FACTORY     = E.FACTORY&#xD;&#xA;   AND R.EQP_NAME    = E.EQP_NAME&#xD;&#xA; WHERE R.FACTORY     = @factory&#xD;&#xA;   AND R.LINE_NAME   = @line_name&#xD;&#xA;   AND E.DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY R.SEQ ASC">
            <QP N="factory" />
            <QP N="line_name" />
          </QY>
        </SG>
        <SG _S="3613" N="SearchEquipmentEvent">
          <QY P="MsSql" Q="SELECT EVENT_SEQ, &#xD;&#xA;EVENT_ID, &#xD;&#xA;PRV_EVENT_ID, &#xD;&#xA;NXT_EVENT_ID, &#xD;&#xA;USED_TIMEOUT,&#xD;&#xA;TIMEOUT,&#xD;&#xA;TIMEOUT_ITL_NAME,&#xD;&#xA;USED_CONDITION,&#xD;&#xA;CONDITION_NAME&#xD;&#xA;  FROM QEESEQPEFL&#xD;&#xA; WHERE FACTORY     = @factory &#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND EVENT_ID = @evt_id">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="evt_id" />
          </QY>
        </SG>
        <SG _S="3619" N="InsertEquipmentEvent">
          <QY P="MsSql" Q="INSERT INTO QEESEQPEFL(&#xD;&#xA;   FACTORY,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   EVENT_SEQ,&#xD;&#xA;   EVENT_ID,&#xD;&#xA;   PRV_EVENT_ID,&#xD;&#xA;   NXT_EVENT_ID,&#xD;&#xA;   USED_TIMEOUT,&#xD;&#xA;   TIMEOUT,&#xD;&#xA;   USED_CONDITION,&#xD;&#xA;   CONDITION_NAME,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @eqp_name,&#xD;&#xA;   @evt_seq,&#xD;&#xA;   @evt_id,&#xD;&#xA;   @prv_evt_id,&#xD;&#xA;   @nxt_evt_id,&#xD;&#xA;   @used_timeout,&#xD;&#xA;   @evt_timeout,&#xD;&#xA;   @used_cdt,&#xD;&#xA;   @cdt_name,&#xD;&#xA;   @user_id,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @user_id,&#xD;&#xA;   @tran_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="evt_seq" />
            <QP N="evt_id" />
            <QP N="prv_evt_id" />
            <QP N="nxt_evt_id" />
            <QP N="used_timeout" />
            <QP N="evt_timeout" />
            <QP N="used_cdt" />
            <QP N="cdt_name" />
            <QP N="user_id" />
            <QP N="tran_time" />
          </QY>
        </SG>
        <SG _S="3829" N="InsertEquipmentEventInterlock">
          <QY P="MsSql" Q="INSERT INTO QEESEQPEIT(&#xD;&#xA;   FACTORY,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   EVENT_ID,&#xD;&#xA;   ITL_NAME,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @eqp_name,&#xD;&#xA;   @evt_id,&#xD;&#xA;   @itl_name,&#xD;&#xA;   @user_id,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @user_id,&#xD;&#xA;   @tran_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="evt_id" />
            <QP N="itl_name" />
            <QP N="user_id" />
            <QP N="tran_time" />
          </QY>
        </SG>
        <SG _S="3618" N="DeleteEquipmentEvent">
          <QY P="MsSql" Q="DELETE FROM QEESEQPEFL&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND EQP_NAME   = @eqp_name">
