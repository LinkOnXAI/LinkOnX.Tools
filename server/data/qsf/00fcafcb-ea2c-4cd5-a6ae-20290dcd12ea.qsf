          <QY P="MsSql" Q="SELECT MODEL, MODEL_DESC, REL_MODEL_VER, LAST_MODEL_VER&#xD;&#xA;  FROM QEESMDLDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY MODEL">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="565" N="ModelVerSelector">
        <SG _S="566" N="ListModel">
          <QY P="MsSql" Q="SELECT MODEL, MODEL_DESC, REL_MODEL_VER, LAST_MODEL_VER&#xD;&#xA;  FROM QEESMDLDEF&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA; ORDER BY MODEL">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="567" N="ListModelVer">
          <QY P="MsSql" Q="SELECT MODEL_VER, MODEL_VER_DESC, MODEL_RELEASE, MODEL_COMMENT&#xD;&#xA;  FROM QEESMDLVER&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND MODEL   = @model&#xD;&#xA; ORDER BY MODEL_VER DESC">
            <QP N="factory" />
            <QP N="model" />
          </QY>
        </SG>
      </F>
      <F _S="544" N="SndWizard">
        <SG _S="549" N="HasModelVer">
          <QY P="MsSql" Q="SELECT MODEL, MODEL_SCHEMA&#xD;&#xA;  FROM QEESMDLVER&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND MODEL  = @model&#xD;&#xA;   AND MODEL_VER = @mdl_ver">
            <QP N="factory" />
            <QP N="model" />
            <QP N="mdl_ver" />
          </QY>
        </SG>
        <SG _S="3117" N="HasSndAtr">
          <QY P="MsSql" Q="SELECT SVS_NODE_SCHEMA&#xD;&#xA;  FROM QEESSNDATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND SVS_NODE           = @svs_node&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="svs_node" />
            <QP N="attr_category" />
          </QY>
        </SG>
      </F>
      <F _S="3499" N="UserSelector">
        <SG _S="3500" N="SearchUserList">
          <QY P="MsSql" Q="SELECT USER_ID, USER_DESC&#xD;&#xA;  FROM QSECUSRDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY USER_ID">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="3402" N="EquipmentSelector">
        <SG _S="3403" N="ListEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME, EQP_DESC, DELETE_FLAG&#xD;&#xA;  FROM QEESEQPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND DELETE_FLAG = ISNULL(@delete_flag, DELETE_FLAG)&#xD;&#xA; ORDER BY EQP_NAME">
            <QP N="factory" />
            <QP N="delete_flag" />
          </QY>
        </SG>
      </F>
      <F _S="3795" N="EquipmentSelectorEx">
        <SG _S="3796" N="ListEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME, EQP_DESC, EQP_TYPE, DELETE_FLAG&#xD;&#xA;  FROM QEESEQPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EQP_TYPE = ISNULL(@type, EQP_TYPE)&#xD;&#xA; ORDER BY EQP_NAME">
            <QP N="factory" />
            <QP N="type" />
          </QY>
        </SG>
        <SG _S="3797" N="ListEquipmentType">
          <QY P="MsSql" Q="SELECT EQP_TYPE, EQP_TYPE_DESC&#xD;&#xA;  FROM QEESEQPTYP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY EQP_TYPE">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="3798" N="AlarmSelector">
        <SG _S="3800" N="ListEquipmentType">
          <QY P="MsSql" Q="SELECT EQP_TYPE, EQP_TYPE_DESC&#xD;&#xA;  FROM QEESEQPTYP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY EQP_TYPE">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3801" N="ListAlarm">
          <QY P="MsSql" Q="SELECT ALARM_NAME, ALARM_DESC, EQP_TYPE&#xD;&#xA;  FROM QEESALMDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EQP_TYPE = ISNULL(@type, EQP_TYPE)&#xD;&#xA; ORDER BY ALARM_NAME">
            <QP N="factory" />
            <QP N="type" />
          </QY>
        </SG>
        <SG _S="4013" N="ListAlarmByMes">
          <QY P="MsSql" Q="SELECT TAG_ID, ALARM_CODE, ALARM_DESC&#xD;&#xA;  FROM CRASALMDEF&#xD;&#xA; WHERE FACTORY_CODE = @factory&#xD;&#xA;   AND EQUIP_CODE = @eqp_name&#xD;&#xA; ORDER BY TAG_ID">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
      </F>
      <F _S="3515" N="EquipmentLineSelector">
        <SG _S="3516" N="ListEquipmentLine">
          <QY P="MsSql" Q="SELECT LINE_NAME, LINE_DESC&#xD;&#xA;  FROM QEESEQPLIN&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY LINE_NAME">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="3517" N="EquipmentTypeSelector">
        <SG _S="3518" N="ListEquipmentType">
          <QY P="MsSql" Q="SELECT EQP_TYPE, EQP_TYPE_DESC&#xD;&#xA;  FROM QEESEQPTYP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY EQP_TYPE">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="609" N="SndSelector">
        <SG _S="615" N="ListModel">
          <QY P="MsSql" Q="SELECT A.MODEL, A.MODEL_DESC, B.MODEL_VER, B.MODEL_VER_DESC, B.MODEL_RELEASE&#xD;&#xA;  FROM QEESMDLDEF A&#xD;&#xA;  LEFT JOIN QEESMDLVER B&#xD;&#xA;    ON A.FACTORY = B.FACTORY&#xD;&#xA;   AND A.MODEL   = B.MODEL&#xD;&#xA; WHERE A.FACTORY = @factory&#xD;&#xA; ORDER BY A.MODEL, B.MODEL_VER DESC">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3414" N="ListSndGroup">
          <QY P="MsSql" Q="SELECT SVS_NODE_GROUP,&#xD;&#xA;	SVS_NODE_GROUP_DESC&#xD;&#xA;  FROM QEESSNDGRP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY SVS_NODE_GROUP">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="616" N="ListSnd">
          <QY P="MsSql" Q="SELECT A.SVS_NODE AS NODE_NAME, A.SVS_NODE_DESC AS NODE_DESC, A.SVS_NODE_GROUP,  A.STEP, A.UP_DOWN, A.NEED_ACTION, A.NEXT_NEED_ACTION,&#xD;&#xA;       B.MODEL, B.MODEL_VER&#xD;&#xA;  FROM QEESSNDDEF A&#xD;&#xA; INNER JOIN QEESSNDATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = B.SVS_NODE&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'   &#xD;&#xA;   AND B.ATTR_CATEGORY = @attr_category   &#xD;&#xA;  AND A.SVS_NODE_GROUP        = ISNULL(@svs_node_group, A.SVS_NODE_GROUP) &#xD;&#xA;   AND ( &#xD;&#xA;       (B.MODEL        = ISNULL(@model, B.MODEL))&#xD;&#xA;       )&#xD;&#xA; ORDER BY A.SVS_NODE">
            <QP N="factory" />
            <QP N="attr_category" />
            <QP N="svs_node_group" />
            <QP N="model" />
          </QY>
        </SG>
        <SG _S="2908" N="ListAllSnd">
          <QY P="MsSql" Q="SELECT SVS_NODE, SVS_NODE_DESC, UP_DOWN, STATUS, DELETE_FLAG&#xD;&#xA;  FROM QEESSNDDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND DELETE_FLAG = ISNULL(@delete_flag, DELETE_FLAG)&#xD;&#xA; ORDER BY SVS_NODE">
            <QP N="factory" />
            <QP N="delete_flag" />
          </QY>
        </SG>
        <SG _S="1378" N="SearchSnd">
          <QY P="MsSql" Q="SELECT  B.MODEL&#xD;&#xA;  FROM QEESSNDDEF A&#xD;&#xA;  LEFT JOIN QEESSNDATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = B.SVS_NODE&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'&#xD;&#xA;   AND A.SVS_NODE           LIKE @svs_node&#xD;&#xA; ORDER BY B.MODEL">
            <QP N="factory" />
            <QP N="svs_node" />
          </QY>
        </SG>
      </F>
      <F _S="3727" N="BaseNodeSelector">
        <SG _S="3728" N="ListBaseNode">
          <QY P="MsSql" Q="SELECT A.NODE_NAME, A.NODE_DESC, A.STEP, A.UP_DOWN, A.NEED_ACTION, A.NEXT_NEED_ACTION,&#xD;&#xA;       B.MODEL, B.MODEL_VER&#xD;&#xA; FROM QEESBNDDEF A&#xD;&#xA; INNER JOIN QEESBNDATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.NODE_NAME = B.NODE_NAME&#xD;&#xA; WHERE A.FACTORY = @factory&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'   &#xD;&#xA;   AND B.ATTR_CATEGORY = @attr_category   &#xD;&#xA; ORDER BY A.NODE_NAME">
            <QP N="factory" />
            <QP N="attr_category" />
          </QY>
        </SG>
      </F>
      <F _S="1767" N="EventSelector">
        <SG _S="1768" N="ListSndEvent">
          <QY P="MsSql" Q="SELECT EVENT_ID, EVENT_DESC&#xD;&#xA;  FROM QEESSNDEVT&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY EVENT_ID">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="3359" N="EquipmentSndSelector">
        <SG _S="3360" N="ListEquipment">
          <QY P="MsSql" Q="SELECT D.EQP_NAME, F.SVS_NODE, D.EQP_DESC, D.DELETE_FLAG&#xD;&#xA;FROM QRASEQPDEF D&#xD;&#xA;LEFT JOIN QEESSNDCFG F ON    &#xD;&#xA;	F.OBJ_TYPE = 'CONTROLLER'&#xD;&#xA;	AND F.ATTR_CATEGORY = 'Applied'&#xD;&#xA;	AND F.DATA = D.EQP_NAME&#xD;&#xA; WHERE D.FACTORY = @factory &#xD;&#xA;       AND D.DELETE_FLAG = ISNULL(@delete_flag, D.DELETE_FLAG)&#xD;&#xA;	AND F.SVS_NODE IS NOT NULL&#xD;&#xA; ORDER BY D.EQP_NAME;">
            <QP N="factory" />
            <QP N="delete_flag" />
          </QY>
        </SG>
      </F>
      <F _S="2194" N="SndGroupSelector">
        <SG _S="2197" N="ListSndGroup">
          <QY P="MsSql" Q="SELECT SVS_NODE_GROUP, SVS_NODE_GROUP_DESC&#xD;&#xA;  FROM QEESSNDGRP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY SVS_NODE_GROUP">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="3894" N="ContainerSelector">
        <SG _S="3895" N="ListContainer">
          <QY P="MsSql" Q="SELECT CTN_NAME, CTN_DESC&#xD;&#xA;  FROM QEESCTNDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY CTN_NAME">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="3457" N="LineEquipmentSelector">
        <SG _S="3458" N="ListEquipmentIncludeLine">
          <QY P="MsSql" Q="SELECT EQP_NAME, EQP_DESC&#xD;&#xA;  FROM QEESEQPDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EQP_NAME IN &#xD;&#xA;       (&#xD;&#xA;	   SELECT EQP_NAME &#xD;&#xA;	     FROM QEESLINEQP &#xD;&#xA;		WHERE FACTORY   = @factory&#xD;&#xA;		  AND LINE_NAME = @line_name&#xD;&#xA;	   )&#xD;&#xA;   AND DELETE_FLAG &lt;&gt; 'Y'&#xD;&#xA; ORDER BY EQP_NAME ASC">
            <QP N="factory" />
            <QP N="line_name" />
          </QY>
        </SG>
        <SG _S="4078" N="ListEquipmentExcludedLine">
          <QY P="MsSql" Q="SELECT EQP_NAME, EQP_DESC&#xD;&#xA;  FROM QEESEQPDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EQP_NAME NOT IN &#xD;&#xA;       (&#xD;&#xA;	   SELECT EQP_NAME &#xD;&#xA;	     FROM QEESLINEQP &#xD;&#xA;		WHERE FACTORY = @factory&#xD;&#xA;	   )&#xD;&#xA;   AND DELETE_FLAG &lt;&gt; 'Y'&#xD;&#xA; ORDER BY EQP_NAME ASC">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="3610" N="EquipmentEventSelector">
        <SG _S="3611" N="ListEquipmentEvent">
          <QY P="MsSql" Q="SELECT EVENT_ID, EVENT_DESC&#xD;&#xA;FROM QEESEQPEVT&#xD;&#xA;WHERE FACTORY = @factory&#xD;&#xA;AND EVENT_ID NOT IN (SELECT EVENT_ID FROM QEESEQPEFL WHERE FACTORY = @factory AND EQP_NAME = @eqp_name)&#xD;&#xA;ORDER BY EVENT_ID ASC">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
      </F>
      <F _S="3823" N="EquipmentAlarmSelector">
        <SG _S="3825" N="ListEquipmentAlarm">
          <QY P="MsSql" Q="SELECT EQP.ALARM_NAME, ALM.ALARM_DESC, ALM.ALARM_LEVEL, EQP.USED_CONDITION, EQP.CONDITION_NAME, EQP.SET_COUNT, EQP.CLEAR_COUNT&#xD;&#xA;  FROM (&#xD;&#xA;SELECT A.FACTORY, A.EQP_TYPE, A.EQP_NAME, A.ALARM_NAME, A.USED_CONDITION, A.CONDITION_NAME,&#xD;&#xA;       SUM(CASE WHEN B.ALARM_STATUS = 'Set' THEN 1 ELSE 0 END) AS SET_COUNT,&#xD;&#xA;       SUM(CASE WHEN B.ALARM_STATUS = 'Clear' THEN 1 ELSE 0 END) AS CLEAR_COUNT&#xD;&#xA;  FROM QEESEQPALM A&#xD;&#xA;  LEFT JOIN QEESEQPAIL B&#xD;&#xA;    ON A.FACTORY    = B.FACTORY&#xD;&#xA;   AND A.EQP_TYPE   = B.EQP_TYPE&#xD;&#xA;   AND A.EQP_NAME   = B.EQP_NAME&#xD;&#xA;   AND A.ALARM_NAME = B.ALARM_NAME&#xD;&#xA; WHERE A.FACTORY    = @factory&#xD;&#xA;   AND A.EQP_TYPE   = @eqp_type&#xD;&#xA;   AND A.EQP_NAME   = @eqp_name&#xD;&#xA; GROUP BY A.FACTORY, A.EQP_TYPE, A.EQP_NAME, A.ALARM_NAME, A.USED_CONDITION, A.CONDITION_NAME&#xD;&#xA;       ) EQP&#xD;&#xA;  LEFT JOIN QEESALMDEF ALM&#xD;&#xA;    ON EQP.FACTORY    = ALM.FACTORY&#xD;&#xA;   AND EQP.EQP_TYPE   = ALM.EQP_TYPE&#xD;&#xA;   AND EQP.ALARM_NAME = ALM.ALARM_NAME&#xD;&#xA; ORDER BY EQP.ALARM_NAME">
            <QP N="factory" />
            <QP N="eqp_type" />
            <QP N="eqp_name" />
          </QY>
        </SG>
      </F>
      <F _S="4027" N="EquipmentRecipeConditionCodeSelector">
        <SG _S="4033" N="ListRecipeCondition">
          <QY P="MsSql" Q="SELECT A.EQ_ACTION AS CONDITION_CODE, B.DATA_3 AS CONDITION_VALUE, B.DATA_4 AS CONDITION_DESC,&#xD;&#xA;       A.FORMULA_NAME, A.FORMULA_DESC, A.EXPRESSION_VALUE&#xD;&#xA;  FROM QRMSEQPPMC A&#xD;&#xA;  LEFT JOIN QGCMTBLDAT B&#xD;&#xA;    ON A.FACTORY    = B.FACTORY&#xD;&#xA;   AND A.EQ_ACTION  = B.DATA_2&#xD;&#xA; WHERE A.FACTORY    = @factory&#xD;&#xA;   AND A.EQP_NAME   = @eqp_name&#xD;&#xA;   AND A.EQ_ACTION &lt;&gt; 'NONE'">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
      </F>
      <F _S="4007" N="EquipmentUnitSelector">
        <SG _S="4008" N="ListEquipmentUnit">
          <QY P="MsSql" Q="SELECT  UNIT_NAME, UNIT_DESC&#xD;&#xA;  FROM QEESEQPUNT&#xD;&#xA; WHERE FACTORY     = @factory &#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA; ORDER BY UNIT_SEQ">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
      </F>
      <F _S="3602" N="InterlockSelector">
        <SG _S="3603" N="ListInterlock">
          <QY P="MsSql" Q="SELECT ITL_NAME, ITL_DESC&#xD;&#xA;FROM QEESITLDEF&#xD;&#xA;WHERE FACTORY = @factory&#xD;&#xA;AND ITL_NAME NOT IN (SELECT ITL_NAME &#xD;&#xA;	FROM QEESCDTITL &#xD;&#xA;	WHERE FACTORY = @factory AND CDT_NAME = @cdt_name)&#xD;&#xA;ORDER BY ITL_NAME ASC">
            <QP N="factory" />
            <QP N="cdt_name" />
          </QY>
        </SG>
        <SG _S="3614" N="ListInterlockByAll">
          <QY P="MsSql" Q="SELECT ITL_NAME, ITL_DESC&#xD;&#xA;FROM QEESITLDEF&#xD;&#xA;WHERE FACTORY = @factory&#xD;&#xA;ORDER BY ITL_NAME ASC">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="3615" N="ConditionSelector">
        <SG _S="3616" N="ListConditionGroup">
          <QY P="MsSql" Q="SELECT CDG_NAME, CDG_DESC&#xD;&#xA;  FROM QEESCDGDEF&#xD;&#xA; WHERE FACTORY     = @factory &#xD;&#xA; ORDER BY CDG_NAME">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3617" N="ListCondition">
          <QY P="MsSql" Q="SELECT  CDT_NAME, CDT_DESC&#xD;&#xA;  FROM QEESCDTDEF&#xD;&#xA; WHERE FACTORY     = @factory &#xD;&#xA; 	AND CDT_GROUP = @cdt_group&#xD;&#xA; ORDER BY CDT_NAME">
            <QP N="factory" />
            <QP N="cdt_group" />
          </QY>
        </SG>
      </F>
      <F _S="3779" N="LineSelector">
        <SG _S="3780" N="ListLine">
          <QY P="MsSql" Q="SELECT LINE_NAME, LINE_DESC&#xD;&#xA;  FROM QEESLINDEF&#xD;&#xA;  WHERE FACTORY = @factory&#xD;&#xA;  AND DELETE_FLAG = 'N'">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="3869" N="ContainerWizard">
        <SG _S="3870" N="SearchContainer">
          <QY P="MsSql" Q="SELECT CTN_NAME, CTN_DESC &#xD;&#xA;  FROM QEESCTNDEF&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND CTN_NAME       = @ctn_name&#xD;&#xA;   AND DELETE_FLAG   != 'Y'">
            <QP N="factory" />
            <QP N="ctn_name" />
          </QY>
        </SG>
      </F>
      <F _S="3935" N="PackageSelector">
        <SG _S="3939" N="ListPackage">
          <QY P="MsSql" Q="SELECT PACKAGE, PKG_DESC, REL_PKG_VER, LAST_PKG_VER&#xD;&#xA;  FROM QEESCPGDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY PACKAGE">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="3936" N="PackageVerSelector">
        <SG _S="3940" N="ListPackage">
          <QY P="MsSql" Q="SELECT PACKAGE, PKG_DESC, REL_PKG_VER, LAST_PKG_VER&#xD;&#xA;  FROM QEESCPGDEF&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA; ORDER BY PACKAGE">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3941" N="ListPackageVer">
          <QY P="MsSql" Q="SELECT PKG_VER, PKG_VER_DESC, PKG_RELEASE, PKG_COMMENT&#xD;&#xA;  FROM QEESCPGVER&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND PACKAGE = @package&#xD;&#xA; ORDER BY PKG_VER DESC">
            <QP N="factory" />
            <QP N="package" />
          </QY>
        </SG>
      </F>
      <F _S="3976" N="SqlConnectorSelector">
        <SG _S="3977" N="ListSqlConnector">
          <QY P="MsSql" Q="SELECT NAME, PROVIDER, CNT_STRING&#xD;&#xA;  FROM QEESDSRDEF&#xD;&#xA; WHERE FACTORY = @factory &#xD;&#xA; ORDER BY NAME">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="4105" N="LineEquipmentSelectorEx">
        <SG _S="4106" N="ListLine">
          <QY P="MsSql" Q="SELECT LINE_NAME, LINE_DESC&#xD;&#xA;  FROM QEESLINDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY LINE_NAME">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="4107" N="ListEquipment">
          <QY P="MsSql" Q="SELECT L.LINE_NAME, L.EQP_NAME, E.EQP_DESC, E.EQP_TYPE, E.ITL_MODE&#xD;&#xA;  FROM QEESLINEQP L&#xD;&#xA; INNER JOIN QEESEQPDEF E&#xD;&#xA;    ON L.FACTORY     = E.FACTORY&#xD;&#xA;   AND L.EQP_NAME    = E.EQP_NAME&#xD;&#xA;   AND E.DELETE_FLAG = 'N'&#xD;&#xA; WHERE L.FACTORY     = @factory&#xD;&#xA;   AND L.LINE_NAME   = ISNULL(@line_name, LINE_NAME)&#xD;&#xA; ORDER BY L.LINE_NAME, L.SEQ">
            <QP N="factory" />
            <QP N="line_name" />
          </QY>
        </SG>
      </F>
