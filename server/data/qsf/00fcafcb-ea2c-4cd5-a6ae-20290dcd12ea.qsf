        <SG _S="4192" N="InsertVersion">
          <QY P="MsSql" Q="INSERT INTO QEESEQPSVR (&#xD;&#xA;    FACTORY,&#xD;&#xA;    EQP_TYPE,&#xD;&#xA;    EQP_NAME,&#xD;&#xA;    SPEC_VER,&#xD;&#xA;    SPEC_VER_DESC,&#xD;&#xA;    ACTIVE,&#xD;&#xA;    CREATE_USER_ID,&#xD;&#xA;    CREATE_TIME,&#xD;&#xA;    UPDATE_USER_ID,&#xD;&#xA;    UPDATE_TIME,&#xD;&#xA;    DELETE_FLAG&#xD;&#xA;)&#xD;&#xA;VALUES (&#xD;&#xA;    @factory,&#xD;&#xA;    @eqp_type,&#xD;&#xA;    @eqp_name,&#xD;&#xA;    @spec_ver,&#xD;&#xA;    @spec_ver_desc,&#xD;&#xA;    @active,&#xD;&#xA;    @create_user_id,&#xD;&#xA;    @create_time,&#xD;&#xA;    @update_user_id,&#xD;&#xA;    @update_time,&#xD;&#xA;    'N'&#xD;&#xA;);">
