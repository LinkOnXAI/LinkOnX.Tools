        </SG>
        <SG _S="4112" N="SearchEquipmentHistoryPaging">
          <QY P="MsSql" Q="SELECT TRAN_TIME, EQP_NAME, HIST_SEQ, EVENT_ID, COMM_STATE, CTRL_MODE, PROC_STATE, EQP_MODE, ALARM,&#xD;&#xA;       EVT_H_1, EVT_D_1, EVT_H_2, EVT_D_2, EVT_H_3, EVT_D_3, EVT_H_4, EVT_D_4, EVT_H_5, EVT_D_5, &#xD;&#xA;       EVT_H_6, EVT_D_6, EVT_H_7, EVT_D_7, EVT_H_8, EVT_D_8, EVT_H_9, EVT_D_9, EVT_H_10, EVT_D_10, &#xD;&#xA;       EVT_H_11, EVT_D_11, EVT_H_12, EVT_D_12, EVT_H_13, EVT_D_13, EVT_H_14, EVT_D_14, EVT_H_15, EVT_D_15, &#xD;&#xA;       EVT_H_16, EVT_D_16, EVT_H_17, EVT_D_17, EVT_H_18, EVT_D_18, EVT_H_19, EVT_D_19, EVT_H_20, EVT_D_20,&#xD;&#xA;       TRAN_USER_ID,&#xD;&#xA;       TRAN_COMMENT&#xD;&#xA;  FROM QEESEQPHIS&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND EQP_NAME   = ISNULL(@eqp_name, EQP_NAME)&#xD;&#xA;   AND TRAN_TIME &gt;= @tran_from_time&#xD;&#xA;   AND TRAN_TIME &lt;= ISNULL(@tran_to_time, TRAN_TIME)&#xD;&#xA; ORDER BY HIST_SEQ DESC&#xD;&#xA;OFFSET (CONVERT(int, @PAGE_NO)-1) * CONVERT(int, @PAGE_SIZE) ROW FETCH NEXT CONVERT(int, @PAGE_SIZE) ROW ONLY">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
            <QP N="PAGE_NO" />
            <QP N="PAGE_SIZE" />
          </QY>
        </SG>
        <SG _S="4113" N="CountEquipmentHistory">
          <QY P="MsSql" Q="SELECT COUNT(*) AS CNT&#xD;&#xA;  FROM QEESEQPHIS&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND EQP_NAME   = ISNULL(@eqp_name, EQP_NAME)&#xD;&#xA;   AND TRAN_TIME &gt;= @tran_from_time&#xD;&#xA;   AND TRAN_TIME &lt;= ISNULL(@tran_to_time, TRAN_TIME)">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
      </F>
      <F _S="3524" N="OEEReport">
        <SG _S="3525" N="SearchOEEReportByType">
          <QY P="MsSql" Q="SELECT A.EQP_NAME, A.PROC_STATE, (CASE WHEN A.MIN_PERIOD = 0 THEN (DATEDIFF(SECOND, A.TRAN_TIME, GETDATE()) + A.PERIOD) ELSE A.PERIOD END) AS CAL_PERIOD&#xD;&#xA;FROM (&#xD;&#xA;SELECT EQP_NAME, &#xD;&#xA;	PROC_STATE, &#xD;&#xA;	MAX(C_TRAN_TIME) AS TRAN_TIME,&#xD;&#xA;	SUM(HIS_PERIOD) AS PERIOD,&#xD;&#xA;	MIN(HIS_PERIOD) AS MIN_PERIOD&#xD;&#xA;	FROM QEESOEERPT &#xD;&#xA;	WHERE FACTORY      = @factory&#xD;&#xA;   AND EQP_NAME IN (SELECT EQP_NAME FROM QEESEQPDEF WHERE FACTORY = @factory AND EQP_TYPE = @eqp_type)&#xD;&#xA;   AND (HIS_MONTH BETWEEN @start_month AND @end_month)&#xD;&#xA;   AND TRAN_TIME &gt;= @tran_from_time&#xD;&#xA;   AND TRAN_TIME &lt;= ISNULL(@tran_to_time, TRAN_TIME)&#xD;&#xA;GROUP BY PROC_STATE, EQP_NAME&#xD;&#xA;) A&#xD;&#xA;ORDER BY EQP_NAME ASC, PERIOD DESC;">
            <QP N="factory" />
            <QP N="eqp_type" />
            <QP N="start_month" />
            <QP N="end_month" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
        <SG _S="3792" N="SearchEquipmentOEEHistory">
          <QY P="MsSql" Q="SELECT TRAN_TIME, EQP_NAME, EVENT_ID, PROC_STATE, HIS_PERIOD,&#xD;&#xA;       EVT_H_1, EVT_D_1, EVT_H_2, EVT_D_2, EVT_H_3, EVT_D_3, EVT_H_4, EVT_D_4, EVT_H_5, EVT_D_5, &#xD;&#xA;       EVT_H_6, EVT_D_6, EVT_H_7, EVT_D_7, EVT_H_8, EVT_D_8, EVT_H_9, EVT_D_9, EVT_H_10, EVT_D_10, &#xD;&#xA;       EVT_H_11, EVT_D_11, EVT_H_12, EVT_D_12, EVT_H_13, EVT_D_13, EVT_H_14, EVT_D_14, EVT_H_15, EVT_D_15, &#xD;&#xA;       EVT_H_16, EVT_D_16, EVT_H_17, EVT_D_17, EVT_H_18, EVT_D_18, EVT_H_19, EVT_D_19, EVT_H_20, EVT_D_20,&#xD;&#xA;       TRAN_USER_ID,&#xD;&#xA;       TRAN_COMMENT&#xD;&#xA;  FROM QEESOEERPT&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND EQP_NAME          = ISNULL(@eqp_name, EQP_NAME)&#xD;&#xA;   AND (HIS_MONTH BETWEEN @start_month AND @end_month)&#xD;&#xA;   AND TRAN_TIME &gt;= @tran_from_time&#xD;&#xA;   AND TRAN_TIME &lt;= ISNULL(@tran_to_time, TRAN_TIME)&#xD;&#xA; ORDER BY TRAN_TIME DESC">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="start_month" />
            <QP N="end_month" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
      </F>
      <F _S="3526" N="AlarmReport">
        <SG _S="3527" N="SearchAlarmTrend">
          <QY P="MsSql" Q="SELECT A.* &#xD;&#xA;  FROM &#xD;&#xA;     (&#xD;&#xA;SELECT ALARM_NAME, ALARM_ID, ALARM_TEXT, ALARM_LEVEL,&#xD;&#xA;       COUNT(*) AS ALARM_COUNT, &#xD;&#xA;       SUM(EFFECT_PERIOD) AS EFFECT_PERIOD,&#xD;&#xA;       RANK() OVER (ORDER BY COUNT(*) DESC) AS ALARM_RANK&#xD;&#xA;  FROM QEESALMHIS&#xD;&#xA; WHERE FACTORY          = @factory&#xD;&#xA;   AND EQP_NAME         = @eqp_name&#xD;&#xA;   AND (HIS_MONTH BETWEEN @start_month AND @end_month)&#xD;&#xA;   AND SET_TIME        &gt;= @tran_from_time&#xD;&#xA;   AND SET_TIME        &lt;= ISNULL(@tran_to_time, SET_TIME)&#xD;&#xA; GROUP BY ALARM_NAME, ALARM_ID, ALARM_TEXT, ALARM_LEVEL&#xD;&#xA;       ) A&#xD;&#xA; ORDER BY A.ALARM_COUNT DESC;">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="start_month" />
            <QP N="end_month" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
        <SG _S="4079" N="SearchHourlyAlarmOverview">
          <QY P="MsSql" Q="WITH Hours AS (&#xA;    SELECT 0 AS HOUR_OF_DAY&#xA;     UNION ALL&#xA;    SELECT HOUR_OF_DAY + 1&#xA;      FROM Hours&#xA;     WHERE HOUR_OF_DAY &lt; 23&#xA;)&#xA;SELECT &#xA;    H.HOUR_OF_DAY,                                    -- 시간대 (0~23)&#xA;    ISNULL(COUNT(Q.C_SET_TIME), 0) AS ALARM_COUNT,    -- 알람 발생 빈도 (없으면 0)&#xA;    ISNULL(SUM(Q.EFFECT_PERIOD), 0) AS EFFECT_PERIOD  -- EFFECT_PERIOD 합계 (없으면 0)&#xA; FROM Hours H&#xA; LEFT JOIN QEESALMHIS Q&#xA;   ON H.HOUR_OF_DAY     = DATEPART(HOUR, Q.C_SET_TIME) &#xA;  AND Q.FACTORY         = @factory&#xA;  AND Q.EQP_NAME        = @eqp_name&#xA;  AND Q.HIS_MONTH BETWEEN @start_month AND @end_month&#xA;  AND Q.SET_TIME       &gt;= @from_time&#xA;  AND Q.SET_TIME       &lt;= @to_time&#xA;GROUP BY H.HOUR_OF_DAY&#xA;ORDER BY H.HOUR_OF_DAY" />
        </SG>
        <SG _S="4080" N="SearchHourlyAlarmList">
          <QY P="MsSql" Q="SELECT A.* &#xD;&#xA;  FROM &#xD;&#xA;     (&#xD;&#xA;SELECT ALARM_NAME, ALARM_ID, ALARM_TEXT, ALARM_LEVEL,&#xD;&#xA;       COUNT(*) AS ALARM_COUNT, &#xD;&#xA;       SUM(EFFECT_PERIOD) AS EFFECT_PERIOD&#xD;&#xA;  FROM QEESALMHIS&#xD;&#xA; WHERE FACTORY         = @factory &#xA;   AND EQP_NAME        = @eqp_name &#xA;   AND HIS_MONTH BETWEEN @start_month AND @end_month&#xA;   AND SET_TIME       &gt;= @from_time&#xA;   AND SET_TIME       &lt;= @to_time&#xD;&#xA;   AND DATEPART(HOUR, C_SET_TIME)  = @tran_hour&#xD;&#xA; GROUP BY ALARM_NAME, ALARM_ID, ALARM_TEXT, ALARM_LEVEL&#xD;&#xA;       ) A&#xD;&#xA; ORDER BY A.ALARM_COUNT DESC;">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="start_month" />
            <QP N="end_month&#xA;" />
            <QP N="from_time&#xA;" />
            <QP N="to_time" />
            <QP N="tran_hour" />
          </QY>
        </SG>
        <SG _S="4081" N="SearchWeeklyAlarmOverview">
          <QY P="MsSql" Q="WITH Days AS (&#xA;    SELECT 1 AS DAY_OF_WEEK&#xA;     UNION ALL&#xA;    SELECT DAY_OF_WEEK + 1&#xA;      FROM Days&#xA;     WHERE DAY_OF_WEEK &lt; 7&#xA;)&#xA;SELECT &#xA;    CASE D.DAY_OF_WEEK&#xA;        WHEN 1 THEN 'Sun'&#xA;        WHEN 2 THEN 'Mon'&#xA;        WHEN 3 THEN 'Tue'&#xA;        WHEN 4 THEN 'Wed'&#xA;        WHEN 5 THEN 'Thu'&#xA;        WHEN 6 THEN 'Fri'&#xA;        WHEN 7 THEN 'Sat'&#xA;    END AS DAY_OF_WEEK,                             -- 요일 이름 (sun, mon, ...)&#xA;    ISNULL(COUNT(Q.C_SET_TIME), 0) AS ALARM_COUNT,  -- 알람 발생 빈도 (없으면 0)&#xA;    ISNULL(SUM(Q.EFFECT_PERIOD), 0) AS ALARM_EFFECT -- EFFECT_PERIOD 합계 (없으면 0)&#xA; FROM Days D&#xA; LEFT JOIN QEESALMHIS Q&#xA;   ON D.DAY_OF_WEEK     = DATEPART(WEEKDAY, Q.C_SET_TIME) &#xA;  AND Q.FACTORY         = @factory &#xA;  AND Q.EQP_NAME        = @eqp_name &#xA;  AND Q.HIS_MONTH BETWEEN @start_month AND @end_month&#xA;  AND Q.SET_TIME       &gt;= @from_time&#xA;  AND Q.SET_TIME       &lt;= @to_time&#xA;GROUP BY D.DAY_OF_WEEK&#xA;ORDER BY D.DAY_OF_WEEK" />
        </SG>
        <SG _S="4083" N="SearchDailyAlarmOverview">
          <QY P="MsSql" Q="WITH Dates AS (&#xD;&#xA;    SELECT CAST(@from_date AS DATE) AS DATE_OF_EVENT  -- 시작 날짜 (YYYY-MM-DD 형식)&#xD;&#xA;     UNION ALL&#xD;&#xA;    SELECT DATEADD(DAY, 1, DATE_OF_EVENT)             -- 날짜를 +1일씩 증가&#xD;&#xA;      FROM Dates&#xD;&#xA;     WHERE DATE_OF_EVENT &lt; CAST(@to_date AS DATE)     -- 종료 날짜 (YYYY-MM-DD 형식)&#xD;&#xA;)&#xD;&#xA;SELECT &#xD;&#xA;    CONVERT(VARCHAR(10), D.DATE_OF_EVENT, 120) AS TRAN_DATE, -- 일자 (YYYY-MM-DD 형식)&#xD;&#xA;    ISNULL(COUNT(Q.C_SET_TIME), 0) AS ALARM_COUNT,            -- 알람 발생 빈도 (없으면 0)&#xD;&#xA;    ISNULL(SUM(Q.EFFECT_PERIOD), 0) AS ALARM_EFFECT           -- EFFECT_PERIOD 합계 (없으면 0)&#xD;&#xA; FROM Dates D&#xD;&#xA; LEFT JOIN QEESALMHIS Q&#xD;&#xA;   ON CONVERT(DATE, Q.C_SET_TIME) = D.DATE_OF_EVENT &#xD;&#xA;  AND Q.FACTORY         = @factory&#xA;  AND Q.EQP_NAME        = @eqp_name&#xA;  AND Q.HIS_MONTH BETWEEN @start_month AND @end_month&#xA;  AND Q.SET_TIME       &gt;= @from_time&#xA;  AND Q.SET_TIME       &lt;= @to_time          &#xD;&#xA;GROUP BY D.DATE_OF_EVENT&#xD;&#xA;ORDER BY D.DATE_OF_EVENT">
            <QP N="from_date" />
            <QP N="to_date" />
            <QP N="factory&#xA;" />
            <QP N="eqp_name&#xA;" />
            <QP N="start_month" />
            <QP N="end_month&#xA;" />
            <QP N="from_time&#xA;" />
            <QP N="to_time" />
          </QY>
        </SG>
        <SG _S="4084" N="SearchDailyAlarmList">
          <QY P="MsSql" Q="SELECT A.* &#xD;&#xA;  FROM &#xD;&#xA;     (&#xD;&#xA;SELECT ALARM_NAME, ALARM_ID, ALARM_TEXT, ALARM_LEVEL,&#xD;&#xA;       COUNT(*) AS ALARM_COUNT, &#xD;&#xA;       SUM(EFFECT_PERIOD) AS EFFECT_PERIOD&#xD;&#xA;  FROM QEESALMHIS&#xD;&#xA; WHERE FACTORY         = @factory &#xA;   AND EQP_NAME        = @eqp_name &#xA;   AND HIS_MONTH BETWEEN @start_month AND @end_month&#xA;   AND SET_TIME       &gt;= @from_time&#xA;   AND SET_TIME       &lt;= @to_time&#xD;&#xA; GROUP BY ALARM_NAME, ALARM_ID, ALARM_TEXT, ALARM_LEVEL&#xD;&#xA;       ) A&#xD;&#xA; ORDER BY A.ALARM_COUNT DESC;">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="start_month" />
            <QP N="end_month&#xA;" />
            <QP N="from_time&#xA;" />
            <QP N="to_time" />
          </QY>
        </SG>
        <SG _S="4082" N="SearchWeeklyAlarmList">
          <QY P="MsSql" Q="SELECT A.* &#xD;&#xA;  FROM &#xD;&#xA;     (&#xD;&#xA;SELECT ALARM_NAME, ALARM_ID, ALARM_TEXT, ALARM_LEVEL,&#xD;&#xA;       COUNT(*) AS ALARM_COUNT, &#xD;&#xA;       SUM(EFFECT_PERIOD) AS EFFECT_PERIOD&#xD;&#xA;  FROM QEESALMHIS&#xD;&#xA; WHERE FACTORY         = @factory &#xA;   AND EQP_NAME        = @eqp_name &#xA;   AND HIS_MONTH BETWEEN @start_month AND @end_month&#xA;   AND SET_TIME       &gt;= @from_time&#xA;   AND SET_TIME       &lt;= @to_time&#xD;&#xA;   AND DATEPART(WEEKDAY, C_SET_TIME)   = @tran_week_day&#xD;&#xA; GROUP BY ALARM_NAME, ALARM_ID, ALARM_TEXT, ALARM_LEVEL&#xD;&#xA;       ) A&#xD;&#xA; ORDER BY A.ALARM_COUNT DESC">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="start_month" />
            <QP N="end_month&#xA;" />
            <QP N="from_time&#xA;" />
            <QP N="to_time" />
            <QP N="tran_week_day" />
          </QY>
        </SG>
        <SG _S="3789" N="SearchAlarmTrendByEqType">
          <QY P="MsSql" Q="SELECT A.* &#xD;&#xA;  FROM &#xD;&#xA;       (&#xD;&#xA;SELECT EQP_NAME, ALARM_NAME, ALARM_ID, ALARM_TEXT,&#xD;&#xA;       COUNT(*) AS ALARM_COUNT, &#xD;&#xA;	   SUM(EFFECT_PERIOD) AS EFFECT_PERIOD&#xD;&#xA;  FROM QEESALMHIS&#xD;&#xA; WHERE FACTORY            = @factory&#xD;&#xA;   AND EQP_NAME IN &#xD;&#xA;       (&#xD;&#xA;	   SELECT EQP_NAME &#xD;&#xA;	     FROM QEESEQPDEF &#xD;&#xA;		WHERE FACTORY     = @factory &#xD;&#xA;		  AND EQP_TYPE    = @eqp_type&#xD;&#xA;		  AND DELETE_FLAG = 'N'&#xD;&#xA;	   )&#xD;&#xA;   AND (HIS_MONTH BETWEEN @start_month AND @end_month)&#xD;&#xA;   AND SET_TIME        &gt;= @tran_from_time&#xD;&#xA;   AND SET_TIME        &lt;= ISNULL(@tran_to_time, SET_TIME)&#xD;&#xA; GROUP BY EQP_NAME, ALARM_NAME, ALARM_ID, ALARM_TEXT&#xD;&#xA;       ) A&#xD;&#xA;ORDER BY A.ALARM_COUNT, A.EFFECT_PERIOD;">
            <QP N="factory" />
            <QP N="eqp_type" />
            <QP N="start_month" />
            <QP N="end_month" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
        <SG _S="4016" N="SearchAlarmTrendByEqLine">
          <QY P="MsSql" Q="SELECT A.* &#xD;&#xA;  FROM &#xD;&#xA;       (&#xD;&#xA;SELECT EQP_NAME, ALARM_NAME, ALARM_ID, ALARM_TEXT, ALARM_LEVEL,&#xD;&#xA;       COUNT(*) AS ALARM_COUNT, &#xD;&#xA;	   SUM(EFFECT_PERIOD) AS EFFECT_PERIOD&#xD;&#xA;  FROM QEESALMHIS&#xD;&#xA; WHERE FACTORY          = @factory&#xD;&#xA;   AND EQP_NAME IN &#xD;&#xA;       (&#xD;&#xA;	   SELECT EQP_NAME &#xD;&#xA;	     FROM QEESLINEQP &#xD;&#xA;		WHERE FACTORY   = @factory &#xD;&#xA;		  AND LINE_NAME = @line_name&#xD;&#xA;	   )&#xD;&#xA;   AND HIS_MONTH       &gt;= @start_month &#xD;&#xA;   AND HIS_MONTH       &lt;= @end_month&#xD;&#xA;   AND SET_TIME        &gt;= @tran_from_time&#xD;&#xA;   AND SET_TIME        &lt;= ISNULL(@tran_to_time, SET_TIME)&#xD;&#xA; GROUP BY EQP_NAME, ALARM_NAME, ALARM_ID, ALARM_TEXT, ALARM_LEVEL&#xD;&#xA;       ) A&#xD;&#xA;ORDER BY A.EQP_NAME ASC, A.ALARM_COUNT DESC, A.EFFECT_PERIOD DESC">
            <QP N="factory" />
            <QP N="line_name" />
            <QP N="start_month" />
            <QP N="end_month" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
        <SG _S="4015" N="SearchAlarmTrendByUnit2">
          <QY P="MsSql" Q="SP_EES_ALARM_TREND_BY_UNIT @factory, @eqp_name, @month_from, @month_to, @from_date, @to_date">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="month_from" />
            <QP N="month_to" />
            <QP N="from_date" />
            <QP N="to_date" />
          </QY>
        </SG>
        <SG _S="4051" N="SearchAlarmTrendByUnit">
          <QY P="MsSql" Q="WITH BaseData AS (&#xD;&#xA;	SELECT FACTORY, EQP_NAME, ALARM_NAME, ALARM_ID, ALARM_TEXT, ALARM_LEVEL,&#xD;&#xA;		   COUNT(*) AS ALARM_COUNT, &#xD;&#xA;		   SUM(EFFECT_PERIOD) AS EFFECT_PERIOD,&#xD;&#xA;		   RANK() OVER (ORDER BY COUNT(*) DESC) AS ALARM_RANK&#xD;&#xA;	  FROM QEESALMHIS&#xD;&#xA;	 WHERE FACTORY          = @factory&#xD;&#xA;	   AND EQP_NAME         = @eqp_name&#xD;&#xA;	   AND (HIS_MONTH BETWEEN @start_month AND @end_month)&#xD;&#xA;	   AND SET_TIME        &gt;= @tran_from_time&#xD;&#xA;	   AND SET_TIME        &lt;= ISNULL(@tran_to_time, SET_TIME)&#xD;&#xA;	 GROUP BY FACTORY, EQP_NAME, ALARM_NAME, ALARM_ID, ALARM_TEXT, ALARM_LEVEL&#xD;&#xA;)&#xD;&#xA;SELECT ISNULL(UNT.UNIT_NAME, 'Unassigned') AS UNIT_NAME,&#xA;       ALM.ALARM_NAME, ALM.ALARM_ID, ALM.ALARM_TEXT, ALM.ALARM_LEVEL, ALM.ALARM_COUNT, ALM.EFFECT_PERIOD&#xA;  FROM BaseData ALM&#xA;  LEFT JOIN QEESALMUNT UNT&#xA;	ON ALM.FACTORY  = UNT.FACTORY &#xA;   AND ALM.EQP_NAME = UNT.EQP_NAME&#xA;   AND ALM.ALARM_ID = UNT.ALARM_ID&#xA;ORDER BY &#xA;    CASE &#xA;        WHEN ISNULL(UNT.UNIT_NAME, 'Unassigned') = 'Unassigned' THEN 1 &#xA;        ELSE 0 &#xA;    END,&#xA;    UNIT_NAME">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="start_month" />
            <QP N="end_month" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
        <SG _S="3529" N="SearchAlarmHistory">
          <QY P="MsSql" Q="SELECT SET_TIME, EQP_NAME, HIST_SEQ, ALARM_NAME, ALARM_ID, ALARM_LEVEL, ALARM_TEXT, CLEAR_TIME, ALARM_STATE, HIS_PERIOD, EFFECT_PERIOD,&#xD;&#xA;       EVT_H_1, EVT_D_1, EVT_H_2, EVT_D_2, EVT_H_3, EVT_D_3, EVT_H_4, EVT_D_4, EVT_H_5, EVT_D_5, &#xD;&#xA;       EVT_H_6, EVT_D_6, EVT_H_7, EVT_D_7, EVT_H_8, EVT_D_8, EVT_H_9, EVT_D_9, EVT_H_10, EVT_D_10, &#xD;&#xA;       EVT_H_11, EVT_D_11, EVT_H_12, EVT_D_12, EVT_H_13, EVT_D_13, EVT_H_14, EVT_D_14, EVT_H_15, EVT_D_15, &#xD;&#xA;       EVT_H_16, EVT_D_16, EVT_H_17, EVT_D_17, EVT_H_18, EVT_D_18, EVT_H_19, EVT_D_19, EVT_H_20, EVT_D_20,&#xD;&#xA;       TRAN_USER_ID,&#xD;&#xA;       TRAN_COMMENT&#xD;&#xA;  FROM QEESALMHIS&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND EQP_NAME     = ISNULL(@eqp_name, EQP_NAME)&#xD;&#xA;   AND (HIS_MONTH BETWEEN @start_month AND @end_month)&#xD;&#xA;   AND SET_TIME    &gt;= @tran_from_time&#xD;&#xA;   AND SET_TIME    &lt;= ISNULL(@tran_to_time, SET_TIME)&#xD;&#xA; ORDER BY HIST_SEQ DESC">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="start_month" />
            <QP N="end_month" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
        <SG _S="3528" N="SearchAlarmDistribution">
          <QY P="MsSql" Q="SELECT &#xD;&#xA; HIST_SEQ,&#xD;&#xA; EQP_NAME, &#xD;&#xA; ALARM_NAME,&#xD;&#xA; SET_TIME,&#xD;&#xA; CLEAR_TIME,&#xD;&#xA; C_SET_TIME,&#xD;&#xA; C_CLEAR_TIME,&#xD;&#xA; HIS_PERIOD, &#xD;&#xA; ALARM_TEXT&#xD;&#xA;FROM QEESALMHIS&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EQP_NAME  IN (SELECT EQP_NAME FROM QEESEQPDEF WHERE FACTORY = @factory AND EQP_TYPE = @eqp_type)&#xD;&#xA;   AND (HIS_MONTH BETWEEN @start_month AND @end_month)&#xD;&#xA;   AND ALARM_STATE = 'C'&#xD;&#xA;   AND SET_TIME &gt;= @tran_from_time&#xD;&#xA;   AND SET_TIME &lt;= ISNULL(@tran_to_time, SET_TIME)&#xD;&#xA;ORDER BY EQP_NAME, SET_TIME;">
            <QP N="factory" />
            <QP N="eqp_type" />
            <QP N="start_month" />
            <QP N="end_month" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
        <SG _S="3781" N="SearchAlarmDistributionByLine">
          <QY P="MsSql" Q="SELECT HIST_SEQ, EQP_NAME, ALARM_NAME, SET_TIME, CLEAR_TIME, C_SET_TIME, C_CLEAR_TIME, &#xD;&#xA;       HIS_PERIOD, ALARM_TEXT&#xD;&#xA;  FROM QEESALMHIS&#xD;&#xA; WHERE FACTORY          = @factory&#xD;&#xA;   AND EQP_NAME IN &#xD;&#xA;       (&#xD;&#xA;	   SELECT EQP_NAME &#xD;&#xA;	     FROM QEESLINEQP &#xD;&#xA;		WHERE FACTORY   = @factory &#xD;&#xA;		  AND LINE_NAME = @line_name&#xD;&#xA;	   )&#xD;&#xA;   AND ALARM_STATE      = 'C'&#xD;&#xA;   AND HIS_MONTH       &gt;= @start_month &#xD;&#xA;   AND HIS_MONTH       &lt;= @end_month&#xD;&#xA;   AND SET_TIME        &gt;= @tran_from_time&#xD;&#xA;   AND SET_TIME        &lt;= ISNULL(@tran_to_time, SET_TIME)&#xD;&#xA;ORDER BY EQP_NAME, SET_TIME;">
            <QP N="factory" />
            <QP N="line_name" />
            <QP N="start_month" />
            <QP N="end_month" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
        <SG _S="4014" N="SearchAlarmDistributionByUnit">
          <QY P="MsSql" Q="SP_EES_ALARM_DISTRIBUTION_BY_UNIT @factory, @eqp_name, @month_from, @month_to, @from_date, @to_date">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="month_from" />
            <QP N="month_to" />
            <QP N="from_date" />
            <QP N="to_date" />
          </QY>
        </SG>
        <SG _S="3790" N="SearchAlarmTrendByEqType2" IPC="T">
          <QY P="MsSql" Q="ALMEFFCNT_BY_EQTYPE @factory, @eqp_type, @month_from, @month_to, @from_date, @to_date">
            <QP N="factory" />
            <QP N="eqp_type" />
            <QP N="month_from" />
            <QP N="month_to" />
            <QP N="from_date" />
            <QP N="to_date" />
          </QY>
        </SG>
        <SG _S="3793" N="SearchAlarmDefectListTotalProc">
          <QY P="MsSql" Q="  SELECT COUNT(*) AS TOT_PROC&#xD;&#xA;  FROM (  &#xD;&#xA;	SELECT DISTINCT EVT_D_1 AS LOT_ID&#xD;&#xA;  		FROM QEESOEERPT  &#xD;&#xA; 	WHERE EQP_NAME = @eqp_name&#xD;&#xA;   		AND (HIS_MONTH BETWEEN @start_month AND @end_month)&#xD;&#xA;   		AND TRAN_TIME &gt;= @tran_from_time&#xD;&#xA;   		AND TRAN_TIME &lt;= @tran_to_time&#xD;&#xA;   		AND PROC_STATE = 'RUN'&#xD;&#xA;   		AND FACTORY      = @factory&#xD;&#xA;   ) A">
            <QP N="eqp_name" />
            <QP N="start_month" />
            <QP N="end_month" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3794" N="SearchAlarmDefectList" IPC="T">
          <QY P="MsSql" Q="SP_EES_ALARM_DEFECT_LIST_BY_EQ @factory, @eqp_name, @alm_name, @month_from, @month_to, @from_date, @to_date">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="alm_name" />
            <QP N="month_from" />
            <QP N="month_to" />
            <QP N="from_date" />
            <QP N="to_date" />
          </QY>
        </SG>
        <SG _S="4114" N="SearchAlarmHistoryPaging">
          <QY P="MsSql" Q="SELECT SET_TIME, EQP_NAME, HIST_SEQ, ALARM_NAME, ALARM_ID, ALARM_LEVEL, ALARM_TEXT, CLEAR_TIME, ALARM_STATE, HIS_PERIOD, EFFECT_PERIOD,&#xD;&#xA;       EVT_H_1, EVT_D_1, EVT_H_2, EVT_D_2, EVT_H_3, EVT_D_3, EVT_H_4, EVT_D_4, EVT_H_5, EVT_D_5, &#xD;&#xA;       EVT_H_6, EVT_D_6, EVT_H_7, EVT_D_7, EVT_H_8, EVT_D_8, EVT_H_9, EVT_D_9, EVT_H_10, EVT_D_10, &#xD;&#xA;       EVT_H_11, EVT_D_11, EVT_H_12, EVT_D_12, EVT_H_13, EVT_D_13, EVT_H_14, EVT_D_14, EVT_H_15, EVT_D_15, &#xD;&#xA;       EVT_H_16, EVT_D_16, EVT_H_17, EVT_D_17, EVT_H_18, EVT_D_18, EVT_H_19, EVT_D_19, EVT_H_20, EVT_D_20,&#xD;&#xA;       TRAN_USER_ID,&#xD;&#xA;       TRAN_COMMENT&#xD;&#xA;  FROM QEESALMHIS&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND EQP_NAME     = ISNULL(@eqp_name, EQP_NAME)&#xD;&#xA;   AND (HIS_MONTH BETWEEN @start_month AND @end_month)&#xD;&#xA;   AND SET_TIME    &gt;= @tran_from_time&#xD;&#xA;   AND SET_TIME    &lt;= ISNULL(@tran_to_time, SET_TIME)&#xD;&#xA; ORDER BY HIST_SEQ DESC&#xD;&#xA;OFFSET (CONVERT(int, @PAGE_NO)-1) * CONVERT(int, @PAGE_SIZE) ROW FETCH NEXT CONVERT(int, @PAGE_SIZE) ROW ONLY">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="start_month" />
            <QP N="end_month" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
            <QP N="PAGE_NO" />
            <QP N="PAGE_SIZE" />
          </QY>
        </SG>
        <SG _S="4115" N="CountAlarmHistory">
          <QY P="MsSql" Q="SELECT COUNT(*) AS CNT&#xD;&#xA;  FROM QEESALMHIS&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND EQP_NAME     = ISNULL(@eqp_name, EQP_NAME)&#xD;&#xA;   AND (HIS_MONTH BETWEEN @start_month AND @end_month)&#xD;&#xA;   AND SET_TIME    &gt;= @tran_from_time&#xD;&#xA;   AND SET_TIME    &lt;= ISNULL(@tran_to_time, SET_TIME)">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="start_month" />
            <QP N="end_month" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
      </F>
      <F _S="2729" N="SndNeedActionList">
        <SG _S="2737" N="ListSnd">
          <QY P="MsSql" Q="SELECT A.SVS_NODE, A.SVS_NODE_DESC, A.SVS_NODE_GROUP, A.STEP, A.UP_DOWN, A.STATUS, A.RELOAD_CNT, A.ALARM, A.NEED_ACTION, A.NEXT_NEED_ACTION,&#xD;&#xA;       ISNULL(B.MODEL, 'N/A') SET_MODEL, ISNULL(B.MODEL_VER, 0) SET_MODEL_VER, ISNULL(C.MODEL, 'N/A') REL_MODEL, ISNULL(C.MODEL_VER, 0) REL_MODEL_VER, ISNULL(D.MODEL, 'N/A') APL_MODEL, ISNULL(D.MODEL_VER, 0) APL_MODEL_VER       &#xD;&#xA;  FROM QEESSNDDEF A&#xD;&#xA;  LEFT JOIN QEESSNDATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = B.SVS_NODE&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QEESSNDATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = C.SVS_NODE&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QEESSNDATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = D.SVS_NODE&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.DELETE_FLAG = 'N'    &#xD;&#xA;   AND A.NEED_ACTION = @need_action  &#xD;&#xA; ORDER BY A.SVS_NODE">
            <QP N="factory" />
            <QP N="need_action" />
          </QY>
        </SG>
      </F>
      <F _S="811" N="UserHistory">
        <SG _S="814" N="SearchUserHistory">
          <QY P="MsSql" Q="SELECT TRAN_TIME, USER_ID, HIST_SEQ,&#xD;&#xA;       SYSTEM, EVENT_ID, ACTION, HOST_IP, HOST_NAME,&#xD;&#xA;       EVT_H_1, EVT_D_1, EVT_H_2, EVT_D_2, EVT_H_3, EVT_D_3, EVT_H_4, EVT_D_4, EVT_H_5, EVT_D_5, &#xD;&#xA;       EVT_H_6, EVT_D_6, EVT_H_7, EVT_D_7, EVT_H_8, EVT_D_8, EVT_H_9, EVT_D_9, EVT_H_10, EVT_D_10,       &#xD;&#xA;       EVT_H_11, EVT_D_11, EVT_H_12, EVT_D_12, EVT_H_13, EVT_D_13, EVT_H_14, EVT_D_14, EVT_H_15, EVT_D_15, &#xD;&#xA;       EVT_H_16, EVT_D_16, EVT_H_17, EVT_D_17, EVT_H_18, EVT_D_18, EVT_H_19, EVT_D_19, EVT_H_20, EVT_D_20,&#xD;&#xA;       TRAN_COMMENT&#xD;&#xA;  FROM QSECUSRHIS&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND SYSTEM     = @system&#xD;&#xA;   AND USER_ID    = ISNULL(@user_id, USER_ID)&#xD;&#xA;   AND TRAN_TIME &gt;= @tran_from_time&#xD;&#xA;   AND TRAN_TIME &lt;= ISNULL(@tran_to_time, TRAN_TIME)&#xD;&#xA; ORDER BY TRAN_TIME">
            <QP N="factory" />
            <QP N="system" />
            <QP N="user_id" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
        <SG _S="4122" N="SearchUserHistoryPaging">
          <QY P="MsSql" Q="SELECT TRAN_TIME, USER_ID, HIST_SEQ,&#xD;&#xA;       SYSTEM, EVENT_ID, ACTION, HOST_IP, HOST_NAME,&#xD;&#xA;       EVT_H_1, EVT_D_1, EVT_H_2, EVT_D_2, EVT_H_3, EVT_D_3, EVT_H_4, EVT_D_4, EVT_H_5, EVT_D_5, &#xD;&#xA;       EVT_H_6, EVT_D_6, EVT_H_7, EVT_D_7, EVT_H_8, EVT_D_8, EVT_H_9, EVT_D_9, EVT_H_10, EVT_D_10,       &#xD;&#xA;       EVT_H_11, EVT_D_11, EVT_H_12, EVT_D_12, EVT_H_13, EVT_D_13, EVT_H_14, EVT_D_14, EVT_H_15, EVT_D_15, &#xD;&#xA;       EVT_H_16, EVT_D_16, EVT_H_17, EVT_D_17, EVT_H_18, EVT_D_18, EVT_H_19, EVT_D_19, EVT_H_20, EVT_D_20,&#xD;&#xA;       TRAN_COMMENT&#xD;&#xA;  FROM QSECUSRHIS&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND SYSTEM     = @system&#xD;&#xA;   AND USER_ID    = ISNULL(@user_id, USER_ID)&#xD;&#xA;   AND TRAN_TIME &gt;= @tran_from_time&#xD;&#xA;   AND TRAN_TIME &lt;= ISNULL(@tran_to_time, TRAN_TIME)&#xD;&#xA; ORDER BY TRAN_TIME&#xD;&#xA;OFFSET (CONVERT(int, @PAGE_NO)-1) * CONVERT(int, @PAGE_SIZE) ROW FETCH NEXT CONVERT(int, @PAGE_SIZE) ROW ONLY">
            <QP N="factory" />
            <QP N="system" />
            <QP N="user_id" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
            <QP N="PAGE_NO" />
            <QP N="PAGE_SIZE" />
          </QY>
        </SG>
        <SG _S="4123" N="CountUserHistory">
          <QY P="MsSql" Q="SELECT COUNT(*) AS CNT&#xD;&#xA;  FROM QSECUSRHIS&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND SYSTEM     = @system&#xD;&#xA;   AND USER_ID    = ISNULL(@user_id, USER_ID)&#xD;&#xA;   AND TRAN_TIME &gt;= @tran_from_time&#xD;&#xA;   AND TRAN_TIME &lt;= ISNULL(@tran_to_time, TRAN_TIME)">
            <QP N="factory" />
            <QP N="system" />
            <QP N="user_id" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
      </F>
      <F _S="3550" N="ModelingHistory">
        <SG _S="3552" N="SearchModelingHistory">
          <QY P="MsSql" Q="SELECT TRAN_TIME, HIST_SEQ, USER_ID,&#xD;&#xA;       SYSTEM, EVENT_ID, ACTION, HOST_IP, HOST_NAME,&#xD;&#xA;       EVT_H_1, EVT_D_1, EVT_H_2, EVT_D_2, EVT_H_3, EVT_D_3, EVT_H_4, EVT_D_4, EVT_H_5, EVT_D_5, &#xD;&#xA;       EVT_H_6, EVT_D_6, EVT_H_7, EVT_D_7, EVT_H_8, EVT_D_8, EVT_H_9, EVT_D_9, EVT_H_10, EVT_D_10,       &#xD;&#xA;       EVT_H_11, EVT_D_11, EVT_H_12, EVT_D_12, EVT_H_13, EVT_D_13, EVT_H_14, EVT_D_14, EVT_H_15, EVT_D_15, &#xD;&#xA;       EVT_H_16, EVT_D_16, EVT_H_17, EVT_D_17, EVT_H_18, EVT_D_18, EVT_H_19, EVT_D_19, EVT_H_20, EVT_D_20,&#xD;&#xA;       TRAN_COMMENT&#xD;&#xA;  FROM QEESBMLHIS&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND SYSTEM     = @system&#xD;&#xA;   AND USER_ID    = ISNULL(@user_id, USER_ID)&#xD;&#xA;   AND TRAN_TIME &gt;= @tran_from_time&#xD;&#xA;   AND TRAN_TIME &lt;= ISNULL(@tran_to_time, TRAN_TIME)&#xD;&#xA; ORDER BY HIST_SEQ DESC">
            <QP N="factory" />
            <QP N="system" />
            <QP N="user_id" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
        <SG _S="4125" N="SearchModelingHistoryPaging">
          <QY P="MsSql" Q="SELECT TRAN_TIME, HIST_SEQ, USER_ID,&#xD;&#xA;       SYSTEM, EVENT_ID, ACTION, HOST_IP, HOST_NAME,&#xD;&#xA;       EVT_H_1, EVT_D_1, EVT_H_2, EVT_D_2, EVT_H_3, EVT_D_3, EVT_H_4, EVT_D_4, EVT_H_5, EVT_D_5, &#xD;&#xA;       EVT_H_6, EVT_D_6, EVT_H_7, EVT_D_7, EVT_H_8, EVT_D_8, EVT_H_9, EVT_D_9, EVT_H_10, EVT_D_10,       &#xD;&#xA;       EVT_H_11, EVT_D_11, EVT_H_12, EVT_D_12, EVT_H_13, EVT_D_13, EVT_H_14, EVT_D_14, EVT_H_15, EVT_D_15, &#xD;&#xA;       EVT_H_16, EVT_D_16, EVT_H_17, EVT_D_17, EVT_H_18, EVT_D_18, EVT_H_19, EVT_D_19, EVT_H_20, EVT_D_20,&#xD;&#xA;       TRAN_COMMENT&#xD;&#xA;  FROM QEESBMLHIS&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND SYSTEM     = @system&#xD;&#xA;   AND USER_ID    = ISNULL(@user_id, USER_ID)&#xD;&#xA;   AND TRAN_TIME &gt;= @tran_from_time&#xD;&#xA;   AND TRAN_TIME &lt;= ISNULL(@tran_to_time, TRAN_TIME)&#xD;&#xA; ORDER BY HIST_SEQ DESC&#xD;&#xA;OFFSET (CONVERT(int, @PAGE_NO)-1) * CONVERT(int, @PAGE_SIZE) ROW FETCH NEXT CONVERT(int, @PAGE_SIZE) ROW ONLY">
            <QP N="factory" />
            <QP N="system" />
            <QP N="user_id" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
            <QP N="PAGE_NO" />
            <QP N="PAGE_SIZE" />
          </QY>
        </SG>
        <SG _S="4126" N="CountModelingHistory">
          <QY P="MsSql" Q="SELECT COUNT(*) AS CNT&#xD;&#xA;  FROM QEESBMLHIS&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND SYSTEM     = @system&#xD;&#xA;   AND USER_ID    = ISNULL(@user_id, USER_ID)&#xD;&#xA;   AND TRAN_TIME &gt;= @tran_from_time&#xD;&#xA;   AND TRAN_TIME &lt;= ISNULL(@tran_to_time, TRAN_TIME)">
            <QP N="factory" />
            <QP N="system" />
            <QP N="user_id" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
      </F>
      <F _S="4052" N="AlarmEffectLot">
        <SG _S="4053" N="SearchAlarmHistory">
          <QY P="MsSql" Q="WITH BaseData AS (&#xD;&#xA;	SELECT FACTORY, EQP_NAME, ALARM_NAME, ALARM_ID, ALARM_LEVEL, ALARM_TEXT, SET_TIME, CLEAR_TIME&#xA;	  FROM QEESALMHIS&#xA;	 WHERE FACTORY         = @factory&#xA;	   AND EQP_NAME        = @eqp_name&#xA;	   AND HIS_MONTH BETWEEN @from_mohth AND @to_mohth&#xA;	   AND (&#xA;		   -- 기간 내에 발생한 알람&#xA;		   (SET_TIME   &gt;= @from_time AND SET_TIME   &lt;= @to_time)&#xA;		   -- 기간 내에 해제한 알람&#xA;		   OR &#xA;		   (CLEAR_TIME &gt;= @from_time AND CLEAR_TIME &lt;= @to_time)&#xA;		   -- 기간 내에 지속된 알람&#xA;		   OR &#xA;		   (SET_TIME   &lt;= @from_time AND CLEAR_TIME &gt;= @to_time)&#xA;		   )&#xA;)&#xA;SELECT ALM.SET_TIME, ALM.CLEAR_TIME,&#xA;       ISNULL(UNT.UNIT_NAME, 'Unassigned') AS UNIT_NAME,&#xA;       ALM.ALARM_NAME, ALM.ALARM_ID, ALM.ALARM_LEVEL, ALM.ALARM_TEXT&#xA;  FROM BaseData ALM&#xA;  LEFT JOIN QEESALMUNT UNT&#xA;	ON ALM.FACTORY   = UNT.FACTORY &#xA;   AND ALM.EQP_NAME  = UNT.EQP_NAME&#xA;   AND ALM.ALARM_ID  = UNT.ALARM_ID&#xA; ORDER BY ALM.SET_TIME">
            <QP N="factory&#xA;	" />
            <QP N="eqp_name&#xA;	" />
            <QP N="from_mohth" />
            <QP N="to_mohth&#xA;	" />
          </QY>
        </SG>
        <SG _S="4055" N="SearchAlarmHistory_bak">
          <QY P="MsSql" Q="WITH BaseData AS (&#xD;&#xA;	SELECT FACTORY, EQP_NAME, ALARM_NAME, ALARM_ID, ALARM_LEVEL, ALARM_TEXT, SET_TIME, CLEAR_TIME&#xA;	  FROM QEESALMHIS&#xA;	 WHERE FACTORY         = @factory&#xA;	   AND EQP_NAME        = @eqp_name&#xA;	   AND HIS_MONTH BETWEEN @from_mohth AND @to_mohth&#xA;	   AND (&#xA;		   (HIS_MONTH = @from_mohth AND HIS_DAY  &gt;= @from_day) OR&#xA;		   (HIS_MONTH = @to_mohth   AND HIS_DAY  &lt;= @to_day)   OR&#xA;		   (HIS_MONTH &gt; @from_mohth AND HIS_MONTH &lt; @to_mohth)&#xA;		   )&#xA;	   AND (&#xA;		   -- 기간 내에 발생한 알람&#xA;		   (SET_TIME   &gt;= @from_time AND SET_TIME   &lt;= @to_time)&#xA;		   -- 기간 내에 해제한 알람&#xA;		   OR &#xA;		   (CLEAR_TIME &gt;= @from_time AND CLEAR_TIME &lt;= @to_time)&#xA;		   -- 기간 내에 지속된 알람&#xA;		   OR &#xA;		   (SET_TIME   &lt;= @from_time AND CLEAR_TIME &gt;= @to_time)&#xA;		   )&#xA;)&#xA;SELECT ALM.SET_TIME, ALM.CLEAR_TIME,&#xA;       ISNULL(UNT.UNIT_NAME, 'Unassigned') AS UNIT_NAME,&#xA;       ALM.ALARM_NAME, ALM.ALARM_ID, ALM.ALARM_LEVEL, ALM.ALARM_TEXT&#xA;  FROM BaseData ALM&#xA;  LEFT JOIN QEESALMUNT UNT&#xA;	ON ALM.FACTORY   = UNT.FACTORY &#xA;   AND ALM.EQP_NAME  = UNT.EQP_NAME&#xA;   AND ALM.ALARM_ID  = UNT.ALARM_ID&#xD;&#xA; WHERE UNT.UNIT_NAME = ISNULL(@unit_name, UNT.UNIT_NAME)&#xA; ORDER BY ALM.SET_TIME">
            <QP N="factory&#xA;	" />
            <QP N="eqp_name&#xA;	" />
            <QP N="from_mohth" />
            <QP N="to_mohth&#xA;	" />
            <QP N="from_day" />
            <QP N="to_mohth" />
            <QP N="to_day" />
            <QP N="unit_name" />
          </QY>
        </SG>
        <SG _S="4070" N="SearchUnitLotHistory">
          <QY P="MsSql" Q="SELECT LOT_ID, START_TIME, END_TIME&#xA;  FROM QEESULTHIS&#xA; WHERE FACTORY      = @factory&#xA;   AND EQP_NAME     = @eqp_name&#xA;   AND UNIT_NAME    = @unit_name&#xA;   AND (&#xA;	   -- 기간 내에 시작된 LOT&#xA;	   (START_TIME &gt;= @from_time AND START_TIME &lt;= @to_time)&#xA;	   -- 기간 내에 종료된 LOT&#xA;	   OR &#xA;	   (END_TIME   &gt;= @from_time AND END_TIME   &lt;= @to_time)&#xA;	   -- 기간 내에 지속된 LOT&#xA;	   OR &#xA;	   (START_TIME &lt;= @from_time AND END_TIME   &gt;= @to_time)&#xA;	   )&#xA; ORDER BY START_TIME">
            <QP N="factory&#xA;" />
            <QP N="eqp_name&#xA;" />
            <QP N="unit_name&#xA;" />
          </QY>
        </SG>
        <SG _S="4054" N="SearchUnitLotHistory_bak1">
          <QY P="MsSql" Q="WITH UnitStart AS (&#xA;    -- 기간 내에 시작된 LOT&#xA;    SELECT LOT_ID&#xA;      FROM QEESUNTHIS&#xA;     WHERE FACTORY   = @factory&#xA;       AND TRAN_TIME BETWEEN @from_time AND @to_time&#xA;       AND EQP_NAME  = @eqp_name&#xA;       AND UNIT_NAME = @unit_name&#xA;	   AND EVENT_ID  = 'UNIT_START'&#xA;	 GROUP BY LOT_ID&#xA;&#xA;),&#xA;UnitEnd AS (&#xA;    -- 기간 내에 종료된 LOT&#xA;    SELECT LOT_ID&#xA;      FROM QEESUNTHIS&#xA;     WHERE FACTORY   = @factory&#xA;       AND TRAN_TIME BETWEEN @from_time AND @to_time&#xA;       AND EQP_NAME  = @eqp_name&#xA;       AND UNIT_NAME = @unit_name&#xA;	   AND EVENT_ID  = 'UNIT_END'&#xA;	 GROUP BY LOT_ID&#xA;)&#xA;SELECT DISTINCT LOT_ID &#xA;  FROM &#xA;  (&#xA;  SELECT LOT_ID FROM UnitStart&#xA;   UNION ALL&#xA;  SELECT LOT_ID FROM UnitEnd&#xA;  ) AS EffectLotIds" />
        </SG>
        <SG _S="4056" N="SearchUnitLotHistory_bak2">
          <QY P="MsSql" Q="WITH UnitStart AS (&#xA;    -- 기간 내에 시작된 LOT (중복 투입은 최초 투입으로 계산)&#xA;    SELECT LOT_ID, MIN(TRAN_TIME) AS UNIT_START_TIME&#xA;      FROM QEESUNTHIS&#xA;     WHERE FACTORY   = @factory&#xA;       AND TRAN_TIME BETWEEN @from_time AND @to_time&#xA;       AND EQP_NAME  = @eqp_name&#xA;       AND UNIT_NAME = @unit_name&#xA;	   AND EVENT_ID  = 'UNIT_START'&#xA;	 GROUP BY LOT_ID&#xA;&#xA;),&#xA;UnitEnd AS (&#xA;    -- 기간 내에 종료된 LOT (중복 배출은 마지막 배출로 계산)&#xA;    SELECT LOT_ID, MAX(TRAN_TIME) AS UNIT_END_TIME&#xA;      FROM QEESUNTHIS&#xA;     WHERE FACTORY   = @factory&#xA;       AND TRAN_TIME BETWEEN @from_time AND @to_time&#xA;       AND EQP_NAME  = @eqp_name&#xA;       AND UNIT_NAME = @unit_name&#xA;	   AND EVENT_ID  = 'UNIT_END'&#xA;	 GROUP BY LOT_ID&#xA;)&#xA;SELECT S.LOT_ID, S.UNIT_START_TIME, ISNULL(E.UNIT_END_TIME, ' ') AS UNIT_END_TIME&#xA;  FROM UnitStart S&#xA;  LEFT JOIN UnitEnd E&#xA;    ON S.LOT_ID = E.LOT_ID&#xA; ORDER BY S.UNIT_START_TIME;" />
        </SG>
      </F>
      <F _S="4095" N="EquipmentLineLotHistory">
        <SG _S="4096" N="ListLineLotHistory">
          <QY P="MsSql" Q="SELECT LOT_SEQ, S_LOT_ID, P_LOT_ID, TRAN_IN_TIME, TRAN_OUT_TIME&#xD;&#xA;  FROM QEESLLTHIS&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND LINE_NAME    = @line_name&#xD;&#xA;   AND TRAN_IN_TIME BETWEEN @from_time AND @to_time&#xD;&#xA; ORDER BY LOT_SEQ">
            <QP N="factory" />
            <QP N="line_name" />
            <QP N="from_time" />
            <QP N="to_time" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="411" N="SndTransaction">
      <F _S="8095" N="EquipmentEvent">
        <SG _S="8096" N="SearchSnd">
          <QY P="MsSql" Q="SELECT SVS_NODE&#xD;&#xA;  FROM QEESSNDDEF  &#xD;&#xA;  WITH (UPDLOCK)&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SVS_NODE         = @svs_node&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="svs_node" />
          </QY>
        </SG>
        <SG _S="8097" N="SearchEquipment">
          <QY P="MsSql" Q="SELECT A.EQP_NAME, B.COMM_STATE, B.CTRL_MODE&#xD;&#xA;  FROM QEESEQPDEF A&#xD;&#xA;  	LEFT JOIN QRASEQPSTS B&#xD;&#xA;  	ON A.EQP_NAME = B.EQP_NAME&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.EQP_NAME = @eqp_name&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="8099" N="InsertEquipmentHis">
          <QY P="MsSql" Q="INSERT INTO QEESEQPHIS (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   EVENT_ID,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   COMM_STATE,&#xD;&#xA;   CTRL_MODE,&#xD;&#xA;   SVS_NODE,&#xD;&#xA;   SVS_NODE_EVENT_ID,      &#xD;&#xA;   EVT_H_1,&#xD;&#xA;   EVT_D_1,   &#xD;&#xA;   EVT_H_2,&#xD;&#xA;   EVT_D_2,&#xD;&#xA;   EVT_H_3,&#xD;&#xA;   EVT_D_3,&#xD;&#xA;   EVT_H_4,&#xD;&#xA;   EVT_D_4,&#xD;&#xA;   EVT_H_5,&#xD;&#xA;   EVT_D_5,&#xD;&#xA;   EVT_H_6,&#xD;&#xA;   EVT_D_6,&#xD;&#xA;   EVT_H_7,&#xD;&#xA;   EVT_D_7,&#xD;&#xA;   EVT_H_8,&#xD;&#xA;   EVT_D_8,&#xD;&#xA;   EVT_H_9,&#xD;&#xA;   EVT_D_9,&#xD;&#xA;   EVT_H_10,&#xD;&#xA;   EVT_D_10,&#xD;&#xA;   EVT_H_11,&#xD;&#xA;   EVT_D_11,   &#xD;&#xA;   EVT_H_12,&#xD;&#xA;   EVT_D_12,&#xD;&#xA;   EVT_H_13,&#xD;&#xA;   EVT_D_13,&#xD;&#xA;   EVT_H_14,&#xD;&#xA;   EVT_D_14,&#xD;&#xA;   EVT_H_15,&#xD;&#xA;   EVT_D_15,&#xD;&#xA;   EVT_H_16,&#xD;&#xA;   EVT_D_16,&#xD;&#xA;   EVT_H_17,&#xD;&#xA;   EVT_D_17,&#xD;&#xA;   EVT_H_18,&#xD;&#xA;   EVT_D_18,&#xD;&#xA;   EVT_H_19,&#xD;&#xA;   EVT_D_19,&#xD;&#xA;   EVT_H_20,&#xD;&#xA;   EVT_D_20,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT      &#xD;&#xA;) &#xD;&#xA;VALUES( &#xD;&#xA;   @factory,&#xD;&#xA;   @eqp_name,&#xD;&#xA;   @last_his_seq,&#xD;&#xA;   @event_id,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @comm_state,&#xD;&#xA;   @ctrl_mode,&#xD;&#xA;   @svs_node,&#xD;&#xA;   @svs_node_event_id,&#xD;&#xA;   @evt_h_1,&#xD;&#xA;   @evt_d_1,   &#xD;&#xA;   @evt_h_2,&#xD;&#xA;   @evt_d_2,&#xD;&#xA;   @evt_h_3,&#xD;&#xA;   @evt_d_3,&#xD;&#xA;   @evt_h_4,&#xD;&#xA;   @evt_d_4,&#xD;&#xA;   @evt_h_5,&#xD;&#xA;   @evt_d_5,&#xD;&#xA;   @evt_h_6,&#xD;&#xA;   @evt_d_6,&#xD;&#xA;   @evt_h_7,&#xD;&#xA;   @evt_d_7,&#xD;&#xA;   @evt_h_8,&#xD;&#xA;   @evt_d_8,&#xD;&#xA;   @evt_h_9,&#xD;&#xA;   @evt_d_9,&#xD;&#xA;   @evt_h_10,&#xD;&#xA;   @evt_d_10,&#xD;&#xA;   @evt_h_11,&#xD;&#xA;   @evt_d_11,   &#xD;&#xA;   @evt_h_12,&#xD;&#xA;   @evt_d_12,&#xD;&#xA;   @evt_h_13,&#xD;&#xA;   @evt_d_13,&#xD;&#xA;   @evt_h_14,&#xD;&#xA;   @evt_d_14,&#xD;&#xA;   @evt_h_15,&#xD;&#xA;   @evt_d_15,&#xD;&#xA;   @evt_h_16,&#xD;&#xA;   @evt_d_16,&#xD;&#xA;   @evt_h_17,&#xD;&#xA;   @evt_d_17,&#xD;&#xA;   @evt_h_18,&#xD;&#xA;   @evt_d_18,&#xD;&#xA;   @evt_h_19,&#xD;&#xA;   @evt_d_19,&#xD;&#xA;   @evt_h_20,&#xD;&#xA;   @evt_d_20,&#xD;&#xA;   @tran_user_id,&#xD;&#xA;   @tran_comment)">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="last_his_seq" />
            <QP N="event_id" />
            <QP N="tran_time" />
            <QP N="comm_state" />
            <QP N="ctrl_mode" />
            <QP N="svs_node" />
            <QP N="svs_node_event_id" />
            <QP N="evt_h_1" />
            <QP N="evt_d_1" />
            <QP N="evt_h_2" />
            <QP N="evt_d_2" />
            <QP N="evt_h_3" />
            <QP N="evt_d_3" />
            <QP N="evt_h_4" />
            <QP N="evt_d_4" />
            <QP N="evt_h_5" />
