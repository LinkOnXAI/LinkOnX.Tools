        <SG _S="4195" N="ListEquipment">
          <QY P="MsSql" Q="SELECT E.EQP_NAME, E.EQP_DESC,&#xD;&#xA;       ISNULL(S.ACTIVE_VER, 0) AS ACTIVE_VER, ISNULL(S.LAST_VER, 0) AS LAST_VER&#xD;&#xA;  FROM QEESEQPDEF E&#xD;&#xA;  LEFT JOIN QEESEQPSPC S&#xD;&#xA;    ON E.FACTORY     = S.FACTORY&#xD;&#xA;   AND E.EQP_TYPE    = S.EQP_TYPE&#xD;&#xA;   AND E.EQP_NAME    = S.EQP_NAME&#xD;&#xA; WHERE E.FACTORY     = @factory &#xD;&#xA;   AND E.EQP_TYPE    = @eqp_type&#xD;&#xA;   AND E.DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY E.EQP_NAME">
