        <SG _S="4064" N="HasAlarmStatus">
          <QY P="MsSql" Q="SELECT  * &#xD;&#xA;  FROM QEESALMSTS&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;   AND ALARM_NAME = @alarm_name">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="alarm_name" />
          </QY>
        </SG>
        <SG _S="4065" N="HasAlarmStatusRemain">
          <QY P="MsSql" Q="WITH AlarmData AS (&#xD;&#xA;    SELECT COUNT(*) AS ALARM_COUNT&#xD;&#xA;      FROM QEESALMSTS&#xD;&#xA;     WHERE FACTORY     = @factory&#xD;&#xA;       AND EQP_NAME    = @eqp_name&#xD;&#xA;       AND ALARM_NAME != @alarm_name&#xD;&#xA;)&#xD;&#xA;SELECT CASE WHEN ALARM_COUNT &gt; 0 THEN 'Y' ELSE 'N' END AS ALARM,&#xD;&#xA;       CASE WHEN ALARM_COUNT &gt; 0 THEN 'ALARM' ELSE 'IDLE' END AS PROC_STATE&#xD;&#xA;  FROM AlarmData">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="alarm_name" />
          </QY>
        </SG>
        <SG _S="4066" N="HasAlarmHistory">
          <QY P="MsSql" Q="SELECT TOP 1 *, dbo.ToTicks(GETDATE()) AS CUR_TICKS &#xD;&#xA;  FROM QEESALMHIS&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EQP_NAME    = @eqp_name&#xD;&#xA;   AND EVENT_ID    = @event_id&#xD;&#xA;   AND ALARM_STATE = 'S'&#xD;&#xA;   AND ALARM_NAME  = @alarm_name &#xD;&#xA; ORDER BY HIST_SEQ ASC">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="event_id" />
            <QP N="alarm_name" />
          </QY>
        </SG>
