        <SG _S="3572" N="InsertEqpType">
          <QY P="MsSql" Q="INSERT INTO QEESEQPTYP(&#xD;&#xA;   FACTORY,&#xD;&#xA;   EQP_TYPE,&#xD;&#xA;   EQP_TYPE_DESC,&#xD;&#xA;   PROD_COLLECTABLE,&#xD;&#xA;   PROC_MODE,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @eqp_type,&#xD;&#xA;   @eqp_type_desc,&#xD;&#xA;   @prod_collectable,&#xD;&#xA;   @proc_mode,&#xD;&#xA;   @user_id,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @user_id,&#xD;&#xA;   @tran_time&#xD;&#xA;)">
