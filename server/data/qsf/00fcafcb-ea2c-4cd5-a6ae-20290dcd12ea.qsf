        <SG _S="1553" N="SearchSndControllerAtr">
          <QY P="MsSql" Q="SELECT DATA&#xD;&#xA;  FROM QEESSNDCFG&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND SVS_NODE           = @svs_node&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category&#xD;&#xA;   AND OBJ_TYPE      = @obj_type&#xD;&#xA;   AND KEY_NAME      = @eqp_name_key">
            <QP N="factory" />
            <QP N="svs_node" />
            <QP N="attr_category" />
            <QP N="obj_type" />
            <QP N="eqp_name_key" />
          </QY>
        </SG>
        <SG _S="3413" N="InsertSndEquipmentHis">
          <QY P="MsSql" Q="INSERT INTO QEESEQPHIS (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   EVENT_ID,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   COMM_STATE,&#xD;&#xA;   CTRL_MODE,&#xD;&#xA;   SVS_NODE,&#xD;&#xA;   SVS_NODE_EVENT_ID,      &#xD;&#xA;   EVT_H_1,&#xD;&#xA;   EVT_D_1,   &#xD;&#xA;   EVT_H_2,&#xD;&#xA;   EVT_D_2,&#xD;&#xA;   EVT_H_3,&#xD;&#xA;   EVT_D_3,&#xD;&#xA;   EVT_H_4,&#xD;&#xA;   EVT_D_4,&#xD;&#xA;   EVT_H_5,&#xD;&#xA;   EVT_D_5,&#xD;&#xA;   EVT_H_6,&#xD;&#xA;   EVT_D_6,&#xD;&#xA;   EVT_H_7,&#xD;&#xA;   EVT_D_7,&#xD;&#xA;   EVT_H_8,&#xD;&#xA;   EVT_D_8,&#xD;&#xA;   EVT_H_9,&#xD;&#xA;   EVT_D_9,&#xD;&#xA;   EVT_H_10,&#xD;&#xA;   EVT_D_10,&#xD;&#xA;   EVT_H_11,&#xD;&#xA;   EVT_D_11,   &#xD;&#xA;   EVT_H_12,&#xD;&#xA;   EVT_D_12,&#xD;&#xA;   EVT_H_13,&#xD;&#xA;   EVT_D_13,&#xD;&#xA;   EVT_H_14,&#xD;&#xA;   EVT_D_14,&#xD;&#xA;   EVT_H_15,&#xD;&#xA;   EVT_D_15,&#xD;&#xA;   EVT_H_16,&#xD;&#xA;   EVT_D_16,&#xD;&#xA;   EVT_H_17,&#xD;&#xA;   EVT_D_17,&#xD;&#xA;   EVT_H_18,&#xD;&#xA;   EVT_D_18,&#xD;&#xA;   EVT_H_19,&#xD;&#xA;   EVT_D_19,&#xD;&#xA;   EVT_H_20,&#xD;&#xA;   EVT_D_20,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT      &#xD;&#xA;) &#xD;&#xA;VALUES( &#xD;&#xA;   @factory,&#xD;&#xA;   @eqp_name,&#xD;&#xA;   @last_his_seq,&#xD;&#xA;   @event_id,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @comm_state,&#xD;&#xA;   @ctrl_mode,&#xD;&#xA;   @svs_node,&#xD;&#xA;   @svs_node_event_id,&#xD;&#xA;   @evt_h_1,&#xD;&#xA;   @evt_d_1,   &#xD;&#xA;   @evt_h_2,&#xD;&#xA;   @evt_d_2,&#xD;&#xA;   @evt_h_3,&#xD;&#xA;   @evt_d_3,&#xD;&#xA;   @evt_h_4,&#xD;&#xA;   @evt_d_4,&#xD;&#xA;   @evt_h_5,&#xD;&#xA;   @evt_d_5,&#xD;&#xA;   @evt_h_6,&#xD;&#xA;   @evt_d_6,&#xD;&#xA;   @evt_h_7,&#xD;&#xA;   @evt_d_7,&#xD;&#xA;   @evt_h_8,&#xD;&#xA;   @evt_d_8,&#xD;&#xA;   @evt_h_9,&#xD;&#xA;   @evt_d_9,&#xD;&#xA;   @evt_h_10,&#xD;&#xA;   @evt_d_10,&#xD;&#xA;   @evt_h_11,&#xD;&#xA;   @evt_d_11,   &#xD;&#xA;   @evt_h_12,&#xD;&#xA;   @evt_d_12,&#xD;&#xA;   @e