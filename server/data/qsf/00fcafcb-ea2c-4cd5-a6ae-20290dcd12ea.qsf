        <SG _S="4019" N="HasEquipmentUnit">
          <QY P="MsSql" Q="SELECT UNIT_SEQ, UNIT_NAME, UNIT_DESC, QUALITY_COLLECTABLE&#xD;&#xA;  FROM QEESEQPUNT&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND EQP_NAME  = @eqp_name&#xD;&#xA;   AND UNIT_NAME = @unit_name">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="unit_name" />
          </QY>
        </SG>
        <SG _S="3981" N="InsertEquipmentUnit">
          <QY P="MsSql" Q="INSERT INTO QEESEQPUNT (&#xD;&#xA;   FACTORY,&#xD;&#xA;   UNIT_SEQ,&#xD;&#xA;   UNIT_NAME,&#xD;&#xA;   UNIT_DESC,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   QUALITY_COLLECTABLE,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @unit_seq,&#xD;&#xA;   @unit_name,&#xD;&#xA;   @unit_desc,&#xD;&#xA;   @eqp_name,&#xD;&#xA;   @quality_collectable,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="unit_seq" />
            <QP N="unit_name" />
            <QP N="unit_desc" />
            <QP N="eqp_name" />
            <QP N="quality_collectable" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
