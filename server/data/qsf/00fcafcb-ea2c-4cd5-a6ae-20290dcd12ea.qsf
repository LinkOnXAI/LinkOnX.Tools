      <F _S="4150" N="EQTParameterSpec">
        <SG _S="4151" N="ListVersion">
          <QY P="MsSql" Q="WITH VersionData AS (&#xD;&#xA;  SELECT FACTORY, SPEC_VER, SPEC_VER_DESC, ACTIVE, CREATE_TIME, CREATE_USER_ID, UPDATE_TIME, UPDATE_USER_ID&#xD;&#xA;    FROM QEESEQTSVR&#xA;   WHERE FACTORY     = @factory &#xA;     AND EQP_TYPE    = @eqp_type&#xA;	 AND DELETE_FLAG = 'N'&#xA;)&#xA;SELECT VER.SPEC_VER, VER.SPEC_VER_DESC, VER.ACTIVE, &#xA;       VER.CREATE_TIME, CASE WHEN USER_C.USER_NAME IS NULL THEN VER.CREATE_USER_ID ELSE CONCAT(VER.CREATE_USER_ID, ' [', USER_C.USER_NAME, ']') END AS CREATE_USER , &#xD;&#xA;	   VER.UPDATE_TIME, CASE WHEN USER_U.USER_NAME IS NULL THEN VER.UPDATE_USER_ID ELSE CONCAT(VER.UPDATE_USER_ID, ' [', USER_U.USER_NAME, ']') END AS UPDATE_USER&#xA;  FROM VersionData VER&#xA;  LEFT JOIN QSECUSRDEF USER_C&#xA;    ON VER.FACTORY        = USER_C.FACTORY&#xA;   AND VER.CREATE_USER_ID = USER_C.USER_ID&#xA;  LEFT JOIN QSECUSRDEF USER_U&#xA;    ON VER.FACTORY        = USER_U.FACTORY&#xA;   AND VER.UPDATE_USER_ID = USER_U.USER_ID&#xD;&#xA; ORDER BY VER.SPEC_VER DESC">
            <QP N="factory" />
            <QP N="eqp_type&#xA;	" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="4153" N="ListEquipmentType">
          <QY P="MsSql" Q="SELECT T.EQP_TYPE, T.EQP_TYPE_DESC, &#xD;&#xA;       ISNULL(S.ACTIVE_VER, 0) AS ACTIVE_VER, ISNULL(S.LAST_VER, 0) AS LAST_VER&#xD;&#xA;  FROM QEESEQPTYP T&#xD;&#xA;  LEFT JOIN QEESEQTSPC S&#xD;&#xA;    ON T.FACTORY     = S.FACTORY&#xD;&#xA;   AND T.EQP_TYPE    = S.EQP_TYPE&#xD;&#xA; WHERE T.FACTORY     = @factory &#xD;&#xA;   AND T.DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY T.EQP_TYPE">
            <QP N="factory" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="4152" N="ListVersionParam">
          <QY P="MsSql" Q="WITH BaseData AS (&#xA;	SELECT FACTORY, EQP_TYPE, PARA_ID, PARA_CATEGORY, PARA_FORMAT, PARA_VALIDATION_RULE, PARA_TARGET_VALUE, PARA_USL, PARA_UCL, PARA_LCL, PARA_LSL&#xA;	  FROM QEESEQTSVP&#xA;	 WHERE FACTORY  = @factory &#xA;	   AND EQP_TYPE = @eqp_type&#xA;	   AND SPEC_VER = @spec_ver&#xA;   )&#xA;SELECT DAT.PARA_ID, ISNULL(PAR.PARA_DESC, '') AS PARA_DESC,&#xA;       DAT.PARA_CATEGORY, DAT.PARA_FORMAT,&#xA;	   DAT.PARA_VALIDATION_RULE, DAT.PARA_TARGET_VALUE, DAT.PARA_USL, DAT.PARA_UCL, DAT.PARA_LCL, DAT.PARA_LSL&#xA;  FROM BaseData DAT&#xA;  LEFT JOIN QEESPARDEF PAR&#xA;    ON DAT.FACTORY  = PAR.FACTORY&#xA;   AND DAT.EQP_TYPE = PAR.EQP_TYPE&#xA;   AND DAT.PARA_ID  = PAR.PARA_ID&#xD;&#xA; ORDER BY DAT.PARA_ID">
            <QP N="factory" />
            <QP N="eqp_type&#xA;	" />
            <QP N="spec_ver&#xA;" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="4160" N="ListVersionParamPaging">
          <QY P="MsSql" Q="WITH BaseData AS (&#xA;	SELECT FACTORY, EQP_TYPE, PARA_ID, PARA_CATEGORY, PARA_FORMAT, PARA_VALIDATION_RULE, PARA_TARGET_VALUE, PARA_USL, PARA_UCL, PARA_LCL, PARA_LSL&#xA;	  FROM QEESEQTSVP&#xA;	 WHERE FACTORY  = @factory &#xA;	   AND EQP_TYPE = @eqp_type&#xA;	   AND SPEC_VER = @spec_ver    &#xA;   )&#xA;SELECT DAT.PARA_ID, ISNULL(PAR.PARA_DESC, '') AS PARA_DESC,&#xA;       DAT.PARA_CATEGORY, DAT.PARA_FORMAT,&#xA;	   DAT.PARA_VALIDATION_RULE, DAT.PARA_TARGET_VALUE, DAT.PARA_USL, DAT.PARA_UCL, DAT.PARA_LCL, DAT.PARA_LSL&#xA;  FROM BaseData DAT&#xA;  LEFT JOIN QEESPARDEF PAR&#xA;    ON DAT.FACTORY  = PAR.FACTORY&#xA;   AND DAT.EQP_TYPE = PAR.EQP_TYPE&#xA;   AND DAT.PARA_ID  = PAR.PARA_ID&#xD;&#xA; ORDER BY DAT.PARA_ID&#xD;&#xA;OFFSET (CONVERT(int, @PAGE_NO)-1) * CONVERT(int, @PAGE_SIZE) ROW FETCH NEXT CONVERT(int, @PAGE_SIZE) ROW ONLY">
            <QP N="factory" />
            <QP N="eqp_type&#xA;	" />
            <QP N="spec_ver" />
            <QP N="PAGE_NO" />
            <QP N="PAGE_SIZE" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
