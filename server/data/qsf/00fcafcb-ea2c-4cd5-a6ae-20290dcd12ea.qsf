            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="unit_name" />
          </QY>
        </SG>
        <SG _S="4018" N="UpdateEquipmentUnitWithoutSeq">
          <QY P="MsSql" Q="UPDATE QEESEQPUNT SET&#xD;&#xA;   UNIT_DESC            = @unit_desc,&#xD;&#xA;   QUALITY_COLLECTABLE  = @quality_collectable,&#xD;&#xA;   UPDATE_USER_ID       = @update_user_id,&#xD;&#xA;   UPDATE_TIME          = @update_time&#xD;&#xA; WHERE FACTORY          = @factory&#xD;&#xA;   AND EQP_NAME         = @eqp_name&#xD;&#xA;   AND UNIT_NAME        = @unit_name">
            <QP N="unit_desc" />
