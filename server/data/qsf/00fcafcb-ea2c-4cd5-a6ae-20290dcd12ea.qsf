        <SG _S="3928" N="HasContainerAtr">
          <QY P="MsSql" Q="SELECT CTN_NAME, PACKAGE, PKG_VER&#xD;&#xA;  FROM QEESCTNATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND CTN_NAME       = @ctn_name&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="ctn_name" />
            <QP N="attr_category" />
          </QY>
        </SG>
        <SG _S="3942" N="HasPackageVer">
          <QY P="MsSql" Q="SELECT PACKAGE&#xD;&#xA;  FROM QEESCPGVER&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND PACKAGE = @package&#xD;&#xA;   AND PKG_VER = @pkg_ver">
            <QP N="factory" />
            <QP N="package" />
            <QP N="pkg_ver" />
          </QY>
        </SG>
        <SG _S="3864" N="ListContainer">
          <QY P="MsSql" Q="SELECT A.CTN_NAME, A.CTN_DESC, A.STEP, A.UP_DOWN, A.ALARM, A.NEED_ACTION, A.NEXT_NEED_ACTION,  ISNULL(B.PACKAGE, 'N/A')  SET_PACKAGE,  ISNULL(B.PKG_VER, 0) SET_PKG_VER, ISNULL(C.PACKAGE, 'N/A') REL_PACKAGE, ISNULL(C.PKG_VER, 0) REL_PKG_VER, ISNULL(D.PACKAGE, 'N/A') APL_PACKAGE, ISNULL(D.PKG_VER, 0) APL_PKG_VER, LAST_EVENT_ID&#xD;&#xA;  FROM QEESCTNDEF A&#xD;&#xA;  LEFT JOIN QEESCTNATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.CTN_NAME    = B.CTN_NAME&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QEESCTNATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.CTN_NAME    = C.CTN_NAME&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QEESCTNATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.CTN_NAME    = D.CTN_NAME&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'&#xD;&#xA; ORDER BY A.CTN_NAME">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3865" N="SearchContainer">
          <QY P="MsSql" Q="SELECT A.CTN_NAME, A.CTN_DESC, A.STEP,  B.PACKAGE, B.PKG_VER&#xD;&#xA;  FROM QEESCTNDEF A&#xD;&#xA;  LEFT JOIN QEESCTNATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.CTN_NAME    = B.CTN_NAME&#xD;&#xA;   AND B.ATTR_CATEGORY = @attr_category&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.CTN_NAME       = @ctn_name&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="attr_category" />
            <QP N="factory" />
            <QP N="ctn_name" />
          </QY>
        </SG>
        <SG _S="3866" N="InsertContainer">
          <QY P="MsSql" Q="INSERT INTO QEESCTNDEF (&#xD;&#xA;   FACTORY,&#xD;&#xA;   CTN_NAME,&#xD;&#xA;   CTN_DESC,  &#xD;&#xA;   STEP,&#xD;&#xA;   UP_DOWN,&#xD;&#xA;   STATUS,&#xD;&#xA;   NEED_ACTION,&#xD;&#xA;   NEXT_NEED_ACTION,&#xD;&#xA;   ALARM,&#xD;&#xA;   LAST_EVENT_ID,&#xD;&#xA;   LAST_EVENT_TIME,&#xD;&#xA;   LAST_HIST_SEQ,&#xD;&#xA;   DELETE_FLAG,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @ctn_name,&#xD;&#xA;   @ctn_desc,&#xD;&#xA;   @step,&#xD;&#xA;   @up_down,&#xD;&#xA;   @status,&#xD;&#xA;   @need_action,&#xD;&#xA;   @next_need_action,&#xD;&#xA;   @alarm,&#xD;&#xA;   @last_event_id,&#xD;&#xA;   @last_event_time,&#xD;&#xA;   @last_hist_seq,&#xD;&#xA;   @delete_flag,   &#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="ctn_name" />
            <QP N="ctn_desc" />
            <QP N="step" />
            <QP N="up_down" />
            <QP N="status" />
            <QP N="need_action" />
            <QP N="next_need_action" />
            <QP N="alarm" />
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="last_hist_seq" />
            <QP N="delete_flag" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
