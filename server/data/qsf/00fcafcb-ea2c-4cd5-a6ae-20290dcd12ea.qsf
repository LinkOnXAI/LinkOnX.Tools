        <SG _S="4202" N="UpdateVersion">
          <QY P="MsSql" Q="UPDATE QEESEQPSVR SET &#xD;&#xA;    ACTIVE          = @active,&#xD;&#xA;    SPEC_VER_DESC   = @spec_ver_desc,&#xD;&#xA;    UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;    UPDATE_TIME     = @update_time&#xD;&#xA;WHERE FACTORY       = @factory &#xD;&#xA;  AND EQP_TYPE      = @eqp_type &#xD;&#xA;  AND EQP_NAME      = @eqp_name&#xD;&#xA;  AND SPEC_VER      = @spec_ver">
            <QP N="active" />
            <QP N="spec_ver_desc" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eqp_type" />
