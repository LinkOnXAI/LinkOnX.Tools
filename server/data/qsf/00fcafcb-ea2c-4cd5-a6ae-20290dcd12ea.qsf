          <QY P="MsSql" Q="SELECT * FROM QEESCTNDEF &#xD;&#xA;WHERE FACTORY = @factory&#xD;&#xA;AND CTN_NAME = @ctn_name&#xD;&#xA;AND DELETE_FLAG &lt;&gt; 'Y'">
            <QP N="factory" />
