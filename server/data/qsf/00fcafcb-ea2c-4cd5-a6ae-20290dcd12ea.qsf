      <F _S="4041" N="AlarmClear">
        <SG _S="4042" N="HasEquipment">
          <QY P="MsSql" Q="SELECT  EQP_TYPE &#xD;&#xA;  FROM QEESEQPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EQP_NAME    = @eqp_name&#xD;&#xA;   AND DELETE_FLAG = 'N' ">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="4043" N="HasAlarm">
          <QY P="MsSql" Q="SELECT ALM.* &#xD;&#xA;  FROM QEESALMDEF ALM&#xD;&#xA; INNER JOIN QEESEQPDEF EQP&#xD;&#xA;    ON ALM.FACTORY     = EQP.FACTORY&#xD;&#xA;   AND ALM.EQP_TYPE    = EQP.EQP_TYPE&#xD;&#xA; WHERE ALM.FACTORY     = @factory&#xD;&#xA;   AND EQP.EQP_NAME    = @eqp_name&#xD;&#xA;   AND ALM.PLC_ADDRESS = @plc_address&#xD;&#xA;   AND ALM.DELETE_FLAG = 'N'&#xD;&#xA;">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="plc_address" />
          </QY>
        </SG>
        <SG _S="4044" N="HasEquipmentStatus">
          <QY P="MsSql" Q="SELECT  * &#xD;&#xA;  FROM QEESEQPSTS&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EQP_NAME = @eqp_name">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="4045" N="HasAlarmStatus">
          <QY P="MsSql" Q="SELECT  * &#xD;&#xA;  FROM QEESALMSTS&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;   AND ALARM_NAME = @alarm_name">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="alarm_name" />
          </QY>
        </SG>
        <SG _S="4046" N="HasAlarmStatusRemain">
          <QY P="MsSql" Q="WITH AlarmData AS (&#xD;&#xA;    SELECT COUNT(*) AS ALARM_COUNT&#xD;&#xA;      FROM QEESALMSTS&#xD;&#xA;     WHERE FACTORY     = @factory&#xD;&#xA;       AND EQP_NAME    = @eqp_name&#xD;&#xA;       AND ALARM_NAME != @alarm_name&#xD;&#xA;)&#xD;&#xA;SELECT CASE WHEN ALARM_COUNT &gt; 0 THEN 'Y' ELSE 'N' END AS ALARM,&#xD;&#xA;       CASE WHEN ALARM_COUNT &gt; 0 THEN 'ALARM' ELSE 'IDLE' END AS PROC_STATE&#xD;&#xA;  FROM AlarmData">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="alarm_name" />
          </QY>
        </SG>
      </F>
      <F _S="3686" N="BaseNodeRelease">
