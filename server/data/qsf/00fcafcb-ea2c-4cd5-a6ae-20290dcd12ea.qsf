        <SG _S="4002" N="DeleteEquipmentUnit">
          <QY P="MsSql" Q="DELETE &#xD;&#xA;  FROM QEESEQPUNT&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND EQP_NAME  = @eqp_name&#xD;&#xA;   AND UNIT_NAME = @unit_name">
