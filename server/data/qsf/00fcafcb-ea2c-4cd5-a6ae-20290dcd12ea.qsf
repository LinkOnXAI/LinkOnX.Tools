          </QY>
        </SG>
        <SG _S="4075" N="DeleteUnitLotStatus">
          <QY P="MsSql" Q="DELETE  &#xD;&#xA;  FROM QEESULTSTS&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND EQP_NAME  = @eqp_name&#xD;&#xA;   AND UNIT_NAME = @unit_name&#xD;&#xA;   AND LOT_ID    = @lot_id">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="unit_name" />
            <QP N="lot_id" />
          </QY>
        </SG>
        <SG _S="4076" N="InsertUnitLotHistory">
          <QY P="MsSql" Q="INSERT INTO QEESULTHIS (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   UNIT_NAME,&#xD;&#xA;   LOT_ID,&#xD;&#xA;   START_TIME,&#xD;&#xA;   HIS_MONTH,&#xD;&#xA;   HIS_DAY,&#xD;&#xA;   START_TICKS,&#xD;&#xA;   END_TIME,&#xD;&#xA;   END_TICKS,&#xD;&#xA;   HIS_PERIOD,&#xD;&#xA;   RECIPE_ID,&#xD;&#xA;   END_FLAG,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT      &#xD;&#xA;) &#xD;&#xA;VALUES( &#xD;&#xA;   @factory,&#xD;&#xA;   @eqp_name,&#xD;&#xA;   @unit_name,&#xD;&#xA;   @lot_id,&#xD;&#xA;   @start_time,&#xD;&#xA;   @his_month,   &#xD;&#xA;   @his_day,&#xD;&#xA;   @start_ticks,   &#xD;&#xA;   @end_time,&#xD;&#xA;   @end_ticks,&#xD;&#xA;   @his_period,&#xD;&#xA;   @recipe_id,&#xD;&#xA;   'Y',&#xD;&#xA;   @user_id,&#xD;&#xA;   @tran_comment)">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="unit_name" />
            <QP N="lot_id" />
            <QP N="start_time" />
            <QP N="his_month" />
            <QP N="his_day" />
            <QP N="start_ticks" />
            <QP N="end_time" />
            <QP N="end_ticks" />
            <QP N="his_period" />
            <QP N="recipe_id" />
            <QP N="user_id" />
            <QP N="tran_comment" />
          </QY>
        </SG>
        <SG _S="4077" N="InsertUnitHistory">
          <QY P="MsSql" Q="INSERT INTO QEESUNTHIS (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   UNIT_NAME,&#xD;&#xA;   EVENT_ID,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   HIS_MONTH,&#xD;&#xA;   HIS_DAY,&#xD;&#xA;   HIS_TICKS,&#xD;&#xA;   LOT_ID,&#xD;&#xA;   RECIPE_ID,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT      &#xD;&#xA;) &#xD;&#xA;VALUES( &#xD;&#xA;   @factory,&#xD;&#xA;   @eqp_name,&#xD;&#xA;   @unit_name,&#xD;&#xA;   @event_id,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @his_month,   &#xD;&#xA;   @his_day,&#xD;&#xA;   @his_ticks,&#xD;&#xA;   @lot_id,&#xD;&#xA;   @recipe_id,&#xD;&#xA;   @user_id,&#xD;&#xA;   @tran_comment)">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="unit_name" />
            <QP N="event_id" />
            <QP N="tran_time" />
            <QP N="his_month" />
            <QP N="his_day" />
            <QP N="his_ticks" />
            <QP N="lot_id" />
            <QP N="recipe_id" />
            <QP N="user_id" />
            <QP N="tran_comment" />
          </QY>
        </SG>
      </F>
      <F _S="4089" N="ManualLineLotControl">
        <SG _S="4090" N="HasLotStatus">
          <QY P="MsSql" Q="SELECT S_LOT_ID, P_LOT_ID, CURRENT_EQP_NAME, CREATE_TIME&#xA;  FROM QEESLOTSTS&#xA; WHERE FACTORY   = @factory&#xA;   AND LINE_NAME = @line_name&#xA;   AND LOT_SEQ   = @lot_seq">
            <QP N="factory&#xA;" />
            <QP N="line_name&#xA;" />
            <QP N="lot_seq" />
          </QY>
        </SG>
        <SG _S="4094" N="InsertLineLotHistory">
          <QY P="MsSql" Q="INSERT INTO QEESLLTHIS (&#xD;&#xA;   FACTORY,&#xD;&#xA;   LINE_NAME,&#xD;&#xA;   LOT_SEQ,&#xD;&#xA;   S_LOT_ID,&#xD;&#xA;   P_LOT_ID,&#xD;&#xA;   TRAN_IN_TIME,&#xD;&#xA;   TRAN_OUT_TIME,&#xD;&#xA;   TRAN_COMMENT&#xD;&#xA;   ) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @line_name,&#xD;&#xA;   @lot_seq,&#xD;&#xA;   @s_lot_id,&#xD;&#xA;   @p_lot_id,&#xD;&#xA;   @tran_in_time,&#xD;&#xA;   @tran_out_time,&#xD;&#xA;   @tran_comment&#xD;&#xA;   )">
            <QP N="factory" />
            <QP N="line_name" />
            <QP N="lot_seq" />
            <QP N="s_lot_id" />
            <QP N="p_lot_id" />
            <QP N="tran_in_time" />
            <QP N="tran_out_time" />
            <QP N="tran_comment" />
          </QY>
        </SG>
        <SG _S="4091" N="HasLotStatusDetail">
          <QY P="MsSql" Q="SELECT EQP_SEQ, EQP_NAME, PROC_MODE, PROD_COLLECTABLE,&#xA;	   UNIT_SEQ, UNIT_NAME, QUALITY_COLLECTABLE, PASS_CONDITION, &#xA;	   PROD_TRAN_TIME, PROD_STATUS, QUALITY_TRAN_TIME, QUALITY_STATUS,&#xA;	   CREATE_TIME, CREATE_USER_ID, UPDATE_TIME, UPDATE_USER_ID&#xA;  FROM QEESLOTSTSDTL&#xA; WHERE FACTORY   = @factory&#xA;   AND LINE_NAME = @line_name&#xA;   AND LOT_SEQ   = @lot_seq">
            <QP N="factory&#xA;" />
            <QP N="line_name&#xA;" />
            <QP N="lot_seq" />
          </QY>
        </SG>
        <SG _S="4092" N="DeleteLotStatusDetail">
          <QY P="MsSql" Q="DELETE&#xD;&#xA;  FROM QEESLOTSTSDTL&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND LINE_NAME  = @line_name&#xD;&#xA;   AND LOT_SEQ    = @lot_seq">
            <QP N="factory" />
            <QP N="line_name" />
            <QP N="lot_seq" />
          </QY>
        </SG>
        <SG _S="4093" N="DeleteLotStatus">
          <QY P="MsSql" Q="DELETE&#xD;&#xA;  FROM QEESLOTSTS&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND LINE_NAME  = @line_name&#xD;&#xA;   AND LOT_SEQ    = @lot_seq">
            <QP N="factory" />
            <QP N="line_name" />
            <QP N="lot_seq" />
          </QY>
        </SG>
      </F>
      <F _S="4108" N="EquipmentInterlockModeSwitch">
        <SG _S="4109" N="HasEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME &#xD;&#xA;  FROM QEESEQPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EQP_NAME    = @eqp_name&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="4110" N="UpdateEquipment">
          <QY P="MsSql" Q="UPDATE QEESEQPDEF SET&#xD;&#xA;   ITL_MODE        = @itl_mode,&#xD;&#xA;   UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;   UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EQP_NAME    = @eqp_name">
            <QP N="itl_mode" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="688" N="View">
      <F _S="2583" N="SndSchemaSearch">
        <SG _S="2584" N="SearchSnd">
          <QY P="MsSql" Q="SELECT SVS_NODE&#xD;&#xA;  FROM QEESSNDDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SVS_NODE         = @svs_node&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="svs_node" />
          </QY>
        </SG>
        <SG _S="3139" N="SearchSndAtr">
          <QY P="MsSql" Q="SELECT SVS_NODE_SCHEMA&#xD;&#xA;  FROM QEESSNDATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND SVS_NODE           = @svs_node&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="svs_node" />
            <QP N="attr_category" />
          </QY>
        </SG>
        <SG _S="3141" N="SearchConnectorSts">
          <QY P="MsSql" Q="SELECT CNT_SEQ, CNT_NAME, STATE&#xD;&#xA;  FROM QEESSNDCTS&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND SVS_NODE     = @svs_node">
            <QP N="factory" />
            <QP N="svs_node" />
          </QY>
        </SG>
        <SG _S="3140" N="SearchController">
          <QY P="MsSql" Q="SELECT CTRL_NAME, COMM_STATE, CTRL_MODE&#xD;&#xA;  FROM QEESSNDCTL&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND CTRL_NAME IN&#xD;&#xA;  (&#xD;&#xA;	SELECT DATA&#xD;&#xA;	  FROM QEESSNDCFG&#xD;&#xA;	 WHERE FACTORY       = @factory&#xD;&#xA;	   AND SVS_NODE           = @svs_node&#xD;&#xA;	   AND ATTR_CATEGORY = @attr_category&#xD;&#xA;	   AND OBJ_TYPE      = @obj_type&#xD;&#xA;	   AND KEY_NAME      = @key_eqp_name&#xD;&#xA;   )">
            <QP N="factory" />
            <QP N="svs_node" />
            <QP N="attr_category" />
            <QP N="obj_type" />
            <QP N="key_eqp_name" />
          </QY>
        </SG>
      </F>
      <F _S="3708" N="BndSchemaSearch">
        <SG _S="3710" N="SearchBnd">
          <QY P="MsSql" Q="SELECT NODE_NAME&#xD;&#xA;  FROM QEESBNDDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND NODE_NAME = @node_name&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="node_name" />
          </QY>
        </SG>
        <SG _S="3711" N="SearchBndAtr">
          <QY P="MsSql" Q="SELECT NODE_SCHEMA&#xD;&#xA;  FROM QEESBNDATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND NODE_NAME           = @node_name&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="node_name" />
            <QP N="attr_category" />
          </QY>
        </SG>
        <SG _S="3712" N="SearchBndConnectorSts">
          <QY P="MsSql" Q="SELECT CNT_SEQ, CNT_NAME, STATE&#xD;&#xA;  FROM QEESBNDCTS&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND NODE_NAME  = @node_name">
            <QP N="factory" />
            <QP N="node_name" />
          </QY>
        </SG>
      </F>
      <F _S="2560" N="SndViewer">
        <SG _S="2563" N="ListModel">
          <QY P="MsSql" Q="SELECT A.MODEL, A.MODEL_DESC, B.MODEL_VER, B.MODEL_VER_DESC, B.MODEL_RELEASE&#xD;&#xA;  FROM QEESMDLDEF A&#xD;&#xA;  LEFT JOIN QEESMDLVER B&#xD;&#xA;    ON A.FACTORY = B.FACTORY&#xD;&#xA;   AND A.MODEL   = B.MODEL&#xD;&#xA; WHERE A.FACTORY = @factory&#xD;&#xA; ORDER BY A.MODEL, B.MODEL_VER DESC">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="2565" N="ListSnd">
          <QY P="MsSql" Q="SELECT A.SVS_NODE, A.SVS_NODE_DESC, A.CONTAINER,  A.SVS_NODE_GROUP, A.AUTO_START,  A.STEP, A.UP_DOWN, A.STATUS, A.RELOAD_CNT, A.ALARM, A.NEED_ACTION, A.NEXT_NEED_ACTION,&#xD;&#xA; ISNULL(B.MODEL, 'N/A') SET_MODEL, ISNULL(B.MODEL_VER, 0) SET_MODEL_VER, ISNULL(C.MODEL, 'N/A') REL_MODEL, ISNULL(C.MODEL_VER, 0) REL_MODEL_VER, ISNULL(D.MODEL, 'N/A') APL_MODEL, ISNULL(D.MODEL_VER, 0) APL_MODEL_VER&#xD;&#xA;         FROM QEESSNDDEF A&#xD;&#xA;  LEFT JOIN QEESSNDATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = B.SVS_NODE&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QEESSNDATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = C.SVS_NODE&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QEESSNDATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = D.SVS_NODE&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'    &#xD;&#xA;   AND A.CONTAINER        = ISNULL(@ctn_name, A.CONTAINER) &#xD;&#xA;   AND A.SVS_NODE_GROUP        = ISNULL(@svs_node_group, A.SVS_NODE_GROUP) &#xD;&#xA;   AND ( &#xD;&#xA;       (B.MODEL        = ISNULL(@model, B.MODEL) AND B.MODEL_VER = ISNULL(@mdl_ver, B.MODEL_VER))&#xD;&#xA;    OR (C.MODEL        = ISNULL(@model, C.MODEL) AND C.MODEL_VER = ISNULL(@mdl_ver, C.MODEL_VER))&#xD;&#xA;    OR (D.MODEL        = ISNULL(@model, D.MODEL) AND D.MODEL_VER = ISNULL(@mdl_ver, D.MODEL_VER))&#xD;&#xA;       )&#xD;&#xA;  ORDER BY A.SVS_NODE">
            <QP N="factory" />
            <QP N="ctn_name" />
            <QP N="svs_node_group" />
            <QP N="model" />
            <QP N="mdl_ver" />
          </QY>
        </SG>
        <SG _S="3404" N="ListSndGroup">
          <QY P="MsSql" Q="SELECT SVS_NODE_GROUP,&#xD;&#xA;	SVS_NODE_GROUP_DESC&#xD;&#xA;  FROM QEESSNDGRP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY SVS_NODE_GROUP">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3897" N="ListContainer">
          <QY P="MsSql" Q="SELECT CTN_NAME, CTN_DESC, UP_DOWN, ALARM&#xD;&#xA;  FROM QEESCTNDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY CTN_NAME">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="2566" N="SearchSnd">
          <QY P="MsSql" Q="SELECT A.CONTAINER, A.SVS_NODE_GROUP,  B.MODEL FROM QEESSNDDEF A&#xD;&#xA;  LEFT JOIN QEESSNDATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = B.SVS_NODE&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.SVS_NODE           LIKE @svs_node&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'&#xD;&#xA; ORDER BY &#xD;&#xA; (CASE @target&#xD;&#xA;  WHEN 'Container'  THEN A.CONTAINER&#xD;&#xA;  WHEN 'Group'  THEN A.SVS_NODE_GROUP&#xD;&#xA;  WHEN 'Model'   THEN B.MODEL&#xD;&#xA;   END)">
            <QP N="factory" />
            <QP N="svs_node" />
            <QP N="target" />
          </QY>
        </SG>
        <SG _S="2567" N="SearchSndForUpdate">
          <QY P="MsSql" Q="SELECT A.SVS_NODE, A.SVS_NODE_DESC, A.CONTAINER, A.SVS_NODE_GROUP,  A.STEP,&#xD;&#xA;       B.MODEL, B.MODEL_VER&#xD;&#xA;  FROM QEESSNDDEF A&#xD;&#xA;  LEFT JOIN QEESSNDATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = B.SVS_NODE&#xD;&#xA;   AND B.ATTR_CATEGORY = @attr_category&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.SVS_NODE           = @svs_node&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="attr_category" />
            <QP N="factory" />
            <QP N="svs_node" />
          </QY>
        </SG>
        <SG _S="2568" N="SearchSndForClone">
          <QY P="MsSql" Q="SELECT A.CONTAINER, A.SVS_NODE_GROUP,  A.STEP,   B.MODEL, B.MODEL_VER&#xD;&#xA;  FROM QEESSNDDEF A&#xD;&#xA;  LEFT JOIN QEESSNDATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = B.SVS_NODE&#xD;&#xA;   AND B.ATTR_CATEGORY = @attr_category&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.SVS_NODE           = @svs_node&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="attr_category" />
            <QP N="factory" />
            <QP N="svs_node" />
          </QY>
        </SG>
      </F>
      <F _S="3963" N="NodeViewer">
        <SG _S="3965" N="ListSNode">
          <QY P="MsSql" Q="SELECT A.SVS_NODE, A.SVS_NODE_DESC, A.CONTAINER,  A.SVS_NODE_GROUP, A.AUTO_START,  A.STEP, A.UP_DOWN, A.STATUS, A.RELOAD_CNT, A.ALARM, A.NEED_ACTION, A.NEXT_NEED_ACTION,&#xD;&#xA; ISNULL(B.MODEL, 'N/A') SET_MODEL, ISNULL(B.MODEL_VER, 0) SET_MODEL_VER, ISNULL(C.MODEL, 'N/A') REL_MODEL, ISNULL(C.MODEL_VER, 0) REL_MODEL_VER, ISNULL(D.MODEL, 'N/A') APL_MODEL, ISNULL(D.MODEL_VER, 0) APL_MODEL_VER&#xD;&#xA;         FROM QEESSNDDEF A&#xD;&#xA;  LEFT JOIN QEESSNDATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = B.SVS_NODE&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QEESSNDATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = C.SVS_NODE&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QEESSNDATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = D.SVS_NODE&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'    &#xD;&#xA;   AND A.CONTAINER        = ISNULL(@ctn_name, A.CONTAINER) &#xD;&#xA;  ORDER BY A.SVS_NODE">
            <QP N="factory" />
            <QP N="ctn_name" />
          </QY>
        </SG>
        <SG _S="3967" N="ListBNode">
          <QY P="MsSql" Q="SELECT A.NODE_NAME, &#xD;&#xA;A.NODE_DESC, &#xD;&#xA;A.CONTAINER,&#xD;&#xA;A.AUTO_START,&#xD;&#xA;A.STEP, &#xD;&#xA;A.UP_DOWN, &#xD;&#xA;A.STATUS, &#xD;&#xA;A.ALARM, &#xD;&#xA;A.AUTO_RELEASE, &#xD;&#xA;A.NEED_ACTION, &#xD;&#xA;A.NEXT_NEED_ACTION,&#xD;&#xA;ISNULL(B.MODEL, 'N/A') SET_MODEL, &#xD;&#xA;ISNULL(B.MODEL_VER, 0) SET_MODEL_VER, &#xD;&#xA;ISNULL(C.MODEL, 'N/A') REL_MODEL, &#xD;&#xA;ISNULL(C.MODEL_VER, 0) REL_MODEL_VER, &#xD;&#xA;ISNULL(D.MODEL, 'N/A') APL_MODEL, &#xD;&#xA;ISNULL(D.MODEL_VER, 0) APL_MODEL_VER&#xD;&#xA;         FROM QEESBNDDEF A&#xD;&#xA;  LEFT JOIN QEESBNDATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.NODE_NAME           = B.NODE_NAME&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QEESBNDATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.NODE_NAME           = C.NODE_NAME&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QEESBNDATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.NODE_NAME           = D.NODE_NAME&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.CONTAINER        = ISNULL(@ctn_name, A.CONTAINER) &#xD;&#xA;   AND A.DELETE_FLAG   = 'N'&#xD;&#xA;  ORDER BY A.NODE_NAME">
            <QP N="factory" />
            <QP N="ctn_name" />
          </QY>
        </SG>
        <SG _S="3966" N="ListContainer">
          <QY P="MsSql" Q="SELECT CTN_NAME, CTN_DESC, UP_DOWN, ALARM&#xD;&#xA;  FROM QEESCTNDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY CTN_NAME">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="3704" N="BaseNodeViewer">
        <SG _S="3706" N="ListBaseNode">
          <QY P="MsSql" Q="SELECT A.NODE_NAME, &#xD;&#xA;A.NODE_DESC, &#xD;&#xA;A.CONTAINER,&#xD;&#xA;A.AUTO_START,&#xD;&#xA;A.STEP, &#xD;&#xA;A.UP_DOWN, &#xD;&#xA;A.STATUS, &#xD;&#xA;A.ALARM, &#xD;&#xA;A.AUTO_START,&#xD;&#xA;A.AUTO_RELEASE, &#xD;&#xA;A.NEED_ACTION, &#xD;&#xA;A.NEXT_NEED_ACTION,&#xD;&#xA;ISNULL(B.MODEL, 'N/A') SET_MODEL, &#xD;&#xA;ISNULL(B.MODEL_VER, 0) SET_MODEL_VER, &#xD;&#xA;ISNULL(C.MODEL, 'N/A') REL_MODEL, &#xD;&#xA;ISNULL(C.MODEL_VER, 0) REL_MODEL_VER, &#xD;&#xA;ISNULL(D.MODEL, 'N/A') APL_MODEL, &#xD;&#xA;ISNULL(D.MODEL_VER, 0) APL_MODEL_VER&#xD;&#xA;         FROM QEESBNDDEF A&#xD;&#xA;  LEFT JOIN QEESBNDATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.NODE_NAME           = B.NODE_NAME&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QEESBNDATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.NODE_NAME           = C.NODE_NAME&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QEESBNDATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.NODE_NAME           = D.NODE_NAME&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.CONTAINER        = ISNULL(@ctn_name, A.CONTAINER) &#xD;&#xA;   AND A.DELETE_FLAG   = 'N'&#xD;&#xA;  ORDER BY A.NODE_NAME">
            <QP N="factory" />
            <QP N="ctn_name" />
          </QY>
        </SG>
        <SG _S="3954" N="ListContainer">
          <QY P="MsSql" Q="SELECT CTN_NAME, CTN_DESC, UP_DOWN, ALARM&#xD;&#xA;  FROM QEESCTNDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY CTN_NAME">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="3445" N="Report">
        <SG _S="3450" N="ListReport">
          <QY P="MsSql" Q="SELECT RPT_NAME, RPT_DESC, REL_RPT_VER, LAST_RPT_VER&#xD;&#xA;  FROM QEESRPTDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY RPT_NAME">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3453" N="HasReport">
          <QY P="MsSql" Q="SELECT REL_RPT_VER, LAST_RPT_VER&#xD;&#xA;  FROM QEESRPTDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND RPT_NAME = @rpt_name">
            <QP N="factory" />
            <QP N="rpt_name" />
          </QY>
        </SG>
        <SG _S="3454" N="HasReportVer">
          <QY P="MsSql" Q="SELECT RPT_VER_PATH, CREATE_TIME&#xD;&#xA;  FROM QEESRPTVER&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND RPT_NAME  = @rpt_name&#xD;&#xA;   AND RPT_VER  = @rpt_ver">
            <QP N="factory" />
            <QP N="rpt_name" />
            <QP N="rpt_ver" />
          </QY>
        </SG>
      </F>
      <F _S="2600" N="NodeLogList">
        <SG _S="3736" N="HasBaseNode">
          <QY P="MsSql" Q="SELECT NODE_DESC, UP_DOWN, STATUS&#xD;&#xA;  FROM QEESBNDDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND NODE_NAME         = @node_name&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="node_name" />
          </QY>
        </SG>
        <SG _S="3737" N="HasServiceNode">
          <QY P="MsSql" Q="SELECT SVS_NODE_GROUP, UP_DOWN, STATUS&#xD;&#xA;  FROM QEESSNDDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SVS_NODE         = @node_name&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="node_name" />
          </QY>
        </SG>
      </F>
      <F _S="3537" N="NodeLog">
        <SG _S="3738" N="HasServiceNode">
          <QY P="MsSql" Q="SELECT SVS_NODE_GROUP, UP_DOWN, STATUS&#xD;&#xA;  FROM QEESSNDDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SVS_NODE         = @node_name&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="node_name" />
          </QY>
        </SG>
        <SG _S="3740" N="HasBaseNode">
          <QY P="MsSql" Q="SELECT NODE_DESC, UP_DOWN, STATUS&#xD;&#xA;  FROM QEESBNDDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND NODE_NAME         = @node_name&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="node_name" />
          </QY>
        </SG>
      </F>
      <F _S="2604" N="NodeBackupLogList">
        <SG _S="3739" N="HasServiceNode">
          <QY P="MsSql" Q="SELECT SVS_NODE_GROUP, UP_DOWN, STATUS&#xD;&#xA;  FROM QEESSNDDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SVS_NODE         = @node_name&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="node_name" />
          </QY>
        </SG>
        <SG _S="3741" N="HasBaseNode">
          <QY P="MsSql" Q="SELECT NODE_DESC, UP_DOWN, STATUS&#xD;&#xA;  FROM QEESBNDDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND NODE_NAME         = @node_name&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="node_name" />
          </QY>
        </SG>
      </F>
      <F _S="3773" N="ServiceUI">
        <SG _S="3774" N="ListFactory">
          <QY P="MsSql" Q="SELECT FACTORY&#xD;&#xA;  FROM QSYSFACDEF" />
        </SG>
        <SG _S="3775" N="ListBaseNode">
          <QY P="MsSql" Q="SELECT A.NODE_NAME, &#xD;&#xA;A.NODE_DESC, &#xD;&#xA;A.STEP, &#xD;&#xA;A.UP_DOWN, &#xD;&#xA;A.STATUS, &#xD;&#xA;A.ALARM, &#xD;&#xA;A.NEED_ACTION, &#xD;&#xA;A.NEXT_NEED_ACTION,&#xD;&#xA;ISNULL(B.MODEL, 'N/A') SET_MODEL, &#xD;&#xA;ISNULL(B.MODEL_VER, 0) SET_MODEL_VER, &#xD;&#xA;ISNULL(C.MODEL, 'N/A') REL_MODEL, &#xD;&#xA;ISNULL(C.MODEL_VER, 0) REL_MODEL_VER, &#xD;&#xA;ISNULL(D.MODEL, 'N/A') APL_MODEL, &#xD;&#xA;ISNULL(D.MODEL_VER, 0) APL_MODEL_VER&#xD;&#xA;         FROM QEESBNDDEF A&#xD;&#xA;  LEFT JOIN QEESBNDATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.NODE_NAME           = B.NODE_NAME&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QEESBNDATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.NODE_NAME           = C.NODE_NAME&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QEESBNDATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.NODE_NAME           = D.NODE_NAME&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'&#xD;&#xA;  ORDER BY A.NODE_NAME">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3776" N="ListServiceNode">
          <QY P="MsSql" Q="SELECT A.SVS_NODE AS NODE_NAME, &#xD;&#xA;	A.SVS_NODE_DESC AS NODE_DESC, &#xD;&#xA;	A.STEP, &#xD;&#xA;	A.UP_DOWN, &#xD;&#xA;	A.STATUS, &#xD;&#xA;	A.ALARM, &#xD;&#xA;	A.NEED_ACTION, &#xD;&#xA;	A.NEXT_NEED_ACTION,&#xD;&#xA;      ISNULL(B.MODEL, 'N/A') SET_MODEL, &#xD;&#xA;      ISNULL(B.MODEL_VER, 0) SET_MODEL_VER, &#xD;&#xA;      ISNULL(C.MODEL, 'N/A') REL_MODEL, &#xD;&#xA;      ISNULL(C.MODEL_VER, 0) REL_MODEL_VER, &#xD;&#xA;      ISNULL(D.MODEL, 'N/A') APL_MODEL, &#xD;&#xA;      ISNULL(D.MODEL_VER, 0) APL_MODEL_VER&#xD;&#xA;         FROM QEESSNDDEF A&#xD;&#xA;  LEFT JOIN QEESSNDATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = B.SVS_NODE&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QEESSNDATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = C.SVS_NODE&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QEESSNDATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = D.SVS_NODE&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'&#xD;&#xA;  ORDER BY A.SVS_NODE">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="3777" N="AlarmStatus">
        <SG _S="3778" N="SelectAlarmSetList">
          <QY P="MsSql" Q="SELECT EQP_NAME ,ALARM_NAME ,ALARM_ID ,ALARM_LEVEL ,ALARM_TEXT ,SET_TIME,&#xD;&#xA;       DATEDIFF(s, CONVERT([datetime],stuff(stuff(stuff(stuff([SET_TIME],(9),(0),' '),(12),(0),':'),(15),(0),':'),(18),(0),'.')), GETDATE()) AS ELAPSED&#xD;&#xA;  FROM QEESALMSTS&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EQP_NAME  IN &#xD;&#xA;       (&#xD;&#xA;	   SELECT EQP_NAME&#xD;&#xA;         FROM QEESLINEQP&#xD;&#xA;        WHERE FACTORY   = @factory&#xD;&#xA;          AND LINE_NAME = @line_name&#xD;&#xA;          AND EQP_NAME  = ISNULL(@eqp_name, EQP_NAME)&#xD;&#xA;       )&#xD;&#xA; ORDER BY EQP_NAME, ALARM_NAME">
            <QP N="factory" />
            <QP N="line_name" />
            <QP N="eqp_name" />
          </QY>
        </SG>
      </F>
      <F _S="4011" N="UnitLotStatus">
        <SG _S="4012" N="SelectUnitLotList">
          <QY P="MsSql" Q="SELECT A.EQP_NAME, A.UNIT_NAME,&#xD;&#xA;       ISNULL(B.LOT_ID, 'N/A') AS LOT_ID, &#xD;&#xA;       ISNULL(B.START_TIME, 'N/A') AS START_TIME,&#xD;&#xA;       CASE WHEN B.START_TIME IS NOT NULL &#xD;&#xA;	        THEN DATEDIFF(s, CONVERT([datetime],stuff(stuff(stuff(stuff(B.START_TIME,(9),(0),' '),(12),(0),':'),(15),(0),':'),(18),(0),'.')), GETDATE()) &#xD;&#xA;            ELSE 0 END AS ELAPSED&#xD;&#xA;  FROM QEESEQPUNT A&#xD;&#xA;  LEFT JOIN QEESULTSTS B &#xD;&#xA;    ON B.FACTORY   = A.FACTORY&#xD;&#xA;   AND B.EQP_NAME  = A.EQP_NAME&#xD;&#xA;   AND B.UNIT_NAME = A.UNIT_NAME&#xD;&#xA; WHERE A.FACTORY   = @factory&#xD;&#xA;   AND A.EQP_NAME  IN &#xD;&#xA;       (&#xD;&#xA;	   SELECT EQP_NAME&#xD;&#xA;         FROM QEESLINEQP&#xD;&#xA;        WHERE FACTORY   = @factory&#xD;&#xA;          AND LINE_NAME = @line_name&#xD;&#xA;          AND EQP_NAME  = ISNULL(@eqp_name, EQP_NAME)&#xD;&#xA;       )&#xD;&#xA; ORDER BY A.EQP_NAME, A.UNIT_SEQ">
            <QP N="factory" />
            <QP N="line_name" />
            <QP N="eqp_name" />
          </QY>
        </SG>
      </F>
      <F _S="4085" N="LotStatus">
        <SG _S="4086" N="ListEquipmentLineLotStatus">
          <QY P="MsSql" Q="SELECT LOT_SEQ, S_LOT_ID, P_LOT_ID, CURRENT_EQP_NAME, CREATE_TIME,&#xD;&#xA;       DATEDIFF(MINUTE, &#xD;&#xA;			CONVERT([datetime],stuff(stuff(stuff(stuff([CREATE_TIME],(9),(0),' '),(12),(0),':'),(15),(0),':'),(18),(0),'.')), &#xD;&#xA;			GETDATE()) AS ELAPSED&#xD;&#xA;  FROM QEESLOTSTS&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND LINE_NAME = @line_name&#xD;&#xA; ORDER BY LOT_SEQ">
            <QP N="factory" />
            <QP N="line_name" />
          </QY>
        </SG>
        <SG _S="4087" N="ListEquipmentLineLotStatusDetail_bak">
          <QY P="MsSql" Q="SELECT EQP_NAME, PROD_TRAN_TIME, &#xD;&#xA;	   UNIT_NAME, QUALITY_COLLECTABLE, PASS_CONDITION, QUALITY_TRAN_TIME, QUALITY_STATUS&#xD;&#xA;  FROM QEESLOTSTSDTL&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND LINE_NAME = @line_name&#xD;&#xA;   AND LOT_SEQ   = @lot_seq&#xD;&#xA; ORDER BY EQP_SEQ, UNIT_SEQ">
            <QP N="factory" />
            <QP N="line_name" />
            <QP N="lot_seq" />
          </QY>
        </SG>
        <SG _S="4088" N="ListEquipmentLineLotStatusDetail">
          <QY P="MsSql" Q="SELECT DTL.EQP_NAME, DTL.PROC_MODE,&#xD;&#xA;       DTL.UNIT_NAME, UL.START_TIME, UL.END_TIME, &#xD;&#xA;	   DTL.QUALITY_COLLECTABLE, DTL.PASS_CONDITION, DTL.QUALITY_TRAN_TIME, DTL.QUALITY_STATUS&#xD;&#xA;  FROM QEESLOTSTSDTL DTL&#xD;&#xA;  LEFT JOIN QEESULTHIS UL&#xD;&#xA;    ON DTL.FACTORY   = UL.FACTORY&#xD;&#xA;   AND DTL.EQP_NAME  = UL.EQP_NAME&#xD;&#xA;   AND DTL.UNIT_NAME = UL.UNIT_NAME&#xD;&#xA;   AND (&#xD;&#xA;       DTL.S_LOT_ID  = UL.LOT_ID&#xD;&#xA;	OR DTL.P_LOT_ID  = UL.LOT_ID&#xD;&#xA;	   )&#xD;&#xA;   AND UL.START_TIME BETWEEN @from_time AND @to_time&#xD;&#xA; WHERE DTL.FACTORY   = @factory&#xD;&#xA;   AND DTL.LINE_NAME = @line_name&#xD;&#xA;   AND DTL.LOT_SEQ   = @lot_seq&#xD;&#xA; ORDER BY DTL.EQP_SEQ, DTL.UNIT_SEQ">
            <QP N="from_time" />
            <QP N="to_time" />
            <QP N="factory" />
            <QP N="line_name" />
            <QP N="lot_seq" />
          </QY>
        </SG>
      </F>
      <F _S="4130" N="InterlockOverviewer">
        <SG _S="4131" N="ListEquipment">
          <QY P="MsSql" Q="WITH TbLINEQP AS (&#xD;&#xA;    SELECT FACTORY, LINE_NAME, SEQ, EQP_NAME&#xD;&#xA;      FROM QEESLINEQP&#xD;&#xA;     WHERE FACTORY   = @factory&#xD;&#xA;       AND LINE_NAME = @line_name&#xD;&#xA;),&#xD;&#xA;TbEQPDEF AS (&#xD;&#xA;    SELECT D.FACTORY, D.EQP_TYPE, D.EQP_NAME, D.EQP_DESC, D.ITL_MODE&#xD;&#xA;      FROM QEESEQPDEF D&#xD;&#xA;     INNER JOIN TbLINEQP L&#xD;&#xA;        ON D.FACTORY  = L.FACTORY&#xD;&#xA;       AND D.EQP_NAME = L.EQP_NAME&#xD;&#xA;),&#xD;&#xA;-- Event Flow Condition &amp; Interlock&#xD;&#xA;TbEQPEFL AS (&#xD;&#xA;    SELECT E.FACTORY, E.EQP_NAME, &#xD;&#xA;           SUM(CASE WHEN F.USED_TIMEOUT = 'Yes' THEN 1 ELSE 0 END) AS EFL_TIMEOUT,&#xD;&#xA;           SUM(CASE WHEN F.USED_CONDITION = 'Yes' THEN 1 ELSE 0 END) AS EFL_CONDITION&#xD;&#xA;      FROM QEESEQPEFL F&#xD;&#xA;     INNER JOIN TbEQPDEF E&#xD;&#xA;        ON F.FACTORY  = E.FACTORY&#xD;&#xA;       AND F.EQP_NAME = E.EQP_NAME&#xD;&#xA;     GROUP BY E.FACTORY, E.EQP_NAME&#xD;&#xA;),&#xD;&#xA;-- Alarm Condition&#xD;&#xA;TbEQPALM AS (&#xD;&#xA;    SELECT E.FACTORY, E.EQP_NAME, COUNT(A.ALARM_NAME) AS ALM_CONDITION&#xD;&#xA;      FROM QEESEQPALM A&#xD;&#xA;     INNER JOIN TbEQPDEF E&#xD;&#xA;        ON A.FACTORY        = E.FACTORY&#xD;&#xA;	   AND A.EQP_TYPE       = E.EQP_TYPE&#xD;&#xA;       AND A.EQP_NAME       = E.EQP_NAME&#xD;&#xA;     WHERE A.USED_CONDITION = 'Yes'&#xD;&#xA;     GROUP BY E.FACTORY, E.EQP_NAME&#xD;&#xA;),&#xD;&#xA;-- Alarm Interlock&#xD;&#xA;TbEQPAIL AS (&#xD;&#xA;    SELECT E.FACTORY, E.EQP_NAME, COUNT(*) AS ALM_INTERLOCK&#xD;&#xA;      FROM QEESEQPAIL A&#xD;&#xA;     INNER JOIN TbEQPDEF E&#xD;&#xA;        ON A.FACTORY  = E.FACTORY&#xD;&#xA;	   AND A.EQP_TYPE = E.EQP_TYPE&#xD;&#xA;       AND A.EQP_NAME = E.EQP_NAME&#xD;&#xA;     GROUP BY E.FACTORY, E.EQP_NAME&#xD;&#xA;)&#xD;&#xA;SELECT LIN.EQP_NAME, EQP.EQP_DESC, EQP.EQP_TYPE, EQP.ITL_MODE, &#xD;&#xA;	   (CASE WHEN ISNULL(EFL.EFL_CONDITION, 0) &gt; 0 THEN 'Yes' ELSE 'No' END) AS EFL_CONDITION,&#xD;&#xA;       (CASE WHEN ISNULL(EFL.EFL_TIMEOUT, 0) &gt; 0 THEN 'Yes' ELSE 'No' END) AS EFL_TIMEOUT, &#xD;&#xA;	   (CASE WHEN ISNULL(ALM.ALM_CONDITION, 0) &gt; 0 THEN 'Yes' ELSE 'No' END) AS ALM_CONDITION,&#xD;&#xA;	   (CASE WHEN ISNULL(AIL.ALM_INTERLOCK, 0) &gt; 0 THEN 'Yes' ELSE 'No' END) AS ALM_INTERLOCK&#xD;&#xA;  FROM TbLINEQP LIN&#xD;&#xA; INNER JOIN TbEQPDEF EQP&#xD;&#xA;    ON LIN.FACTORY  = EQP.FACTORY&#xD;&#xA;   AND LIN.EQP_NAME = EQP.EQP_NAME&#xD;&#xA;  LEFT JOIN TbEQPEFL EFL&#xD;&#xA;    ON LIN.FACTORY  = EFL.FACTORY&#xD;&#xA;   AND LIN.EQP_NAME = EFL.EQP_NAME&#xD;&#xA;  LEFT JOIN TbEQPALM ALM&#xD;&#xA;    ON LIN.FACTORY  = ALM.FACTORY&#xD;&#xA;   AND LIN.EQP_NAME = ALM.EQP_NAME&#xD;&#xA;  LEFT JOIN TbEQPAIL AIL&#xD;&#xA;    ON LIN.FACTORY  = AIL.FACTORY&#xD;&#xA;   AND LIN.EQP_NAME = AIL.EQP_NAME&#xD;&#xA;ORDER BY LIN.SEQ;">
            <QP N="factory" />
            <QP N="line_name" />
          </QY>
        </SG>
        <SG _S="4132" N="ListLine">
          <QY P="MsSql" Q="SELECT LINE_NAME, LINE_DESC&#xD;&#xA;  FROM QEESLINDEF&#xD;&#xA; WHERE FACTORY     = @factory &#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY LINE_NAME">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="4133" N="ListEquipmentEvent">
          <QY P="MsSql" Q="SELECT EFL.EVENT_SEQ, EFL.EVENT_ID, EVT.EVENT_DESC, &#xD;&#xA;       EFL.USED_CONDITION, EFL.CONDITION_NAME, EFL.USED_TIMEOUT, EFL.TIMEOUT&#xD;&#xA;  FROM QEESEQPEFL EFL&#xD;&#xA;  LEFT JOIN QEESEQPEVT EVT&#xD;&#xA;    ON EFL.FACTORY  = EVT.FACTORY&#xD;&#xA;   AND EFL.EVENT_ID = EVT.EVENT_ID&#xD;&#xA; WHERE EFL.FACTORY  = @factory &#xD;&#xA;   AND EFL.EQP_NAME = @eqp_name&#xD;&#xA; ORDER BY EFL.EVENT_SEQ ASC">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="4134" N="SearchEquipmentEventInterlock">
          <QY P="MsSql" Q="SELECT EVENT_ID, ITL_NAME&#xD;&#xA;  FROM QEESEQPEIT&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND EQP_NAME  = @eqp_name&#xD;&#xA; ORDER BY ITL_NAME">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="4135" N="ListEquipmentAlarm">
          <QY P="MsSql" Q="SELECT EQP.ALARM_NAME, ALM.ALARM_DESC, ALM.ALARM_LEVEL, ALM.ALARM_ID, ALM.ALARM_TEXT, EQP.USED_CONDITION, EQP.CONDITION_NAME, EQP.SET_COUNT, EQP.CLEAR_COUNT&#xD;&#xA;  FROM (&#xD;&#xA;SELECT A.FACTORY, A.EQP_TYPE, A.EQP_NAME, A.ALARM_NAME, A.USED_CONDITION, A.CONDITION_NAME,&#xD;&#xA;       SUM(CASE WHEN B.ALARM_STATUS = 'Set' THEN 1 ELSE 0 END) AS SET_COUNT,&#xD;&#xA;       SUM(CASE WHEN B.ALARM_STATUS = 'Clear' THEN 1 ELSE 0 END) AS CLEAR_COUNT&#xD;&#xA;  FROM QEESEQPALM A&#xD;&#xA;  LEFT JOIN QEESEQPAIL B&#xD;&#xA;    ON A.FACTORY    = B.FACTORY&#xD;&#xA;   AND A.EQP_TYPE   = B.EQP_TYPE&#xD;&#xA;   AND A.EQP_NAME   = B.EQP_NAME&#xD;&#xA;   AND A.ALARM_NAME = B.ALARM_NAME&#xD;&#xA; WHERE A.FACTORY    = @factory&#xD;&#xA;   AND A.EQP_TYPE   = @eqp_type&#xD;&#xA;   AND A.EQP_NAME   = @eqp_name&#xD;&#xA; GROUP BY A.FACTORY, A.EQP_TYPE, A.EQP_NAME, A.ALARM_NAME, A.USED_CONDITION, A.CONDITION_NAME&#xD;&#xA;       ) EQP&#xD;&#xA;  LEFT JOIN QEESALMDEF ALM&#xD;&#xA;    ON EQP.FACTORY    = ALM.FACTORY&#xD;&#xA;   AND EQP.EQP_TYPE   = ALM.EQP_TYPE&#xD;&#xA;   AND EQP.ALARM_NAME = ALM.ALARM_NAME&#xD;&#xA; ORDER BY EQP.ALARM_NAME">
            <QP N="factory" />
            <QP N="eqp_type" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="4136" N="SearchEquipmentAlarmInterlock">
          <QY P="MsSql" Q="SELECT EQP.ALARM_STATUS, EQP.ITL_NAME, ITL.ITL_DESC&#xD;&#xA;  FROM (&#xD;&#xA;SELECT FACTORY, ALARM_STATUS, ITL_NAME&#xD;&#xA;  FROM QEESEQPAIL &#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND EQP_TYPE   = @eqp_type&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;   AND ALARM_NAME = @alarm_name&#xD;&#xA;       ) EQP&#xD;&#xA;  LEFT JOIN QEESITLDEF ITL&#xD;&#xA;    ON EQP.FACTORY    = ITL.FACTORY&#xD;&#xA;   AND EQP.ITL_NAME   = ITL.ITL_NAME&#xD;&#xA; ORDER BY EQP.ALARM_STATUS, EQP.ITL_NAME">
            <QP N="factory" />
            <QP N="eqp_type" />
            <QP N="eqp_name" />
            <QP N="alarm_name" />
          </QY>
        </SG>
        <SG _S="4137" N="SearchEquipmentEvent">
          <QY P="MsSql" Q="SELECT EVENT_SEQ, EVENT_ID, PRV_EVENT_ID, NXT_EVENT_ID, USED_TIMEOUT, TIMEOUT, TIMEOUT_ITL_NAME, USED_CONDITION, CONDITION_NAME&#xD;&#xA;  FROM QEESEQPEFL&#xD;&#xA; WHERE FACTORY  = @factory &#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND EVENT_ID = @evt_id">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="evt_id" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="199" N="Report">
      <F _S="378" N="SndList">
        <SG _S="379" N="ListSnd">
          <QY P="MsSql" Q="SELECT A.SVS_NODE, A.SVS_DESC, A.SVS_GROUP,  A.STEP, A.UP_DOWN, A.STATUS, A.RELOAD_CNT,&#xD;&#xA;       ISNULL(B.MODEL, 'N/A') SET_MODEL, ISNULL(B.MODEL_VER, 0) SET_MODEL_VER, ISNULL(C.MODEL, 'N/A') REL_MODEL, ISNULL(C.MODEL_VER, 0) REL_MODEL_VER, ISNULL(D.MODEL, 'N/A') APL_MODEL, ISNULL(D.MODEL_VER, 0) APL_MODEL_VER, &#xD;&#xA;       A.NEED_ACTION, A.NEXT_NEED_ACTION, A.LAST_EVENT_TIME, A.LAST_EVENT_ID,&#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME, A.UPDATE_USER_ID, A.UPDATE_TIME&#xD;&#xA;  FROM QEESSNDDEF A&#xD;&#xA;  LEFT JOIN QEESSNDATR B &#xD;&#xA;    ON A.FACTORY              = B.FACTORY&#xD;&#xA;   AND A.SVS_NODE                     = B.SVS_NODE&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QEESSNDATR C &#xD;&#xA;    ON A.FACTORY              = C.FACTORY&#xD;&#xA;   AND A.SVS_NODE                     = C.SVS_NODE&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QEESSNDATR D &#xD;&#xA;    ON A.FACTORY              = D.FACTORY&#xD;&#xA;   AND A.SVS_NODE                     = D.SVS_NODE&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY           = @factory&#xD;&#xA;   AND B.MODEL                 = ISNULL(@model, B.MODEL)&#xD;&#xA;   AND A.DELETE_FLAG        = 'N'&#xD;&#xA; ORDER BY A.SVS_NODE">
            <QP N="factory" />
            <QP N="model" />
          </QY>
        </SG>
        <SG _S="624" N="SearchSnd">
          <QY P="MsSql" Q="SELECT A.SVS_NODE, A.SVS_NODE_DESC, &#xD;&#xA;       A.SVS_NODE_GROUP, &#xD;&#xA;       A.UP_DOWN, A.STATUS, A.STEP,&#xD;&#xA;       A.NEED_ACTION, A.NEXT_NEED_ACTION, A.RELOAD_CNT,&#xD;&#xA;       ISNULL(B.MODEL, 'N/A') SET_MODEL, ISNULL(B.MODEL_VER, 0) SET_MODEL_VER, &#xD;&#xA;       ISNULL(C.MODEL, 'N/A') REL_MODEL, ISNULL(C.MODEL_VER, 0) REL_MODEL_VER, &#xD;&#xA;       ISNULL(D.MODEL, 'N/A') APL_MODEL, ISNULL(D.MODEL_VER, 0) APL_MODEL_VER, &#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME,&#xD;&#xA;       A.UPDATE_USER_ID, A.UPDATE_TIME,&#xD;&#xA;       A.LAST_EVENT_TIME, A.LAST_EVENT_ID&#xD;&#xA;  FROM QEESSNDDEF A&#xD;&#xA;  LEFT JOIN QEESSNDATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = B.SVS_NODE&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QEESSNDATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = C.SVS_NODE&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QEESSNDATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = D.SVS_NODE&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.SVS_NODE           = @svs_node&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="factory" />
            <QP N="svs_node" />
          </QY>
        </SG>
      </F>
