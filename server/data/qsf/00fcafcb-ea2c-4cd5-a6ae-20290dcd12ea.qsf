          <QY P="MsSql" Q="INSERT INTO QEESEQPSPC (&#xD;&#xA;    FACTORY,&#xD;&#xA;    EQP_TYPE,&#xD;&#xA;    EQP_NAME,&#xD;&#xA;    ACTIVE_VER,&#xD;&#xA;    LAST_VER,&#xD;&#xA;    CREATE_USER_ID,&#xD;&#xA;    CREATE_TIME,&#xD;&#xA;    UPDATE_USER_ID,&#xD;&#xA;    UPDATE_TIME&#xD;&#xA;)&#xD;&#xA;VALUES (&#xD;&#xA;    @factory,&#xD;&#xA;    @eqp_type,&#xD;&#xA;    @eqp_name,&#xD;&#xA;    @active_ver,&#xD;&#xA;    @last_ver,&#xD;&#xA;    @create_user_id,&#xD;&#xA;    @create_time,&#xD;&#xA;    @update_user_id,&#xD;&#xA;    @update_time&#xD;&#xA;);">
