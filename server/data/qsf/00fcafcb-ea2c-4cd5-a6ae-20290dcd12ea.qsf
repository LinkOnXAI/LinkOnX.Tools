            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="3828" N="DeleteEquipmentEventInterlockByEventId">
          <QY P="MsSql" Q="DELETE FROM QEESEQPEIT&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;   AND EVENT_ID   = @event_id">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="event_id" />
          </QY>
        </SG>
        <SG _S="3834" N="DeleteEquipmentEventInterlockByEqpName">
          <QY P="MsSql" Q="DELETE FROM QEESEQPEIT&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND EQP_NAME   = @eqp_name">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="3827" N="SearchEquipmentEventInterlock">
          <QY P="MsSql" Q="SELECT EVENT_ID, ITL_NAME&#xD;&#xA;  FROM QEESEQPEIT&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND EQP_NAME  = @eqp_name&#xD;&#xA; ORDER BY ITL_NAME">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="3830" N="UpdateEquipmentEvent">
          <QY P="MsSql" Q="UPDATE QEESEQPEFL SET&#xD;&#xA;   USED_TIMEOUT   = @used_timeout,&#xD;&#xA;   TIMEOUT        = @timeout,&#xD;&#xA;   USED_CONDITION = @used_condition,&#xD;&#xA;   CONDITION_NAME = @condition_name,&#xD;&#xA;   UPDATE_TIME    = @tran_time,&#xD;&#xA;   UPDATE_USER_ID = @user_id&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;   AND EVENT_ID   = @event_id">
            <QP N="used_timeout" />
            <QP N="timeout" />
            <QP N="used_condition" />
            <QP N="condition_name" />
            <QP N="tran_time" />
            <QP N="user_id" />
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="event_id" />
          </QY>
        </SG>
        <SG _S="3831" N="HasEquipmentEvent">
          <QY P="MsSql" Q="SELECT EVENT_SEQ, EVENT_ID, &#xD;&#xA;       PRV_EVENT_ID, NXT_EVENT_ID, USED_TIMEOUT, TIMEOUT, USED_CONDITION, CONDITION_NAME&#xD;&#xA;  FROM QEESEQPEFL&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EQP_NAME = @eqp_name">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="3833" N="HasEquipmentEventInterlock">
          <QY P="MsSql" Q="SELECT EVENT_ID, ITL_NAME&#xD;&#xA;  FROM QEESEQPEIT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EQP_NAME = @eqp_name">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="3835" N="HasInterlock">
          <QY P="MsSql" Q="SELECT ITL_NAME&#xD;&#xA;  FROM QEESITLDEF&#xD;&#xA; WHERE FACTORY  = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3832" N="HasEvent">
          <QY P="MsSql" Q="SELECT EVENT_ID&#xD;&#xA;  FROM QEESEQPEVT&#xD;&#xA; WHERE FACTORY  = @factory">
            <QP N="factory" />
