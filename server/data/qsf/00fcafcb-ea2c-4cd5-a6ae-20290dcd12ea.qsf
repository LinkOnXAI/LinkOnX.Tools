        <SG _S="3929" N="InsertContainerAtr">
          <QY P="MsSql" Q="INSERT INTO QEESCTNATR (&#xD;&#xA;   FACTORY,&#xD;&#xA;   CTN_NAME,&#xD;&#xA;   ATTR_CATEGORY,&#xD;&#xA;   PACKAGE,&#xD;&#xA;   PKG_VER,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @ctn_name,&#xD;&#xA;   @attr_category,&#xD;&#xA;   @package,&#xD;&#xA;   @pkg_ver,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="ctn_name" />
            <QP N="attr_category" />
            <QP N="package" />
            <QP N="pkg_ver" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
