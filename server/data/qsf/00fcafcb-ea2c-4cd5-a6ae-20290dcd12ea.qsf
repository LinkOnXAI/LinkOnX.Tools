        <SG _S="3863" N="HasContainer">
          <QY P="MsSql" Q="SELECT CTN_NAME, UP_DOWN, STATUS, DELETE_FLAG, NEED_ACTION, NEXT_NEED_ACTION, ALARM&#xD;&#xA;  FROM QEESCTNDEF&#xD;&#xA; WHERE FACTORY        = @factory&#xD;&#xA;   AND CTN_NAME        = @ctn_name">
