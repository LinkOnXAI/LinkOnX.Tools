        <SG _S="4193" N="InsertVersionParam">
          <QY P="MsSql" Q="INSERT INTO QEESEQPSVP (&#xD;&#xA;    FACTORY,&#xD;&#xA;    EQP_TYPE,&#xD;&#xA;    EQP_NAME,&#xD;&#xA;    SPEC_VER,&#xD;&#xA;    PARA_ID,&#xD;&#xA;    PARA_CATEGORY,&#xD;&#xA;    PARA_FORMAT,&#xD;&#xA;    PARA_VALIDATION_RULE,&#xD;&#xA;    PARA_TARGET_VALUE,&#xD;&#xA;    PARA_USL,&#xD;&#xA;    PARA_UCL,&#xD;&#xA;    PARA_LCL,&#xD;&#xA;    PARA_LSL,&#xD;&#xA;    CREATE_USER_ID,&#xD;&#xA;    CREATE_TIME,&#xD;&#xA;    UPDATE_USER_ID,&#xD;&#xA;    UPDATE_TIME&#xD;&#xA;)&#xD;&#xA;VALUES (&#xD;&#xA;    @factory,&#xD;&#xA;    @eqp_type,&#xD;&#xA;    @eqp_name,&#xD;&#xA;    @spec_ver,&#xD;&#xA;    @para_id,&#xD;&#xA;    @para_category,&#xD;&#xA;    @para_format,&#xD;&#xA;    @para_validation_rule,&#xD;&#xA;    @para_target_value,&#xD;&#xA;    @para_usl,&#xD;&#xA;    @para_ucl,&#xD;&#xA;    @para_lcl,&#xD;&#xA;    @para_lsl,&#xD;&#xA;    @create_user_id,&#xD;&#xA;    @create_time,&#xD;&#xA;    @update_user_id,&#xD;&#xA;    @update_time&#xD;&#xA;);">
            <QP N="factory" />
            <QP N="eqp_type" />
            <QP N="eqp_name" />
            <QP N="spec_ver" />
            <QP N="para_id" />
            <QP N="para_category" />
            <QP N="para_format" />
            <QP N="para_validation_rule" />
            <QP N="para_target_value" />
            <QP N="para_usl" />
            <QP N="para_ucl" />
            <QP N="para_lcl" />
            <QP N="para_lsl" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
