        <SG _S="3867" N="UpdateContainer">
          <QY P="MsSql" Q="UPDATE QEESCTNDEF SET&#xD;&#xA;  CTN_DESC         = @ctn_desc, &#xD;&#xA;  STEP = @step,&#xD;&#xA;  UP_DOWN          = @up_down,&#xD;&#xA;  STATUS           = @status, &#xD;&#xA;  NEED_ACTION	   = @need_action,&#xD;&#xA;  NEXT_NEED_ACTION = @next_need_action,&#xD;&#xA;  ALARM            = @alarm,&#xD;&#xA;  LAST_EVENT_ID    = @last_event_id,&#xD;&#xA;  LAST_EVENT_TIME  = @last_event_time,&#xD;&#xA;  LAST_HIST_SEQ    = @hist_seq,&#xD;&#xA;  DELETE_FLAG      = @delete_flag,&#xD;&#xA;  UPDATE_USER_ID   = @update_user_id,&#xD;&#xA;  UPDATE_TIME      = @update_time&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND CTN_NAME     = @ctn_name">
            <QP N="ctn_desc" />
            <QP N="step" />
            <QP N="up_down" />
            <QP N="status" />
            <QP N="need_action" />
            <QP N="next_need_action" />
            <QP N="alarm" />
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="hist_seq" />
            <QP N="delete_flag" />
            <QP N="update_user_id" />
