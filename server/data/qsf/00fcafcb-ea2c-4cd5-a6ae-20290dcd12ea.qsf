      <F _S="3932" N="ContainerFilePack">
        <SG _S="3934" N="HasPackageVer">
          <QY P="MsSql" Q="SELECT PKG_VER_PATH, PKG_RELEASE&#xD;&#xA;  FROM QEESCPGVER  &#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND PACKAGE = @package&#xD;&#xA;   AND PKG_VER = @pkg_ver">
