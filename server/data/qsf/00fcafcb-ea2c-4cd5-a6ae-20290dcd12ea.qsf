            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="unit_name" />
          </QY>
        </SG>
        <SG _S="3986" N="ListEquipmentType">
          <QY P="MsSql" Q="SELECT EQP_TYPE, EQP_TYPE_DESC&#xD;&#xA;  FROM QEESEQPTYP&#xD;&#xA; WHERE FACTORY     = @factory &#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY EQP_TYPE">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3987" N="ListEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME, EQP_DESC, EQP_TYPE&#xD;&#xA;  FROM QEESEQPDEF&#xD;&#xA; WHERE FACTORY     = @factory &#xD;&#xA;   AND EQP_TYPE = @eqp_type&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY EQP_NAME">
            <QP N="factory" />
            <QP N="eqp_type" />
          </QY>
        </SG>
        <SG _S="3982" N="ListEquipmentUnit">
          <QY P="MsSql" Q="SELECT UNIT_SEQ, UNIT_NAME, UNIT_DESC, QUALITY_COLLECTABLE&#xD;&#xA;  FROM QEESEQPUNT&#xD;&#xA; WHERE FACTORY    = @factory &#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA; ORDER BY UNIT_SEQ">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="3989" N="DeleteAllEquipmentUnit">
          <QY P="MsSql" Q="DELETE &#xD;&#xA;  FROM QEESEQPUNT&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND EQP_NAME   = @eqp_name">
