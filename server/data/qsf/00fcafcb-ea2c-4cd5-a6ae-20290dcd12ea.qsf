        </SG>
        <SG _S="3366" N="HasSnd">
          <QY P="MsSql" Q="SELECT SVS_NODE_GROUP, UP_DOWN, STATUS&#xD;&#xA;  FROM QEESSNDDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SVS_NODE         = @svs_node&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="svs_node" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="486" N="Dialog">
      <F _S="2933" N="ModelSelector">
