      </F>
      <F _S="3802" N="EquipmentAlarm">
        <SG _S="3804" N="ListLine">
          <QY P="MsSql" Q="SELECT LINE_NAME, LINE_DESC&#xD;&#xA;  FROM QEESLINDEF&#xD;&#xA; WHERE FACTORY     = @factory &#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY LINE_NAME">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3806" N="ListTypeAlarm">
          <QY P="MsSql" Q="SELECT ALARM_NAME, ALARM_DESC, ALARM_LEVEL, ALARM_ID, ALARM_TEXT&#xD;&#xA;  FROM QEESALMDEF&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EQP_TYPE = @eqp_type&#xD;&#xA;   AND ALARM_NAME NOT IN&#xD;&#xA;       (&#xD;&#xA;SELECT DISTINCT ALARM_NAME &#xD;&#xA;  FROM QEESEQPALM &#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EQP_TYPE = @eqp_type&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;	   )&#xD;&#xA; ORDER BY ALARM_NAME">
            <QP N="factory" />
            <QP N="eqp_type" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="3805" N="ListEquipment">
          <QY P="MsSql" Q="SELECT R.SEQ, R.EQP_NAME, E.EQP_DESC, E.EQP_TYPE&#xD;&#xA;  FROM QEESLINEQP R&#xD;&#xA;  LEFT JOIN QEESEQPDEF E&#xD;&#xA;    ON R.FACTORY     = E.FACTORY&#xD;&#xA;   AND R.EQP_NAME    = E.EQP_NAME&#xD;&#xA; WHERE R.FACTORY     = @factory&#xD;&#xA;   AND R.LINE_NAME   = @line_name&#xD;&#xA;   AND E.DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY R.SEQ ASC">
            <QP N="factory" />
            <QP N="line_name" />
          </QY>
        </SG>
        <SG _S="3807" N="ListEquipmentAlarm">
          <QY P="MsSql" Q="SELECT EQP.ALARM_NAME, ALM.ALARM_DESC, ALM.ALARM_LEVEL, ALM.ALARM_ID, ALM.ALARM_TEXT, EQP.USED_CONDITION, EQP.CONDITION_NAME, EQP.SET_COUNT, EQP.CLEAR_COUNT&#xD;&#xA;  FROM (&#xD;&#xA;SELECT A.FACTORY, A.EQP_TYPE, A.EQP_NAME, A.ALARM_NAME, A.USED_CONDITION, A.CONDITION_NAME,&#xD;&#xA;       SUM(CASE WHEN B.ALARM_STATUS = 'Set' THEN 1 ELSE 0 END) AS SET_COUNT,&#xD;&#xA;       SUM(CASE WHEN B.ALARM_STATUS = 'Clear' THEN 1 ELSE 0 END) AS CLEAR_COUNT&#xD;&#xA;  FROM QEESEQPALM A&#xD;&#xA;  LEFT JOIN QEESEQPAIL B&#xD;&#xA;    ON A.FACTORY    = B.FACTORY&#xD;&#xA;   AND A.EQP_TYPE   = B.EQP_TYPE&#xD;&#xA;   AND A.EQP_NAME   = B.EQP_NAME&#xD;&#xA;   AND A.ALARM_NAME = B.ALARM_NAME&#xD;&#xA; WHERE A.FACTORY    = @factory&#xD;&#xA;   AND A.EQP_TYPE   = @eqp_type&#xD;&#xA;   AND A.EQP_NAME   = @eqp_name&#xD;&#xA; GROUP BY A.FACTORY, A.EQP_TYPE, A.EQP_NAME, A.ALARM_NAME, A.USED_CONDITION, A.CONDITION_NAME&#xD;&#xA;       ) EQP&#xD;&#xA;  LEFT JOIN QEESALMDEF ALM&#xD;&#xA;    ON EQP.FACTORY    = ALM.FACTORY&#xD;&#xA;   AND EQP.EQP_TYPE   = ALM.EQP_TYPE&#xD;&#xA;   AND EQP.ALARM_NAME = ALM.ALARM_NAME&#xD;&#xA; ORDER BY EQP.ALARM_NAME">
            <QP N="factory" />
            <QP N="eqp_type" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="3810" N="SearchEquipmentAlarmInterlock">
          <QY P="MsSql" Q="SELECT EQP.ALARM_STATUS, EQP.ITL_NAME, ITL.ITL_DESC&#xD;&#xA;  FROM (&#xD;&#xA;SELECT FACTORY, ALARM_STATUS, ITL_NAME&#xD;&#xA;  FROM QEESEQPAIL &#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND EQP_TYPE   = @eqp_type&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;   AND ALARM_NAME = @alarm_name&#xD;&#xA;       ) EQP&#xD;&#xA;  LEFT JOIN QEESITLDEF ITL&#xD;&#xA;    ON EQP.FACTORY    = ITL.FACTORY&#xD;&#xA;   AND EQP.ITL_NAME   = ITL.ITL_NAME&#xD;&#xA; ORDER BY EQP.ALARM_STATUS, EQP.ITL_NAME">
            <QP N="factory" />
            <QP N="eqp_type" />
            <QP N="eqp_name" />
            <QP N="alarm_name" />
          </QY>
        </SG>
        <SG _S="3822" N="SearchEquipmentAlarmCondition">
          <QY P="MsSql" Q="SELECT USED_CONDITION, CONDITION_NAME&#xD;&#xA;  FROM QEESEQPALM&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND EQP_TYPE   = @eqp_type&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;   AND ALARM_NAME = @alarm_name">
            <QP N="factory" />
            <QP N="eqp_type" />
            <QP N="eqp_name" />
            <QP N="alarm_name" />
          </QY>
        </SG>
        <SG _S="3811" N="InsertEquipmentAlarm">
          <QY P="MsSql" Q="INSERT INTO QEESEQPALM (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EQP_TYPE,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   ALARM_NAME,&#xD;&#xA;   USED_CONDITION,&#xD;&#xA;   CONDITION_NAME,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   UPDATE_TIME,&#xD;&#xA;   UPDATE_USER_ID&#xD;&#xA; ) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @eqp_type,&#xD;&#xA;   @eqp_name,&#xD;&#xA;   @alarm_name,&#xD;&#xA;   @used_condition,&#xD;&#xA;   @condition_name,&#xD;&#xA;   @create_time,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @update_time,&#xD;&#xA;   @update_user_id&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="eqp_type" />
            <QP N="eqp_name" />
            <QP N="alarm_name" />
            <QP N="used_condition" />
            <QP N="condition_name" />
            <QP N="create_time" />
            <QP N="create_user_id" />
            <QP N="update_time" />
            <QP N="update_user_id" />
          </QY>
        </SG>
        <SG _S="3818" N="InsertEquipmentAlarmInterlock">
          <QY P="MsSql" Q="INSERT INTO QEESEQPAIL (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EQP_TYPE,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   ALARM_NAME,&#xD;&#xA;   ALARM_STATUS,&#xD;&#xA;   ITL_NAME,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   UPDATE_TIME,&#xD;&#xA;   UPDATE_USER_ID&#xD;&#xA; ) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @eqp_type,&#xD;&#xA;   @eqp_name,&#xD;&#xA;   @alarm_name,&#xD;&#xA;   @alarm_status,&#xD;&#xA;   @itl_name,&#xD;&#xA;   @create_time,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @update_time,&#xD;&#xA;   @update_user_id&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="eqp_type" />
            <QP N="eqp_name" />
            <QP N="alarm_name" />
            <QP N="alarm_status" />
            <QP N="itl_name" />
            <QP N="create_time" />
            <QP N="create_user_id" />
            <QP N="update_time" />
            <QP N="update_user_id" />
          </QY>
        </SG>
        <SG _S="3812" N="DeleteEquipmentAlarm">
          <QY P="MsSql" Q="DELETE&#xD;&#xA;  FROM QEESEQPALM&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND EQP_TYPE   = @eqp_type&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;   AND ALARM_NAME = @alarm_name">
            <QP N="factory" />
            <QP N="eqp_type" />
            <QP N="eqp_name" />
            <QP N="alarm_name" />
          </QY>
        </SG>
        <SG _S="3817" N="DeleteEquipmentAlarmInterlock">
          <QY P="MsSql" Q="DELETE&#xD;&#xA;  FROM QEESEQPAIL&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND EQP_TYPE   = @eqp_type&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;   AND ALARM_NAME = @alarm_name">
            <QP N="factory" />
            <QP N="eqp_type" />
            <QP N="eqp_name" />
            <QP N="alarm_name" />
          </QY>
        </SG>
        <SG _S="3814" N="HasTypeAlarm">
          <QY P="MsSql" Q="SELECT ALARM_NAME&#xD;&#xA;  FROM QEESALMDEF&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EQP_TYPE = @eqp_type">
            <QP N="factory" />
            <QP N="eqp_type" />
          </QY>
        </SG>
        <SG _S="3820" N="HasEquipmentAlarm">
          <QY P="MsSql" Q="SELECT ALARM_NAME&#xD;&#xA;  FROM QEESEQPALM&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND EQP_TYPE   = @eqp_type&#xD;&#xA;   AND EQP_NAME   = @eqp_name">
            <QP N="factory" />
            <QP N="eqp_type" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="3821" N="UpdateEquipmentAlarm">
          <QY P="MsSql" Q="UPDATE QEESEQPALM SET&#xD;&#xA;   USED_CONDITION = @used_condition,&#xD;&#xA;   CONDITION_NAME = @condition_name,&#xD;&#xA;   UPDATE_TIME    = @update_time,&#xD;&#xA;   UPDATE_USER_ID = @update_user_id&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND EQP_TYPE   = @eqp_type&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;   AND ALARM_NAME = @alarm_name">
            <QP N="used_condition" />
            <QP N="condition_name" />
            <QP N="update_time" />
            <QP N="update_user_id" />
            <QP N="factory" />
            <QP N="eqp_type" />
            <QP N="eqp_name" />
            <QP N="alarm_name" />
          </QY>
        </SG>
        <SG _S="3815" N="HasInterlock">
          <QY P="MsSql" Q="SELECT ITL_NAME&#xD;&#xA;  FROM QEESITLDEF&#xD;&#xA; WHERE FACTORY  = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3819" N="HasCondition">
          <QY P="MsSql" Q="SELECT CDT_NAME&#xD;&#xA;  FROM QEESCDTDEF&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3816" N="HasEquipment">
          <QY P="MsSql" Q=" SELECT EQP_NAME, EQP_TYPE&#xD;&#xA;  FROM QEESEQPDEF&#xD;&#xA; WHERE FACTORY     = @factory &#xD;&#xA;   AND EQP_NAME    = @eqp_name&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
      </F>
      <F _S="3994" N="EquipmentUnitAlarm">
        <SG _S="3996" N="HasEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME, DELETE_FLAG&#xD;&#xA;  FROM QEESEQPDEF&#xD;&#xA; WHERE FACTORY  = @factory &#xD;&#xA;   AND EQP_NAME = @eqp_name">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="3997" N="HasEquipmentUnit">
          <QY P="MsSql" Q="SELECT UNIT_SEQ, UNIT_NAME&#xD;&#xA;  FROM QEESEQPUNT&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND EQP_NAME  = @eqp_name&#xD;&#xA;   AND UNIT_NAME = @unit_name">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="unit_name" />
          </QY>
        </SG>
        <SG _S="3998" N="ListEquipmentType">
          <QY P="MsSql" Q="SELECT EQP_TYPE, EQP_TYPE_DESC&#xD;&#xA;  FROM QEESEQPTYP&#xD;&#xA; WHERE FACTORY     = @factory &#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY EQP_TYPE">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3999" N="ListEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME, EQP_DESC, EQP_TYPE&#xD;&#xA;  FROM QEESEQPDEF&#xD;&#xA; WHERE FACTORY     = @factory &#xD;&#xA;   AND EQP_TYPE    = @eqp_type&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY EQP_NAME">
            <QP N="factory" />
            <QP N="eqp_type" />
          </QY>
        </SG>
        <SG _S="4009" N="ListEquipmentAlarm">
          <QY P="MsSql" Q="SELECT A.UNIT_NAME, A.ALARM_ID, Y.PLC_ADDRESS, Y.ALARM_TEXT, Y.ALARM_LEVEL&#xA;  FROM QEESALMUNT A&#xA; INNER JOIN QEESEQPDEF B&#xA;    ON A.FACTORY     = B.FACTORY&#xA;   AND A.EQP_NAME    = B.EQP_NAME&#xA;   AND B.DELETE_FLAG = 'N'&#xA; LEFT JOIN QEESALMDEF Y&#xA;    ON A.FACTORY     = Y.FACTORY&#xA;   AND B.EQP_TYPE    = Y.EQP_TYPE&#xA;   AND A.ALARM_ID    = Y.ALARM_ID&#xA; WHERE A.FACTORY     = @factory&#xA;   AND A.EQP_NAME    = @eqp_name&#xA; ORDER BY A.UNIT_NAME, A.ALARM_ID;">
            <QP N="factory&#xA;" />
            <QP N="eqp_name&#xA;" />
          </QY>
        </SG>
        <SG _S="4010" N="ListEquipmentTypeAlarm">
          <QY P="MsSql" Q="SELECT A.EQP_NAME, A.UNIT_NAME, A.ALARM_ID, Y.PLC_ADDRESS, Y.ALARM_TEXT, Y.ALARM_LEVEL&#xA;  FROM QEESALMUNT A&#xA; INNER JOIN QEESEQPDEF B&#xA;    ON A.FACTORY     = B.FACTORY&#xA;   AND A.EQP_NAME    = B.EQP_NAME&#xA;   AND B.EQP_TYPE    = @eqp_type&#xA;   AND B.DELETE_FLAG = 'N'&#xA; LEFT JOIN QEESALMDEF Y&#xA;    ON A.FACTORY     = Y.FACTORY&#xA;   AND B.EQP_TYPE    = Y.EQP_TYPE&#xA;   AND A.ALARM_ID    = Y.ALARM_ID&#xA; WHERE A.FACTORY     = @factory&#xA; ORDER BY A.EQP_NAME, A.UNIT_NAME, A.ALARM_ID">
            <QP N="eqp_type&#xA;" />
            <QP N="factory&#xA;" />
          </QY>
        </SG>
        <SG _S="4000" N="ListEquipmentUnit">
          <QY P="MsSql" Q="SELECT UNIT_SEQ, UNIT_NAME&#xD;&#xA;  FROM QEESEQPUNT&#xD;&#xA; WHERE FACTORY  = @factory &#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA; ORDER BY UNIT_NAME">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="4003" N="ListEquipmentUnitAlarm">
          <QY P="MsSql" Q="SELECT A.ALARM_ID, Y.PLC_ADDRESS, Y.ALARM_TEXT, Y.ALARM_LEVEL&#xA;  FROM QEESALMUNT A&#xA; INNER JOIN QEESEQPDEF B&#xA;    ON A.FACTORY     = B.FACTORY&#xA;   AND A.EQP_NAME    = B.EQP_NAME&#xA;   AND B.DELETE_FLAG = 'N'&#xA; LEFT JOIN QEESALMDEF Y&#xA;    ON A.FACTORY     = Y.FACTORY&#xA;   AND B.EQP_TYPE    = Y.EQP_TYPE&#xA;   AND A.ALARM_ID    = Y.ALARM_ID&#xA; WHERE A.FACTORY     = @factory&#xA;   AND A.EQP_NAME    = @eqp_name&#xA;   AND A.UNIT_NAME   = @unit_name&#xA; ORDER BY A.ALARM_ID">
            <QP N="factory&#xA;" />
            <QP N="eqp_name&#xA;" />
            <QP N="unit_name&#xA;" />
          </QY>
        </SG>
        <SG _S="4004" N="ListAlarmDefinition">
          <QY P="MsSql" Q="SELECT ALARM_ID, PLC_ADDRESS, ALARM_TEXT, ALARM_LEVEL&#xD;&#xA;  FROM QEESALMDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EQP_TYPE    = @eqp_type&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY ALARM_ID">
            <QP N="factory" />
            <QP N="eqp_type" />
          </QY>
        </SG>
        <SG _S="4006" N="InsertEquipmentUnitAlarm">
          <QY P="MsSql" Q="INSERT INTO QEESALMUNT (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   UNIT_NAME,&#xD;&#xA;   ALARM_ID,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @eqp_name,&#xD;&#xA;   @unit_name,&#xD;&#xA;   @alarm_id,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="unit_name" />
            <QP N="alarm_id" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="4005" N="DeleteEquipmentUnitAlarm">
          <QY P="MsSql" Q="DELETE FROM QEESALMUNT&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND EQP_NAME  = @eqp_name&#xD;&#xA;   AND UNIT_NAME = @unit_name&#xD;&#xA;   AND ALARM_ID  = @alarm_id">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="unit_name" />
            <QP N="alarm_id" />
          </QY>
        </SG>
      </F>
      <F _S="4097" N="EquipmentProcQuadCheckUnit">
        <SG _S="4098" N="ListProcessQualityCheckUnit">
          <QY P="MsSql" Q="SELECT A.TARGET_EQP_NAME, ISNULL(B.EQP_DESC, '') AS EQP_DESC, ISNULL(D.PROC_MODE, 'Unknown') AS PROC_MODE,&#xD;&#xA;       A.TARGET_UNIT_NAME, ISNULL(C.UNIT_DESC, '') AS UNIT_DESC, ISNULL(C.QUALITY_COLLECTABLE, 'No') as QUALITY_COLLECTABLE&#xD;&#xA;  FROM QEESPQCUNT A&#xD;&#xA;  LEFT JOIN QEESEQPDEF B&#xD;&#xA;    ON A.FACTORY          = B.FACTORY&#xD;&#xA;   AND A.TARGET_EQP_NAME  = B.EQP_NAME&#xD;&#xA;  LEFT JOIN QEESEQPUNT C&#xD;&#xA;    ON A.FACTORY = C.FACTORY&#xD;&#xA;   AND A.TARGET_EQP_NAME  = C.EQP_NAME&#xD;&#xA;   AND A.TARGET_UNIT_NAME = C.UNIT_NAME&#xD;&#xA;  LEFT JOIN QEESEQPTYP D&#xD;&#xA;    ON B.FACTORY          = D.FACTORY&#xD;&#xA;   AND B.EQP_TYPE         = D.EQP_TYPE&#xD;&#xA; WHERE A.FACTORY          = @factory&#xA;   AND A.EQP_NAME         = @eqp_name&#xD;&#xA; ORDER BY A.TARGET_EQP_NAME, C.UNIT_SEQ">
            <QP N="factory&#xA;" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="4101" N="ListLineEquipmentUnit">
          <QY P="MsSql" Q="SELECT A.EQP_NAME, ISNULL(B.EQP_DESC, '') AS EQP_DESC, ISNULL(D.PROC_MODE, 'Unknown') AS PROC_MODE,&#xD;&#xA;       C.UNIT_NAME, C.UNIT_DESC, C.QUALITY_COLLECTABLE&#xD;&#xA;  FROM QEESLINEQP A&#xD;&#xA;  LEFT JOIN QEESEQPDEF B&#xD;&#xA;    ON A.FACTORY   = B.FACTORY&#xD;&#xA;   AND A.EQP_NAME  = B.EQP_NAME&#xD;&#xA; INNER JOIN QEESEQPUNT C&#xD;&#xA;    ON A.FACTORY   = C.FACTORY&#xD;&#xA;   AND A.EQP_NAME  = C.EQP_NAME&#xD;&#xA;  LEFT JOIN QEESEQPTYP D&#xD;&#xA;    ON B.FACTORY   = D.FACTORY&#xD;&#xA;   AND B.EQP_TYPE  = D.EQP_TYPE&#xD;&#xA; WHERE A.FACTORY   = @factory&#xD;&#xA;   AND A.LINE_NAME = @line_name&#xD;&#xA;   AND A.SEQ      &lt;= @seq&#xD;&#xA; ORDER BY A.SEQ, C.UNIT_SEQ">
            <QP N="factory" />
            <QP N="line_name" />
            <QP N="seq" />
          </QY>
        </SG>
        <SG _S="4099" N="ListLine">
          <QY P="MsSql" Q="SELECT LINE_NAME, LINE_DESC&#xD;&#xA;  FROM QEESLINDEF&#xD;&#xA; WHERE FACTORY     = @factory &#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY LINE_NAME">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="4100" N="ListEquipment">
          <QY P="MsSql" Q="SELECT EQP.SEQ, EQP.EQP_NAME, EQP.EQP_DESC, COUNT(UNT.TARGET_UNIT_NAME) AS TARGET_UNIT_COUNT&#xD;&#xA;  FROM (&#xD;&#xA;SELECT R.FACTORY, R.LINE_NAME, R.SEQ, R.EQP_NAME, E.EQP_DESC&#xD;&#xA;  FROM QEESLINEQP R&#xD;&#xA;  LEFT JOIN QEESEQPDEF E&#xD;&#xA;    ON R.FACTORY     = E.FACTORY&#xD;&#xA;   AND R.EQP_NAME    = E.EQP_NAME&#xD;&#xA; WHERE R.FACTORY     = @factory&#xD;&#xA;   AND R.LINE_NAME   = @line_name&#xD;&#xA;   AND E.DELETE_FLAG = 'N'&#xD;&#xA;       ) AS EQP&#xD;&#xA;  LEFT JOIN QEESPQCUNT UNT&#xD;&#xA;    ON EQP.FACTORY = UNT.FACTORY&#xD;&#xA;   AND EQP.LINE_NAME = UNT.LINE_NAME&#xD;&#xA;   AND EQP.EQP_NAME  = UNT.EQP_NAME&#xD;&#xA; GROUP BY EQP.SEQ, EQP.EQP_NAME, EQP.EQP_DESC&#xD;&#xA; ORDER BY EQP.SEQ">
            <QP N="factory" />
            <QP N="line_name" />
          </QY>
        </SG>
        <SG _S="4102" N="HasLineEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME&#xD;&#xA;  FROM QEESLINEQP&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND LINE_NAME = @line_name&#xD;&#xA;   AND EQP_NAME  = @eqp_name">
            <QP N="factory" />
            <QP N="line_name" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="4103" N="InsertProcessQualityCheckUnit">
          <QY P="MsSql" Q="INSERT INTO QEESPQCUNT (&#xD;&#xA;   FACTORY,&#xD;&#xA;   LINE_NAME,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   TARGET_EQP_NAME,&#xD;&#xA;   TARGET_UNIT_NAME,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   UPDATE_TIME,&#xD;&#xA;   UPDATE_USER_ID&#xD;&#xA;   ) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @line_name,&#xD;&#xA;   @eqp_name,&#xD;&#xA;   @target_eqp_name,&#xD;&#xA;   @target_unit_name,&#xD;&#xA;   @create_time,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @update_time,&#xD;&#xA;   @update_user_id&#xD;&#xA;   )">
            <QP N="factory" />
            <QP N="line_name" />
            <QP N="eqp_name" />
            <QP N="target_eqp_name" />
            <QP N="target_unit_name" />
            <QP N="create_time" />
            <QP N="create_user_id" />
            <QP N="update_time" />
            <QP N="update_user_id" />
          </QY>
        </SG>
        <SG _S="4104" N="DeleteProcessQualityCheckUnit">
          <QY P="MsSql" Q="DELETE &#xD;&#xA;  FROM QEESPQCUNT&#xD;&#xA; WHERE FACTORY          = @factory&#xD;&#xA;   AND LINE_NAME        = @line_name&#xD;&#xA;   AND EQP_NAME         = @eqp_name&#xD;&#xA;   AND TARGET_EQP_NAME  = @target_eqp_name&#xD;&#xA;   AND TARGET_UNIT_NAME = @target_unit_name">
            <QP N="factory" />
            <QP N="line_name" />
            <QP N="eqp_name" />
            <QP N="target_eqp_name" />
            <QP N="target_unit_name" />
          </QY>
        </SG>
        <SG _S="4111" N="ListEquipment_bak">
          <QY P="MsSql" Q="SELECT R.SEQ, R.EQP_NAME, E.EQP_DESC&#xD;&#xA;  FROM QEESLINEQP R&#xD;&#xA;  LEFT JOIN QEESEQPDEF E&#xD;&#xA;    ON R.FACTORY     = E.FACTORY&#xD;&#xA;   AND R.EQP_NAME    = E.EQP_NAME&#xD;&#xA; WHERE R.FACTORY     = @factory&#xD;&#xA;   AND R.LINE_NAME   = @line_name&#xD;&#xA;   AND E.DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY R.SEQ ASC">
            <QP N="factory" />
            <QP N="line_name" />
          </QY>
        </SG>
      </F>
      <F _S="4020" N="NonProcessConditionByRecipe">
        <SG _S="4021" N="ListLine">
          <QY P="MsSql" Q="SELECT LINE_NAME, LINE_DESC&#xD;&#xA;  FROM QEESLINDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY LINE_NAME">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="4034" N="ListCondition">
          <QY P="MsSql" Q="SELECT A.CONDITION_CODE, B.DATA_3 AS CONDITION_VALUE, B.DATA_4 AS CONDITION_DESC&#xD;&#xA;  FROM QEESUNTNPC A&#xD;&#xA;  LEFT JOIN QGCMTBLDAT B&#xD;&#xA;    ON A.FACTORY        = B.FACTORY&#xD;&#xA;   AND A.CONDITION_CODE = B.DATA_2&#xD;&#xA; WHERE A.FACTORY        = @factory&#xD;&#xA;   AND A.EQP_NAME       = @eqp_name&#xD;&#xA;   AND A.UNIT_NAME      = @unit_name&#xD;&#xA; ORDER BY A.CONDITION_CODE">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="unit_name" />
          </QY>
        </SG>
        <SG _S="4024" N="ListRecipeParamControlCode">
          <QY P="MsSql" Q="SELECT DISTINCT A.EQ_ACTION, B.DATA_3&#xD;&#xA;  FROM QRMSEQPPMC A&#xD;&#xA;  LEFT JOIN QGCMTBLDAT B&#xD;&#xA;    ON A.FACTORY   = B.FACTORY&#xD;&#xA;   AND A.EQ_ACTION = B.DATA_2&#xD;&#xA; WHERE A.FACTORY   = @factory&#xD;&#xA;   AND A.EQP_NAME  = @eqp_name&#xD;&#xA; ORDER BY B.DATA_3">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="4025" N="ListRecipeParamControlFormula">
          <QY P="MsSql" Q="SELECT FORMULA_NAME, FORMULA_DESC, EXPRESSION_VALUE&#xD;&#xA;  FROM QRMSEQPPMC&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND EQP_NAME  = @eqp_name&#xD;&#xA;   AND EQ_ACTION = @action&#xD;&#xA; ORDER BY FORMULA_PRIORITY">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="action" />
          </QY>
        </SG>
        <SG _S="4023" N="ListEquipmentUnit">
          <QY P="MsSql" Q="SELECT UNIT_NAME, UNIT_DESC&#xD;&#xA;  FROM QEESEQPUNT&#xD;&#xA; WHERE FACTORY    = @factory &#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA; ORDER BY UNIT_SEQ">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="4022" N="ListEquipment">
          <QY P="MsSql" Q="SELECT A.EQP_NAME, B.EQP_DESC&#xD;&#xA;  FROM QEESLINEQP A&#xD;&#xA;  LEFT JOIN QEESEQPDEF B&#xD;&#xA;    ON A.FACTORY   = B.FACTORY&#xD;&#xA;   AND A.EQP_NAME  = B.EQP_NAME&#xD;&#xA; WHERE A.FACTORY   = @factory&#xD;&#xA;   AND A.LINE_NAME = @line_name&#xD;&#xA; ORDER BY SEQ">
            <QP N="factory" />
            <QP N="line_name" />
          </QY>
        </SG>
        <SG _S="4040" N="InsertNonProcessCondition">
          <QY P="MsSql" Q="INSERT QEESUNTNPC (&#xD;&#xA;	FACTORY, &#xD;&#xA;	EQP_NAME,&#xD;&#xA;	UNIT_NAME,&#xD;&#xA;	CONDITION_CODE,&#xD;&#xA;	CREATE_USER_ID,&#xD;&#xA;	CREATE_TIME,&#xD;&#xA;	UPDATE_USER_ID,&#xD;&#xA;	UPDATE_TIME&#xD;&#xA;	) VALUES (&#xD;&#xA;	@factory,&#xD;&#xA;	@eqp_name,&#xD;&#xA;	@unit_name,&#xD;&#xA;	@condition_code,&#xD;&#xA;	@create_user_id,&#xD;&#xA;	@create_time,&#xD;&#xA;	@update_user_id,&#xD;&#xA;	@update_time)">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="unit_name" />
            <QP N="condition_code" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="4039" N="DeleteNonProcessCondition">
          <QY P="MsSql" Q="DELETE&#xD;&#xA;  FROM QEESUNTNPC&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND EQP_NAME  = @eqp_name&#xD;&#xA;   AND UNIT_NAME = @unit_name">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="unit_name" />
          </QY>
        </SG>
        <SG _S="4036" N="HasEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME&#xD;&#xA;  FROM QEESEQPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EQP_NAME    = @eqp_name&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="4037" N="HasEquipmentUnit">
          <QY P="MsSql" Q="SELECT UNIT_NAME&#xD;&#xA;  FROM QEESEQPUNT&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND EQP_NAME  = @eqp_name&#xD;&#xA;   AND UNIT_NAME = @unit_name">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="unit_name" />
          </QY>
        </SG>
        <SG _S="4038" N="HasRecipeParamControlCode">
          <QY P="MsSql" Q="SELECT EQ_ACTION&#xD;&#xA;  FROM QRMSEQPPMC&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND EQP_NAME  = @eqp_name">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
      </F>
      <F _S="3530" N="AlarmEvent">
        <SG _S="3534" N="ListAlarmEvent">
          <QY P="MsSql" Q="SELECT EVENT_ID, EVENT_DESC&#xD;&#xA;  FROM QEESALMEVT&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY EVENT_ID">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3563" N="HasAlarmEvent">
          <QY P="MsSql" Q="SELECT EVENT_ID&#xD;&#xA;  FROM QEESALMEVT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EVENT_ID = @event_id">
            <QP N="factory" />
            <QP N="event_id" />
          </QY>
        </SG>
        <SG _S="3535" N="SearchAlarmEvent">
          <QY P="MsSql" Q="SELECT EVENT_ID, EVENT_DESC, ALT_COMMENT, &#xD;&#xA;       DATA_1_PRT, DATA_2_PRT, DATA_3_PRT, DATA_4_PRT, DATA_5_PRT, DATA_6_PRT, DATA_7_PRT, DATA_8_PRT, DATA_9_PRT, DATA_10_PRT,&#xD;&#xA;       DATA_11_PRT, DATA_12_PRT, DATA_13_PRT, DATA_14_PRT, DATA_15_PRT, DATA_16_PRT, DATA_17_PRT, DATA_18_PRT, DATA_19_PRT, DATA_20_PRT&#xD;&#xA;  FROM QEESALMEVT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EVENT_ID = @event_id">
            <QP N="factory" />
            <QP N="event_id" />
          </QY>
        </SG>
        <SG _S="3564" N="InsertAlarmEvent">
          <QY P="MsSql" Q="INSERT INTO QEESALMEVT(&#xD;&#xA;   FACTORY,&#xD;&#xA;   EVENT_ID,&#xD;&#xA;   EVENT_DESC,&#xD;&#xA;   ALT_COMMENT,&#xD;&#xA;   DATA_1_PRT,   &#xD;&#xA;   DATA_2_PRT,   &#xD;&#xA;   DATA_3_PRT,   &#xD;&#xA;   DATA_4_PRT,   &#xD;&#xA;   DATA_5_PRT,   &#xD;&#xA;   DATA_6_PRT,   &#xD;&#xA;   DATA_7_PRT,   &#xD;&#xA;   DATA_8_PRT,   &#xD;&#xA;   DATA_9_PRT,   &#xD;&#xA;   DATA_10_PRT,   &#xD;&#xA;   DATA_11_PRT,   &#xD;&#xA;   DATA_12_PRT,   &#xD;&#xA;   DATA_13_PRT,   &#xD;&#xA;   DATA_14_PRT,   &#xD;&#xA;   DATA_15_PRT,   &#xD;&#xA;   DATA_16_PRT,   &#xD;&#xA;   DATA_17_PRT,   &#xD;&#xA;   DATA_18_PRT,   &#xD;&#xA;   DATA_19_PRT,   &#xD;&#xA;   DATA_20_PRT,   &#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @event_id,&#xD;&#xA;   @event_desc,&#xD;&#xA;   @alt_comment,&#xD;&#xA;   @data_1_prt,  &#xD;&#xA;   @data_2_prt,  &#xD;&#xA;   @data_3_prt,  &#xD;&#xA;   @data_4_prt,  &#xD;&#xA;   @data_5_prt,  &#xD;&#xA;   @data_6_prt,  &#xD;&#xA;   @data_7_prt,  &#xD;&#xA;   @data_8_prt,  &#xD;&#xA;   @data_9_prt,  &#xD;&#xA;   @data_10_prt,  &#xD;&#xA;   @data_11_prt,  &#xD;&#xA;   @data_12_prt,  &#xD;&#xA;   @data_13_prt,  &#xD;&#xA;   @data_14_prt,  &#xD;&#xA;   @data_15_prt,  &#xD;&#xA;   @data_16_prt,  &#xD;&#xA;   @data_17_prt,  &#xD;&#xA;   @data_18_prt,  &#xD;&#xA;   @data_19_prt,  &#xD;&#xA;   @data_20_prt,  &#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="event_id" />
            <QP N="event_desc" />
            <QP N="alt_comment" />
            <QP N="data_1_prt" />
            <QP N="data_2_prt" />
            <QP N="data_3_prt" />
            <QP N="data_4_prt" />
            <QP N="data_5_prt" />
            <QP N="data_6_prt" />
            <QP N="data_7_prt" />
            <QP N="data_8_prt" />
            <QP N="data_9_prt" />
            <QP N="data_10_prt" />
            <QP N="data_11_prt" />
            <QP N="data_12_prt" />
            <QP N="data_13_prt" />
            <QP N="data_14_prt" />
            <QP N="data_15_prt" />
            <QP N="data_16_prt" />
            <QP N="data_17_prt" />
            <QP N="data_18_prt" />
            <QP N="data_19_prt" />
            <QP N="data_20_prt" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="3565" N="UpdateAlarmEvent">
          <QY P="MsSql" Q="UPDATE QEESALMEVT SET&#xD;&#xA;   EVENT_DESC     = @event_desc,&#xD;&#xA;   ALT_COMMENT    = @alt_comment,&#xD;&#xA;   DATA_1_PRT     = @data_1_prt,&#xD;&#xA;   DATA_2_PRT     = @data_2_prt,&#xD;&#xA;   DATA_3_PRT     = @data_3_prt,&#xD;&#xA;   DATA_4_PRT     = @data_4_prt,&#xD;&#xA;   DATA_5_PRT     = @data_5_prt,&#xD;&#xA;   DATA_6_PRT     = @data_6_prt,&#xD;&#xA;   DATA_7_PRT     = @data_7_prt,&#xD;&#xA;   DATA_8_PRT     = @data_8_prt,&#xD;&#xA;   DATA_9_PRT     = @data_9_prt,&#xD;&#xA;   DATA_10_PRT    = @data_10_prt,&#xD;&#xA;   DATA_11_PRT    = @data_11_prt,&#xD;&#xA;   DATA_12_PRT    = @data_12_prt,&#xD;&#xA;   DATA_13_PRT    = @data_13_prt,&#xD;&#xA;   DATA_14_PRT    = @data_14_prt,&#xD;&#xA;   DATA_15_PRT    = @data_15_prt,&#xD;&#xA;   DATA_16_PRT    = @data_16_prt,&#xD;&#xA;   DATA_17_PRT    = @data_17_prt,&#xD;&#xA;   DATA_18_PRT    = @data_18_prt,&#xD;&#xA;   DATA_19_PRT    = @data_19_prt,&#xD;&#xA;   DATA_20_PRT    = @data_20_prt,&#xD;&#xA;   UPDATE_USER_ID = @update_user_id,&#xD;&#xA;   UPDATE_TIME    = @update_time&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND EVENT_ID   = @event_id">
            <QP N="event_desc" />
            <QP N="alt_comment" />
            <QP N="data_1_prt" />
            <QP N="data_2_prt" />
            <QP N="data_3_prt" />
            <QP N="data_4_prt" />
            <QP N="data_5_prt" />
            <QP N="data_6_prt" />
            <QP N="data_7_prt" />
            <QP N="data_8_prt" />
            <QP N="data_9_prt" />
            <QP N="data_10_prt" />
            <QP N="data_11_prt" />
            <QP N="data_12_prt" />
            <QP N="data_13_prt" />
            <QP N="data_14_prt" />
            <QP N="data_15_prt" />
            <QP N="data_16_prt" />
            <QP N="data_17_prt" />
            <QP N="data_18_prt" />
            <QP N="data_19_prt" />
            <QP N="data_20_prt" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="event_id" />
          </QY>
        </SG>
        <SG _S="3566" N="DeleteAlarmEvent">
          <QY P="MsSql" Q="DELETE FROM QEESALMEVT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EVENT_ID = @event_id">
            <QP N="factory" />
            <QP N="event_id" />
          </QY>
        </SG>
      </F>
      <F _S="3519" N="Alarm">
        <SG _S="3520" N="ListAlarm">
          <QY P="MsSql" Q="SELECT ALARM_NAME, ALARM_DESC, ALARM_ID, ALARM_LEVEL, ALARM_TEXT&#xD;&#xA;  FROM QEESALMDEF&#xD;&#xA; WHERE FACTORY     = @factory &#xD;&#xA;   AND EQP_TYPE = @eqp_type&#xD;&#xA; ORDER BY ALARM_NAME">
            <QP N="factory" />
            <QP N="eqp_type" />
          </QY>
        </SG>
        <SG _S="3521" N="SearchAlarm">
          <QY P="MsSql" Q="SELECT EQP_TYPE, ALARM_NAME, ALARM_DESC, ALARM_ID, ALARM_LEVEL, ALARM_TEXT, PLC_ADDRESS&#xD;&#xA;  FROM QEESALMDEF&#xD;&#xA; WHERE FACTORY     = @factory &#xD;&#xA;   AND EQP_TYPE = @eqp_type&#xD;&#xA;   AND ALARM_NAME = @alarm_name">
            <QP N="factory" />
            <QP N="eqp_type" />
            <QP N="alarm_name" />
          </QY>
        </SG>
        <SG _S="3567" N="HasAlarm">
          <QY P="MsSql" Q="SELECT ALARM_NAME&#xD;&#xA;  FROM QEESALMDEF&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EQP_TYPE = @eqp_type&#xD;&#xA;   AND ALARM_NAME = @alarm_name">
            <QP N="factory" />
            <QP N="eqp_type" />
            <QP N="alarm_name" />
          </QY>
        </SG>
        <SG _S="3568" N="InsertAlarm">
          <QY P="MsSql" Q="INSERT INTO QEESALMDEF(&#xD;&#xA;   FACTORY,&#xD;&#xA;   ALARM_NAME,&#xD;&#xA;   EQP_TYPE,&#xD;&#xA;   ALARM_DESC,&#xD;&#xA;   ALARM_ID,&#xD;&#xA;   ALARM_LEVEL,&#xD;&#xA;   ALARM_TEXT,&#xD;&#xA;   PLC_ADDRESS,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @alarm_name,&#xD;&#xA;   @eqp_type,&#xD;&#xA;   @alarm_desc,&#xD;&#xA;   @alarm_id,&#xD;&#xA;   @alarm_level,&#xD;&#xA;   @alarm_text,&#xD;&#xA;   @plc_address,&#xD;&#xA;   @user_id,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @user_id,&#xD;&#xA;   @tran_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="alarm_name" />
            <QP N="eqp_type" />
            <QP N="alarm_desc" />
            <QP N="alarm_id" />
            <QP N="alarm_level" />
            <QP N="alarm_text" />
