        </SG>
        <SG _S="2768" N="InsertSndGroup">
          <QY P="MsSql" Q="INSERT INTO QEESSNDGRP (&#xD;&#xA;	FACTORY,&#xD;&#xA;	SVS_NODE_GROUP,&#xD;&#xA;	SVS_NODE_GROUP_DESC,&#xD;&#xA;	CREATE_USER_ID,&#xD;&#xA;	CREATE_TIME,&#xD;&#xA;	UPDATE_USER_ID,&#xD;&#xA;	UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;	@factory,&#xD;&#xA;	@svs_node_group,&#xD;&#xA;	@svs_node_group_desc,&#xD;&#xA;	@create_user_id,&#xD;&#xA;	@create_time,&#xD;&#xA;	@update_user_id,&#xD;&#xA;	@update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="svs_node_group" />
            <QP N="svs_node_group_desc" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="2769" N="UpdateSndGroup">
          <QY P="MsSql" Q="UPDATE QEESSNDGRP SET&#xD;&#xA;    SVS_NODE_GROUP_DESC      =@svs_node_group_desc,&#xD;&#xA;    UPDATE_USER_ID =@update_user_id,&#xD;&#xA;    UPDATE_TIME    =@update_time&#xD;&#xA; WHERE FACTORY     =@factory&#xD;&#xA;   AND SVS_NODE_GROUP    = @svs_node_group">
            <QP N="svs_node_group_desc" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="svs_node_group" />
          </QY>
        </SG>
        <SG _S="2770" N="DeleteSndGroup">
          <QY P="MsSql" Q="DELETE &#xD;&#xA;  FROM QEESSNDGRP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND SVS_NODE_GROUP        = @svs_node_group">
            <QP N="factory" />
            <QP N="svs_node_group" />
          </QY>
        </SG>
        <SG _S="2771" N="CountSnd">
          <QY P="MsSql" Q="SELECT SVS_NODE&#xD;&#xA;  FROM QEESSNDDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SVS_NODE_GROUP        = @svs_node_group&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="svs_node_group" />
          </QY>
        </SG>
      </F>
      <F _S="212" N="Snd">
        <SG _S="579" N="SndCount">
          <QY P="MsSql" Q="SELECT COUNT(SVS_NODE) AS CNT FROM QEESSNDDEF WHERE FACTORY = @factory&#xD;&#xA;   AND DELETE_FLAG &lt;&gt; 'Y'">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3455" N="HasDuplicateSndName">
          <QY P="MsSql" Q="SELECT * FROM QEESSNDDEF &#xD;&#xA;WHERE FACTORY = @factory&#xD;&#xA;AND SVS_NODE = @svs_node&#xD;&#xA;AND DELETE_FLAG &lt;&gt; 'Y'">
            <QP N="factory" />
            <QP N="svs_node" />
          </QY>
        </SG>
        <SG _S="3374" N="HasSndAtr">
          <QY P="MsSql" Q="SELECT SVS_NODE, MODEL, MODEL_VER, SVS_NODE_SCHEMA&#xD;&#xA;  FROM QEESSNDATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND SVS_NODE           = @svs_node&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="svs_node" />
            <QP N="attr_category" />
          </QY>
        </SG>
        <SG _S="579" N="HasSnd">
          <QY P="MsSql" Q="SELECT A.SVS_NODE, A.SVS_GROUP,  A.STEP, A.UP_DOWN, A.STATUS,&#xD;&#xA;       A.DELETE_FLAG, A.NEED_ACTION, A.NEXT_NEED_ACTION, ALARM,&#xD;&#xA;       B.MODEL, B.MDL_VER, ,&#xD;&#xA;       B.SVS_SCHEMA&#xD;&#xA;  FROM QEESSNDDEF A&#xD;&#xA;  LEFT JOIN QEESSNDATR B&#xD;&#xA;    ON A.FACTORY        = B.FACTORY&#xD;&#xA;   AND A.SVS_NODE            = B.SVS_NODE&#xD;&#xA;   AND B.ATTR_CATEGORY  = @attr_category&#xD;&#xA; WHERE A.FACTORY        = @factory&#xD;&#xA;   AND A.SVS_NODE            = @svs_node">
            <QP N="attr_category" />
            <QP N="factory" />
            <QP N="svs_node" />
          </QY>
        </SG>
        <SG _S="583" N="HasModelVer">
          <QY P="MsSql" Q="SELECT MODEL&#xD;&#xA;  FROM QEESMDLVER&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND MODEL  = @model&#xD;&#xA;   AND MODEL_VER = @mdl_ver">
            <QP N="factory" />
            <QP N="model" />
            <QP N="mdl_ver" />
          </QY>
        </SG>
        <SG _S="3119" N="HasDuplicateOfControllerName">
          <QY P="MsSql" Q="SELECT SVS_NODE&#xD;&#xA;  FROM QEESSNDCFG&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND SVS_NODE          &lt;&gt; @svs_node&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category&#xD;&#xA;   AND OBJ_TYPE      = @obj_type&#xD;&#xA;   AND KEY_NAME      = @eqp_name_key&#xD;&#xA;   AND DATA          = @eqp_name">
            <QP N="factory" />
            <QP N="svs_node" />
            <QP N="attr_category" />
            <QP N="obj_type" />
            <QP N="eqp_name_key" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="219" N="ListSnd">
          <QY P="MsSql" Q="SELECT A.SVS_NODE, A.SVS_NODE_DESC, A.CONTAINER, A.SVS_NODE_GROUP, A.AUTO_START, A.STEP,&#xD;&#xA;       ISNULL(B.MODEL, ' ') AS 'SETUP_MODEL', ISNULL(B.MODEL_VER, 0) AS 'SETUP_MODEL_VER',&#xD;&#xA;	   ISNULL(C.MODEL, ' ') AS 'RELEASE_MODEL', ISNULL(C.MODEL_VER, 0) AS 'RELEASE_MODEL_VER',&#xD;&#xA;	   ISNULL(D.MODEL, ' ') AS 'APPLIED_MODEL', ISNULL(D.MODEL_VER, 0) AS 'APPLIED_MODEL_VER'&#xD;&#xA;  FROM QEESSNDDEF A&#xD;&#xA;  LEFT JOIN QEESSNDATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.SVS_NODE      = B.SVS_NODE&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'&#xD;&#xA;  LEFT JOIN QEESSNDATR C&#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.SVS_NODE      = C.SVS_NODE&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'&#xD;&#xA;  LEFT JOIN QEESSNDATR D&#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.SVS_NODE      = D.SVS_NODE&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'&#xD;&#xA; ORDER BY A.SVS_NODE">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="541" N="SearchSnd">
          <QY P="MsSql" Q="SELECT A.SVS_NODE, A.SVS_NODE_DESC, A.CONTAINER, A.SVS_NODE_GROUP, A.STEP, A.AUTO_START,  B.MODEL, B.MODEL_VER&#xD;&#xA;  FROM QEESSNDDEF A&#xD;&#xA;  LEFT JOIN QEESSNDATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = B.SVS_NODE&#xD;&#xA;   AND B.ATTR_CATEGORY = @attr_category&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.SVS_NODE           = @svs_node&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="attr_category" />
            <QP N="factory" />
            <QP N="svs_node" />
          </QY>
        </SG>
        <SG _S="279" N="InsertSnd">
          <QY P="MsSql" Q="INSERT INTO QEESSNDDEF (&#xD;&#xA;   FACTORY,&#xD;&#xA;   SVS_NODE,&#xD;&#xA;   SVS_NODE_DESC,  &#xD;&#xA;   CONTAINER,&#xD;&#xA;   SVS_NODE_GROUP,&#xD;&#xA;   STEP,&#xD;&#xA;   UP_DOWN,&#xD;&#xA;   STATUS,&#xD;&#xA;   NEED_ACTION,&#xD;&#xA;   NEXT_NEED_ACTION,&#xD;&#xA;   ALARM,&#xD;&#xA;   AUTO_START,&#xD;&#xA;   LAST_EVENT_ID,&#xD;&#xA;   LAST_EVENT_TIME,&#xD;&#xA;   LAST_HIST_SEQ,&#xD;&#xA;   DELETE_FLAG,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @svs_node,&#xD;&#xA;   @svs_node_desc,&#xD;&#xA;   @ctn_name,&#xD;&#xA;   @svs_node_group,&#xD;&#xA;   @step,&#xD;&#xA;   @up_down,&#xD;&#xA;   @status,&#xD;&#xA;   @need_action,&#xD;&#xA;   @next_need_action,&#xD;&#xA;   @alarm,&#xD;&#xA;   @auto_start,&#xD;&#xA;   @last_event_id,&#xD;&#xA;   @last_event_time,&#xD;&#xA;   @last_hist_seq,&#xD;&#xA;   @delete_flag,   &#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="svs_node" />
            <QP N="svs_node_desc" />
            <QP N="ctn_name" />
            <QP N="svs_node_group" />
            <QP N="step" />
            <QP N="up_down" />
            <QP N="status" />
            <QP N="need_action" />
            <QP N="next_need_action" />
            <QP N="alarm" />
            <QP N="auto_start" />
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="last_hist_seq" />
            <QP N="delete_flag" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="281" N="InsertSndAtr">
          <QY P="MsSql" Q="INSERT INTO QEESSNDATR (&#xD;&#xA;   FACTORY,&#xD;&#xA;   SVS_NODE,&#xD;&#xA;   ATTR_CATEGORY,&#xD;&#xA;   MODEL,&#xD;&#xA;   MODEL_VER,&#xD;&#xA;   SVS_NODE_SCHEMA,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @svs_node,&#xD;&#xA;   @attr_category,&#xD;&#xA;   @model,&#xD;&#xA;   @mdl_ver,&#xD;&#xA;   @svs_node_schema,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="svs_node" />
            <QP N="attr_category" />
            <QP N="model" />
            <QP N="mdl_ver" />
            <QP N="svs_node_schema" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="3120" N="InsertSndConfig">
          <QY P="MsSql" Q="INSERT INTO QEESSNDCFG (&#xD;&#xA;   FACTORY,&#xD;&#xA;   SVS_NODE,&#xD;&#xA;   ATTR_CATEGORY,&#xD;&#xA;   OBJ_TYPE,&#xD;&#xA;   OBJ_NAME,&#xD;&#xA;   KEY_SEQ,&#xD;&#xA;   KEY_NAME,&#xD;&#xA;   DATA,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @svs_node,&#xD;&#xA;   @attr_category,&#xD;&#xA;   @obj_type,&#xD;&#xA;   @obj_name,&#xD;&#xA;   @key_seq,&#xD;&#xA;   @key_name,&#xD;&#xA;   @data,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
