        <SG _S="3696" N="InsertBaseNodeConfig">
          <QY P="MsSql" Q="INSERT INTO QEESBNDCFG (&#xD;&#xA;   FACTORY,&#xD;&#xA;   NODE_NAME,&#xD;&#xA;   ATTR_CATEGORY,&#xD;&#xA;   OBJ_TYPE,&#xD;&#xA;   OBJ_NAME,&#xD;&#xA;   KEY_SEQ,&#xD;&#xA;   KEY_NAME,&#xD;&#xA;   DATA,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @node_name,&#xD;&#xA;   @attr_category,&#xD;&#xA;   @obj_type,&#xD;&#xA;   @obj_name,&#xD;&#xA;   @key_seq,&#xD;&#xA;   @key_name,&#xD;&#xA;   @data,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
