      <F _S="785" N="ModelDataPush">
        <SG _S="786" N="SearchModel">
          <QY P="MsSql" Q="SELECT MODEL_DESC&#xD;&#xA;  FROM QEESMDLDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND MODEL  = @model">
            <QP N="factory" />
            <QP N="model" />
          </QY>
        </SG>
      </F>
      <F _S="787" N="ModelVerDataPush">
        <SG _S="788" N="SearchModelVer">
          <QY P="MsSql" Q="SELECT MODEL_VER_DESC, MODEL_RELEASE&#xD;&#xA;  FROM QEESMDLVER&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND MODEL  = @model&#xD;&#xA;   AND MODEL_VER = @mdl_ver">
            <QP N="factory" />
            <QP N="model" />
            <QP N="mdl_ver" />
          </QY>
        </SG>
      </F>
      <F _S="795" N="SndDataPush">
        <SG _S="796" N="SearchSnd">
          <QY P="MsSql" Q="SELECT A.SVS_NODE, A.SVS_NODE_DESC, A.CONTAINER, A.SVS_NODE_GROUP, A.AUTO_START,  A.STEP, A.UP_DOWN, A.STATUS, A.RELOAD_CNT, A.NEED_ACTION, A.NEXT_NEED_ACTION, ALARM,&#xD;&#xA;       ISNULL(B.MODEL, 'N/A') SET_MODEL, ISNULL(B.MODEL_VER, 0) SET_MODEL_VER, ISNULL(C.MODEL, 'N/A') REL_MODEL, ISNULL(C.MODEL_VER, 0) REL_MODEL_VER, ISNULL(D.MODEL, 'N/A') APL_MODEL, ISNULL(D.MODEL_VER, 0) APL_MODEL_VER, &#xD;&#xA;       A.LAST_EVENT_ID,&#xD;&#xA;       D.SVS_NODE_SCHEMA&#xD;&#xA;  FROM QEESSNDDEF A&#xD;&#xA;  WITH (NOLOCK)&#xD;&#xA;  LEFT JOIN QEESSNDATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = B.SVS_NODE&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QEESSNDATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = C.SVS_NODE&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QEESSNDATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = D.SVS_NODE&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.SVS_NODE           = @svs_node&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="factory" />
            <QP N="svs_node" />
          </QY>
        </SG>
        <SG _S="3384" N="SearchControllerSts">
          <QY P="MsSql" Q="SELECT CTRL_NAME, COMM_STATE, CTRL_MODE&#xD;&#xA;  FROM QEESSNDCTL&#xD;&#xA;  WITH (NOLOCK)&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND CTRL_NAME IN&#xD;&#xA;       (&#xD;&#xA;		SELECT DATA&#xD;&#xA;		  FROM QEESSNDCFG&#xD;&#xA;		 WHERE FACTORY       = @factory&#xD;&#xA;		   AND SVS_NODE           = @svs_node&#xD;&#xA;		   AND ATTR_CATEGORY = @attr_category&#xD;&#xA;		   AND KEY_NAME      = @key_eqp_name&#xD;&#xA;       )">
            <QP N="factory" />
            <QP N="svs_node" />
            <QP N="attr_category" />
            <QP N="key_eqp_name" />
          </QY>
        </SG>
        <SG _S="3150" N="SearchConnectorSts">
          <QY P="MsSql" Q="SELECT CNT_SEQ, CNT_NAME, STATE&#xD;&#xA;  FROM QEESSNDCTS&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND SVS_NODE     = @svs_node">
            <QP N="factory" />
            <QP N="svs_node" />
          </QY>
        </SG>
      </F>
      <F _S="3843" N="ContainerDataPush">
        <SG _S="3844" N="SearchContainer">
          <QY P="MsSql" Q="SELECT A.CTN_NAME, A.CTN_DESC, A.STEP, A.UP_DOWN, A.ALARM, A.NEED_ACTION, A.NEXT_NEED_ACTION,  ISNULL(B.PACKAGE, 'N/A')  SET_PACKAGE,  ISNULL(B.PKG_VER, 0) SET_PKG_VER, ISNULL(C.PACKAGE, 'N/A') REL_PACKAGE, ISNULL(C.PKG_VER, 0) REL_PKG_VER, ISNULL(D.PACKAGE, 'N/A') APL_PACKAGE, ISNULL(D.PKG_VER, 0) APL_PKG_VER, LAST_EVENT_ID&#xD;&#xA;  FROM QEESCTNDEF A&#xD;&#xA;  LEFT JOIN QEESCTNATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.CTN_NAME    = B.CTN_NAME&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QEESCTNATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.CTN_NAME    = C.CTN_NAME&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QEESCTNATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.CTN_NAME    = D.CTN_NAME&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.CTN_NAME = @ctn_name&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="factory" />
            <QP N="ctn_name" />
          </QY>
        </SG>
      </F>
      <F _S="3713" N="BaseNodeDataPush">
        <SG _S="3715" N="SearchBaseNode">
          <QY P="MsSql" Q="SELECT A.NODE_NAME, &#xD;&#xA;A.NODE_DESC, &#xD;&#xA;A.CONTAINER,&#xD;&#xA;A.STEP, &#xD;&#xA;A.UP_DOWN, &#xD;&#xA;A.STATUS,&#xD;&#xA;A.ALARM, &#xD;&#xA;A.AUTO_START,&#xD;&#xA;A.AUTO_RELEASE, &#xD;&#xA;A.NEED_ACTION,&#xD;&#xA; A.NEXT_NEED_ACTION, &#xD;&#xA; ISNULL(B.MODEL, 'N/A') SET_MODEL, &#xD;&#xA;ISNULL(B.MODEL_VER, 0) SET_MODEL_VER, &#xD;&#xA;ISNULL(C.MODEL, 'N/A') REL_MODEL, &#xD;&#xA;ISNULL(C.MODEL_VER, 0) REL_MODEL_VER, &#xD;&#xA;ISNULL(D.MODEL, 'N/A') APL_MODEL, &#xD;&#xA;ISNULL(D.MODEL_VER, 0) APL_MODEL_VER, &#xD;&#xA;       A.LAST_EVENT_ID,&#xD;&#xA;       D.NODE_SCHEMA&#xD;&#xA;  FROM QEESBNDDEF A&#xD;&#xA;  WITH (NOLOCK)&#xD;&#xA;  LEFT JOIN QEESBNDATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.NODE_NAME           = B.NODE_NAME&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QEESBNDATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.NODE_NAME           = C.NODE_NAME&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QEESBNDATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.NODE_NAME           = D.NODE_NAME&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.NODE_NAME           = @node_name&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="factory" />
            <QP N="node_name" />
          </QY>
        </SG>
        <SG _S="3716" N="SearchConnectorSts">
          <QY P="MsSql" Q="SELECT CNT_SEQ, CNT_NAME, STATE&#xD;&#xA;  FROM QEESBNDCTS&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND NODE_NAME= @node_name">
            <QP N="factory" />
            <QP N="node_name" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="1419" N="DataPurge">
      <F _S="1420" N="DataPurge">
        <SG _S="1427" N="SearchFactory">
          <QY P="MsSql" Q="SELECT FACTORY&#xD;&#xA; FROM QSYSFACDEF" />
        </SG>
        <SG _S="4138" N="SearchPurgeTable">
          <QY P="MsSql" Q="SELECT DATA_2 AS TABLE_NAME, DATA_3 AS TIME_COLUMN, DATA_4 AS PURGE_SCHEDULE&#xD;&#xA;  FROM QGCMTBLDAT&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND TABLE_NAME = 'HISTORY_PURGE'&#xD;&#xA;   AND DATA_1     = 'EES'">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="4139" N="ExecPurgeHistory" IPC="T">
          <QY P="MsSql" Q="SP_PURGE_HISTORY @table_name, @factory, @time_column, @purge_time, @purge_count">
            <QP N="table_name" />
            <QP N="factory" />
            <QP N="time_column" />
            <QP N="purge_time" />
            <QP N="purge_count" />
          </QY>
        </SG>
        <SG _S="3855" N="DeleteContainerHistory" UMG="No" D="Not Used">
          <QY P="MsSql" Q="WITH TMP_DELETE AS (&#xD;&#xA;	SELECT TRAN_TIME, ROW_NUMBER() OVER(ORDER BY TRAN_TIME) AS ROWNUM &#xD;&#xA;		FROM QEESCTNHIS&#xD;&#xA;		WHERE FACTORY = @factory&#xD;&#xA;		AND TRAN_TIME &lt; @tran_time&#xD;&#xA;)&#xD;&#xA;DELETE FROM TMP_DELETE WHERE ROWNUM &lt;= @delete_cnt">
            <QP N="factory" />
            <QP N="tran_time" />
            <QP N="delete_cnt" />
          </QY>
        </SG>
        <SG _S="1424" N="DeleteSndHistory" UMG="No" D="Not Used">
          <QY P="MsSql" Q="WITH TMP_DELETE AS (&#xD;&#xA;	SELECT TRAN_TIME, ROW_NUMBER() OVER(ORDER BY TRAN_TIME) AS ROWNUM &#xD;&#xA;		FROM QEESSNDHIS&#xD;&#xA;		WHERE FACTORY = @factory&#xD;&#xA;		AND TRAN_TIME &lt; @tran_time&#xD;&#xA;)&#xD;&#xA;DELETE FROM TMP_DELETE WHERE ROWNUM &lt;= @delete_cnt">
            <QP N="factory" />
            <QP N="tran_time" />
            <QP N="delete_cnt" />
          </QY>
        </SG>
        <SG _S="3744" N="DeleteBaseNodeHistory" UMG="No" D="Not Used">
          <QY P="MsSql" Q="WITH TMP_DELETE AS (&#xD;&#xA;	SELECT TRAN_TIME, ROW_NUMBER() OVER(ORDER BY TRAN_TIME) AS ROWNUM &#xD;&#xA;		FROM QEESBNDHIS&#xD;&#xA;		WHERE FACTORY = @factory&#xD;&#xA;		AND TRAN_TIME &lt; @tran_time&#xD;&#xA;)&#xD;&#xA;DELETE FROM TMP_DELETE WHERE ROWNUM &lt;= @delete_cnt">
            <QP N="factory" />
            <QP N="tran_time" />
            <QP N="delete_cnt" />
          </QY>
        </SG>
        <SG _S="3408" N="DeleteEquipmentHistory" UMG="No" D="Not Used">
          <QY P="MsSql" Q="WITH TMP_DELETE AS (&#xD;&#xA;	SELECT TRAN_TIME, ROW_NUMBER() OVER(ORDER BY TRAN_TIME) AS ROWNUM &#xD;&#xA;		FROM QEESEQPHIS&#xD;&#xA;		WHERE FACTORY = @factory&#xD;&#xA;		AND TRAN_TIME &lt; @tran_time&#xD;&#xA;)&#xD;&#xA;DELETE FROM TMP_DELETE WHERE ROWNUM &lt;= @delete_cnt">
            <QP N="factory" />
            <QP N="tran_time" />
            <QP N="delete_cnt" />
          </QY>
        </SG>
        <SG _S="3745" N="DeleteAlarmHistory" UMG="No" D="Not Used">
          <QY P="MsSql" Q="WITH TMP_DELETE AS (&#xD;&#xA;	SELECT SET_TIME, ROW_NUMBER() OVER(ORDER BY SET_TIME) AS ROWNUM &#xD;&#xA;		FROM QEESALMHIS&#xD;&#xA;		WHERE FACTORY = @factory&#xD;&#xA;		AND SET_TIME &lt; @tran_time&#xD;&#xA;)&#xD;&#xA;DELETE FROM TMP_DELETE WHERE ROWNUM &lt;= @delete_cnt">
            <QP N="factory" />
            <QP N="tran_time" />
            <QP N="delete_cnt" />
          </QY>
        </SG>
        <SG _S="3782" N="DeleteOEEData" UMG="No" D="Not Used">
          <QY P="MsSql" Q="WITH TMP_DELETE AS (&#xD;&#xA;	SELECT TRAN_TIME, ROW_NUMBER() OVER(ORDER BY TRAN_TIME) AS ROWNUM &#xD;&#xA;		FROM QEESOEERPT&#xD;&#xA;		WHERE HIS_MONTH &lt;= @his_month&#xD;&#xA;		AND FACTORY = @factory&#xD;&#xA;		AND TRAN_TIME &lt; @tran_time&#xD;&#xA;)&#xD;&#xA;DELETE FROM TMP_DELETE WHERE ROWNUM &lt;= @delete_cnt">
            <QP N="his_month" />
            <QP N="factory" />
            <QP N="tran_time" />
            <QP N="delete_cnt" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="3544" N="Modeling" D="Modeling">
      <F _S="3545" N="ModelingHistory">
        <SG _S="3546" N="InsertMdlHistory">
          <QY P="MsSql" Q="INSERT INTO QEESBMLHIS(&#xD;&#xA;   FACTORY,&#xD;&#xA;   USER_ID,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   EVENT_ID,&#xD;&#xA;   ACTION,&#xD;&#xA;   SYSTEM,&#xD;&#xA;   HOST_IP,&#xD;&#xA;   HOST_NAME,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   EVT_H_1,&#xD;&#xA;   EVT_D_1,&#xD;&#xA;   EVT_H_2,&#xD;&#xA;   EVT_D_2,&#xD;&#xA;   EVT_H_3,&#xD;&#xA;   EVT_D_3,&#xD;&#xA;   EVT_H_4,&#xD;&#xA;   EVT_D_4,&#xD;&#xA;   EVT_H_5,&#xD;&#xA;   EVT_D_5,&#xD;&#xA;   EVT_H_6,&#xD;&#xA;   EVT_D_6,&#xD;&#xA;   EVT_H_7,&#xD;&#xA;   EVT_D_7,&#xD;&#xA;   EVT_H_8,&#xD;&#xA;   EVT_D_8,&#xD;&#xA;   EVT_H_9,&#xD;&#xA;   EVT_D_9,&#xD;&#xA;   EVT_H_10,&#xD;&#xA;   EVT_D_10,    &#xD;&#xA;   EVT_H_11,&#xD;&#xA;   EVT_D_11,&#xD;&#xA;   EVT_H_12,&#xD;&#xA;   EVT_D_12,&#xD;&#xA;   EVT_H_13,&#xD;&#xA;   EVT_D_13,&#xD;&#xA;   EVT_H_14,&#xD;&#xA;   EVT_D_14,&#xD;&#xA;   EVT_H_15,&#xD;&#xA;   EVT_D_15,&#xD;&#xA;   EVT_H_16,&#xD;&#xA;   EVT_D_16,&#xD;&#xA;   EVT_H_17,&#xD;&#xA;   EVT_D_17,&#xD;&#xA;   EVT_H_18,&#xD;&#xA;   EVT_D_18,&#xD;&#xA;   EVT_H_19,&#xD;&#xA;   EVT_D_19,&#xD;&#xA;   EVT_H_20,&#xD;&#xA;   EVT_D_20,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @user_id,&#xD;&#xA;   @hist_seq,&#xD;&#xA;   @event_id, &#xD;&#xA;   @action, &#xD;&#xA;   @system,&#xD;&#xA;   @host_ip,&#xD;&#xA;   @host_name,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @evt_h_1,&#xD;&#xA;   @evt_d_1,   &#xD;&#xA;   @evt_h_2,&#xD;&#xA;   @evt_d_2,&#xD;&#xA;   @evt_h_3,&#xD;&#xA;   @evt_d_3,&#xD;&#xA;   @evt_h_4,&#xD;&#xA;   @evt_d_4,&#xD;&#xA;   @evt_h_5,&#xD;&#xA;   @evt_d_5,&#xD;&#xA;   @evt_h_6,&#xD;&#xA;   @evt_d_6,&#xD;&#xA;   @evt_h_7,&#xD;&#xA;   @evt_d_7,&#xD;&#xA;   @evt_h_8,&#xD;&#xA;   @evt_d_8,&#xD;&#xA;   @evt_h_9,&#xD;&#xA;   @evt_d_9,&#xD;&#xA;   @evt_h_10,&#xD;&#xA;   @evt_d_10,&#xD;&#xA;   @evt_h_11,&#xD;&#xA;   @evt_d_11,   &#xD;&#xA;   @evt_h_12,&#xD;&#xA;   @evt_d_12,&#xD;&#xA;   @evt_h_13,&#xD;&#xA;   @evt_d_13,&#xD;&#xA;   @evt_h_14,&#xD;&#xA;   @evt_d_14,&#xD;&#xA;   @evt_h_15,&#xD;&#xA;   @evt_d_15,&#xD;&#xA;   @evt_h_16,&#xD;&#xA;   @evt_d_16,&#xD;&#xA;   @evt_h_17,&#xD;&#xA;   @evt_d_17,&#xD;&#xA;   @evt_h_18,&#xD;&#xA;   @evt_d_18,&#xD;&#xA;   @evt_h_19,&#xD;&#xA;   @evt_d_19,&#xD;&#xA;   @evt_h_20,&#xD;&#xA;   @evt_d_20,   &#xD;&#xA;   @tran_user_id,&#xD;&#xA;   @tran_comment&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="user_id" />
            <QP N="hist_seq" />
            <QP N="event_id" />
            <QP N="action" />
            <QP N="system" />
            <QP N="host_ip" />
            <QP N="host_name" />
            <QP N="tran_time" />
            <QP N="evt_h_1" />
            <QP N="evt_d_1" />
            <QP N="evt_h_2" />
            <QP N="evt_d_2" />
            <QP N="evt_h_3" />
            <QP N="evt_d_3" />
            <QP N="evt_h_4" />
            <QP N="evt_d_4" />
            <QP N="evt_h_5" />
            <QP N="evt_d_5" />
            <QP N="evt_h_6" />
            <QP N="evt_d_6" />
            <QP N="evt_h_7" />
            <QP N="evt_d_7" />
            <QP N="evt_h_8" />
            <QP N="evt_d_8" />
            <QP N="evt_h_9" />
            <QP N="evt_d_9" />
            <QP N="evt_h_10" />
            <QP N="evt_d_10" />
            <QP N="evt_h_11" />
            <QP N="evt_d_11" />
            <QP N="evt_h_12" />
            <QP N="evt_d_12" />
            <QP N="evt_h_13" />
            <QP N="evt_d_13" />
            <QP N="evt_h_14" />
            <QP N="evt_d_14" />
            <QP N="evt_h_15" />
            <QP N="evt_d_15" />
            <QP N="evt_h_16" />
            <QP N="evt_d_16" />
            <QP N="evt_h_17" />
            <QP N="evt_d_17" />
            <QP N="evt_h_18" />
            <QP N="evt_d_18" />
            <QP N="evt_h_19" />
            <QP N="evt_d_19" />
            <QP N="evt_h_20" />
            <QP N="evt_d_20" />
            <QP N="tran_user_id" />
            <QP N="tran_comment" />
          </QY>
        </SG>
        <SG _S="3548" N="SelectModelingSeq">
          <QY P="MsSql" Q="SELECT NEXT VALUE FOR SEQ_EES_BML_HIS" />
        </SG>
      </F>
      <F _S="3553" N="ModelingRevert">
        <SG _S="3554" N="HasRevision">
          <QY P="MsSql" Q="SELECT * FROM QEESBMLHIS &#xD;&#xA;WHERE FACTORY = @factory&#xD;&#xA; AND HIST_SEQ = @hist_seq">
            <QP N="factory" />
            <QP N="hist_seq" />
          </QY>
        </SG>
        <SG _S="3555" N="DeleteModelingHistory">
          <QY P="MsSql" Q="DELETE FROM QEESBMLHIS WHERE FACTORY = @factory AND HIST_SEQ &gt; @hist_seq">
            <QP N="factory" />
            <QP N="hist_seq" />
          </QY>
        </SG>
      </F>
      <F _S="3689" N="ModelingRelease">
        <SG _S="3690" N="InsertReleaseModel">
          <QY P="MsSql" Q="INSERT INTO QEESBMLVER (&#xD;&#xA;   FACTORY,&#xD;&#xA;   BASE_MODEL,&#xD;&#xA;   BASE_MODEL_VER,&#xD;&#xA;   BASE_MODEL_VER_PATH,&#xD;&#xA;   BASE_MODEL_COMMENT,&#xD;&#xA;   BASE_MODEL_SCHEMA,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @model,&#xD;&#xA;   @mdl_ver,&#xD;&#xA;   @mdl_ver_path,&#xD;&#xA;   @mdl_comment,&#xD;&#xA;   @mdl_schema,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="model" />
            <QP N="mdl_ver" />
            <QP N="mdl_ver_path" />
            <QP N="mdl_comment" />
            <QP N="mdl_schema" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="3691" N="SelectReleaseVer">
          <QY P="MsSql" Q="SELECT NEXT VALUE FOR SEQ_EES_REL_VER" />
        </SG>
        <SG _S="3700" N="ListReleaseVer">
          <QY P="MsSql" Q="SELECT BASE_MODEL, BASE_MODEL_VER, BASE_MODEL_VER_PATH, CREATE_TIME, UPDATE_TIME&#xD;&#xA;  FROM QEESBMLVER&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY BASE_MODEL_VER DESC">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3701" N="SearchReleaseVer">
          <QY P="MsSql" Q="SELECT BASE_MODEL, BASE_MODEL_VER, BASE_MODEL_COMMENT, BASE_MODEL_VER_PATH&#xD;&#xA;  FROM QEESBMLVER&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND BASE_MODEL  = @model&#xD;&#xA;   AND BASE_MODEL_VER  = @mdl_ver">
            <QP N="factory" />
            <QP N="model" />
            <QP N="mdl_ver" />
          </QY>
        </SG>
        <SG _S="3768" N="ListBaseNode">
          <QY P="MsSql" Q="SELECT A.NODE_NAME, &#xD;&#xA;A.NODE_DESC, &#xD;&#xA;A.STEP, &#xD;&#xA;A.UP_DOWN, &#xD;&#xA;A.STATUS, &#xD;&#xA;A.ALARM, &#xD;&#xA;A.AUTO_RELEASE, &#xD;&#xA;A.NEED_ACTION, &#xD;&#xA;A.NEXT_NEED_ACTION,&#xD;&#xA;ISNULL(B.MODEL, 'N/A') SET_MODEL, &#xD;&#xA;ISNULL(B.MODEL_VER, 0) SET_MODEL_VER, &#xD;&#xA;ISNULL(C.MODEL, 'N/A') REL_MODEL, &#xD;&#xA;ISNULL(C.MODEL_VER, 0) REL_MODEL_VER, &#xD;&#xA;ISNULL(D.MODEL, 'N/A') APL_MODEL, &#xD;&#xA;ISNULL(D.MODEL_VER, 0) APL_MODEL_VER&#xD;&#xA;         FROM QEESBNDDEF A&#xD;&#xA;  LEFT JOIN QEESBNDATR B &#xD;&#xA;    ON A.FACTORY = B.FACTORY&#xD;&#xA;   AND A.NODE_NAME = B.NODE_NAME&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QEESBNDATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.NODE_NAME           = C.NODE_NAME&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QEESBNDATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.NODE_NAME           = D.NODE_NAME&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'&#xD;&#xA;  ORDER BY A.NODE_NAME">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3772" N="HasReleaseVersion">
          <QY P="MsSql" Q="SELECT BASE_MODEL, BASE_MODEL_VER, BASE_MODEL_COMMENT, BASE_MODEL_VER_PATH&#xD;&#xA;  FROM QEESBMLVER&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND BASE_MODEL_VER  = @mdl_ver">
            <QP N="factory" />
            <QP N="mdl_ver" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="4174" N="ContainerWatcher">
      <F _S="4175" N="WatcherControl">
        <SG _S="4176" N="ListContainer">
          <QY P="MsSql" Q="SELECT CTN_NAME, UP_DOWN, DELETE_FLAG&#xD;&#xA;  FROM QEESCTNDEF&#xD;&#xA; WHERE FACTORY     = @factory">
            <QP N="factory" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="4177" N="ListFactory">
          <QY P="MsSql" Q="SELECT FACTORY&#xD;&#xA;  FROM QSYSFACDEF" />
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="4184" N="UpdateContainer">
          <QY P="MsSql" Q="UPDATE QEESCTNDEF SET&#xD;&#xA;  UP_DOWN         = @up_down,&#xD;&#xA;  LAST_EVENT_ID   = @last_event_id,&#xD;&#xA;  LAST_EVENT_TIME = @last_event_time,&#xD;&#xA;  LAST_HIST_SEQ   = @hist_seq,&#xD;&#xA;  UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;  UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND CTN_NAME   = @ctn_name">
            <QP N="up_down" />
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="hist_seq" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="ctn_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="4183" N="HasContainer">
          <QY P="MsSql" Q="SELECT CTN_NAME, UP_DOWN, STEP&#xD;&#xA;  FROM QEESCTNDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND CTN_NAME    = @ctn_name&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="ctn_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
      </F>
      <F _S="4178" N="AbnormalDetect">
        <SG _S="4181" N="UpdateContainer_Start">
          <QY P="MsSql" Q="UPDATE QEESCTNDEF SET&#xD;&#xA;  LAST_EVENT_ID   = @last_event_id,&#xD;&#xA;  LAST_EVENT_TIME = @last_event_time,&#xD;&#xA;  LAST_HIST_SEQ   = @hist_seq,&#xD;&#xA;  UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;  UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND CTN_NAME   = @ctn_name">
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="hist_seq" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="ctn_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="4182" N="UpdateContainer_Abort">
          <QY P="MsSql" Q="UPDATE QEESCTNDEF SET&#xD;&#xA;  UP_DOWN         = @up_down,&#xD;&#xA;  LAST_EVENT_ID   = @last_event_id,&#xD;&#xA;  LAST_EVENT_TIME = @last_event_time,&#xD;&#xA;  LAST_HIST_SEQ   = @hist_seq,&#xD;&#xA;  UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;  UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND CTN_NAME   = @ctn_name">
            <QP N="up_down" />
