        <SG _S="1344" N="HasVariableIdGroup">
          <QY P="MsSql" Q="SELECT VID_GROUP, RANGE_FROM, RANGE_TO&#xD;&#xA;  FROM QSYSPTMVGP&#xD;&#xA; WHERE FACTORY   = @factory">
