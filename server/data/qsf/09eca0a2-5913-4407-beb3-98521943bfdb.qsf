        <SG _S="1369" N="InsertVariableLink">
          <QY P="MsSql" Q="INSERT INTO QSYSPTMPVL (&#xD;&#xA;   FACTORY,&#xD;&#xA;   TAGSET_GROUP,&#xD;&#xA;   TAGSET_NAME,&#xD;&#xA;   TAG_CATEGORY,&#xD;&#xA;   TAG_NAME,&#xD;&#xA;   VID,&#xD;&#xA;   TAG_DESC,&#xD;&#xA;   TAG_REGISTER,&#xD;&#xA;   TAG_DEC_ADDRESS,&#xD;&#xA;   TAG_FULL_ADDRESS,&#xD;&#xA;   TAG_INPUT_ADDRESS,&#xD;&#xA;   TAG_TYPE,&#xD;&#xA;   TAG_FORMAT,&#xD;&#xA;   TAG_PLC_FORMAT,&#xD;&#xA;   TAG_LENGTH,&#xD;&#xA;   TAG_ALARM,&#xD;&#xA;   TAG_BRANCH,&#xD;&#xA;   IS_LINKED,&#xD;&#xA;   IS_RETIRED,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @tagset_group,&#xD;&#xA;   @tagset_name,&#xD;&#xA;   @tag_category,&#xD;&#xA;   @tag_name,&#xD;&#xA;   @vid,&#xD;&#xA;   @tag_desc,&#xD;&#xA;   @tag_register,&#xD;&#xA;   @tag_dec_address,&#xD;&#xA;   @tag_full_address,&#xD;&#xA;   @tag_input_address,&#xD;&#xA;   @tag_type,&#xD;&#xA;   @tag_format,&#xD;&#xA;   @tag_plc_format,&#xD;&#xA;   @tag_length,&#xD;&#xA;   @tag_alarm,&#xD;&#xA;   @tag_branch,&#xD;&#xA;   @is_linked,&#xD;&#xA;   @is_retired,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;   )">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
            <QP N="tag_category" />
            <QP N="tag_name" />
            <QP N="vid" />
            <QP N="tag_desc" />
            <QP N="tag_register" />
            <QP N="tag_dec_address" />
            <QP N="tag_full_address" />
            <QP N="tag_input_address" />
            <QP N="tag_type" />
            <QP N="tag_format" />
            <QP N="tag_plc_format" />
            <QP N="tag_length" />
            <QP N="tag_alarm" />
            <QP N="tag_branch" />
            <QP N="is_linked" />
            <QP N="is_retired" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="1370" N="ListVariableLink">
          <QY P="MsSql" Q="SELECT TAG_CATEGORY, TAG_NAME, TAG_DESC, VID,&#xD;&#xA;       TAG_REGISTER, TAG_DEC_ADDRESS, TAG_FULL_ADDRESS,	TAG_INPUT_ADDRESS,&#xD;&#xA;       TAG_PLC_FORMAT, TAG_FORMAT, TAG_LENGTH, TAG_ALARM, TAG_TYPE, TAG_BRANCH, &#xD;&#xA;	   IS_LINKED, IS_RETIRED&#xD;&#xA;  FROM QSYSPTMPVL&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME  = @tagset_name&#xD;&#xA; ORDER BY TAG_CATEGORY, TAG_NAME">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="1371" N="ListPlcTagSet">
          <QY P="MsSql" Q="SELECT A.TAGSET_NAME, A.TAGSET_DESC, A.TAGSET_LAST_VER, &#xD;&#xA;       A.TAGSET_PLC_MAKER, A.TAGSET_PLC_MODEL,&#xD;&#xA;	   A.TAGSET_OPER, A.TAGSET_AREA, A.TAGSET_LINE,&#xD;&#xA;	   A.CMF_1, A.CMF_2, A.CMF_3, A.CMF_4, A.CMF_5, &#xD;&#xA;	   A.CMF_6, A.CMF_7, A.CMF_8, A.CMF_9, A.CMF_10, &#xD;&#xA;       A.CREATE_TIME, CASE WHEN USER_C.USER_NAME IS NULL THEN A.CREATE_USER_ID ELSE CONCAT(A.CREATE_USER_ID, ' [', USER_C.USER_NAME, ']') END AS CREATE_USER , &#xD;&#xA;       A.UPDATE_TIME, CASE WHEN USER_U.USER_NAME IS NULL THEN A.UPDATE_USER_ID ELSE CONCAT(A.UPDATE_USER_ID, ' [', USER_U.USER_NAME, ']') END AS UPDATE_USER&#xD;&#xA;  FROM (&#xD;&#xA;SELECT *&#xD;&#xA;  FROM QSYSPTMDEF&#xD;&#xA; WHERE FACTORY      = @factory   &#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;       )  A&#xD;&#xA;  LEFT JOIN QSECUSRDEF USER_C&#xD;&#xA;    ON A.FACTORY        = USER_C.FACTORY&#xD;&#xA;   AND A.CREATE_USER_ID = USER_C.USER_ID&#xD;&#xA;  LEFT JOIN QSECUSRDEF USER_U&#xD;&#xA;    ON A.FACTORY        = USER_U.FACTORY&#xD;&#xA;   AND A.UPDATE_USER_ID = USER_U.USER_ID&#xD;&#xA; ORDER BY A.TAGSET_NAME">
            <QP N="factory" />
            <QP N="tagset_group" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="1372" N="ListPlcTagSetGroup">
          <QY P="MsSql" Q="SELECT GROUP_NAME, GROUP_DESC&#xD;&#xA;  FROM QSYSPTMGRP&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
