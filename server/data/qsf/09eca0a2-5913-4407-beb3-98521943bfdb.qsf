        <SG _S="1021" N="SearchEapAtr">
          <QY P="MsSql" Q="SELECT EAP, EAP_SCHEMA&#xD;&#xA;  FROM QRASEAPATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP           = @eap&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
