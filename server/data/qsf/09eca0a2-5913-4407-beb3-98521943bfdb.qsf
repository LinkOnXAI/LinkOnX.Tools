      <F _S="1019" N="EapReloadSuccess">
        <SG _S="1020" N="SearchEap">
          <QY P="MsSql" Q="SELECT EAP, SERVER, UP_DOWN, STATUS, STEP, NEED_ACTION, NEXT_NEED_ACTION&#xD;&#xA;  FROM QRASEAPDEF&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP           = @eap&#xD;&#xA;   AND DELETE_FLAG   = 'N'">
