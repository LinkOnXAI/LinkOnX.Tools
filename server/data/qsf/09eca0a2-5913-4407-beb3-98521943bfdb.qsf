        <SG _S="1307" N="SearchSuggestByAllTagsetGroup">
          <QY P="MsSql" Q="WITH C AS&#xA;(&#xA;    SELECT TAG_NAME, LOGICAL_TAG, COUNT(*) AS CNT&#xA;      FROM QSYSPTMPLL&#xA;     WHERE FACTORY      = @factory&#xA;       AND TAG_NAME     = @tag_name&#xA;       AND IS_LINKED    = @is_linked&#xA;       AND LOGICAL_TAG &lt;&gt; ' '&#xA;     GROUP BY TAG_NAME, LOGICAL_TAG&#xA;),&#xA;R AS&#xA;(&#xA;    SELECT TAG_NAME, LOGICAL_TAG, CNT,&#xA;           RANK() OVER&#xA;           (&#xA;               PARTITION BY TAG_NAME&#xA;               ORDER BY CNT DESC&#xA;           ) AS RN&#xA;      FROM C&#xA;)&#xA;SELECT LOGICAL_TAG, CNT&#xA;  FROM R&#xA; WHERE RN = 1&#xA; ORDER BY CNT DESC, LOGICAL_TAG ASC">
            <QP N="factory&#xA;" />
            <QP N="tag_name&#xA;" />
            <QP N="is_linked&#xA;" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="1308" N="SearchSuggestBySameTagsetGroup">
          <QY P="MsSql" Q="WITH C AS&#xA;(&#xA;    SELECT TAG_NAME, LOGICAL_TAG, COUNT(*) AS CNT&#xA;      FROM QSYSPTMPLL&#xA;     WHERE FACTORY      = @factory&#xD;&#xA;       AND TAGSET_GROUP = @tagset_group&#xA;       AND TAG_NAME     = @tag_name&#xA;       AND IS_LINKED    = @is_linked&#xA;       AND LOGICAL_TAG &lt;&gt; ' '&#xA;     GROUP BY TAG_NAME, LOGICAL_TAG&#xA;),&#xA;R AS&#xA;(&#xA;    SELECT TAG_NAME, LOGICAL_TAG, CNT,&#xA;           RANK() OVER&#xA;           (&#xA;               PARTITION BY TAG_NAME&#xA;               ORDER BY CNT DESC&#xA;           ) AS RN&#xA;      FROM C&#xA;)&#xA;SELECT LOGICAL_TAG, CNT&#xA;  FROM R&#xA; WHERE RN = 1&#xA; ORDER BY CNT DESC, LOGICAL_TAG ASC">
            <QP N="factory" />
            <QP N="tagset_group&#xA;" />
            <QP N="tag_name&#xA;" />
            <QP N="is_linked&#xA;" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
