        </SG>
      </F>
      <F _S="1217" N="EquipmentPlcTagQuickRead">
        <SG _S="1219" N="HasEap">
          <QY P="MsSql" Q="SELECT EAP&#xD;&#xA;  FROM QRASEAPDEF  &#xD;&#xA;  WITH (UPDLOCK)&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EAP         = @eap&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
