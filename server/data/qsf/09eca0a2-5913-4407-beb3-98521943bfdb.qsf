        <SG _S="271" N="ListUserGroupAlert" UMG="No">
          <QY P="MsSql" Q="SELECT A.EVENT_ID, (CASE WHEN A.EVENT_TYPE = 'Server' THEN B.EVENT_DESC WHEN A.EVENT_TYPE = 'EAP' THEN C.EVENT_DESC WHEN A.EVENT_TYPE = 'Equipment' THEN D.EVENT_DESC END)&#xD;&#xA;  FROM QSECURGALT A&#xD;&#xA;  LEFT JOIN QSYSSVREVT B&#xD;&#xA;    ON A.FACTORY  = B.FACTORY&#xD;&#xA;   AND A.EVENT_ID = B.EVENT_ID&#xD;&#xA;  LEFT JOIN QRASEAPEVT C&#xD;&#xA;    ON A.FACTORY  = C.FACTORY&#xD;&#xA;   AND A.EVENT_ID = C.EVENT_ID&#xD;&#xA;  LEFT JOIN QRASEQPEVT D&#xD;&#xA;    ON A.FACTORY  = D.FACTORY&#xD;&#xA;   AND A.FACTORY  = D.EVENT_ID&#xD;&#xA; WHERE A.FACTORY    = @factory&#xD;&#xA;   AND A.USER_GRP   = @user_grp&#xD;&#xA;   AND A.EVENT_TYPE = @event_type">
            <QP N="factory" />
            <QP N="user_grp" />
            <QP N="event_type" />
          </QY>
        </SG>
