      <F _S="907" N="ComponentStatus">
        <SG _S="908" N="ListComponentVer">
          <QY P="MsSql" Q="SELECT COM_VER, COM_VER_DESC, COM_RELEASE &#xD;&#xA;  FROM QSCOMVER&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND COMPONENT = @component&#xD;&#xA; ORDER BY COM_VER DESC">
            <QP N="factory" />
            <QP N="component" />
          </QY>
        </SG>
        <SG _S="909" N="SearchComponent">
          <QY P="MsSql" Q="SELECT A.COMPONENT, A.COM_DESC, A.COM_TYPE,&#xD;&#xA;       A.REL_COM_VER, A.LAST_COM_VER,&#xD;&#xA;       B.COM_VER, B.COM_RELEASE, B.COM_VER_DESC,&#xD;&#xA;       B.COM_VER_PATH, B.COM_COMMENT,&#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME, &#xD;&#xA;       A.UPDATE_USER_ID, A.UPDATE_TIME&#xD;&#xA;  FROM QSCOMDEF A&#xD;&#xA; INNER JOIN QSCOMVER B&#xD;&#xA;    ON A.FACTORY   = B.FACTORY&#xD;&#xA;   AND A.COMPONENT = B.COMPONENT&#xD;&#xA; WHERE A.FACTORY   = @factory &#xD;&#xA;   AND A.COMPONENT = @component&#xD;&#xA;   AND B.COM_VER   = @com_ver">
            <QP N="factory" />
            <QP N="component" />
            <QP N="com_ver" />
