            <QP N="evt_h_20" />
            <QP N="evt_d_20" />
            <QP N="tran_user_id" />
            <QP N="tran_comment" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
