        </SG>
      </F>
      <F _S="462" N="CustomRemoteCommand">
        <SG _S="463" N="HasCommand">
          <QY P="MsSql" Q="SELECT COMMAND&#xD;&#xA;  FROM QRASCUSRCM&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND COMMAND = @command">
            <QP N="factory" />
            <QP N="command" />
          </QY>
        </SG>
        <SG _S="464" N="ListCommand">
          <QY P="MsSql" Q="SELECT COMMAND, CMD_DESC, CREATE_TIME&#xD;&#xA;  FROM QRASCUSRCM&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY COMMAND">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="465" N="SearchCommand">
          <QY P="MsSql" Q="SELECT COMMAND, CMD_DESC, &#xD;&#xA;       DATA_1_PRT, DATA_2_PRT, DATA_3_PRT, DATA_4_PRT, DATA_5_PRT, &#xD;&#xA;       DATA_6_PRT, DATA_7_PRT, DATA_8_PRT, DATA_9_PRT, DATA_10_PRT,&#xD;&#xA;       DATA_11_PRT, DATA_12_PRT, DATA_13_PRT, DATA_14_PRT, DATA_15_PRT, &#xD;&#xA;       DATA_16_PRT, DATA_17_PRT, DATA_18_PRT, DATA_19_PRT, DATA_20_PRT,&#xD;&#xA;       CREATE_TIME&#xD;&#xA;  FROM QRASCUSRCM&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND COMMAND = @command&#xD;&#xA; ORDER BY COMMAND">
            <QP N="factory" />
            <QP N="command" />
          </QY>
        </SG>
        <SG _S="466" N="InsertCommand">
          <QY P="MsSql" Q="INSERT INTO QRASCUSRCM (&#xD;&#xA;   FACTORY,&#xD;&#xA;   COMMAND,&#xD;&#xA;   CMD_DESC,&#xD;&#xA;   DATA_1_PRT,&#xD;&#xA;   DATA_2_PRT,&#xD;&#xA;   DATA_3_PRT,&#xD;&#xA;   DATA_4_PRT,&#xD;&#xA;   DATA_5_PRT,&#xD;&#xA;   DATA_6_PRT,&#xD;&#xA;   DATA_7_PRT,&#xD;&#xA;   DATA_8_PRT,&#xD;&#xA;   DATA_9_PRT,&#xD;&#xA;   DATA_10_PRT,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @command,&#xD;&#xA;   @cmd_desc,&#xD;&#xA;   @data_1_prt,&#xD;&#xA;   @data_2_prt,&#xD;&#xA;   @data_3_prt,&#xD;&#xA;   @data_4_prt,&#xD;&#xA;   @data_5_prt,&#xD;&#xA;   @data_6_prt,&#xD;&#xA;   @data_7_prt,&#xD;&#xA;   @data_8_prt,&#xD;&#xA;   @data_9_prt,&#xD;&#xA;   @data_10_prt,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="command" />
            <QP N="cmd_desc" />
            <QP N="data_1_prt" />
            <QP N="data_2_prt" />
            <QP N="data_3_prt" />
            <QP N="data_4_prt" />
            <QP N="data_5_prt" />
            <QP N="data_6_prt" />
            <QP N="data_7_prt" />
            <QP N="data_8_prt" />
            <QP N="data_9_prt" />
            <QP N="data_10_prt" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="467" N="UpdateCommand">
          <QY P="MsSql" Q="UPDATE QRASCUSRCM SET&#xD;&#xA;  CMD_DESC        = @cmd_desc,&#xD;&#xA;  DATA_1_PRT      = @data_1_prt,&#xD;&#xA;  DATA_2_PRT      = @data_2_prt,&#xD;&#xA;  DATA_3_PRT      = @data_3_prt,&#xD;&#xA;  DATA_4_PRT      = @data_4_prt,&#xD;&#xA;  DATA_5_PRT      = @data_5_prt,&#xD;&#xA;  DATA_6_PRT      = @data_6_prt,&#xD;&#xA;  DATA_7_PRT      = @data_7_prt,&#xD;&#xA;  DATA_8_PRT      = @data_8_prt,&#xD;&#xA;  DATA_9_PRT      = @data_9_prt,&#xD;&#xA;  DATA_10_PRT     = @data_10_prt,&#xD;&#xA;  UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;  UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND COMMAND    = @command">
            <QP N="cmd_desc" />
            <QP N="data_1_prt" />
            <QP N="data_2_prt" />
            <QP N="data_3_prt" />
            <QP N="data_4_prt" />
            <QP N="data_5_prt" />
            <QP N="data_6_prt" />
            <QP N="data_7_prt" />
            <QP N="data_8_prt" />
            <QP N="data_9_prt" />
            <QP N="data_10_prt" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="command" />
          </QY>
        </SG>
        <SG _S="468" N="DeleteCommand">
          <QY P="MsSql" Q="DELETE &#xD;&#xA;  FROM QRASCUSRCM&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND COMMAND = @command">
            <QP N="factory" />
            <QP N="command" />
          </QY>
        </SG>
      </F>
      <F _S="469" N="Branch">
        <SG _S="470" N="SearchEapAppliedModel">
          <QY P="MsSql" Q="SELECT MODEL, MDL_VER&#xD;&#xA;  FROM QRASEAPATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP = &#xD;&#xA;       (&#xD;&#xA;SELECT EAP&#xD;&#xA;  FROM QRASEQPDEF&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EQP_NAME      = @eqp_name&#xD;&#xA;   AND DELETE_FLAG   = 'N'&#xD;&#xA;       )&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="attr_category" />
          </QY>
        </SG>
        <SG _S="471" N="SearchEapAppliedModelTag">
          <QY P="MsSql" Q="SELECT CNT_NAME, CNT_RK, PLC_TAG_ADDR AS TAG_ADDR, TAG_NAME, TAG_DESC, PLC_TAG_TYPE, PLC_TAG_FORMAT&#xD;&#xA;  FROM QRASMDLPTG&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND MODEL    = @model&#xD;&#xA;   AND MDL_VER  = @mdl_ver&#xD;&#xA; ORDER BY CNT_NAME, PLC_TAG_ADDR">
            <QP N="factory" />
            <QP N="model" />
            <QP N="mdl_ver" />
          </QY>
        </SG>
        <SG _S="472" N="SearchTagAlias">
          <QY P="MsSql" Q="SELECT IBN_NAME, TAG_ADDR, TAG_ADDR_ALIAS&#xD;&#xA;  FROM QEMSIBNPTA&#xD;&#xA; WHERE FACTORY  = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="473" N="SearchBranchEquipmentModel">
          <QY P="MsSql" Q="SELECT CONCAT ('Active,', TAGSET_VER, ',', BUILD_MDL, ',', BUILD_MDL_VER) AS VER_INFO&#xD;&#xA;  FROM QEMSIBNVER&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND IBN_NAME   = @ibn_name&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;   AND TAGSET_VER = &#xD;&#xA;       (&#xD;&#xA;SELECT ACTIVE_VER&#xD;&#xA;  FROM QEMSIBNEQP&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND IBN_NAME   = @ibn_name&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;       )&#xD;&#xA; UNION ALL&#xD;&#xA;SELECT CONCAT ('Last,', TAGSET_VER, ',', BUILD_MDL, ',', BUILD_MDL_VER) AS VER_INFO&#xD;&#xA;  FROM QEMSIBNVER&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND IBN_NAME   = @ibn_name&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;   AND TAGSET_VER = &#xD;&#xA;       (&#xD;&#xA;SELECT LAST_VER&#xD;&#xA;  FROM QEMSIBNEQP&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND IBN_NAME   = @ibn_name&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;       )&#xD;&#xA; UNION ALL&#xD;&#xA;SELECT CONCAT ('Applied,', TAGSET_VER, ',', BUILD_MDL, ',', BUILD_MDL_VER) AS VER_INFO&#xD;&#xA;  FROM QEMSIBNVER&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND IBN_NAME   = @ibn_name&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;   AND TAGSET_VER = &#xD;&#xA;       (&#xD;&#xA;SELECT APPLIED_VER&#xD;&#xA;  FROM QEMSIBNEQP&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND IBN_NAME   = @ibn_name&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;       )">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="474" N="SearchBranchEquipmentModelTag">
          <QY P="MsSql" Q="SELECT IBN.CNT_NAME, IBN.CNT_RK, IBN.TAG_ADDR, IBN.TAG_ADDR_ALIAS,&#xD;&#xA;       MDL.TAG_NAME, MDL.TAG_DESC, MDL.PLC_TAG_TYPE, MDL.PLC_TAG_FORMAT&#xD;&#xA;  FROM &#xD;&#xA;     (&#xD;&#xA;SELECT VER.FACTORY, VER.BUILD_MDL, VER.BUILD_MDL_VER, TAG.CNT_RK, TAG.CNT_NAME, TAG.TAG_ADDR, TAG.TAG_ADDR_ALIAS&#xD;&#xA;  FROM QEMSIBNVER VER&#xD;&#xA;  LEFT JOIN QEMSIBNPTG TAG&#xD;&#xA;    ON VER.FACTORY    = TAG.FACTORY &#xD;&#xA;   AND VER.IBN_NAME   = TAG.IBN_NAME&#xD;&#xA;   AND VER.EQP_NAME   = TAG.EQP_NAME&#xD;&#xA;   AND VER.TAGSET_VER = TAG.TAGSET_VER&#xD;&#xA; WHERE VER.FACTORY    = @factory&#xD;&#xA;   AND VER.IBN_NAME   = @ibn_name&#xD;&#xA;   AND VER.EQP_NAME   = @eqp_name&#xD;&#xA;   AND VER.TAGSET_VER = @tagset_ver&#xD;&#xA;     ) IBN&#xD;&#xA;  LEFT JOIN QRASMDLPTG MDL&#xD;&#xA;    ON IBN.FACTORY       = MDL.FACTORY&#xD;&#xA;   AND IBN.BUILD_MDL     = MDL.MODEL&#xD;&#xA;   AND IBN.BUILD_MDL_VER = MDL.MDL_VER&#xD;&#xA;   AND IBN.CNT_RK        = MDL.CNT_RK&#xD;&#xA;   AND IBN.TAG_ADDR      = MDL.PLC_TAG_ADDR&#xD;&#xA; ORDER BY IBN.CNT_NAME, IBN.TAG_ADDR">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
            <QP N="tagset_ver" />
          </QY>
        </SG>
        <SG _S="475" N="InsertBranch">
          <QY P="MsSql" Q="INSERT INTO QEMSIBNDEF (&#xD;&#xA;   FACTORY,&#xD;&#xA;   IBN_NAME,&#xD;&#xA;   IBN_DESC,&#xD;&#xA;   PROTOCOL,&#xD;&#xA;   PROTOCOL_ATTR,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @ibn_name,&#xD;&#xA;   @ibn_desc,&#xD;&#xA;   @protocol,&#xD;&#xA;   @protocol_attr,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="ibn_desc" />
            <QP N="protocol" />
            <QP N="protocol_attr" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="476" N="InsertBranchEquipmentTagForClone">
          <QY P="MsSql" Q="INSERT INTO QEMSIBNPTG(&#xD;&#xA;   FACTORY,&#xD;&#xA;   IBN_NAME,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   TAGSET_VER,&#xD;&#xA;   CNT_RK,&#xD;&#xA;   CNT_NAME,&#xD;&#xA;   TAG_ADDR,&#xD;&#xA;   TAG_ADDR_ALIAS,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) &#xD;&#xA;SELECT &#xD;&#xA;   FACTORY, &#xD;&#xA;   @ibn_name,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   @tagset_ver,&#xD;&#xA;   CNT_RK,&#xD;&#xA;   CNT_NAME,&#xD;&#xA;   TAG_ADDR,&#xD;&#xA;   TAG_ADDR_ALIAS,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;  FROM QEMSIBNPTG&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND IBN_NAME   = @ref_ibn_name&#xD;&#xA;   AND EQP_NAME   = @ref_eqp_name&#xD;&#xA;   AND TAGSET_VER = @ref_tagset_ver">
            <QP N="ibn_name" />
            <QP N="tagset_ver" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="ref_ibn_name" />
            <QP N="ref_eqp_name" />
            <QP N="ref_tagset_ver" />
          </QY>
        </SG>
        <SG _S="477" N="InsertBranchEquipmentVersionForClone">
          <QY P="MsSql" Q="INSERT INTO QEMSIBNVER(&#xD;&#xA;   FACTORY,&#xD;&#xA;   IBN_NAME,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   TAGSET_VER,&#xD;&#xA;   TAGSET_VER_DESC,&#xD;&#xA;   ACTIVE,&#xD;&#xA;   BUILD_MDL,&#xD;&#xA;   BUILD_MDL_VER,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) &#xD;&#xA;SELECT &#xD;&#xA;   FACTORY,&#xD;&#xA;   @ibn_name,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   @tagset_ver,&#xD;&#xA;   @tagset_ver_desc,&#xD;&#xA;   @active,&#xD;&#xA;   BUILD_MDL,&#xD;&#xA;   BUILD_MDL_VER,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;  FROM QEMSIBNVER&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND IBN_NAME   = @ref_ibn_name&#xD;&#xA;   AND EQP_NAME   = @ref_eqp_name&#xD;&#xA;   AND TAGSET_VER = @ref_tagset_ver">
            <QP N="ibn_name" />
            <QP N="tagset_ver" />
            <QP N="tagset_ver_desc" />
            <QP N="active" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="ref_ibn_name" />
            <QP N="ref_eqp_name" />
            <QP N="ref_tagset_ver" />
          </QY>
        </SG>
        <SG _S="478" N="UpdateBranch">
          <QY P="MsSql" Q="UPDATE QEMSIBNDEF SET&#xD;&#xA;  IBN_DESC           = @ibn_desc,&#xD;&#xA;  PROTOCOL           = @protocol,&#xD;&#xA;  PROTOCOL_ATTR      = @protocol_attr,&#xD;&#xA;  UPDATE_USER_ID     = @update_user_id,&#xD;&#xA;  UPDATE_TIME        = @update_time&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND IBN_NAME      = @ibn_name">
            <QP N="ibn_desc" />
            <QP N="protocol" />
            <QP N="protocol_attr" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
        <SG _S="479" N="ListBranchEquipmentVersion">
          <QY P="MsSql" Q="SELECT TAGSET_VER, TAGSET_VER_DESC, ACTIVE, BUILD_MDL, BUILD_MDL_VER&#xD;&#xA;  FROM QEMSIBNVER&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND IBN_NAME = @ibn_name&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA; ORDER BY TAGSET_VER DESC">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="480" N="ListBranch">
          <QY P="MsSql" Q="SELECT IBN_NAME, IBN_DESC, PROTOCOL, PROTOCOL_ATTR&#xD;&#xA;  FROM QEMSIBNDEF&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA; ORDER BY IBN_NAME">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="481" N="SearchReferenceBranch">
          <QY P="MsSql" Q="SELECT IBN_DESC, PROTOCOL, PROTOCOL_ATTR&#xD;&#xA;  FROM QEMSIBNDEF&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND IBN_NAME  = @ibn_name">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
        <SG _S="482" N="ListBranchEquipment">
          <QY P="MsSql" Q="SELECT IBN.EQP_NAME, ISNULL(EQP.EQP_DESC, ' ') EQP_DESC, IBN.ENABLE, IBN.NEED_ACTION, IBN.ACTIVE_VER, IBN.APPLIED_VER, IBN.LAST_VER&#xD;&#xA;  FROM QEMSIBNEQP IBN&#xD;&#xA;  LEFT JOIN QRASEQPDEF EQP&#xD;&#xA;    ON IBN.FACTORY  = EQP.FACTORY&#xD;&#xA;   AND IBN.EQP_NAME =  EQP.EQP_NAME&#xD;&#xA; WHERE IBN.FACTORY  = @factory&#xD;&#xA;   AND IBN.IBN_NAME = @ibn_name&#xD;&#xA; ORDER BY IBN.EQP_NAME">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
        <SG _S="483" N="SearchReferenceBranchEquipment">
          <QY P="MsSql" Q="SELECT IBN.EQP_NAME, ISNULL(EQP.EQP_DESC, ' ') EQP_DESC, IBN.ACTIVE_VER, IBN.APPLIED_VER, IBN.LAST_VER&#xD;&#xA;  FROM QEMSIBNEQP IBN&#xD;&#xA;  LEFT JOIN QRASEQPDEF EQP&#xD;&#xA;    ON IBN.FACTORY  = EQP.FACTORY&#xD;&#xA;   AND IBN.EQP_NAME = EQP.EQP_NAME&#xD;&#xA; WHERE IBN.FACTORY  = @factory&#xD;&#xA;   AND IBN.IBN_NAME = @ibn_name&#xD;&#xA; ORDER BY IBN.EQP_NAME">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
        <SG _S="484" N="ListBranchEquipmentTag">
          <QY P="MsSql" Q="SELECT IBN.CNT_NAME, IBN.CNT_RK, IBN.TAG_ADDR, IBN.TAG_ADDR_ALIAS,&#xD;&#xA;       MDL.TAG_NAME, MDL.TAG_DESC, MDL.PLC_TAG_TYPE, MDL.PLC_TAG_FORMAT&#xD;&#xA;  FROM &#xD;&#xA;     (&#xD;&#xA;SELECT VER.FACTORY, VER.BUILD_MDL, VER.BUILD_MDL_VER, TAG.CNT_RK, TAG.CNT_NAME, TAG.TAG_ADDR, TAG.TAG_ADDR_ALIAS&#xD;&#xA;  FROM QEMSIBNVER VER&#xD;&#xA;  LEFT JOIN QEMSIBNPTG TAG&#xD;&#xA;    ON VER.FACTORY    = TAG.FACTORY &#xD;&#xA;   AND VER.IBN_NAME   = TAG.IBN_NAME&#xD;&#xA;   AND VER.EQP_NAME   = TAG.EQP_NAME&#xD;&#xA;   AND VER.TAGSET_VER = TAG.TAGSET_VER&#xD;&#xA; WHERE VER.FACTORY    = @factory&#xD;&#xA;   AND VER.IBN_NAME   = @ibn_name&#xD;&#xA;   AND VER.EQP_NAME   = @eqp_name&#xD;&#xA;   AND VER.TAGSET_VER = @tagset_ver&#xD;&#xA;     ) IBN&#xD;&#xA;  LEFT JOIN QRASMDLPTG MDL&#xD;&#xA;    ON IBN.FACTORY       = MDL.FACTORY&#xD;&#xA;   AND IBN.BUILD_MDL     = MDL.MODEL&#xD;&#xA;   AND IBN.BUILD_MDL_VER = MDL.MDL_VER&#xD;&#xA;   AND IBN.CNT_RK        = MDL.CNT_RK&#xD;&#xA;   AND IBN.TAG_ADDR      = MDL.PLC_TAG_ADDR&#xD;&#xA; ORDER BY IBN.CNT_NAME, IBN.TAG_ADDR">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
            <QP N="tagset_ver" />
          </QY>
        </SG>
        <SG _S="485" N="HasBranch">
          <QY P="MsSql" Q="SELECT IBN_NAME, IBN_DESC, PROTOCOL, PROTOCOL_ATTR&#xD;&#xA;  FROM QEMSIBNDEF&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND IBN_NAME = @ibn_name">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
        <SG _S="486" N="HasBranchEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME, ACTIVE_VER&#xD;&#xA;  FROM QEMSIBNEQP&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND IBN_NAME = @ibn_name">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
        <SG _S="487" N="DeleteBranch">
          <QY P="MsSql" Q="DELETE&#xD;&#xA;  FROM QEMSIBNDEF&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND IBN_NAME = @ibn_name">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
        <SG _S="488" N="DeleteBranchPlcTagAlias">
          <QY P="MsSql" Q="DELETE&#xD;&#xA;  FROM QEMSIBNPTA&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND IBN_NAME = @ibn_name">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
        <SG _S="489" N="UpdateEquipmentNeedAction">
          <QY P="MsSql" Q="UPDATE QEMSIBNEQP SET&#xD;&#xA;   NEED_ACTION      = @need_action,&#xD;&#xA;   UPDATE_USER_ID   = @update_user_id,&#xD;&#xA;   UPDATE_TIME      = @update_time&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND IBN_NAME     = @ibn_name&#xD;&#xA;   AND NEED_ACTION &lt;&gt; @need_action_execlude">
            <QP N="need_action" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="need_action_execlude" />
          </QY>
        </SG>
        <SG _S="490" N="InsertBranchEquipmentForClone">
          <QY P="MsSql" Q="INSERT INTO QEMSIBNEQP(&#xD;&#xA;   FACTORY,&#xD;&#xA;   IBN_NAME,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   ENABLE,&#xD;&#xA;   NEED_ACTION,&#xD;&#xA;   APPLIED_VER,&#xD;&#xA;   ACTIVE_VER,&#xD;&#xA;   LAST_VER,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @ibn_name,&#xD;&#xA;   @eqp_name,&#xD;&#xA;   @enable,&#xD;&#xA;   @need_action,&#xD;&#xA;   @applied_ver,&#xD;&#xA;   @active_ver,&#xD;&#xA;   @last_ver,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
            <QP N="enable" />
            <QP N="need_action" />
            <QP N="applied_ver" />
            <QP N="active_ver" />
            <QP N="last_ver" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
      </F>
      <F _S="491" N="BranchV2">
        <SG _S="492" N="SearchTagAlias">
          <QY P="MsSql" Q="SELECT IBN_NAME, TAG_ADDR, TAG_ADDR_ALIAS&#xD;&#xA;  FROM QEMSIBNPTA&#xD;&#xA; WHERE FACTORY  = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="493" N="SearchBranchEquipmentVersion">
          <QY P="MsSql" Q="SELECT CONCAT ('Active,', EQP_TAGSET_VER, ',', PTM_TAGSET_GROUP, ',', PTM_TAGSET_NAME, ',', PTM_TAGSET_VER) AS VER_INFO&#xD;&#xA;  FROM CEMSIBNVER&#xD;&#xA; WHERE FACTORY        = @factory&#xD;&#xA;   AND IBN_NAME       = @ibn_name&#xD;&#xA;   AND EQP_NAME       = @eqp_name&#xD;&#xA;   AND EQP_TAGSET_VER = &#xD;&#xA;       (&#xD;&#xA;SELECT ACTIVE_VER&#xD;&#xA;  FROM QEMSIBNEQP&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND IBN_NAME   = @ibn_name&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;       )&#xD;&#xA; UNION ALL&#xD;&#xA;SELECT CONCAT ('Last,', EQP_TAGSET_VER, ',', PTM_TAGSET_GROUP, ',', PTM_TAGSET_NAME, ',', PTM_TAGSET_VER) AS VER_INFO&#xD;&#xA;  FROM CEMSIBNVER&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND IBN_NAME   = @ibn_name&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;   AND EQP_TAGSET_VER = &#xD;&#xA;       (&#xD;&#xA;SELECT LAST_VER&#xD;&#xA;  FROM QEMSIBNEQP&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND IBN_NAME   = @ibn_name&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;       )&#xD;&#xA; UNION ALL&#xD;&#xA;SELECT CONCAT ('Applied,', EQP_TAGSET_VER, ',', PTM_TAGSET_GROUP, ',', PTM_TAGSET_NAME, ',', PTM_TAGSET_VER) AS VER_INFO&#xD;&#xA;  FROM CEMSIBNVER&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND IBN_NAME   = @ibn_name&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;   AND EQP_TAGSET_VER = &#xD;&#xA;       (&#xD;&#xA;SELECT APPLIED_VER&#xD;&#xA;  FROM QEMSIBNEQP&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND IBN_NAME   = @ibn_name&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;       )">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="494" N="SearchBranchEquipmentTag">
          <QY P="MsSql" Q="SELECT IBN.TAG_NAME, PTM.TAG_DESC, IBN.TAG_FULL_ADDRESS, IBN.TAG_INPUT_ADDRESS, IBN.TAG_ADDR_ALIAS,&#xD;&#xA;       PTM.TAG_PLC_FORMAT, PTM.TAG_FORMAT, PTM.TAG_TYPE, IBN.TAG_VALUE_FILTER, IBN.TAG_CONDITION&#xD;&#xA;  FROM &#xD;&#xA;     (&#xD;&#xA;SELECT VER.FACTORY, VER.PTM_TAGSET_GROUP, VER.PTM_TAGSET_NAME, VER.PTM_TAGSET_VER, &#xD;&#xA;       TAG.TAG_NAME, TAG.TAG_FULL_ADDRESS, TAG.TAG_INPUT_ADDRESS, TAG.TAG_ADDR_ALIAS, TAG.TAG_VALUE_FILTER, TAG.TAG_CONDITION&#xD;&#xA;  FROM CEMSIBNVER VER&#xD;&#xA;  LEFT JOIN CEMSIBNPTG TAG&#xD;&#xA;    ON VER.FACTORY        = TAG.FACTORY &#xD;&#xA;   AND VER.IBN_NAME       = TAG.IBN_NAME&#xD;&#xA;   AND VER.EQP_NAME       = TAG.EQP_NAME&#xD;&#xA;   AND VER.EQP_TAGSET_VER = TAG.EQP_TAGSET_VER&#xD;&#xA; WHERE VER.FACTORY        = @factory&#xD;&#xA;   AND VER.IBN_NAME       = @ibn_name&#xD;&#xA;   AND VER.EQP_NAME       = @eqp_name&#xD;&#xA;   AND VER.EQP_TAGSET_VER = @eqp_tagset_ver&#xD;&#xA;     ) IBN&#xD;&#xA;  LEFT JOIN QSYSPTMTAG PTM&#xD;&#xA;    ON IBN.FACTORY          = PTM.FACTORY&#xD;&#xA;   AND IBN.PTM_TAGSET_GROUP = PTM.TAGSET_GROUP&#xD;&#xA;   AND IBN.PTM_TAGSET_NAME  = PTM.TAGSET_NAME&#xD;&#xA;   AND IBN.PTM_TAGSET_VER   = PTM.TAGSET_VER&#xD;&#xA;   AND IBN.TAG_NAME         = PTM.TAG_NAME&#xD;&#xA; ORDER BY IBN.TAG_NAME">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
            <QP N="eqp_tagset_ver" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="495" N="SearchPlcMapTagSetUsableLastVersion">
          <QY P="MsSql" Q="SELECT ISNULL(V.TAGSET_VER, 0) AS TAGSET_VER, ISNULL(V.TAGSET_VER_DESC, ' ') AS TAGSET_VER_DESC&#xD;&#xA;  FROM &#xD;&#xA;     (&#xD;&#xA;SELECT TOP (1) TAGSET_VER, TAGSET_VER_DESC&#xD;&#xA;  FROM QSYSPTMVER&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME  = @tagset_name&#xD;&#xA;   AND DELETE_FLAG  = 'N'&#xD;&#xA; ORDER BY TAGSET_VER DESC&#xD;&#xA;     ) AS V">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
          </QY>
        </SG>
        <SG _S="496" N="SearchPlcMapTag">
          <QY P="MsSql" Q="SELECT TAG_NAME, TAG_DESC, TAG_FULL_ADDRESS, TAG_INPUT_ADDRESS, TAG_PLC_FORMAT, TAG_FORMAT, TAG_TYPE&#xD;&#xA;  FROM QSYSPTMTAG&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME  = @tagset_name&#xD;&#xA;   AND TAGSET_VER   = @tagset_ver">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
            <QP N="tagset_ver" />
          </QY>
        </SG>
        <SG _S="497" N="InsertBranch">
          <QY P="MsSql" Q="INSERT INTO QEMSIBNDEF (&#xD;&#xA;   FACTORY,&#xD;&#xA;   IBN_NAME,&#xD;&#xA;   IBN_DESC,&#xD;&#xA;   PROTOCOL,&#xD;&#xA;   PROTOCOL_ATTR,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @ibn_name,&#xD;&#xA;   @ibn_desc,&#xD;&#xA;   @protocol,&#xD;&#xA;   @protocol_attr,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="ibn_desc" />
            <QP N="protocol" />
            <QP N="protocol_attr" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="498" N="InsertBranchEquipmentTagForClone">
          <QY P="MsSql" Q="INSERT INTO CEMSIBNPTG(&#xD;&#xA;   FACTORY,&#xD;&#xA;   IBN_NAME,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   EQP_TAGSET_VER,&#xD;&#xA;   TAG_NAME,&#xD;&#xA;   TAG_FULL_ADDRESS,&#xD;&#xA;   TAG_INPUT_ADDRESS,&#xD;&#xA;   TAG_ADDR_ALIAS,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) &#xD;&#xA;SELECT &#xD;&#xA;   FACTORY, &#xD;&#xA;   @ibn_name,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   @eqp_tagset_ver,&#xD;&#xA;   TAG_NAME,&#xD;&#xA;   TAG_FULL_ADDRESS,&#xD;&#xA;   TAG_INPUT_ADDRESS,&#xD;&#xA;   TAG_ADDR_ALIAS,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;  FROM CEMSIBNPTG&#xD;&#xA; WHERE FACTORY        = @factory&#xD;&#xA;   AND IBN_NAME       = @ref_ibn_name&#xD;&#xA;   AND EQP_NAME       = @ref_eqp_name&#xD;&#xA;   AND EQP_TAGSET_VER = @ref_eqp_tagset_ver">
            <QP N="ibn_name" />
            <QP N="eqp_tagset_ver" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="ref_ibn_name" />
            <QP N="ref_eqp_name" />
            <QP N="ref_eqp_tagset_ver" />
          </QY>
        </SG>
        <SG _S="499" N="InsertBranchEquipmentVersionForClone">
          <QY P="MsSql" Q="INSERT INTO CEMSIBNVER(&#xD;&#xA;   FACTORY,&#xD;&#xA;   IBN_NAME,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   EQP_TAGSET_VER,&#xD;&#xA;   EQP_TAGSET_VER_DESC,&#xD;&#xA;   ACTIVE,&#xD;&#xA;   PTM_TAGSET_GROUP,&#xD;&#xA;   PTM_TAGSET_NAME,&#xD;&#xA;   PTM_TAGSET_VER,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) &#xD;&#xA;SELECT &#xD;&#xA;   FACTORY,&#xD;&#xA;   @ibn_name,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   @eqp_tagset_ver,&#xD;&#xA;   @eqp_tagset_ver_desc,&#xD;&#xA;   @active,&#xD;&#xA;   PTM_TAGSET_GROUP,&#xD;&#xA;   PTM_TAGSET_NAME,&#xD;&#xA;   PTM_TAGSET_VER,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;  FROM CEMSIBNVER&#xD;&#xA; WHERE FACTORY        = @factory&#xD;&#xA;   AND IBN_NAME       = @ref_ibn_name&#xD;&#xA;   AND EQP_NAME       = @ref_eqp_name&#xD;&#xA;   AND EQP_TAGSET_VER = @ref_eqp_tagset_ver">
            <QP N="ibn_name" />
            <QP N="eqp_tagset_ver" />
            <QP N="eqp_tagset_ver_desc" />
            <QP N="active" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="ref_ibn_name" />
            <QP N="ref_eqp_name" />
            <QP N="ref_eqp_tagset_ver" />
          </QY>
        </SG>
        <SG _S="500" N="UpdateBranch">
          <QY P="MsSql" Q="UPDATE QEMSIBNDEF SET&#xD;&#xA;  IBN_DESC           = @ibn_desc,&#xD;&#xA;  PROTOCOL           = @protocol,&#xD;&#xA;  PROTOCOL_ATTR      = @protocol_attr,&#xD;&#xA;  UPDATE_USER_ID     = @update_user_id,&#xD;&#xA;  UPDATE_TIME        = @update_time&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND IBN_NAME      = @ibn_name">
            <QP N="ibn_desc" />
            <QP N="protocol" />
            <QP N="protocol_attr" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
        <SG _S="501" N="ListBranchEquipmentVersion">
          <QY P="MsSql" Q="SELECT EQP_TAGSET_VER, EQP_TAGSET_VER_DESC, ACTIVE, &#xD;&#xA;       PTM_TAGSET_GROUP, PTM_TAGSET_NAME, PTM_TAGSET_VER&#xD;&#xA;  FROM CEMSIBNVER&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND IBN_NAME = @ibn_name&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA; ORDER BY EQP_TAGSET_VER DESC">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="1206" N="SearchEquipmentTypeTagset">
          <QY P="MsSql" Q="SELECT T.PTM_TAGSET_GROUP, T.PTM_TAGSET_NAME&#xD;&#xA;  FROM QRASEQPDEF AS E&#xD;&#xA;  JOIN QRASEQPTYP AS T&#xD;&#xA;    ON T.FACTORY     = E.FACTORY&#xD;&#xA;   AND T.TYPE        = E.TYPE&#xD;&#xA; WHERE E.FACTORY     = @factory&#xD;&#xA;   AND E.EQP_NAME    = @eqp_name&#xD;&#xA;   AND E.DELETE_FLAG = 'N'&#xD;&#xA;   AND T.USED_PTM    = 'Yes'">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="1203" N="SearchBranchEquipmentLinkedTag">
          <QY P="MsSql" Q="SELECT TAG_NAME, LINKED_TAG_NAME&#xD;&#xA;  FROM QEMSIBNTLM&#xD;&#xA; WHERE FACTORY         = @factory&#xD;&#xA;   AND IBN_NAME        = @ibn_name&#xD;&#xA;   AND EQP_NAME        = @eqp_name&#xD;&#xA;   AND EQP_TAGSET_VER  = @eqp_tagset_ver">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
            <QP N="eqp_tagset_ver" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="502" N="ListBranch">
          <QY P="MsSql" Q="SELECT IBN_NAME, IBN_DESC, PROTOCOL, PROTOCOL_ATTR&#xD;&#xA;  FROM QEMSIBNDEF&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;  AND TYPE = 'Interface'&#xD;&#xA; ORDER BY IBN_NAME">
            <QP N="factory" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="503" N="SearchReferenceBranch">
          <QY P="MsSql" Q="SELECT IBN_DESC, PROTOCOL, PROTOCOL_ATTR&#xD;&#xA;  FROM QEMSIBNDEF&#xD;&#xA; WHERE FACTORY   = @factory &#xD;&#xA;   AND IBN_NAME  = @ibn_name&#xD;&#xA;   AND TYPE = 'Interface'">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="504" N="ListBranchEquipment">
          <QY P="MsSql" Q="SELECT IBN.EQP_NAME, ISNULL(EQP.EQP_DESC, ' ') EQP_DESC, IBN.ENABLE, IBN.IBN_STATE, IBN.NEED_ACTION, IBN.ACTIVE_VER, IBN.APPLIED_VER, IBN.LAST_VER, IBN.MON_ENABLE&#xD;&#xA;  FROM QEMSIBNEQP IBN&#xD;&#xA;  LEFT JOIN QRASEQPDEF EQP&#xD;&#xA;    ON IBN.FACTORY  = EQP.FACTORY&#xD;&#xA;   AND IBN.EQP_NAME =  EQP.EQP_NAME&#xD;&#xA; WHERE IBN.FACTORY  = @factory&#xD;&#xA;   AND IBN.IBN_NAME = @ibn_name&#xD;&#xA; ORDER BY IBN.EQP_NAME">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="505" N="SearchReferenceBranchEquipment">
          <QY P="MsSql" Q="SELECT IBN.EQP_NAME, ISNULL(EQP.EQP_DESC, ' ') EQP_DESC, IBN.ACTIVE_VER, IBN.APPLIED_VER, IBN.LAST_VER&#xD;&#xA;  FROM QEMSIBNEQP IBN&#xD;&#xA;  LEFT JOIN QRASEQPDEF EQP&#xD;&#xA;    ON IBN.FACTORY  = EQP.FACTORY&#xD;&#xA;   AND IBN.EQP_NAME = EQP.EQP_NAME&#xD;&#xA; WHERE IBN.FACTORY  = @factory&#xD;&#xA;   AND IBN.IBN_NAME = @ibn_name&#xD;&#xA; ORDER BY IBN.EQP_NAME">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
        <SG _S="506" N="ListBranchEquipmentTag">
          <QY P="MsSql" Q="SELECT IBN.TAG_NAME, PTM.TAG_DESC, &#xD;&#xA;       IBN.TAG_FULL_ADDRESS, IBN.TAG_INPUT_ADDRESS, IBN.TAG_ADDR_ALIAS,&#xD;&#xA;       PTM.TAG_PLC_FORMAT, PTM.TAG_FORMAT, PTM.TAG_TYPE, IBN.TAG_VALUE_FILTER, IBN.TAG_CONDITION&#xD;&#xA;  FROM &#xD;&#xA;     (&#xD;&#xA;SELECT VER.FACTORY, VER.PTM_TAGSET_GROUP, VER.PTM_TAGSET_NAME, VER.PTM_TAGSET_VER,&#xD;&#xA;       TAG.TAG_NAME, TAG.TAG_FULL_ADDRESS, TAG.TAG_INPUT_ADDRESS, TAG.TAG_ADDR_ALIAS, TAG.TAG_VALUE_FILTER, TAG.TAG_CONDITION&#xD;&#xA;  FROM CEMSIBNVER VER&#xD;&#xA;  LEFT JOIN CEMSIBNPTG TAG&#xD;&#xA;    ON VER.FACTORY        = TAG.FACTORY &#xD;&#xA;   AND VER.IBN_NAME       = TAG.IBN_NAME&#xD;&#xA;   AND VER.EQP_NAME       = TAG.EQP_NAME&#xD;&#xA;   AND VER.EQP_TAGSET_VER = TAG.EQP_TAGSET_VER&#xD;&#xA; WHERE VER.FACTORY        = @factory&#xD;&#xA;   AND VER.IBN_NAME       = @ibn_name&#xD;&#xA;   AND VER.EQP_NAME       = @eqp_name&#xD;&#xA;   AND VER.EQP_TAGSET_VER = @eqp_tagset_ver&#xD;&#xA;     ) IBN&#xD;&#xA;  LEFT JOIN QSYSPTMTAG PTM&#xD;&#xA;    ON IBN.FACTORY           = PTM.FACTORY&#xD;&#xA;   AND IBN.PTM_TAGSET_GROUP  = PTM.TAGSET_GROUP&#xD;&#xA;   AND IBN.PTM_TAGSET_NAME   = PTM.TAGSET_NAME&#xD;&#xA;   AND IBN.PTM_TAGSET_VER    = PTM.TAGSET_VER&#xD;&#xA;   AND IBN.TAG_NAME          = PTM.TAG_NAME&#xD;&#xA; ORDER BY IBN.TAG_NAME">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
            <QP N="eqp_tagset_ver" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="507" N="HasBranch">
          <QY P="MsSql" Q="SELECT IBN_NAME, IBN_DESC, PROTOCOL, PROTOCOL_ATTR&#xD;&#xA;  FROM QEMSIBNDEF&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND IBN_NAME = @ibn_name">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
        <SG _S="508" N="HasBranchEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME, ACTIVE_VER&#xD;&#xA;  FROM QEMSIBNEQP&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND IBN_NAME = @ibn_name">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
        <SG _S="509" N="DeleteBranch">
          <QY P="MsSql" Q="DELETE&#xD;&#xA;  FROM QEMSIBNDEF&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND IBN_NAME = @ibn_name">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
        <SG _S="510" N="DeleteBranchPlcTagAlias">
          <QY P="MsSql" Q="DELETE&#xD;&#xA;  FROM QEMSIBNPTA&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND IBN_NAME = @ibn_name">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
        <SG _S="511" N="UpdateEquipmentNeedAction">
          <QY P="MsSql" Q="UPDATE QEMSIBNEQP SET&#xD;&#xA;   NEED_ACTION      = @need_action,&#xD;&#xA;   UPDATE_USER_ID   = @update_user_id,&#xD;&#xA;   UPDATE_TIME      = @update_time&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND IBN_NAME     = @ibn_name&#xD;&#xA;   AND NEED_ACTION &lt;&gt; @need_action_execlude">
            <QP N="need_action" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="need_action_execlude" />
          </QY>
        </SG>
        <SG _S="512" N="InsertBranchEquipmentForClone">
          <QY P="MsSql" Q="INSERT INTO QEMSIBNEQP(&#xD;&#xA;   FACTORY,&#xD;&#xA;   IBN_NAME,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   ENABLE,&#xD;&#xA;   NEED_ACTION,&#xD;&#xA;   APPLIED_VER,&#xD;&#xA;   ACTIVE_VER,&#xD;&#xA;   LAST_VER,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @ibn_name,&#xD;&#xA;   @eqp_name,&#xD;&#xA;   @enable,&#xD;&#xA;   @need_action,&#xD;&#xA;   @applied_ver,&#xD;&#xA;   @active_ver,&#xD;&#xA;   @last_ver,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
            <QP N="enable" />
            <QP N="need_action" />
            <QP N="applied_ver" />
            <QP N="active_ver" />
            <QP N="last_ver" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
      </F>
      <F _S="513" N="BranchEquipment">
        <SG _S="514" N="DeleteBranchEquipmentTag">
          <QY P="MsSql" Q="DELETE &#xD;&#xA;  FROM QEMSIBNPTG&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND IBN_NAME   = @ibn_name&#xD;&#xA;   AND EQP_NAME   = @eqp_name">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="515" N="DeleteBranchEquipmentVersion">
          <QY P="MsSql" Q="DELETE &#xD;&#xA;  FROM QEMSIBNVER&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND IBN_NAME   = @ibn_name&#xD;&#xA;   AND EQP_NAME   = @eqp_name">
