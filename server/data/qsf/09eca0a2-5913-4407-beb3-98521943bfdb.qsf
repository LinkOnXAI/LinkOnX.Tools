        <SG _S="833" N="InsertEapEquipmentIeh" D="2017.07.14 by spike.lee">
          <QY P="MsSql" Q="INSERT INTO QRASEQPIEH (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   EVENT_ID,&#xD;&#xA;   TRAN_DATE,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   SYSTEM,&#xD;&#xA;   MDLN,&#xD;&#xA;   SOFTREV,&#xD;&#xA;   CTRL_ME,&#xD;&#xA;   PRI_STATE,&#xD;&#xA;   STATE,&#xD;&#xA;   EVENT_DEFINE,&#xD;&#xA;   EQP_RCP_ID,&#xD;&#xA;   EAP,&#xD;&#xA;   EAP_EVENT_ID,      &#xD;&#xA;   EVT_H_1,&#xD;&#xA;   EVT_D_1,   &#xD;&#xA;   EVT_H_2,&#xD;&#xA;   EVT_D_2,&#xD;&#xA;   EVT_H_3,&#xD;&#xA;   EVT_D_3,&#xD;&#xA;   EVT_H_4,&#xD;&#xA;   EVT_D_4,&#xD;&#xA;   EVT_H_5,&#xD;&#xA;   EVT_D_5,&#xD;&#xA;   EVT_H_6,&#xD;&#xA;   EVT_D_6,&#xD;&#xA;   EVT_H_7,&#xD;&#xA;   EVT_D_7,&#xD;&#xA;   EVT_H_8,&#xD;&#xA;   EVT_D_8,&#xD;&#xA;   EVT_H_9,&#xD;&#xA;   EVT_D_9,&#xD;&#xA;   EVT_H_10,&#xD;&#xA;   EVT_D_10,&#xD;&#xA;   EVT_H_11,&#xD;&#xA;   EVT_D_11,   &#xD;&#xA;   EVT_H_12,&#xD;&#xA;   EVT_D_12,&#xD;&#xA;   EVT_H_13,&#xD;&#xA;   EVT_D_13,&#xD;&#xA;   EVT_H_14,&#xD;&#xA;   EVT_D_14,&#xD;&#xA;   EVT_H_15,&#xD;&#xA;   EVT_D_15,&#xD;&#xA;   EVT_H_16,&#xD;&#xA;   EVT_D_16,&#xD;&#xA;   EVT_H_17,&#xD;&#xA;   EVT_D_17,&#xD;&#xA;   EVT_H_18,&#xD;&#xA;   EVT_D_18,&#xD;&#xA;   EVT_H_19,&#xD;&#xA;   EVT_D_19,&#xD;&#xA;   EVT_H_20,&#xD;&#xA;   EVT_D_20,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT      &#xD;&#xA;) &#xD;&#xA;SELECT &#xD;&#xA;   FACTORY,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   LAST_HIST_SEQ,&#xD;&#xA;   @event_id,&#xD;&#xA;   @tran_date,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @system,&#xD;&#xA;   MDLN,&#xD;&#xA;   SOFTREV,&#xD;&#xA;   CTRL_ME,&#xD;&#xA;   PRI_STATE,&#xD;&#xA;   STATE,&#xD;&#xA;   EVENT_DEFINE,&#xD;&#xA;   EQP_RCP_ID,&#xD;&#xA;   @eap,&#xD;&#xA;   @eap_event_id,&#xD;&#xA;   @evt_h_1,&#xD;&#xA;   @evt_d_1,   &#xD;&#xA;   @evt_h_2,&#xD;&#xA;   @evt_d_2,&#xD;&#xA;   @evt_h_3,&#xD;&#xA;   @evt_d_3,&#xD;&#xA;   @evt_h_4,&#xD;&#xA;   @evt_d_4,&#xD;&#xA;   @evt_h_5,&#xD;&#xA;   @evt_d_5,&#xD;&#xA;   @evt_h_6,&#xD;&#xA;   @evt_d_6,&#xD;&#xA;   @evt_h_7,&#xD;&#xA;   @evt_d_7,&#xD;&#xA;   @evt_h_8,&#xD;&#xA;   @evt_d_8,&#xD;&#xA;   @evt_h_9,&#xD;&#xA;   @evt_d_9,&#xD;&#xA;   @evt_h_10,&#xD;&#xA;   @evt_d_10,&#xD;&#xA;   @evt_h_11,&#xD;&#xA;   @evt_d_11,   &#xD;&#xA;   @evt_h_12,&#xD;&#xA;   @evt_d_12,&#xD;&#xA;   @evt_h_13,&#xD;&#xA;   @evt_d_13,&#xD;&#xA;   @evt_h_14,&#xD;&#xA;   @evt_d_14,&#xD;&#xA;   @evt_h_15,&#xD;&#xA;   @evt_d_15,&#xD;&#xA;   @evt_h_16,&#xD;&#xA;   @evt_d_16,&#xD;&#xA;   @evt_h_17,&#xD;&#xA;   @evt_d_17,&#xD;&#xA;   @evt_h_18,&#xD;&#xA;   @evt_d_18,&#xD;&#xA;   @evt_h_19,&#xD;&#xA;   @evt_d_19,&#xD;&#xA;   @evt_h_20,&#xD;&#xA;   @evt_d_20,&#xD;&#xA;   @tran_user_id,&#xD;&#xA;   @tran_comment&#xD;&#xA;  FROM QRASEQPDEF &#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EQP_NAME    = @eqp_name">
            <QP N="event_id" />
            <QP N="tran_date" />
            <QP N="tran_time" />
            <QP N="system" />
            <QP N="eap" />
            <QP N="eap_event_id" />
            <QP N="evt_h_1" />
            <QP N="evt_d_1" />
            <QP N="evt_h_2" />
            <QP N="evt_d_2" />
            <QP N="evt_h_3" />
            <QP N="evt_d_3" />
            <QP N="evt_h_4" />
