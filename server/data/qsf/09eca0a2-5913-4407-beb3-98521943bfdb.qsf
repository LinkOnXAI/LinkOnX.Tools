        <SG _S="1216" N="HasServer">
          <QY P="MsSql" Q="SELECT A.SVR_IP, A.UP_DOWN, A.STATUS, A.EAS_UP_DOWN,&#xD;&#xA;       A.B_SERVER, A.B_UP_DOWN, A.B_STATUS, A.B_EAS_UP_DOWN, ISNULL(B.SVR_IP, '') B_SVR_IP&#xD;&#xA;  FROM QSYSSVRDEF A&#xD;&#xA;  LEFT JOIN QSYSSVRDEF B&#xD;&#xA;    ON A.FACTORY     = B.FACTORY&#xD;&#xA;   AND A.B_SERVER    = B.SERVER&#xD;&#xA;   AND B.DELETE_FLAG = 'N'&#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.SERVER      = @server&#xD;&#xA;   AND A.DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="server" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
      </F>
    </M>
    <M _S="749" N="View">
      <F _S="750" N="EapSchemaSearch">
        <SG _S="751" N="SearchEap">
          <QY P="MsSql" Q="SELECT EAP&#xD;&#xA;  FROM QRASEAPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EAP         = @eap&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="752" N="SearchEapAtr">
          <QY P="MsSql" Q="SELECT EAP_SCHEMA&#xD;&#xA;  FROM QRASEAPATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP           = @eap&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
          </QY>
        </SG>
        <SG _S="753" N="SearchConnectorSts">
          <QY P="MsSql" Q="SELECT CNT_SEQ, CNT_NAME, STATE&#xD;&#xA;  FROM QRASCNTSTS&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EAP     = @eap">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="754" N="SearchEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME, COMM_STATE, CTRL_MODE&#xD;&#xA;  FROM QRASEQPSTS&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EQP_NAME IN&#xD;&#xA;       (&#xD;&#xA;SELECT DATA&#xD;&#xA;  FROM QRASEAPCFG&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP           = @eap&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category&#xD;&#xA;   AND OBJ_TYPE      = @obj_type&#xD;&#xA;   AND KEY_NAME      = @key_eqp_name&#xD;&#xA;       )">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
            <QP N="obj_type" />
            <QP N="key_eqp_name" />
          </QY>
        </SG>
      </F>
      <F _S="755" N="EapViewer">
        <SG _S="756" N="ListServer">
          <QY P="MsSql" Q="SELECT SERVER, SVR_DESC, SVR_IP, EAS_UP_DOWN, UP_DOWN, STATUS, ALARM&#xD;&#xA;  FROM QSYSSVRDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY SERVER">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="757" N="ListPackage">
          <QY P="MsSql" Q="SELECT A.PACKAGE, A.PKG_DESC, B.PKG_VER, B.PKG_VER_DESC, B.PKG_RELEASE&#xD;&#xA;  FROM QSYSPKGDEF A&#xD;&#xA;  LEFT JOIN QSYSPKGVER B&#xD;&#xA;    ON A.FACTORY = B.FACTORY&#xD;&#xA;   AND A.PACKAGE = B.PACKAGE&#xD;&#xA; WHERE A.FACTORY = @factory&#xD;&#xA; ORDER BY A.PACKAGE, B.PKG_VER DESC">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="758" N="ListModel">
          <QY P="MsSql" Q="SELECT A.MODEL, A.MDL_DESC, B.MDL_VER, B.MDL_VER_DESC, B.MDL_RELEASE&#xD;&#xA;  FROM QSYSMDLDEF A&#xD;&#xA;  LEFT JOIN QSYSMDLVER B&#xD;&#xA;    ON A.FACTORY = B.FACTORY&#xD;&#xA;   AND A.MODEL   = B.MODEL&#xD;&#xA; WHERE A.FACTORY = @factory&#xD;&#xA; ORDER BY A.MODEL, B.MDL_VER DESC">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="759" N="ListLibrary">
          <QY P="MsSql" Q="SELECT A.LIBRARY, A.LIB_DESC, B.LIB_VER, B.LIB_VER_DESC, B.LIB_RELEASE&#xD;&#xA;  FROM QSYSLIBDEF A&#xD;&#xA;  LEFT JOIN QSYSLIBVER B&#xD;&#xA;    ON A.FACTORY   = B.FACTORY&#xD;&#xA;   AND A.LIBRARY   = B.LIBRARY&#xD;&#xA; WHERE A.FACTORY   = @factory&#xD;&#xA; ORDER BY A.LIBRARY, B.LIB_VER DESC">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="760" N="ListEap">
          <QY P="MsSql" Q="SELECT A.EAP, A.EAP_DESC, A.SERVER, A.STEP, A.UP_DOWN, A.STATUS, A.RELOAD_CNT, A.ALARM, A.NEED_ACTION, A.NEXT_NEED_ACTION,&#xD;&#xA;       ISNULL(B.PACKAGE, 'N/A')  SET_PACKAGE,  ISNULL(B.PKG_VER, 0) SET_PKG_VER, ISNULL(C.PACKAGE, 'N/A') REL_PACKAGE, ISNULL(C.PKG_VER, 0) REL_PKG_VER, ISNULL(D.PACKAGE, 'N/A') APL_PACKAGE, ISNULL(D.PKG_VER, 0) APL_PKG_VER,&#xD;&#xA;       ISNULL(B.MODEL, 'N/A') SET_MODEL, ISNULL(B.MDL_VER, 0) SET_MDL_VER, ISNULL(C.MODEL, 'N/A') REL_MODEL, ISNULL(C.MDL_VER, 0) REL_MDL_VER, ISNULL(D.MODEL, 'N/A') APL_MODEL, ISNULL(D.MDL_VER, 0) APL_MDL_VER, &#xD;&#xA;       ISNULL(B.LIBRARY, 'N/A') SET_LIBRARY, ISNULL(B.LIB_VER, 0) SET_LIB_VER, ISNULL(C.LIBRARY, 'N/A') REL_LIBRARY, ISNULL(C.LIB_VER, 0) REL_LIB_VER, ISNULL(D.LIBRARY, 'N/A') APL_LIBRARY, ISNULL(D.LIB_VER, 0) APL_LIB_VER&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP           = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP           = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'    &#xD;&#xA;   AND A.SERVER        = ISNULL(@server, A.SERVER) &#xD;&#xA;   AND ( &#xD;&#xA;       (B.PACKAGE      = ISNULL(@package, B.PACKAGE) AND B.PKG_VER = ISNULL(@pkg_ver, B.PKG_VER))&#xD;&#xA;    OR (C.PACKAGE      = ISNULL(@package, C.PACKAGE) AND C.PKG_VER = ISNULL(@pkg_ver, C.PKG_VER))&#xD;&#xA;    OR (D.PACKAGE      = ISNULL(@package, D.PACKAGE) AND D.PKG_VER = ISNULL(@pkg_ver, D.PKG_VER))&#xD;&#xA;       )&#xD;&#xA;   AND (&#xD;&#xA;       (B.MODEL        = ISNULL(@model, B.MODEL) AND B.MDL_VER = ISNULL(@mdl_ver, B.MDL_VER))&#xD;&#xA;    OR (C.MODEL        = ISNULL(@model, C.MODEL) AND C.MDL_VER = ISNULL(@mdl_ver, C.MDL_VER))&#xD;&#xA;    OR (D.MODEL        = ISNULL(@model, D.MODEL) AND D.MDL_VER = ISNULL(@mdl_ver, D.MDL_VER))&#xD;&#xA;       )&#xD;&#xA;   AND (&#xD;&#xA;       (B.LIBRARY = ISNULL(@library, B.LIBRARY) AND B.LIB_VER = ISNULL(@lib_ver, B.LIB_VER))&#xD;&#xA;    OR (C.LIBRARY = ISNULL(@library, C.LIBRARY) AND C.LIB_VER = ISNULL(@lib_ver, C.LIB_VER))&#xD;&#xA;    OR (D.LIBRARY = ISNULL(@library, D.LIBRARY) AND D.LIB_VER = ISNULL(@lib_ver, D.LIB_VER))&#xD;&#xA;       )&#xD;&#xA; ORDER BY A.EAP">
            <QP N="factory" />
            <QP N="server" />
            <QP N="package" />
            <QP N="pkg_ver" />
            <QP N="model" />
            <QP N="mdl_ver" />
            <QP N="library" />
            <QP N="lib_ver" />
          </QY>
        </SG>
        <SG _S="761" N="SearchEap">
          <QY P="MsSql" Q="SELECT A.SERVER, B.PACKAGE, B.MODEL, B.LIBRARY&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.EAP           LIKE @eap&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'&#xD;&#xA; ORDER BY &#xD;&#xA; (CASE @target&#xD;&#xA;  WHEN 'Server'  THEN A.SERVER&#xD;&#xA;  WHEN 'Package' THEN B.PACKAGE&#xD;&#xA;  WHEN 'model'   THEN B.MODEL&#xD;&#xA;  WHEN 'Library' THEN B.LIBRARY&#xD;&#xA;   END)">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="target" />
          </QY>
        </SG>
        <SG _S="762" N="SearchEapByEquipment">
          <QY P="MsSql" Q="SELECT A.EAP&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA;  LEFT JOIN QRASEQPDEF C&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = C.EAP   &#xD;&#xA;   AND C.DELETE_FLAG &lt;&gt; 'Y'&#xD;&#xA;  LEFT JOIN QRASEQPATR D&#xD;&#xA;    ON C.FACTORY       = D.FACTORY&#xD;&#xA;   AND C.EQP_NAME      = D.EQP_NAME   &#xD;&#xA; WHERE A.FACTORY       = @factory &#xD;&#xA;   AND B.ATTR_CATEGORY = 'Applied' &#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'     &#xD;&#xA;   AND C.EQP_NAME      LIKE @eqp_name&#xD;&#xA;   AND A.EAP NOT LIKE '%_ST'&#xD;&#xA;   AND A.DELETE_FLAG   &lt;&gt; 'Y'">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="763" N="SearchEapForUpdate">
          <QY P="MsSql" Q="SELECT A.EAP, A.EAP_DESC, A.EAP_TYPE, A.OPER_ME, A.SERVER, A.STEP,&#xD;&#xA;       B.PACKAGE, B.PKG_VER, B.MODEL, B.MDL_VER, B.USED_COM, B.COMPONENT, B.COM_VER&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = @attr_category&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.EAP           = @eap&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="attr_category" />
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="764" N="SearchEapForClone">
          <QY P="MsSql" Q="SELECT A.EAP_TYPE, A.OPER_ME, A.SERVER, A.STEP,&#xD;&#xA;       B.PACKAGE, B.PKG_VER, B.MODEL, B.MDL_VER, B.USED_COM, B.COMPONENT, B.COM_VER&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = @attr_category&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.EAP           = @eap&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="attr_category" />
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
      </F>
      <F _S="765" N="EquipmentMonitor">
        <SG _S="766" N="ListEquipmentType">
          <QY P="MsSql" Q="SELECT TYPE, TYPE_DESC&#xD;&#xA;  FROM QRASEQPTYP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY TYPE">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="767" N="ListEquipmentArea">
          <QY P="MsSql" Q="SELECT AREA, AREA_DESC&#xD;&#xA;  FROM QRASEQPARE&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA; ORDER BY AREA">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="768" N="ListEquipmentLine">
          <QY P="MsSql" Q="SELECT LINE, LINE_DESC&#xD;&#xA;  FROM QRASEQPLIN&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY LINE">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="769" N="ListEquipment">
          <QY P="MsSql" Q="SELECT A.EQP_NAME, A.EQP_DESC, &#xD;&#xA;       ISNULL(C.EAP, 'N/A') EAP, ISNULL(C.SERVER, 'N/A') SERVER, ISNULL(C.UP_DOWN, 'N/A') UP_DOWN, ISNULL(C.STATUS, 'N/A') STATUS,&#xD;&#xA;       A.TYPE, A.AREA, A.LINE, A.MDLN, A.SOFTREV, A.CTRL_MODE, A.PRI_STATE, A.STATE, A.ALARM, A.EVENT_DEFINE, A.CMF_5 AS PLC_IP_ADDRESS&#xD;&#xA;  FROM QRASEQPDEF A&#xD;&#xA;  LEFT JOIN QRASEQPATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EQP_NAME      = B.EQP_NAME&#xD;&#xA;   AND B.ATTR_CATEGORY = @attr_category&#xD;&#xA;  LEFT JOIN QRASEAPDEF C&#xD;&#xA;    ON A.FACTORY = C.FACTORY&#xD;&#xA;   AND B.EAP     = C.EAP&#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.TYPE        = ISNULL(@type, A.TYPE)&#xD;&#xA;   AND A.AREA        = ISNULL(@area, A.AREA)&#xD;&#xA;   AND A.LINE        = ISNULL(@line, A.LINE)&#xD;&#xA;   AND A.DELETE_FLAG = 'N'">
            <QP N="attr_category" />
            <QP N="factory" />
            <QP N="type" />
            <QP N="area" />
            <QP N="line" />
          </QY>
        </SG>
        <SG _S="770" N="SearchEquipment">
          <QY P="MsSql" Q="SELECT A.TYPE, A.AREA, A.LINE&#xD;&#xA;  FROM QRASEQPDEF A&#xD;&#xA;  LEFT JOIN QRASEQPATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EQP_NAME      = B.EQP_NAME&#xD;&#xA;  LEFT JOIN QRASEAPDEF C&#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND B.EAP           = C.EAP&#xD;&#xA;  LEFT JOIN QRASEAPATR D&#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND B.EAP           = D.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = D.ATTR_CATEGORY &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Applied'&#xD;&#xA;   AND A.EQP_NAME      LIKE @eqp_name&#xD;&#xA;   AND A.DELETE_FLAG   &lt;&gt; 'Y'&#xD;&#xA; ORDER BY &#xD;&#xA; (CASE @target&#xD;&#xA;  WHEN 'Type'  THEN A.TYPE&#xD;&#xA;  WHEN 'Area'  THEN A.AREA&#xD;&#xA;  WHEN 'Line'  THEN A.LINE&#xD;&#xA;   END)">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="target" />
          </QY>
        </SG>
      </F>
      <F _S="771" N="EapLogList">
        <SG _S="772" N="HasEap">
          <QY P="MsSql" Q="SELECT EAP_TYPE, UP_DOWN, SERVER, STATUS&#xD;&#xA;  FROM QRASEAPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EAP         = @eap&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="773" N="HasServer">
          <QY P="MsSql" Q="SELECT UP_DOWN, STATUS, EAS_UP_DOWN, B_SERVER, B_UP_DOWN, B_STATUS, B_EAS_UP_DOWN &#xD;&#xA;  FROM QSYSSVRDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SERVER      = @server&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="server" />
          </QY>
        </SG>
      </F>
      <F _S="1270" N="EapDatasetFileList">
        <SG _S="1271" N="HasEap">
          <QY P="MsSql" Q="SELECT EAP_TYPE, UP_DOWN, SERVER, STATUS&#xD;&#xA;  FROM QRASEAPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EAP         = @eap&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="1272" N="HasServer">
          <QY P="MsSql" Q="SELECT UP_DOWN, STATUS, EAS_UP_DOWN, B_SERVER, B_UP_DOWN, B_STATUS, B_EAS_UP_DOWN &#xD;&#xA;  FROM QSYSSVRDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SERVER      = @server&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="server" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
      </F>
      <F _S="774" N="EapBackupLogList">
        <SG _S="775" N="HasEap">
          <QY P="MsSql" Q="SELECT EAP, SERVER&#xD;&#xA;  FROM QRASEAPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EAP         = @eap&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="776" N="HasServer">
          <QY P="MsSql" Q="SELECT SVR_IP, UP_DOWN, STATUS, EAS_UP_DOWN &#xD;&#xA;  FROM QSYSSVRDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SERVER      = @server&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="server" />
          </QY>
        </SG>
      </F>
      <F _S="777" N="EAServiceLogList">
        <SG _S="778" N="HasServer">
          <QY P="MsSql" Q="SELECT SERVER, SVR_TYPE, UP_DOWN, EAS_UP_DOWN&#xD;&#xA;  FROM QSYSSVRDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SERVER      = @server&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="server" />
          </QY>
        </SG>
      </F>
      <F _S="779" N="EAServiceBackupLogList">
        <SG _S="780" N="HasServer">
          <QY P="MsSql" Q="SELECT SERVER, SVR_TYPE, UP_DOWN, EAS_UP_DOWN&#xD;&#xA;  FROM QSYSSVRDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SERVER      = @server&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="server" />
          </QY>
        </SG>
      </F>
      <F _S="781" N="EAServiceOption">
        <SG _S="782" N="HasServer">
          <QY P="MsSql" Q="SELECT SERVER, UP_DOWN, EAS_UP_DOWN&#xD;&#xA;  FROM QSYSSVRDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SERVER      = @server&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="server" />
          </QY>
        </SG>
      </F>
      <F _S="783" N="DataHoundViewer">
        <SG _S="784" N="ListDataHound">
          <QY P="MsSql" Q="SELECT NAME, EAP, TYPE, STATUS, RESULT_MESSAGE, SERVER_IP, SERVER_PORT&#xD;&#xA;  FROM QSYSDHDDEF  &#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   ORDER BY NAME">
            <QP N="factory" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="785" N="HasDataHound">
          <QY P="MsSql" Q="SELECT NAME, STATUS    &#xD;&#xA;  FROM QSYSDHDDEF  &#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND NAME = @hound">
            <QP N="factory" />
            <QP N="hound" />
          </QY>
        </SG>
      </F>
      <F _S="1233" N="DataHoundBranchSubscription">
        <SG _S="1235" N="HasBranchEquipment">
          <QY P="MsSql" Q="SELECT IBN_NAME, ACTIVE_VER, APPLIED_VER, LAST_VER&#xD;&#xA;  FROM QEMSIBNEQP&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND IBN_NAME = @ibn_name">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="ibn_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="1236" N="ListBranchEquipmentAppliedTag">
          <QY P="MsSql" Q="WITH VersionData AS (&#xD;&#xA; SELECT V.FACTORY, V.PTM_TAGSET_GROUP, V.PTM_TAGSET_NAME, V.PTM_TAGSET_VER, T.TAG_NAME, T.TAG_ADDR_ALIAS&#xD;&#xA;   FROM CEMSIBNVER V&#xD;&#xA;   LEFT JOIN CEMSIBNPTG T&#xD;&#xA;     ON V.FACTORY        = T.FACTORY&#xD;&#xA;    AND V.IBN_NAME       = T.IBN_NAME&#xD;&#xA;    AND V.EQP_NAME       = T.EQP_NAME&#xD;&#xA;    AND V.EQP_TAGSET_VER = T.EQP_TAGSET_VER&#xA;  WHERE V.FACTORY        = @factory&#xD;&#xA;    AND V.IBN_NAME       = @ibn_name&#xD;&#xA;    AND V.EQP_NAME       = @eqp_name&#xD;&#xA;    AND V.EQP_TAGSET_VER = @eqp_tagset_ver&#xA;)&#xD;&#xA;SELECT IBN.TAG_NAME, IBN.TAG_ADDR_ALIAS, PTM.TAG_PLC_FORMAT, PTM.TAG_FORMAT, PTM.TAG_TYPE&#xD;&#xA;  FROM VersionData IBN&#xD;&#xA;  LEFT JOIN QSYSPTMTAG PTM&#xD;&#xA;    ON IBN.FACTORY          = PTM.FACTORY&#xD;&#xA;   AND IBN.PTM_TAGSET_GROUP = PTM.TAGSET_GROUP&#xD;&#xA;   AND IBN.PTM_TAGSET_NAME  = PTM.TAGSET_NAME&#xD;&#xA;   AND IBN.PTM_TAGSET_VER   = PTM.TAGSET_VER&#xD;&#xA;   AND IBN.TAG_NAME         = PTM.TAG_NAME">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
            <QP N="eqp_tagset_ver&#xA;" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
      </F>
      <F _S="786" N="PlcTagViewer">
        <SG _S="787" N="SelectPlcTagByModel">
          <QY P="MsSql" Q="SELECT FACTORY,&#xD;&#xA;MODEL,&#xD;&#xA;MDL_VER,&#xD;&#xA;CNT_NAME,&#xD;&#xA;SSN_NAME,&#xD;&#xA;TAG_NAME,&#xD;&#xA;TAG_DESC,&#xD;&#xA;TAG_FORMAT,&#xD;&#xA;PLC_TAG_ADDR,&#xD;&#xA;PLC_TAG_TYPE,&#xD;&#xA;PLC_TAG_MDL,&#xD;&#xA;PLC_TAG_AREA,&#xD;&#xA;PLC_TAG_FORMAT,&#xD;&#xA;PLC_TAG_START,&#xD;&#xA;PLC_TAG_LENGTH,&#xD;&#xA;PLC_TAG_ARRAY,&#xD;&#xA;PLC_TAG_CACHE,&#xD;&#xA;PLC_TAG_AL_EVENT,&#xD;&#xA;PLC_TAG_IG_FIRST,&#xD;&#xA;CREATE_USER_ID,&#xD;&#xA;CREATE_TIME,&#xD;&#xA;UPDATE_USER_ID,&#xD;&#xA;UPDATE_TIME &#xD;&#xA;FROM QRASMDLPTG &#xD;&#xA;WHERE FACTORY = @factory&#xD;&#xA; AND MODEL = @model&#xD;&#xA; AND MDL_VER = @model_ver &#xD;&#xA;ORDER BY PLC_TAG_ADDR">
            <QP N="factory" />
            <QP N="model" />
            <QP N="model_ver" />
          </QY>
        </SG>
        <SG _S="788" N="SelectPlcTagByEap">
          <QY P="MsSql" Q="SELECT FACTORY,&#xD;&#xA;MODEL,&#xD;&#xA;MDL_VER,&#xD;&#xA;CNT_NAME,&#xD;&#xA;SSN_NAME,&#xD;&#xA;TAG_NAME,&#xD;&#xA;TAG_DESC,&#xD;&#xA;TAG_FORMAT,&#xD;&#xA;PLC_TAG_ADDR,&#xD;&#xA;PLC_TAG_TYPE,&#xD;&#xA;PLC_TAG_MDL,&#xD;&#xA;PLC_TAG_AREA,&#xD;&#xA;PLC_TAG_FORMAT,&#xD;&#xA;PLC_TAG_START,&#xD;&#xA;PLC_TAG_LENGTH,&#xD;&#xA;PLC_TAG_ARRAY,&#xD;&#xA;PLC_TAG_CACHE,&#xD;&#xA;PLC_TAG_AL_EVENT,&#xD;&#xA;PLC_TAG_IG_FIRST,&#xD;&#xA;CREATE_USER_ID,&#xD;&#xA;CREATE_TIME,&#xD;&#xA;UPDATE_USER_ID,&#xD;&#xA;UPDATE_TIME &#xD;&#xA;FROM QRASMDLPTG &#xD;&#xA;WHERE FACTORY = @factory&#xD;&#xA; AND MODEL = @model,&#xD;&#xA; AND MDL_VER = (&#xD;&#xA; 	SELECT ISNULL(MDL_VER, 0) APL_MDL_VER  &#xD;&#xA; 	FROM QRASEAPATR &#xD;&#xA; 	WHERE FACTORY = @factory &#xD;&#xA; 		AND EAP = @eap &#xD;&#xA; 		AND ATTR_CATEGORY = 'Applied'&#xD;&#xA; 	)&#xD;&#xA;ORDER BY PLC_TAG_ADDR">
            <QP N="factory" />
            <QP N="model" />
            <QP N="eap" />
          </QY>
        </SG>
      </F>
      <F _S="789" N="PlcMapViewer">
        <SG _S="790" N="SearchPlcTagSet">
          <QY P="MsSql" Q="SELECT TAGSET_GROUP, TAGSET_NAME, TAGSET_DESC,&#xD;&#xA;       TAGSET_AREA, TAGSET_LINE, TAGSET_OPER,&#xD;&#xA;	   TAGSET_PLC_MAKER, TAGSET_PLC_MODEL,&#xD;&#xA;	   CMF_1, CMF_2, CMF_3, CMF_4, CMF_5, CMF_6, CMF_7, CMF_8, CMF_9, CMF_10 &#xD;&#xA;  FROM QSYSPTMDEF&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME  = @tagset_name">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
          </QY>
        </SG>
        <SG _S="791" N="SearchPlcTagSetTag">
          <QY P="MsSql" Q="SELECT TAG_CATEGORY, TAG_NAME, TAG_DESC, TAG_REGISTER, TAG_DEC_ADDRESS, TAG_FULL_ADDRESS, TAG_INPUT_ADDRESS,&#xD;&#xA;       TAG_PLC_FORMAT, TAG_FORMAT, TAG_LENGTH, TAG_TYPE, TAG_ALARM,&#xD;&#xA;	   CMF_1, CMF_2, CMF_3, CMF_4, CMF_5, CMF_6, CMF_7, CMF_8, CMF_9, CMF_10&#xD;&#xA;  FROM QSYSPTMTAG&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME  = @tagset_name&#xD;&#xA;   AND TAGSET_VER   = @tagset_ver&#xD;&#xA; ORDER BY TAG_CATEGORY, TAG_REGISTER, TAG_INPUT_ADDRESS">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
            <QP N="tagset_ver" />
          </QY>
        </SG>
      </F>
      <F _S="792" N="BranchViewer">
        <SG _S="793" N="ListBranch">
          <QY P="MsSql" Q="SELECT IBN_NAME, IBN_DESC, PROTOCOL, PROTOCOL_ATTR&#xD;&#xA;  FROM QEMSIBNDEF&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;  AND TYPE = 'Interface'&#xD;&#xA; ORDER BY IBN_NAME">
            <QP N="factory" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="794" N="ListBranchEquipment">
          <QY P="MsSql" Q="SELECT A.EQP_NAME, ISNULL(C.EQP_DESC, ' ') EQP_DESC, A.IBN_NAME, B.PROTOCOL, A.ENABLE, A.NEED_ACTION, A.ACTIVE_VER, A.APPLIED_VER, A.LAST_VER&#xD;&#xA;  FROM QEMSIBNEQP A&#xD;&#xA;  LEFT JOIN QEMSIBNDEF B&#xD;&#xA;    ON A.FACTORY  = B.FACTORY&#xD;&#xA;   AND A.IBN_NAME = B.IBN_NAME&#xD;&#xA;  LEFT JOIN QRASEQPDEF C&#xD;&#xA;    ON A.FACTORY  = C.FACTORY&#xD;&#xA;   AND A.EQP_NAME = C.EQP_NAME&#xD;&#xA; WHERE A.FACTORY  = @factory&#xD;&#xA;   AND A.IBN_NAME = ISNULL(@ibn_name, A.IBN_NAME)&#xD;&#xA; ORDER BY A.EQP_NAME">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
        <SG _S="795" N="ListBranchEquipmentAppliedTag">
          <QY P="MsSql" Q="SELECT IBN.CNT_NAME, IBN.CNT_RK, IBN.TAG_ADDR, IBN.TAG_ADDR_ALIAS,&#xD;&#xA;       MDL.TAG_NAME, MDL.TAG_DESC, MDL.PLC_TAG_TYPE, MDL.PLC_TAG_FORMAT&#xD;&#xA;  FROM &#xD;&#xA;     (&#xD;&#xA;SELECT VER.FACTORY, VER.BUILD_MDL, VER.BUILD_MDL_VER, TAG.CNT_RK, TAG.CNT_NAME, TAG.TAG_ADDR, TAG.TAG_ADDR_ALIAS&#xD;&#xA;  FROM QEMSIBNVER VER&#xD;&#xA;  LEFT JOIN QEMSIBNPTG TAG&#xD;&#xA;    ON VER.FACTORY    = TAG.FACTORY &#xD;&#xA;   AND VER.IBN_NAME   = TAG.IBN_NAME&#xD;&#xA;   AND VER.EQP_NAME   = TAG.EQP_NAME&#xD;&#xA;   AND VER.TAGSET_VER = TAG.TAGSET_VER&#xD;&#xA; WHERE VER.FACTORY    = @factory&#xD;&#xA;   AND VER.IBN_NAME   = @ibn_name&#xD;&#xA;   AND VER.EQP_NAME   = @eqp_name&#xD;&#xA;   AND VER.TAGSET_VER = @tagset_ver&#xD;&#xA;     ) IBN&#xD;&#xA;  LEFT JOIN QRASMDLPTG MDL&#xD;&#xA;    ON IBN.FACTORY       = MDL.FACTORY&#xD;&#xA;   AND IBN.BUILD_MDL     = MDL.MODEL&#xD;&#xA;   AND IBN.BUILD_MDL_VER = MDL.MDL_VER&#xD;&#xA;   AND IBN.CNT_RK        = MDL.CNT_RK&#xD;&#xA;   AND IBN.TAG_ADDR      = MDL.PLC_TAG_ADDR&#xD;&#xA; ORDER BY IBN.CNT_NAME, IBN.TAG_ADDR">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
            <QP N="tagset_ver" />
          </QY>
        </SG>
      </F>
      <F _S="796" N="BranchV2Viewer">
        <SG _S="797" N="ListBranch">
          <QY P="MsSql" Q="SELECT IBN_NAME, IBN_DESC, PROTOCOL, PROTOCOL_ATTR&#xD;&#xA;  FROM QEMSIBNDEF&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND TYPE = 'Interface'&#xD;&#xA; ORDER BY IBN_NAME">
            <QP N="factory" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="798" N="ListBranchEquipment">
          <QY P="MsSql" Q="SELECT A.EQP_NAME, ISNULL(C.EQP_DESC, ' ') EQP_DESC, A.IBN_NAME, B.PROTOCOL, A.ENABLE, A.IBN_STATE, A.NEED_ACTION, A.ACTIVE_VER, A.APPLIED_VER, A.LAST_VER&#xD;&#xA;  FROM QEMSIBNEQP A&#xD;&#xA;  LEFT JOIN QEMSIBNDEF B&#xD;&#xA;    ON A.FACTORY  = B.FACTORY&#xD;&#xA;   AND A.IBN_NAME = B.IBN_NAME&#xD;&#xA;  LEFT JOIN QRASEQPDEF C&#xD;&#xA;    ON A.FACTORY  = C.FACTORY&#xD;&#xA;   AND A.EQP_NAME = C.EQP_NAME&#xD;&#xA; WHERE A.FACTORY  = @factory&#xD;&#xA;   AND A.IBN_NAME = ISNULL(@ibn_name, A.IBN_NAME)&#xD;&#xA; ORDER BY A.EQP_NAME">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="799" N="ListBranchEquipmentAppliedTag">
          <QY P="MsSql" Q="WITH VersionData AS (&#xD;&#xA; SELECT V.FACTORY, V.PTM_TAGSET_GROUP, V.PTM_TAGSET_NAME, V.PTM_TAGSET_VER, T.TAG_NAME, T.TAG_ADDR_ALIAS&#xD;&#xA;   FROM CEMSIBNVER V&#xD;&#xA;   LEFT JOIN CEMSIBNPTG T&#xD;&#xA;     ON V.FACTORY        = T.FACTORY&#xD;&#xA;    AND V.IBN_NAME       = T.IBN_NAME&#xD;&#xA;    AND V.EQP_NAME       = T.EQP_NAME&#xD;&#xA;    AND V.EQP_TAGSET_VER = T.EQP_TAGSET_VER&#xA;  WHERE V.FACTORY        = @factory&#xD;&#xA;    AND V.IBN_NAME       = @ibn_name&#xD;&#xA;    AND V.EQP_NAME       = @eqp_name&#xD;&#xA;    AND V.EQP_TAGSET_VER = @eqp_tagset_ver&#xA;)&#xD;&#xA;SELECT IBN.TAG_NAME, PTM.TAG_DESC, PTM.TAG_FULL_ADDRESS, PTM.TAG_INPUT_ADDRESS, IBN.TAG_ADDR_ALIAS, PTM.TAG_PLC_FORMAT, PTM.TAG_FORMAT, PTM.TAG_TYPE&#xD;&#xA;  FROM VersionData IBN&#xD;&#xA;  LEFT JOIN QSYSPTMTAG PTM&#xD;&#xA;    ON IBN.FACTORY          = PTM.FACTORY&#xD;&#xA;   AND IBN.PTM_TAGSET_GROUP = PTM.TAGSET_GROUP&#xD;&#xA;   AND IBN.PTM_TAGSET_NAME  = PTM.TAGSET_NAME&#xD;&#xA;   AND IBN.PTM_TAGSET_VER   = PTM.TAGSET_VER&#xD;&#xA;   AND IBN.TAG_NAME         = PTM.TAG_NAME">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
            <QP N="eqp_tagset_ver&#xA;" />
          </QY>
        </SG>
      </F>
      <F _S="1252" N="EquipmentBranchStateViewer">
        <SG _S="1254" N="ListEquipmentBranchState">
          <QY P="MsSql" Q="  SELECT A.EQP_NAME, &#xD;&#xA;	ISNULL(C.EQP_DESC, ' ') EQP_DESC, &#xD;&#xA;	B.IBN_NAME, &#xD;&#xA;	B.PROTOCOL, &#xD;&#xA;	A.ENABLE, &#xD;&#xA;	A.IBN_STATE, &#xD;&#xA;	A.PRT_CONNECT_STATE, &#xD;&#xA;	A.PLC_CONNECT_STATE, &#xD;&#xA;	A.LAST_PVAL_TIME, &#xD;&#xA;	A.LAST_SEND_TIME&#xD;&#xA;  FROM QEMSIBNEQP A&#xD;&#xA;  LEFT JOIN QEMSIBNDEF B&#xD;&#xA;    ON A.FACTORY  = B.FACTORY&#xD;&#xA;   AND A.IBN_NAME = B.IBN_NAME&#xD;&#xA;   AND B.TYPE = 'Interface'&#xD;&#xA;  LEFT JOIN QRASEQPDEF C&#xD;&#xA;    ON A.FACTORY  = C.FACTORY&#xD;&#xA;   AND A.EQP_NAME = C.EQP_NAME&#xD;&#xA; WHERE A.FACTORY  = @factory&#xD;&#xA;   AND ISNULL(B.IBN_NAME, ' ') != ' '&#xD;&#xA; ORDER BY A.EQP_NAME, A.IBN_NAME">
            <QP N="factory" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
      </F>
      <F _S="800" N="PlcTagSetCompareViewer">
        <SG _S="801" N="ListLeftPlcTagSetTags">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;	'L' AS POSITION,&#xD;&#xA;	'N' AS COMPARE,&#xD;&#xA;	TAG_SEQ,&#xD;&#xA;	TAG_CATEGORY, 	&#xD;&#xA;	TAG_NAME, &#xD;&#xA;	TAG_DESC,&#xD;&#xA;	TAG_INPUT_ADDRESS,&#xD;&#xA;	TAG_FULL_ADDRESS,&#xD;&#xA;    TAG_REGISTER, 	&#xD;&#xA;	TAG_DEC_ADDRESS,	&#xD;&#xA;	TAG_PLC_FORMAT, &#xD;&#xA;	TAG_FORMAT, &#xD;&#xA;	TAG_LENGTH,&#xD;&#xA;	TAG_TYPE, &#xD;&#xA;	TAG_ALARM	&#xD;&#xA;  FROM QSYSPTMTAG&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME  = @tagset_name&#xD;&#xA;   AND TAGSET_VER   = @tagset_ver&#xD;&#xA; ORDER BY TAG_NAME">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
            <QP N="tagset_ver" />
          </QY>
        </SG>
        <SG _S="802" N="ListRightPlcTagSetTags">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;	'R' AS POSITION,&#xD;&#xA;	'N' AS COMPARE,&#xD;&#xA;	TAG_SEQ,&#xD;&#xA;	TAG_CATEGORY, 	&#xD;&#xA;	TAG_NAME, &#xD;&#xA;	TAG_DESC,&#xD;&#xA;	TAG_INPUT_ADDRESS,&#xD;&#xA;	TAG_FULL_ADDRESS,&#xD;&#xA;    TAG_REGISTER, 	&#xD;&#xA;	TAG_DEC_ADDRESS,	&#xD;&#xA;	TAG_PLC_FORMAT, &#xD;&#xA;	TAG_FORMAT, &#xD;&#xA;	TAG_LENGTH,&#xD;&#xA;	TAG_TYPE, &#xD;&#xA;	TAG_ALARM	&#xD;&#xA;  FROM QSYSPTMTAG&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME  = @tagset_name&#xD;&#xA;   AND TAGSET_VER   = @tagset_ver&#xD;&#xA; ORDER BY TAG_NAME">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
            <QP N="tagset_ver" />
          </QY>
        </SG>
      </F>
      <F _S="803" N="EquipmentStatus">
        <SG _S="804" N="ListEquipment">
          <QY P="MsSql" Q="SELECT A.EQP_NAME,&#xD;&#xA;	A.EQP_DESC,&#xA;       A.EAP, &#xA;	B.COMM_STATE, &#xA;	B.CTRL_MODE, &#xA;	B.PROC_STATE,&#xD;&#xA;	ISNULL(B.LAST_EVENT_ID, ' ') AS LAST_EVENT_ID,&#xD;&#xA;	ISNULL(B.LAST_EVENT_TIME, ' ') AS LAST_EVENT_TIME&#xA;FROM QRASEQPDEF A&#xA;	LEFT JOIN QRASEQPSTS B ON &#xA;	A.FACTORY = B.FACTORY&#xA;	AND A.EQP_NAME = B.EQP_NAME&#xA;WHERE A.FACTORY = @factory&#xD;&#xA; AND A.DELETE_FLAG &lt;&gt; 'Y'">
            <QP N="factory" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
      </F>
    </M>
    <M _S="805" N="RemoteCommand">
      <F _S="806" N="EquipmentEventDefineRequest">
        <SG _S="807" N="HasEap">
          <QY P="MsSql" Q="SELECT UP_DOWN, STATUS    &#xD;&#xA;  FROM QRASEAPDEF  &#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EAP         = @eap&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="808" N="HasEapAtr">
          <QY P="MsSql" Q="SELECT EAP&#xD;&#xA;  FROM QRASEAPATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP           = @eap&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
          </QY>
        </SG>
        <SG _S="809" N="HasEapEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME&#xD;&#xA;  FROM QRASEQPATR &#xD;&#xA;WHERE FACTORY       = @factory&#xD;&#xA;  AND EAP           = @eap&#xD;&#xA;  AND EQP_NAME      = @eqp_name&#xD;&#xA;  AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="eqp_name" />
            <QP N="attr_category" />
          </QY>
        </SG>
        <SG _S="810" N="InsertEapHistory">
          <QY P="MsSql" Q="INSERT INTO QRASEAPHIS (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EAP,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   EVENT_ID,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   SERVER,&#xD;&#xA;   STEP,&#xD;&#xA;   UP_DOWN,&#xD;&#xA;   STATUS,&#xD;&#xA;   NEED_ACTION,&#xD;&#xA;   NEXT_NEED_ACTION,&#xD;&#xA;   SET_PACKAGE,&#xD;&#xA;   SET_PKG_VER,&#xD;&#xA;   REL_PACKAGE,&#xD;&#xA;   REL_PKG_VER,&#xD;&#xA;   APL_PACKAGE,&#xD;&#xA;   APL_PKG_VER,   &#xD;&#xA;   SET_MEL,&#xD;&#xA;   SET_MDL_VER,&#xD;&#xA;   REL_MEL,&#xD;&#xA;   REL_MDL_VER,&#xD;&#xA;   APL_MEL,&#xD;&#xA;   APL_MDL_VER,   &#xD;&#xA;   SET_USED_COM,&#xD;&#xA;   SET_COMPONENT,&#xD;&#xA;   SET_COM_VER,   &#xD;&#xA;   REL_USED_COM,&#xD;&#xA;   REL_COMPONENT,&#xD;&#xA;   REL_COM_VER,   &#xD;&#xA;   APL_USED_COM,&#xD;&#xA;   APL_COMPONENT,&#xD;&#xA;   APL_COM_VER,   &#xD;&#xA;   EVT_H_1,&#xD;&#xA;   EVT_D_1,   &#xD;&#xA;   EVT_H_2,&#xD;&#xA;   EVT_D_2,&#xD;&#xA;   EVT_H_3,&#xD;&#xA;   EVT_D_3,&#xD;&#xA;   EVT_H_4,&#xD;&#xA;   EVT_D_4,&#xD;&#xA;   EVT_H_5,&#xD;&#xA;   EVT_D_5,&#xD;&#xA;   EVT_H_6,&#xD;&#xA;   EVT_D_6,&#xD;&#xA;   EVT_H_7,&#xD;&#xA;   EVT_D_7,&#xD;&#xA;   EVT_H_8,&#xD;&#xA;   EVT_D_8,&#xD;&#xA;   EVT_H_9,&#xD;&#xA;   EVT_D_9,&#xD;&#xA;   EVT_H_10,&#xD;&#xA;   EVT_D_10,&#xD;&#xA;   EVT_H_11,&#xD;&#xA;   EVT_D_11,   &#xD;&#xA;   EVT_H_12,&#xD;&#xA;   EVT_D_12,&#xD;&#xA;   EVT_H_13,&#xD;&#xA;   EVT_D_13,&#xD;&#xA;   EVT_H_14,&#xD;&#xA;   EVT_D_14,&#xD;&#xA;   EVT_H_15,&#xD;&#xA;   EVT_D_15,&#xD;&#xA;   EVT_H_16,&#xD;&#xA;   EVT_D_16,&#xD;&#xA;   EVT_H_17,&#xD;&#xA;   EVT_D_17,&#xD;&#xA;   EVT_H_18,&#xD;&#xA;   EVT_D_18,&#xD;&#xA;   EVT_H_19,&#xD;&#xA;   EVT_D_19,&#xD;&#xA;   EVT_H_20,&#xD;&#xA;   EVT_D_20,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT      &#xD;&#xA;) &#xD;&#xA;SELECT &#xD;&#xA;   A.FACTORY,&#xD;&#xA;   A.EAP,&#xD;&#xA;   A.LAST_HIST_SEQ,&#xD;&#xA;   @event_id,&#xD;&#xA;   @tran_time,&#xD;&#xA;   A.SERVER,&#xD;&#xA;   A.STEP,&#xD;&#xA;   A.UP_DOWN,&#xD;&#xA;   A.STATUS,&#xD;&#xA;   A.NEED_ACTION,&#xD;&#xA;   A.NEXT_NEED_ACTION,   &#xD;&#xA;   NVL(B.PACKAGE, ' '),&#xD;&#xA;   NVL(B.PKG_VER, 0),&#xD;&#xA;   NVL(C.PACKAGE, ' '),&#xD;&#xA;   NVL(C.PKG_VER, 0),&#xD;&#xA;   NVL(D.PACKAGE, ' '),&#xD;&#xA;   NVL(D.PKG_VER, 0),   &#xD;&#xA;   NVL(B.MEL, ' '),&#xD;&#xA;   NVL(B.MDL_VER, 0),&#xD;&#xA;   NVL(C.MEL, ' '),&#xD;&#xA;   NVL(C.MDL_VER, 0),&#xD;&#xA;   NVL(D.MEL, ' '),&#xD;&#xA;   NVL(D.MDL_VER, 0),   &#xD;&#xA;   NVL(B.USED_COM, 'No'),&#xD;&#xA;   NVL(B.COMPONENT, ' '),&#xD;&#xA;   NVL(B.COM_VER, 0),&#xD;&#xA;   NVL(C.USED_COM, 'No'),&#xD;&#xA;   NVL(C.COMPONENT, ' '),&#xD;&#xA;   NVL(C.COM_VER, 0),&#xD;&#xA;   NVL(D.USED_COM, 'No'),&#xD;&#xA;   NVL(D.COMPONENT, ' '),&#xD;&#xA;   NVL(D.COM_VER, 0),&#xD;&#xA;   @evt_h_1,&#xD;&#xA;   @evt_d_1,   &#xD;&#xA;   @evt_h_2,&#xD;&#xA;   @evt_d_2,&#xD;&#xA;   @evt_h_3,&#xD;&#xA;   @evt_d_3,&#xD;&#xA;   @evt_h_4,&#xD;&#xA;   @evt_d_4,&#xD;&#xA;   @evt_h_5,&#xD;&#xA;   @evt_d_5,&#xD;&#xA;   @evt_h_6,&#xD;&#xA;   @evt_d_6,&#xD;&#xA;   @evt_h_7,&#xD;&#xA;   @evt_d_7,&#xD;&#xA;   @evt_h_8,&#xD;&#xA;   @evt_d_8,&#xD;&#xA;   @evt_h_9,&#xD;&#xA;   @evt_d_9,&#xD;&#xA;   @evt_h_10,&#xD;&#xA;   @evt_d_10,&#xD;&#xA;   @evt_h_11,&#xD;&#xA;   @evt_d_11,   &#xD;&#xA;   @evt_h_12,&#xD;&#xA;   @evt_d_12,&#xD;&#xA;   @evt_h_13,&#xD;&#xA;   @evt_d_13,&#xD;&#xA;   @evt_h_14,&#xD;&#xA;   @evt_d_14,&#xD;&#xA;   @evt_h_15,&#xD;&#xA;   @evt_d_15,&#xD;&#xA;   @evt_h_16,&#xD;&#xA;   @evt_d_16,&#xD;&#xA;   @evt_h_17,&#xD;&#xA;   @evt_d_17,&#xD;&#xA;   @evt_h_18,&#xD;&#xA;   @evt_d_18,&#xD;&#xA;   @evt_h_19,&#xD;&#xA;   @evt_d_19,&#xD;&#xA;   @evt_h_20,&#xD;&#xA;   @evt_d_20,&#xD;&#xA;   @tran_user_id,&#xD;&#xA;   @tran_comment&#xD;&#xA;  FROM QRASEAPDEF A  &#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C&#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP           = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D&#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP           = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.EAP         = @eap">
            <QP N="event_id" />
            <QP N="tran_time" />
            <QP N="evt_h_1" />
            <QP N="evt_d_1" />
            <QP N="evt_h_2" />
            <QP N="evt_d_2" />
            <QP N="evt_h_3" />
            <QP N="evt_d_3" />
            <QP N="evt_h_4" />
            <QP N="evt_d_4" />
            <QP N="evt_h_5" />
            <QP N="evt_d_5" />
            <QP N="evt_h_6" />
            <QP N="evt_d_6" />
            <QP N="evt_h_7" />
            <QP N="evt_d_7" />
            <QP N="evt_h_8" />
            <QP N="evt_d_8" />
