            <QP N="tag_addr" />
            <QP N="tag_addr_alias" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="518" N="InsertBranchEquipmentTag">
          <QY P="MsSql" Q="INSERT INTO QEMSIBNPTG(&#xD;&#xA;   FACTORY,&#xD;&#xA;   IBN_NAME,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   TAGSET_VER,&#xD;&#xA;   CNT_RK,&#xD;&#xA;   CNT_NAME,&#xD;&#xA;   TAG_ADDR,&#xD;&#xA;   TAG_ADDR_ALIAS,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @ibn_name,&#xD;&#xA;   @eqp_name,&#xD;&#xA;   @tagset_ver,&#xD;&#xA;   @cnt_rk,&#xD;&#xA;   @cnt_name,&#xD;&#xA;   @tag_addr,&#xD;&#xA;   @tag_addr_alias,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
            <QP N="tagset_ver" />
            <QP N="cnt_rk" />
            <QP N="cnt_name" />
            <QP N="tag_addr" />
            <QP N="tag_addr_alias" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="519" N="InsertBranchEquipmentVersion">
          <QY P="MsSql" Q="INSERT INTO QEMSIBNVER(&#xD;&#xA;   FACTORY,&#xD;&#xA;   IBN_NAME,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   TAGSET_VER,&#xD;&#xA;   TAGSET_VER_DESC,&#xD;&#xA;   ACTIVE,&#xD;&#xA;   BUILD_MDL,&#xD;&#xA;   BUILD_MDL_VER,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @ibn_name,&#xD;&#xA;   @eqp_name,&#xD;&#xA;   @tagset_ver,&#xD;&#xA;   @tagset_ver_desc,&#xD;&#xA;   @active,&#xD;&#xA;   @build_mdl,&#xD;&#xA;   @build_mdl_ver,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
            <QP N="tagset_ver" />
            <QP N="tagset_ver_desc" />
            <QP N="active" />
            <QP N="build_mdl" />
            <QP N="build_mdl_ver" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="520" N="UpdateBranchEquipmentVersionInactive">
          <QY P="MsSql" Q="UPDATE QEMSIBNVER SET&#xD;&#xA;   ACTIVE         = @active_no,&#xD;&#xA;   UPDATE_USER_ID = @update_user_id,&#xD;&#xA;   UPDATE_TIME    = @update_time&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND IBN_NAME   = @ibn_name&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;   AND ACTIVE     = @active_yes">
            <QP N="active_no" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
            <QP N="active_yes" />
          </QY>
        </SG>
        <SG _S="521" N="UpdateBranchEquipmentVersionActive">
          <QY P="MsSql" Q="UPDATE QEMSIBNVER SET&#xD;&#xA;   ACTIVE         = @active,&#xD;&#xA;   UPDATE_USER_ID = @update_user_id,&#xD;&#xA;   UPDATE_TIME    = @update_time&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND IBN_NAME   = @ibn_name&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;   AND TAGSET_VER = @tagset_ver">
            <QP N="active" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
            <QP N="tagset_ver" />
          </QY>
        </SG>
        <SG _S="522" N="UpdateBranchTagAlias">
          <QY P="MsSql" Q="UPDATE QEMSIBNPTA SET&#xD;&#xA;   TAG_ADDR_ALIAS = @tag_addr_alias,&#xD;&#xA;   UPDATE_USER_ID = @update_user_id,&#xD;&#xA;   UPDATE_TIME    = @update_time&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND IBN_NAME   = @ibn_name&#xD;&#xA;   AND TAG_ADDR   = @tag_addr">
            <QP N="tag_addr_alias" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="tag_addr" />
          </QY>
        </SG>
        <SG _S="523" N="HasBranchTagAlias">
          <QY P="MsSql" Q="SELECT TAG_ADDR, TAG_ADDR_ALIAS&#xD;&#xA;  FROM QEMSIBNPTA&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND IBN_NAME = @ibn_name">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
        <SG _S="524" N="UpdateBranchEquipment">
          <QY P="MsSql" Q="UPDATE QEMSIBNEQP SET&#xD;&#xA;   ENABLE         = @enable,&#xD;&#xA;   NEED_ACTION    = @need_action,&#xD;&#xA;   APPLIED_VER    = @applied_ver,&#xD;&#xA;   ACTIVE_VER     = @active_ver,&#xD;&#xA;   LAST_VER       = @last_ver,&#xD;&#xA;   UPDATE_USER_ID = @update_user_id,&#xD;&#xA;   UPDATE_TIME    = @update_time&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND IBN_NAME   = @ibn_name&#xD;&#xA;   AND EQP_NAME   = @eqp_name">
            <QP N="enable" />
            <QP N="need_action" />
            <QP N="applied_ver" />
            <QP N="active_ver" />
            <QP N="last_ver" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="525" N="DeleteBranchEquipment">
          <QY P="MsSql" Q="DELETE &#xD;&#xA;  FROM QEMSIBNEQP&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND IBN_NAME = @ibn_name&#xD;&#xA;   AND EQP_NAME = @eqp_name">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="526" N="HasEquipment">
          <QY P="MsSql" Q="SELECT EQP.EQP_NAME, EQP.EAP, &#xD;&#xA;       (CASE WHEN IBN.EQP_NAME IS NOT NULL THEN 'Yes' ELSE 'No' END) AS IS_REG, ISNULL(IBN.ENABLE, 'No') AS IS_ENABLE,&#xD;&#xA;	   ISNULL(IBN.NEED_ACTION, ' ') AS NEED_ACTION,&#xD;&#xA;	   ISNULL(IBN.ACTIVE_VER, 0) AS ACTIVE_VER, ISNULL(IBN.LAST_VER, 0) AS LAST_VER, ISNULL(IBN.APPLIED_VER, 0) AS APPLIED_VER&#xD;&#xA;  FROM QRASEQPDEF EQP&#xD;&#xA;  LEFT JOIN QEMSIBNEQP IBN&#xD;&#xA;    ON EQP.FACTORY     = IBN.FACTORY&#xD;&#xA;   AND EQP.EQP_NAME    = IBN.EQP_NAME&#xD;&#xA;   AND IBN.IBN_NAME    = @ibn_name&#xD;&#xA; WHERE EQP.FACTORY     = @factory&#xD;&#xA;   AND EQP.EQP_NAME    = @eqp_name&#xD;&#xA;   AND EQP.DELETE_FLAG = 'N'">
            <QP N="ibn_name" />
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="527" N="HasBranch">
          <QY P="MsSql" Q="SELECT IBN_NAME&#xD;&#xA;  FROM QEMSIBNDEF&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND IBN_NAME = @ibn_name">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
        <SG _S="528" N="HasBranchEap">
          <QY P="MsSql" Q="SELECT IBN_NAME&#xD;&#xA;  FROM QEMSIBNDEF&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND IBN_NAME IN (&#xD;&#xA;				   SELECT IBN_NAME &#xD;&#xA;				   FROM QEMSIBNEQP&#xD;&#xA;				   WHERE EQP_NAME = @eap&#xD;&#xA;					 )">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="529" N="HasEapAppliedModelTag">
          <QY P="MsSql" Q="SELECT CNT_RK, PLC_TAG_ADDR&#xD;&#xA;  FROM QRASMDLPTG&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND MODEL    = @model&#xD;&#xA;   AND MDL_VER  = @mdl_ver">
            <QP N="factory" />
            <QP N="model" />
            <QP N="mdl_ver" />
          </QY>
        </SG>
        <SG _S="530" N="HasEapAppliedModel">
          <QY P="MsSql" Q="SELECT MODEL, MDL_VER&#xD;&#xA;  FROM QRASEAPATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP           = @eap&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
          </QY>
        </SG>
      </F>
      <F _S="531" N="BranchV2Equipment">
        <SG _S="532" N="DeleteBranchEquipment">
          <QY P="MsSql" Q="DELETE &#xD;&#xA;  FROM QEMSIBNEQP&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND IBN_NAME = @ibn_name&#xD;&#xA;   AND EQP_NAME = @eqp_name">
