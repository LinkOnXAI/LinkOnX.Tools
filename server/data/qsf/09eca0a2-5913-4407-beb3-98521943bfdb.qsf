      <F _S="1313" N="LinkVariableToLogical">
        <SG _S="1327" N="ListLogicalTag">
          <QY P="MsSql" Q="--VID 그룹 범위 조회 &#xD;&#xA;WITH VID_GROUP_RANGE AS&#xD;&#xA;(&#xD;&#xA;    SELECT FACTORY, VID_GROUP,&#xD;&#xA;           CAST(RANGE_FROM AS bigint) AS RANGE_FROM,&#xD;&#xA;           CAST(RANGE_TO   AS bigint) AS RANGE_TO&#xD;&#xA;      FROM QSYSPTMVGP&#xD;&#xA;     WHERE FACTORY     = @factory&#xD;&#xA;       AND VID_GROUP   = @vid_group&#xD;&#xA;       AND RANGE_FROM &lt;= RANGE_TO&#xD;&#xA;),&#xD;&#xA;-- RANGE_TO - RANGE_FROM + 1 개수만큼 연속된 정수 생성&#xD;&#xA;SEQ AS&#xD;&#xA;(&#xD;&#xA;    SELECT TOP&#xD;&#xA;           (&#xD;&#xA;               SELECT (RANGE_TO - RANGE_FROM + 1)&#xD;&#xA;                 FROM VID_GROUP_RANGE&#xD;&#xA;           )&#xD;&#xA;           ROW_NUMBER() OVER (ORDER BY (SELECT NULL)) - 1 AS N&#xD;&#xA;      FROM SYS.ALL_OBJECTS A&#xD;&#xA;     CROSS JOIN SYS.ALL_OBJECTS B&#xD;&#xA;),&#xD;&#xA;-- 시퀀스 N을 RANGE_FROM에 더해서 VID 생성&#xD;&#xA;VID_RANGE AS&#xD;&#xA;(&#xD;&#xA;    SELECT G.FACTORY, G.VID_GROUP, (G.RANGE_FROM + S.N) AS VID&#xD;&#xA;      FROM VID_GROUP_RANGE G&#xD;&#xA;      JOIN SEQ S&#xD;&#xA;        ON (G.RANGE_FROM + S.N) &lt;= G.RANGE_TO&#xD;&#xA;)&#xD;&#xA;-- 생성된 VID에 맵핑&#xD;&#xA;SELECT R.VID,&#xD;&#xA;       ISNULL(V.LOGICAL_TAG, N'')      AS LOGICAL_TAG,&#xD;&#xA;       ISNULL(L.LOGICAL_TAG_DESC, N'') AS LOGICAL_TAG_DESC,&#xD;&#xA;       CASE WHEN V.VID IS NOT NULL AND L.LOGICAL_TAG IS NULL THEN 'Yes' ELSE 'No' END AS IS_RETIRED&#xD;&#xA;  FROM VID_RANGE R&#xD;&#xA;  LEFT JOIN QSYSPTMVLL V&#xD;&#xA;    ON V.FACTORY     = R.FACTORY&#xD;&#xA;   AND V.VID         = R.VID&#xD;&#xA;   AND V.VID BETWEEN (SELECT RANGE_FROM FROM VID_GROUP_RANGE) AND (SELECT RANGE_TO FROM VID_GROUP_RANGE)&#xD;&#xA;  LEFT JOIN QSYSPTMLGT L&#xD;&#xA;    ON L.FACTORY     = R.FACTORY&#xD;&#xA;   AND L.LOGICAL_TAG = V.LOGICAL_TAG&#xD;&#xA; ORDER BY R.VID">
            <QP N="factory" />
            <QP N="vid_group" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="1364" N="ListVariableIdGroup">
          <QY P="MsSql" Q="SELECT VID_GROUP, VID_GROUP_DESC, RANGE_FROM, RANGE_TO&#xD;&#xA;  FROM QSYSPTMVGP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY RANGE_FROM">
            <QP N="factory" />
          </QY>
          <QY P="Oracle" />
