        <SG _S="291" N="InsertServer">
          <QY P="MsSql" Q="INSERT INTO QSYSSVRDEF (&#xD;&#xA;   FACTORY,&#xD;&#xA;   SERVER,&#xD;&#xA;   SVR_DESC,&#xD;&#xA;   SVR_TYPE,&#xD;&#xA;   SVR_IP,&#xD;&#xA;   B_USED,&#xD;&#xA;   B_MODE,&#xD;&#xA;   UP_DOWN,&#xD;&#xA;   STATUS,&#xD;&#xA;   EAS_UP_DOWN,   &#xD;&#xA;   ALARM,&#xD;&#xA;   B_SERVER,&#xD;&#xA;   B_UP_DOWN,&#xD;&#xA;   B_STATUS,&#xD;&#xA;   B_EAS_UP_DOWN,&#xD;&#xA;   EXPLOG_AGENT_PORT,&#xD;&#xA;   OPC_SVR_MON,&#xD;&#xA;   OPC_SVR_UP_DOWN,&#xD;&#xA;   LAST_EVENT_ID,&#xD;&#xA;   LAST_EVENT_TIME,&#xD;&#xA;   LAST_HIST_SEQ,&#xD;&#xA;   DELETE_FLAG,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @server,&#xD;&#xA;   @svr_desc,&#xD;&#xA;   @svr_type,&#xD;&#xA;   @svr_ip,&#xD;&#xA;   @b_used,&#xD;&#xA;   @b_mode,&#xD;&#xA;   @up_down,&#xD;&#xA;   @status,&#xD;&#xA;   @eas_up_down,   &#xD;&#xA;   @alarm,&#xD;&#xA;   @b_server,&#xD;&#xA;   @b_up_down,&#xD;&#xA;   @b_status,&#xD;&#xA;   @b_eas_up_down,&#xD;&#xA;   @explog_agent_port,&#xD;&#xA;   @opc_svr_mon,&#xD;&#xA;   @opc_svr_up_down,&#xD;&#xA;   @last_event_id,&#xD;&#xA;   @last_event_time,&#xD;&#xA;   @last_hist_seq,&#xD;&#xA;   @delete_flag,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="server" />
            <QP N="svr_desc" />
            <QP N="svr_type" />
