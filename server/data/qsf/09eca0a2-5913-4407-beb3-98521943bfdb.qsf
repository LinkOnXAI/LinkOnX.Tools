        <SG _S="1345" N="InsertVariableIdGroup">
          <QY P="MsSql" Q="INSERT INTO QSYSPTMVGP (&#xD;&#xA;   FACTORY,&#xD;&#xA;   VID_GROUP,&#xD;&#xA;   VID_GROUP_DESC,&#xD;&#xA;   RANGE_FROM,&#xD;&#xA;   RANGE_TO,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;   ) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @vid_group,&#xD;&#xA;   @vid_group_desc,&#xD;&#xA;   @range_from,&#xD;&#xA;   @range_to,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;   )">
            <QP N="factory" />
            <QP N="vid_group" />
            <QP N="vid_group_desc" />
            <QP N="range_from" />
            <QP N="range_to" />
