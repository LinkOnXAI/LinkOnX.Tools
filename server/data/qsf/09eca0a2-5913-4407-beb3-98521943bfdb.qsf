        </SG>
        <SG _S="292" N="UpdateServer">
          <QY P="MsSql" Q="UPDATE QSYSSVRDEF SET&#xD;&#xA;  SVR_DESC        = @svr_desc,&#xD;&#xA;  SVR_TYPE        = @svr_type,&#xD;&#xA;  SVR_IP          = @svr_ip,  &#xD;&#xA;  B_USED          = @b_used,&#xD;&#xA;  B_MODE          = @b_mode,&#xD;&#xA;  UP_DOWN         = @up_down,&#xD;&#xA;  STATUS          = @status,&#xD;&#xA;  EAS_UP_DOWN     = @eas_up_down,&#xD;&#xA;  ALARM           = @alarm,&#xD;&#xA;  B_SERVER        = @b_server,&#xD;&#xA;  B_UP_DOWN       = @b_up_down,&#xD;&#xA;  B_STATUS        = @b_status,&#xD;&#xA;  B_EAS_UP_DOWN   = @b_eas_up_down,&#xD;&#xA;  EXPLOG_AGENT_PORT = @explog_agent_port,&#xD;&#xA;  OPC_SVR_MON     = @opc_svr_mon,&#xD;&#xA;  OPC_SVR_UP_DOWN = @opc_svr_up_down,&#xD;&#xA;  LAST_EVENT_ID   = @last_event_id,&#xD;&#xA;  LAST_EVENT_TIME = @last_event_time,&#xD;&#xA;  LAST_HIST_SEQ   = @hist_seq,&#xD;&#xA;  DELETE_FLAG     = @delete_flag,&#xD;&#xA;  UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;  UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND SERVER  = @server">
