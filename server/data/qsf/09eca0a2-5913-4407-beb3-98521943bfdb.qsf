        <SG _S="971" N="InsertServerResourceHistory">
          <QY P="MsSql" Q="INSERT INTO QSYSSVRRHI (&#xD;&#xA;   FACTORY,&#xD;&#xA;   SERVER,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   CPU_USAGE,&#xD;&#xA;   MEMORY_USAGE,&#xD;&#xA;   DISK_1_USAGE,&#xD;&#xA;   DISK_2_USAGE,&#xD;&#xA;   DISK_3_USAGE,&#xD;&#xA;   DISK_4_USAGE,&#xD;&#xA;   DISK_5_USAGE,&#xD;&#xA;   DISK_6_USAGE,&#xD;&#xA;   DISK_7_USAGE,&#xD;&#xA;   DISK_8_USAGE,&#xD;&#xA;   DISK_9_USAGE,&#xD;&#xA;   DISK_10_USAGE,&#xD;&#xA;   TRAN_USER_ID&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @server,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @cpu_usage,&#xD;&#xA;   @memory_usage,&#xD;&#xA;   @disk_1_usage,&#xD;&#xA;   @disk_2_usage,&#xD;&#xA;   @disk_3_usage,&#xD;&#xA;   @disk_4_usage,&#xD;&#xA;   @disk_5_usage,&#xD;&#xA;   @disk_6_usage,&#xD;&#xA;   @disk_7_usage,&#xD;&#xA;   @disk_8_usage,&#xD;&#xA;   @disk_9_usage,&#xD;&#xA;   @disk_10_usage,&#xD;&#xA;   @tran_user_id&#xD;&#xA;)">
