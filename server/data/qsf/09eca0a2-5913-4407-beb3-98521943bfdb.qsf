          </QY>
        </SG>
        <SG _S="848" N="UpdateEapEquipment">
          <QY P="MsSql" Q="UPDATE QRASEQPDEF SET&#xD;&#xA;   EAP             = @eap,&#xD;&#xA;   UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;   UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EQP_NAME = @eqp_name">
            <QP N="eap" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="849" N="UpdateEapEquipmentStatus">
          <QY P="MsSql" Q="UPDATE QRASEQPSTS SET&#xD;&#xA;   LAST_HIST_SEQ   = @last_his_seq,&#xD;&#xA;   LAST_EVENT_ID   = @last_event_id,&#xD;&#xA;   LAST_EVENT_TIME = @last_event_time,&#xD;&#xA;   UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;   UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EQP_NAME = @eqp_name">
            <QP N="last_his_seq" />
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="850" N="Report">
      <F _S="851" N="ServerList">
        <SG _S="852" N="ListServer">
          <QY P="MsSql" Q="SELECT A.SERVER, A.SVR_DESC, A.SVR_TYPE, A.SVR_IP, ISNULL(B.COUNT , 0) AS COUNT, A.UP_DOWN, A.STATUS, A.EAS_UP_DOWN,&#xD;&#xA;       A.B_USED, A.B_MODE, A.B_SERVER, A.B_UP_DOWN, A.B_STATUS, A.B_EAS_UP_DOWN,&#xD;&#xA;       A.OPC_SVR_MON, A.OPC_SVR_UP_DOWN,&#xD;&#xA;       A.LAST_EVENT_TIME, A.LAST_EVENT_ID, A.CREATE_USER_ID, A.CREATE_TIME, A.UPDATE_USER_ID, A.UPDATE_TIME&#xD;&#xA;  FROM QSYSSVRDEF A&#xD;&#xA;  LEFT JOIN &#xD;&#xA;  (SELECT A.SERVER, COUNT(A.EAP) AS COUNT&#xD;&#xA;     FROM QRASEAPDEF A &#xD;&#xA;     LEFT JOIN QSYSSVRDEF B&#xD;&#xA;       ON A.FACTORY = B.FACTORY&#xD;&#xA;      AND A.SERVER  = B.SERVER&#xD;&#xA;    WHERE A.FACTORY = @factory&#xD;&#xA;      AND A.SERVER  = B.SERVER&#xD;&#xA;      AND A.DELETE_FLAG = 'N'&#xD;&#xA;    GROUP BY A.SERVER) B&#xD;&#xA;    ON A.SERVER = B.SERVER&#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY A.SERVER">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="853" N="ListEap">
          <QY P="MsSql" Q="SELECT A.EAP, A.EAP_DESC, A.EAP_TYPE, A.OPER_ME, A.SERVER, A.STEP, A.UP_DOWN, A.STATUS, A.RELOAD_CNT,&#xD;&#xA;       ISNULL(B.PACKAGE, 'N/A') SET_PACKAGE,  ISNULL(B.PKG_VER, 0) SET_PKG_VER, ISNULL(C.PACKAGE, 'N/A') REL_PACKAGE, ISNULL(C.PKG_VER, 0) REL_PKG_VER, ISNULL(D.PACKAGE, 'N/A') APL_PACKAGE, ISNULL(D.PKG_VER, 0) APL_PKG_VER,&#xD;&#xA;       ISNULL(B.MODEL, 'N/A') SET_MODEL, ISNULL(B.MDL_VER, 0) SET_MDL_VER, ISNULL(C.MODEL, 'N/A') REL_MODEL, ISNULL(C.MDL_VER, 0) REL_MDL_VER, ISNULL(D.MODEL, 'N/A') APL_MODEL, ISNULL(D.MDL_VER, 0) APL_MDL_VER, &#xD;&#xA;       ISNULL(B.USED_COM, 'N/A') SET_USED_COM, ISNULL(B.COMPONENT, 'N/A') SET_COMPONENT, ISNULL(B.COM_VER, 0) SET_COM_VER, ISNULL(C.USED_COM, 'N/A') REL_USED_COM, ISNULL(C.COMPONENT, 'N/A') REL_COMPONENT, ISNULL(C.COM_VER, 0) REL_COM_VER, ISNULL(D.USED_COM, 'N/A') APL_USED_COM, ISNULL(D.COMPONENT, 'N/A') APL_COMPONENT, ISNULL(D.COM_VER, 0) APL_COM_VER,&#xD;&#xA;       A.NEED_ACTION, A.NEXT_NEED_ACTION, A.LAST_EVENT_TIME, A.LAST_EVENT_ID,&#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME, A.UPDATE_USER_ID, A.UPDATE_TIME&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP              = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP              = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP              = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.SERVER           = @server&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'   &#xD;&#xA; ORDER BY EAP">
            <QP N="factory" />
            <QP N="server" />
          </QY>
        </SG>
        <SG _S="854" N="SearchEap">
          <QY P="MsSql" Q="SELECT A.EAP, A.EAP_DESC, &#xD;&#xA;       A.EAP_TYPE, A.OPER_ME, A.SERVER, &#xD;&#xA;       A.UP_DOWN, A.STATUS, A.STEP, &#xD;&#xA;       A.NEED_ACTION, A.NEXT_NEED_ACTION,  A.RELOAD_CNT,&#xD;&#xA;       ISNULL(B.PACKAGE, 'N/A') SET_PACKAGE, ISNULL(B.PKG_VER, 0) SET_PKG_VER, ISNULL(B.MODEL, 'N/A') SET_MODEL, ISNULL(B.MDL_VER, 0) SET_MDL_VER, ISNULL(B.USED_COM, 'N/A') SET_USED_COM, ISNULL(B.COMPONENT, 'N/A') SET_COMPONENT, ISNULL(B.COM_VER, 0) SET_COM_VER,&#xD;&#xA;       ISNULL(C.PACKAGE, 'N/A') REL_PACKAGE, ISNULL(C.PKG_VER, 0) REL_PKG_VER, ISNULL(C.MODEL, 'N/A') REL_MODEL, ISNULL(C.MDL_VER, 0) REL_MDL_VER, ISNULL(C.USED_COM, 'N/A') REL_USED_COM, ISNULL(C.COMPONENT, 'N/A') REL_COMPONENT, ISNULL(C.COM_VER, 0) REL_COM_VER,&#xD;&#xA;       ISNULL(D.PACKAGE, 'N/A') APL_PACKAGE, ISNULL(D.PKG_VER, 0) APL_PKG_VER, ISNULL(D.MODEL, 'N/A') APL_MODEL, ISNULL(D.MDL_VER, 0) APL_MDL_VER, ISNULL(D.USED_COM, 'N/A') APL_USED_COM, ISNULL(D.COMPONENT, 'N/A') APL_COMPONENT, ISNULL(D.COM_VER, 0) APL_COM_VER,&#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME,&#xD;&#xA;       A.UPDATE_USER_ID, A.UPDATE_TIME,&#xD;&#xA;       A.LAST_EVENT_TIME, A.LAST_EVENT_ID&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP              = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP              = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP              = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.EAP                 = @eap&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
      </F>
      <F _S="855" N="ServerStatus">
        <SG _S="856" N="HasServer">
          <QY P="MsSql" Q="SELECT SERVER&#xD;&#xA;  FROM QSYSSVRDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SERVER      = @server">
            <QP N="factory" />
            <QP N="server" />
          </QY>
        </SG>
        <SG _S="857" N="SearchServer">
          <QY P="MsSql" Q="SELECT SERVER, SVR_DESC, &#xD;&#xA;       SVR_TYPE, SVR_IP,&#xD;&#xA;       UP_DOWN, STATUS, EAS_UP_DOWN, &#xD;&#xA;       B_USED, B_MODE, B_SERVER, &#xD;&#xA;       B_UP_DOWN, B_STATUS, B_EAS_UP_DOWN,&#xD;&#xA;       OPC_SVR_MON, OPC_SVR_UP_DOWN,&#xD;&#xA;       CREATE_USER_ID, CREATE_TIME,&#xD;&#xA;       UPDATE_USER_ID, UPDATE_TIME,&#xD;&#xA;       LAST_EVENT_TIME, LAST_EVENT_ID&#xD;&#xA;  FROM QSYSSVRDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND Server      = @server&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="server" />
          </QY>
        </SG>
        <SG _S="858" N="ListEap">
          <QY P="MsSql" Q="SELECT A.EAP, A.EAP_DESC, A.EAP_TYPE, A.OPER_ME, A.SERVER, A.STEP, A.UP_DOWN, A.STATUS, A.RELOAD_CNT,&#xD;&#xA;       ISNULL(B.PACKAGE, 'N/A') SET_PACKAGE,  ISNULL(B.PKG_VER, 0) SET_PKG_VER, ISNULL(C.PACKAGE, 'N/A') REL_PACKAGE, ISNULL(C.PKG_VER, 0) REL_PKG_VER, ISNULL(D.PACKAGE, 'N/A') APL_PACKAGE, ISNULL(D.PKG_VER, 0) APL_PKG_VER,&#xD;&#xA;       ISNULL(B.MODEL, 'N/A') SET_MODEL, ISNULL(B.MDL_VER, 0) SET_MDL_VER, ISNULL(C.MODEL, 'N/A') REL_MODEL, ISNULL(C.MDL_VER, 0) REL_MDL_VER, ISNULL(D.MODEL, 'N/A') APL_MODEL, ISNULL(D.MDL_VER, 0) APL_MDL_VER, &#xD;&#xA;       ISNULL(B.USED_COM, 'N/A') SET_USED_COM, ISNULL(B.COMPONENT, 'N/A') SET_COMPONENT, ISNULL(B.COM_VER, 0) SET_COM_VER, ISNULL(C.USED_COM, 'N/A') REL_USED_COM, ISNULL(C.COMPONENT, 'N/A') REL_COMPONENT, ISNULL(C.COM_VER, 0) REL_COM_VER, ISNULL(D.USED_COM, 'N/A') APL_USED_COM, ISNULL(D.COMPONENT, 'N/A') APL_COMPONENT, ISNULL(D.COM_VER, 0) APL_COM_VER,&#xD;&#xA;       A.NEED_ACTION, A.NEXT_NEED_ACTION, A.LAST_EVENT_TIME, A.LAST_EVENT_ID,&#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME, A.UPDATE_USER_ID, A.UPDATE_TIME&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP              = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP              = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP              = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.SERVER           = @server&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'   &#xD;&#xA; ORDER BY EAP">
            <QP N="factory" />
            <QP N="server" />
          </QY>
        </SG>
        <SG _S="859" N="SearchEap">
          <QY P="MsSql" Q="SELECT A.EAP, A.EAP_DESC, &#xD;&#xA;       A.EAP_TYPE, A.OPER_ME, A.SERVER, &#xD;&#xA;       A.UP_DOWN, A.STATUS, A.STEP, &#xD;&#xA;       A.NEED_ACTION, A.NEXT_NEED_ACTION, A.RELOAD_CNT,&#xD;&#xA;       ISNULL(B.PACKAGE, 'N/A') SET_PACKAGE, ISNULL(B.PKG_VER, 0) SET_PKG_VER, ISNULL(B.MODEL, 'N/A') SET_MODEL, ISNULL(B.MDL_VER, 0) SET_MDL_VER, ISNULL(B.USED_COM, 'N/A') SET_USED_COM, ISNULL(B.COMPONENT, 'N/A') SET_COMPONENT, ISNULL(B.COM_VER, 0) SET_COM_VER,&#xD;&#xA;       ISNULL(C.PACKAGE, 'N/A') REL_PACKAGE, ISNULL(C.PKG_VER, 0) REL_PKG_VER, ISNULL(C.MODEL, 'N/A') REL_MODEL, ISNULL(C.MDL_VER, 0) REL_MDL_VER, ISNULL(C.USED_COM, 'N/A') REL_USED_COM, ISNULL(C.COMPONENT, 'N/A') REL_COMPONENT, ISNULL(C.COM_VER, 0) REL_COM_VER,&#xD;&#xA;       ISNULL(D.PACKAGE, 'N/A') APL_PACKAGE, ISNULL(D.PKG_VER, 0) APL_PKG_VER, ISNULL(D.MODEL, 'N/A') APL_MODEL, ISNULL(D.MDL_VER, 0) APL_MDL_VER, ISNULL(D.USED_COM, 'N/A') APL_USED_COM, ISNULL(D.COMPONENT, 'N/A') APL_COMPONENT, ISNULL(D.COM_VER, 0) APL_COM_VER,&#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME,&#xD;&#xA;       A.UPDATE_USER_ID, A.UPDATE_TIME,&#xD;&#xA;       A.LAST_EVENT_TIME, A.LAST_EVENT_ID&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP              = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP              = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP              = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.EAP                 = @eap&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
      </F>
      <F _S="860" N="ServerHistory">
        <SG _S="861" N="SearchServerHistory" UMG="No">
          <QY P="MsSql" Q="SELECT TRAN_TIME, SERVER, EVENT_ID, SVR_TYPE, SVR_IP, &#xD;&#xA;       UP_DOWN, STATUS, EAS_UP_DOWN, B_USED, &#xD;&#xA;       B_MODE, B_SERVER, B_UP_DOWN, B_STATUS, B_EAS_UP_DOWN, &#xD;&#xA;       OPC_SVR_MON, OPC_SVR_UP_DOWN, TRAN_USER_ID,&#xD;&#xA;       EVT_H_1, EVT_D_1, EVT_H_2, EVT_D_2, EVT_H_3, EVT_D_3, EVT_H_4, EVT_D_4, EVT_H_5, EVT_D_5, &#xD;&#xA;       EVT_H_6, EVT_D_6, EVT_H_7, EVT_D_7, EVT_H_8, EVT_D_8, EVT_H_9, EVT_D_9, EVT_H_10, EVT_D_10,&#xD;&#xA;       EVT_H_11, EVT_D_12, EVT_H_12, EVT_D_12, EVT_H_13, EVT_D_13, EVT_H_14, EVT_D_14, EVT_H_15, EVT_D_15, &#xD;&#xA;       EVT_H_16, EVT_D_16, EVT_H_17, EVT_D_17, EVT_H_18, EVT_D_18, EVT_H_19, EVT_D_19, EVT_H_20, EVT_D_20,&#xD;&#xA;       TRAN_COMMENT &#xD;&#xA;  FROM QSYSSVRHIS &#xD;&#xA; WHERE FACTORY     = @factory &#xD;&#xA;   AND SERVER      = ISNULL(@server, SERVER)&#xD;&#xA;   AND TRAN_TIME &gt;= @tran_from_time&#xD;&#xA;   AND TRAN_TIME &lt;= ISNULL(@tran_to_time, TRAN_TIME)&#xD;&#xA; ORDER BY HIST_SEQ DESC">
            <QP N="factory" />
            <QP N="server" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
      </F>
      <F _S="862" N="ServerResourceList">
        <SG _S="863" N="ListServerResource">
          <QY P="MsSql" Q="SELECT SERVER, UP_DOWN, STATUS, COMPUTER_NAME, WORK_GROUP, USER_NAME, OS,&#xD;&#xA;       CPU, CPU_USAGE, MEMORY, MEMORY_USAGE,&#xD;&#xA;       DISK_1, DISK_1_SIZE, DISK_1_USAGE,&#xD;&#xA;       DISK_2, DISK_2_SIZE, DISK_2_USAGE,&#xD;&#xA;       DISK_3, DISK_3_SIZE, DISK_3_USAGE,&#xD;&#xA;       DISK_4, DISK_4_SIZE, DISK_4_USAGE,&#xD;&#xA;       DISK_5, DISK_5_SIZE, DISK_5_USAGE,&#xD;&#xA;       DISK_6, DISK_6_SIZE, DISK_6_USAGE,&#xD;&#xA;       DISK_7, DISK_7_SIZE, DISK_7_USAGE,&#xD;&#xA;       DISK_8, DISK_8_SIZE, DISK_8_USAGE,&#xD;&#xA;       DISK_9, DISK_9_SIZE, DISK_9_USAGE,&#xD;&#xA;       DISK_10, DISK_10_SIZE, DISK_10_USAGE,&#xD;&#xA;       CREATE_TIME, CREATE_USER_ID, UPDATE_TIME, UPDATE_USER_ID&#xD;&#xA;  FROM QSYSSVRDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SVR_TYPE    = 'Real'&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY SERVER">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="864" N="SearchManagementRate">
          <QY P="MsSql" Q="SELECT SVR_CPU_CAUTION_RATE, SVR_CPU_DANGER_RATE,&#xD;&#xA;       SVR_MEMORY_CAUTION_RATE, SVR_MEMORY_DANGER_RATE,&#xD;&#xA;       SVR_DISK_CAUTION_RATE, SVR_DISK_DANGER_RATE&#xD;&#xA;  FROM QSYSFACDEF&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="865" N="SearchResourceHistory">
          <QY P="MsSql" Q="SELECT TRAN_TIME, CPU_USAGE, MEMORY_USAGE, DISK_1_USAGE AS DISK_USAGE&#xD;&#xA;  FROM QSYSSVRRHI&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND SERVER          = @server&#xD;&#xA;   AND TRAN_TIME &gt;= @tran_from_time&#xD;&#xA;   AND TRAN_TIME &lt;= ISNULL(@tran_to_time, TRAN_TIME)&#xD;&#xA; ORDER BY TRAN_TIME">
            <QP N="factory" />
            <QP N="server" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
        <SG _S="866" N="ListServer">
          <QY P="MsSql" Q="SELECT SERVER, SVR_DESC, SVR_IP &#xD;&#xA;  FROM QSYSSVRDEF&#xD;&#xA; WHERE SVR_TYPE    = 'Real'&#xD;&#xA;   AND DELETE_FLAG = 'N'" />
        </SG>
      </F>
      <F _S="867" N="ServerResourceStatus">
        <SG _S="868" N="HasServer">
          <QY P="MsSql" Q="SELECT SERVER&#xD;&#xA;  FROM QSYSSVRDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SERVER      = @server">
            <QP N="factory" />
            <QP N="server" />
          </QY>
        </SG>
        <SG _S="869" N="SearchCpuHistory">
          <QY P="MsSql" Q="SELECT TRAN_TIME, &#xD;&#xA;       CPU_USAGE&#xD;&#xA;  FROM QSYSSVRRHI&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND TRAN_TIME &gt;= @tran_from_time&#xA;   AND TRAN_TIME &lt;= ISNULL(@tran_to_time, TRAN_TIME)&#xD;&#xA;   AND SERVER       = @server&#xD;&#xA; ORDER BY TRAN_TIME">
            <QP N="factory" />
            <QP N="tran_from_time&#xA;" />
            <QP N="tran_to_time" />
            <QP N="server" />
          </QY>
        </SG>
        <SG _S="870" N="SearchManagementRate">
          <QY P="MsSql" Q="SELECT SVR_CPU_CAUTION_RATE, SVR_CPU_DANGER_RATE, &#xD;&#xA;       SVR_MEMORY_CAUTION_RATE, SVR_MEMORY_DANGER_RATE,&#xD;&#xA;       SVR_DISK_CAUTION_RATE, SVR_DISK_DANGER_RATE&#xD;&#xA;  FROM QSYSFACDEF&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="871" N="SearchServerResource">
          <QY P="MsSql" Q="SELECT SERVER, COMPUTER_NAME, WORK_GROUP, USER_NAME, OS, &#xD;&#xA;       CPU, CPU_USAGE, &#xD;&#xA;       MEMORY, MEMORY_USAGE,&#xD;&#xA;       DISK_1, DISK_1_SIZE, DISK_1_USAGE,&#xD;&#xA;       DISK_2, DISK_2_SIZE, DISK_2_USAGE,&#xD;&#xA;       DISK_3, DISK_3_SIZE, DISK_3_USAGE,&#xD;&#xA;       DISK_4, DISK_4_SIZE, DISK_4_USAGE,&#xD;&#xA;       DISK_5, DISK_5_SIZE, DISK_5_USAGE,&#xD;&#xA;       DISK_6, DISK_6_SIZE, DISK_6_USAGE,&#xD;&#xA;       DISK_7, DISK_7_SIZE, DISK_7_USAGE,&#xD;&#xA;       DISK_8, DISK_8_SIZE, DISK_8_USAGE,&#xD;&#xA;       DISK_9, DISK_9_SIZE, DISK_9_USAGE,&#xD;&#xA;       DISK_10, DISK_10_SIZE, DISK_10_USAGE,&#xD;&#xA;       CREATE_TIME, CREATE_USER_ID, &#xD;&#xA;       UPDATE_TIME, UPDATE_USER_ID&#xD;&#xA;  FROM QSYSSVRDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND SERVER  = @server">
            <QP N="factory" />
            <QP N="server" />
          </QY>
        </SG>
        <SG _S="872" N="SearchMemoryHistory">
          <QY P="MsSql" Q="SELECT A.TRAN_TIME, B.MEMORY, A.MEMORY_USAGE&#xD;&#xA;  FROM QSYSSVRRHI A &#xD;&#xA;  LEFT JOIN QSYSSVRDEF B&#xD;&#xA;    ON A.FACTORY    = B.FACTORY&#xD;&#xA;   AND A.SERVER     = B.SERVER&#xD;&#xA; WHERE A.FACTORY    = @factory&#xD;&#xA;   AND A.TRAN_TIME &gt;= @tran_from_time&#xA;   AND A.TRAN_TIME &lt;= ISNULL(@tran_to_time, TRAN_TIME)&#xD;&#xA;   AND A.SERVER     = @server&#xD;&#xA; ORDER BY A.TRAN_TIME">
            <QP N="factory" />
            <QP N="tran_from_time&#xA;" />
            <QP N="tran_to_time" />
            <QP N="server" />
          </QY>
        </SG>
        <SG _S="873" N="SearchDiskHistory">
          <QY P="MsSql" Q="SELECT A.TRAN_TIME, &#xD;&#xA;       B.DISK_1, B.DISK_1_SIZE, A.DISK_1_USAGE, &#xD;&#xA;       B.DISK_2, B.DISK_2_SIZE, A.DISK_2_USAGE, &#xD;&#xA;       B.DISK_3, B.DISK_3_SIZE, A.DISK_3_USAGE, &#xD;&#xA;       B.DISK_4, B.DISK_4_SIZE, A.DISK_4_USAGE, &#xD;&#xA;       B.DISK_5, B.DISK_5_SIZE, A.DISK_5_USAGE, &#xD;&#xA;       B.DISK_6, B.DISK_6_SIZE, A.DISK_6_USAGE, &#xD;&#xA;       B.DISK_7, B.DISK_7_SIZE, A.DISK_7_USAGE, &#xD;&#xA;       B.DISK_8, B.DISK_8_SIZE, A.DISK_8_USAGE, &#xD;&#xA;       B.DISK_9, B.DISK_9_SIZE, A.DISK_9_USAGE, &#xD;&#xA;       B.DISK_10, B.DISK_10_SIZE, A.DISK_10_USAGE&#xD;&#xA;  FROM QSYSSVRRHI A &#xD;&#xA;  LEFT JOIN QSYSSVRDEF B&#xD;&#xA;    ON A.FACTORY    = B.FACTORY&#xD;&#xA;   AND A.SERVER     = B.SERVER&#xD;&#xA; WHERE A.FACTORY    = @factory&#xD;&#xA;   AND A.TRAN_TIME &gt;= @tran_from_time&#xD;&#xA;   AND A.TRAN_TIME &lt;= ISNULL(@tran_to_time, TRAN_TIME)&#xD;&#xA;   AND A.SERVER     = @server&#xD;&#xA; ORDER BY A.TRAN_TIME">
            <QP N="factory" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
            <QP N="server" />
          </QY>
        </SG>
      </F>
      <F _S="874" N="ServerResourceHistory">
        <SG _S="875" N="SearchServer">
          <QY P="MsSql" Q="SELECT SERVER, SVR_DESC, &#xD;&#xA;       COMPUTER_NAME, WORK_GROUP, OS, CPU, MEMORY, DISK_CNT, &#xD;&#xA;       DISK_1, DISK_1_SIZE, DISK_2, DISK_2_SIZE, DISK_3, DISK_3_SIZE, DISK_4, DISK_4_SIZE, DISK_5, DISK_5_SIZE,&#xD;&#xA;       DISK_6, DISK_6_SIZE, DISK_7, DISK_7_SIZE, DISK_8, DISK_8_SIZE, DISK_9, DISK_9_SIZE, DISK_10, DISK_10_SIZE&#xD;&#xA;  FROM QSYSSVRDEF&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND SERVER   = @server">
            <QP N="factory" />
            <QP N="server" />
          </QY>
        </SG>
        <SG _S="876" N="SearchManagementRate">
          <QY P="MsSql" Q="SELECT SVR_CPU_CAUTION_RATE, SVR_CPU_DANGER_RATE, &#xD;&#xA;       SVR_MEMORY_CAUTION_RATE, SVR_MEMORY_DANGER_RATE,&#xD;&#xA;       SVR_DISK_CAUTION_RATE, SVR_DISK_DANGER_RATE&#xD;&#xA;  FROM QSYSFACDEF&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="877" N="SearchResourceHistory">
          <QY P="MsSql" Q="SELECT TRAN_TIME, CPU_USAGE, MEMORY_USAGE,&#xD;&#xA;       DISK_1_USAGE, DISK_2_USAGE, DISK_3_USAGE, DISK_4_USAGE, DISK_5_USAGE, &#xD;&#xA;       DISK_6_USAGE, DISK_7_USAGE, DISK_8_USAGE, DISK_9_USAGE, DISK_10_USAGE&#xD;&#xA;  FROM QSYSSVRRHI&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SERVER      = @server &#xD;&#xA;   AND TRAN_TIME &gt;= @tran_from_time&#xD;&#xA;   AND TRAN_TIME &lt;= ISNULL(@tran_to_time, TRAN_TIME)&#xD;&#xA; ORDER BY C_TRAN_TIME">
            <QP N="factory" />
            <QP N="server" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
      </F>
      <F _S="878" N="PackageList">
        <SG _S="879" N="ListPackage">
          <QY P="MsSql" Q="SELECT A.PACKAGE, A.PKG_DESC, A.PKG_TYPE, ISNULL(DATA.SET_COUNT, 0), ISNULL(DATA.REL_COUNT, 0), ISNULL(DATA.APP_COUNT, 0), A.REL_PKG_VER, A.LAST_PKG_VER, A.CREATE_USER_ID, A.CREATE_TIME, A.UPDATE_USER_ID, A.UPDATE_TIME&#xD;&#xA;  FROM QSYSPKGDEF A&#xD;&#xA;  LEFT JOIN (  &#xD;&#xA;SELECT B.FACTORY, B.PACKAGE,  SUM(B.SETUP) AS SET_COUNT, SUM(B.RELEASED) AS REL_COUNT, SUM(B.APPLIED) AS APP_COUNT &#xD;&#xA;  FROM (&#xD;&#xA;SELECT FACTORY, PACKAGE,&#xD;&#xA;  CASE WHEN ATTR_CATEGORY='Setup' THEN 1 ELSE 0 END AS SETUP,&#xD;&#xA;  CASE WHEN ATTR_CATEGORY='Released' THEN 1 ELSE 0 END AS RELEASED,&#xD;&#xA;  CASE WHEN ATTR_CATEGORY='Applied' THEN 1 ELSE 0 END AS APPLIED&#xD;&#xA;  FROM QRASEAPATR) B&#xD;&#xA; GROUP BY B.FACTORY, B.PACKAGE) DATA&#xD;&#xA;    ON A.FACTORY = DATA.FACTORY&#xD;&#xA;   AND A.PACKAGE = DATA.PACKAGE&#xD;&#xA; WHERE A.FACTORY = @factory&#xD;&#xA; ORDER BY A.PACKAGE">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="880" N="ListPackageVer">
          <QY P="MsSql" Q="SELECT A.PKG_VER, A.PKG_VER_DESC, ISNULL(SET_COUNT, 0), ISNULL(REL_COUNT, 0), ISNULL(APP_COUNT, 0), A.PKG_VER_PATH, A.PKG_COMMENT,&#xD;&#xA;       A.PKG_RELEASE,&#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME, A.UPDATE_USER_ID, A.UPDATE_TIME &#xD;&#xA;  FROM QSYSPKGVER A&#xD;&#xA;  LEFT JOIN(&#xD;&#xA;SELECT A.FACTORY, A.PACKAGE, A.PKG_VER, SUM(A.SETUP) AS SET_COUNT, SUM(A.RELEASED) AS REL_COUNT, SUM(A.APPLIED) AS APP_COUNT&#xD;&#xA;  FROM (   &#xD;&#xA;SELECT FACTORY, PACKAGE, PKG_VER,  &#xD;&#xA;  CASE WHEN ATTR_CATEGORY='Setup' THEN 1 ELSE 0 END AS SETUP,&#xD;&#xA;  CASE WHEN ATTR_CATEGORY='Released' THEN 1 ELSE 0 END AS RELEASED,&#xD;&#xA;  CASE WHEN ATTR_CATEGORY='Applied' THEN 1 ELSE 0 END AS APPLIED&#xD;&#xA;  FROM QRASEAPATR &#xD;&#xA; ) A&#xD;&#xA; GROUP BY FACTORY, PACKAGE, PKG_VER&#xD;&#xA;  ) DATA&#xD;&#xA;    ON A.FACTORY = DATA.FACTORY&#xD;&#xA;   AND A.PACKAGE = DATA.PACKAGE&#xD;&#xA;   AND A.PKG_VER = DATA.PKG_VER&#xD;&#xA; WHERE A.FACTORY = @factory&#xD;&#xA;   AND A.PACKAGE = @package&#xD;&#xA; ORDER BY A.PKG_VER DESC">
            <QP N="factory" />
            <QP N="package" />
          </QY>
        </SG>
        <SG _S="881" N="ListEap">
          <QY P="MsSql" Q="SELECT A.EAP, A.EAP_DESC, A.EAP_TYPE, A.OPER_ME, A.SERVER, A.STEP, A.UP_DOWN, A.STATUS, A.RELOAD_CNT,&#xD;&#xA;       ISNULL(B.PACKAGE, 'N/A') SET_PACKAGE,  ISNULL(B.PKG_VER, 0) SET_PKG_VER, ISNULL(C.PACKAGE, 'N/A') REL_PACKAGE, ISNULL(C.PKG_VER, 0) REL_PKG_VER, ISNULL(D.PACKAGE, 'N/A') APL_PACKAGE, ISNULL(D.PKG_VER, 0) APL_PKG_VER,&#xD;&#xA;       ISNULL(B.MODEL, 'N/A') SET_MODEL, ISNULL(B.MDL_VER, 0) SET_MDL_VER, ISNULL(C.MODEL, 'N/A') REL_MODEL, ISNULL(C.MDL_VER, 0) REL_MDL_VER, ISNULL(D.MODEL, 'N/A') APL_MODEL, ISNULL(D.MDL_VER, 0) APL_MDL_VER, &#xD;&#xA;       ISNULL(B.USED_COM, 'N/A') SET_USED_COM, ISNULL(B.COMPONENT, 'N/A') SET_COMPONENT, ISNULL(B.COM_VER, 0) SET_COM_VER, ISNULL(C.USED_COM, 'N/A') REL_USED_COM, ISNULL(C.COMPONENT, 'N/A') REL_COMPONENT, ISNULL(C.COM_VER, 0) REL_COM_VER, ISNULL(D.USED_COM, 'N/A') APL_USED_COM, ISNULL(D.COMPONENT, 'N/A') APL_COMPONENT, ISNULL(D.COM_VER, 0) APL_COM_VER,&#xD;&#xA;       A.NEED_ACTION, A.NEXT_NEED_ACTION, A.LAST_EVENT_TIME, A.LAST_EVENT_ID,&#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME, A.UPDATE_USER_ID, A.UPDATE_TIME&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP              = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP              = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP              = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND B.PACKAGE         = @package&#xD;&#xA;   AND B.PKG_VER         = @pkg_ver&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'   &#xD;&#xA; ORDER BY EAP">
            <QP N="factory" />
            <QP N="package" />
            <QP N="pkg_ver" />
          </QY>
        </SG>
        <SG _S="882" N="SearchEap">
          <QY P="MsSql" Q="SELECT A.EAP, A.EAP_DESC, &#xD;&#xA;       A.EAP_TYPE, A.OPER_ME, A.SERVER, &#xD;&#xA;       A.UP_DOWN, A.STATUS, A.STEP, &#xD;&#xA;       A.NEED_ACTION, A.NEXT_NEED_ACTION, A.RELOAD_CNT,&#xD;&#xA;       ISNULL(B.PACKAGE, 'N/A') SET_PACKAGE, ISNULL(B.PKG_VER, 0) SET_PKG_VER, ISNULL(B.MODEL, 'N/A') SET_MODEL, ISNULL(B.MDL_VER, 0) SET_MDL_VER, ISNULL(B.USED_COM, 'N/A') SET_USED_COM, ISNULL(B.COMPONENT, 'N/A') SET_COMPONENT, ISNULL(B.COM_VER, 0) SET_COM_VER,&#xD;&#xA;       ISNULL(C.PACKAGE, 'N/A') REL_PACKAGE, ISNULL(C.PKG_VER, 0) REL_PKG_VER, ISNULL(C.MODEL, 'N/A') REL_MODEL, ISNULL(C.MDL_VER, 0) REL_MDL_VER, ISNULL(C.USED_COM, 'N/A') REL_USED_COM, ISNULL(C.COMPONENT, 'N/A') REL_COMPONENT, ISNULL(C.COM_VER, 0) REL_COM_VER,&#xD;&#xA;       ISNULL(D.PACKAGE, 'N/A') APL_PACKAGE, ISNULL(D.PKG_VER, 0) APL_PKG_VER, ISNULL(D.MODEL, 'N/A') APL_MODEL, ISNULL(D.MDL_VER, 0) APL_MDL_VER, ISNULL(D.USED_COM, 'N/A') APL_USED_COM, ISNULL(D.COMPONENT, 'N/A') APL_COMPONENT, ISNULL(D.COM_VER, 0) APL_COM_VER,&#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME,&#xD;&#xA;       A.UPDATE_USER_ID, A.UPDATE_TIME,&#xD;&#xA;       A.LAST_EVENT_TIME, A.LAST_EVENT_ID&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP              = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP              = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP              = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.EAP                 = @eap&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="883" N="ListPackageVerFile">
          <QY P="MsSql" Q="SELECT FILE_NAME, FILE_TYPE&#xD;&#xA;  FROM QSYSPKGFIL&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND PACKAGE = @package&#xD;&#xA;   AND PKG_VER = @pkg_ver&#xD;&#xA; ORDER BY FILE_TYPE DESC, FILE_NAME ASC">
            <QP N="factory" />
            <QP N="package" />
            <QP N="pkg_ver" />
          </QY>
        </SG>
      </F>
      <F _S="884" N="PackageStatus">
        <SG _S="885" N="ListPackageVer">
          <QY P="MsSql" Q="SELECT PKG_VER, PKG_VER_DESC, PKG_RELEASE &#xD;&#xA;  FROM QSYSPKGVER&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND PACKAGE = @package&#xD;&#xA; ORDER BY PKG_VER DESC">
            <QP N="factory" />
            <QP N="package" />
          </QY>
        </SG>
        <SG _S="886" N="SearchPackage">
          <QY P="MsSql" Q="SELECT A.PACKAGE, A.PKG_DESC, A.PKG_TYPE, &#xD;&#xA;       A.REL_PKG_VER, A.LAST_PKG_VER, &#xD;&#xA;       B.PKG_VER, B.PKG_RELEASE, B.PKG_VER_DESC, &#xD;&#xA;       B.PKG_VER_PATH, B.PKG_COMMENT,&#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME,  &#xD;&#xA;       A.UPDATE_USER_ID, A.UPDATE_TIME&#xD;&#xA;  FROM QSYSPKGDEF A&#xD;&#xA; INNER JOIN QSYSPKGVER B&#xD;&#xA;    ON A.FACTORY = B.FACTORY&#xD;&#xA;   AND A.PACKAGE = B.PACKAGE&#xD;&#xA; WHERE A.FACTORY = @factory &#xD;&#xA;   AND A.PACKAGE = @package&#xD;&#xA;   AND B.PKG_VER = @pkg_ver">
            <QP N="factory" />
            <QP N="package" />
            <QP N="pkg_ver" />
          </QY>
        </SG>
        <SG _S="887" N="ListEap">
          <QY P="MsSql" Q="SELECT A.EAP, A.EAP_DESC, A.EAP_TYPE, A.OPER_ME, A.SERVER, A.STEP, A.UP_DOWN, A.STATUS, A.RELOAD_CNT,&#xD;&#xA;       ISNULL(B.PACKAGE, 'N/A') SET_PACKAGE,  ISNULL(B.PKG_VER, 0) SET_PKG_VER, ISNULL(C.PACKAGE, 'N/A') REL_PACKAGE, ISNULL(C.PKG_VER, 0) REL_PKG_VER, ISNULL(D.PACKAGE, 'N/A') APL_PACKAGE, ISNULL(D.PKG_VER, 0) APL_PKG_VER,&#xD;&#xA;       ISNULL(B.MODEL, 'N/A') SET_MODEL, ISNULL(B.MDL_VER, 0) SET_MDL_VER, ISNULL(C.MODEL, 'N/A') REL_MODEL, ISNULL(C.MDL_VER, 0) REL_MDL_VER, ISNULL(D.MODEL, 'N/A') APL_MODEL, ISNULL(D.MDL_VER, 0) APL_MDL_VER, &#xD;&#xA;       ISNULL(B.USED_COM, 'N/A') SET_USED_COM, ISNULL(B.COMPONENT, 'N/A') SET_COMPONENT, ISNULL(B.COM_VER, 0) SET_COM_VER, ISNULL(C.USED_COM, 'N/A') REL_USED_COM, ISNULL(C.COMPONENT, 'N/A') REL_COMPONENT, ISNULL(C.COM_VER, 0) REL_COM_VER, ISNULL(D.USED_COM, 'N/A') APL_USED_COM, ISNULL(D.COMPONENT, 'N/A') APL_COMPONENT, ISNULL(D.COM_VER, 0) APL_COM_VER,&#xD;&#xA;       A.NEED_ACTION, A.NEXT_NEED_ACTION, A.LAST_EVENT_TIME, A.LAST_EVENT_ID,&#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME, A.UPDATE_USER_ID, A.UPDATE_TIME&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP              = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP              = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP              = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND B.PACKAGE        = @package&#xD;&#xA;   AND B.PKG_VER         = @pkg_ver&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'   &#xD;&#xA; ORDER BY EAP">
            <QP N="factory" />
            <QP N="package" />
            <QP N="pkg_ver" />
          </QY>
        </SG>
        <SG _S="888" N="SearchEap">
          <QY P="MsSql" Q="SELECT A.EAP, A.EAP_DESC, &#xD;&#xA;       A.EAP_TYPE, A.OPER_ME, A.SERVER, &#xD;&#xA;       A.UP_DOWN, A.STATUS, A.STEP, &#xD;&#xA;       A.NEED_ACTION, A.NEXT_NEED_ACTION, A.RELOAD_CNT,&#xD;&#xA;       ISNULL(B.PACKAGE, 'N/A') SET_PACKAGE, ISNULL(B.PKG_VER, 0) SET_PKG_VER, ISNULL(B.MODEL, 'N/A') SET_MODEL, ISNULL(B.MDL_VER, 0) SET_MDL_VER, ISNULL(B.USED_COM, 'N/A') SET_USED_COM, ISNULL(B.COMPONENT, 'N/A') SET_COMPONENT, ISNULL(B.COM_VER, 0) SET_COM_VER,&#xD;&#xA;       ISNULL(C.PACKAGE, 'N/A') REL_PACKAGE, ISNULL(C.PKG_VER, 0) REL_PKG_VER, ISNULL(C.MODEL, 'N/A') REL_MODEL, ISNULL(C.MDL_VER, 0) REL_MDL_VER, ISNULL(C.USED_COM, 'N/A') REL_USED_COM, ISNULL(C.COMPONENT, 'N/A') REL_COMPONENT, ISNULL(C.COM_VER, 0) REL_COM_VER,&#xD;&#xA;       ISNULL(D.PACKAGE, 'N/A') APL_PACKAGE, ISNULL(D.PKG_VER, 0) APL_PKG_VER, ISNULL(D.MODEL, 'N/A') APL_MODEL, ISNULL(D.MDL_VER, 0) APL_MDL_VER, ISNULL(D.USED_COM, 'N/A') APL_USED_COM, ISNULL(D.COMPONENT, 'N/A') APL_COMPONENT, ISNULL(D.COM_VER, 0) APL_COM_VER,&#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME,&#xD;&#xA;       A.UPDATE_USER_ID, A.UPDATE_TIME,&#xD;&#xA;       A.LAST_EVENT_TIME, A.LAST_EVENT_ID&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP              = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP              = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP              = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.EAP                 = @eap&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="889" N="ListPackageVerFile">
          <QY P="MsSql" Q="SELECT FILE_NAME, FILE_TYPE&#xD;&#xA;  FROM QSYSPKGFIL&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND PACKAGE = @package&#xD;&#xA;   AND PKG_VER = @pkg_ver&#xD;&#xA; ORDER BY FILE_TYPE DESC, FILE_NAME ASC">
            <QP N="factory" />
            <QP N="package" />
            <QP N="pkg_ver" />
          </QY>
        </SG>
      </F>
      <F _S="890" N="ModelList">
        <SG _S="891" N="ListModel">
          <QY P="MsSql" Q="SELECT A.MODEL, A.MDL_DESC, A.MDL_TYPE, ISNULL(DATA.SET_COUNT, 0), ISNULL(DATA.REL_COUNT, 0), ISNULL(DATA.APP_COUNT, 0), A.REL_MDL_VER, A.LAST_MDL_VER, A.CREATE_USER_ID, A.CREATE_TIME, A.UPDATE_USER_ID, A.UPDATE_TIME&#xD;&#xA;  FROM QSYSMDLDEF A&#xD;&#xA;  LEFT JOIN (  &#xD;&#xA;SELECT B.FACTORY, B.MODEL,  SUM(B.SETUP) AS SET_COUNT, SUM(B.RELEASED) AS REL_COUNT, SUM(B.APPLIED) AS APP_COUNT &#xD;&#xA;  FROM (&#xD;&#xA;SELECT FACTORY, MODEL,&#xD;&#xA;  CASE WHEN ATTR_CATEGORY='Setup' THEN 1 ELSE 0 END AS SETUP,&#xD;&#xA;  CASE WHEN ATTR_CATEGORY='Released' THEN 1 ELSE 0 END AS RELEASED,&#xD;&#xA;  CASE WHEN ATTR_CATEGORY='Applied' THEN 1 ELSE 0 END AS APPLIED&#xD;&#xA;  FROM QRASEAPATR) B&#xD;&#xA; GROUP BY B.FACTORY, B.MODEL) DATA&#xD;&#xA;    ON A.FACTORY = DATA.FACTORY&#xD;&#xA;   AND A.MODEL   = DATA.MODEL&#xD;&#xA; WHERE A.FACTORY = @factory&#xD;&#xA; ORDER BY A.MODEL">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="892" N="ListModelVer">
          <QY P="MsSql" Q="SELECT A.MDL_VER, A.MDL_VER_DESC, ISNULL(SET_COUNT, 0), ISNULL(REL_COUNT, 0), ISNULL(APP_COUNT, 0), A.MDL_VER_PATH, A.MDL_COMMENT, A.MDL_RELEASE,&#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME, A.UPDATE_USER_ID, A.UPDATE_TIME &#xD;&#xA;  FROM QSYSMDLVER A&#xD;&#xA;  LEFT JOIN(&#xD;&#xA;SELECT A.FACTORY, A.MODEL, A.MDL_VER, SUM(A.SETUP) AS SET_COUNT, SUM(A.RELEASED) AS REL_COUNT, SUM(A.APPLIED) AS APP_COUNT&#xD;&#xA;  FROM (   &#xD;&#xA;SELECT FACTORY, MODEL, MDL_VER,  &#xD;&#xA;  CASE WHEN ATTR_CATEGORY='Setup' THEN 1 ELSE 0 END AS SETUP,&#xD;&#xA;  CASE WHEN ATTR_CATEGORY='Released' THEN 1 ELSE 0 END AS RELEASED,&#xD;&#xA;  CASE WHEN ATTR_CATEGORY='Applied' THEN 1 ELSE 0 END AS APPLIED&#xD;&#xA;  FROM QRASEAPATR &#xD;&#xA; ) A&#xD;&#xA; GROUP BY FACTORY, MODEL, MDL_VER&#xD;&#xA;  ) DATA&#xD;&#xA;    ON A.FACTORY  = DATA.FACTORY&#xD;&#xA;   AND A.MODEL    = DATA.MODEL&#xD;&#xA;   AND A.MDL_VER  = DATA.MDL_VER&#xD;&#xA; WHERE A.FACTORY  = @factory&#xD;&#xA;   AND A.MODEL    = @model&#xD;&#xA; ORDER BY A.MDL_VER DESC">
            <QP N="factory" />
            <QP N="model" />
          </QY>
        </SG>
        <SG _S="893" N="ListEap">
          <QY P="MsSql" Q="SELECT A.EAP, A.EAP_DESC, A.EAP_TYPE, A.OPER_ME, A.SERVER, A.STEP, A.UP_DOWN, A.STATUS, A.RELOAD_CNT,&#xD;&#xA;       ISNULL(B.PACKAGE, 'N/A') SET_PACKAGE,  ISNULL(B.PKG_VER, 0) SET_PKG_VER, ISNULL(C.PACKAGE, 'N/A') REL_PACKAGE, ISNULL(C.PKG_VER, 0) REL_PKG_VER, ISNULL(D.PACKAGE, 'N/A') APL_PACKAGE, ISNULL(D.PKG_VER, 0) APL_PKG_VER,&#xD;&#xA;       ISNULL(B.MODEL, 'N/A') SET_MODEL, ISNULL(B.MDL_VER, 0) SET_MDL_VER, ISNULL(C.MODEL, 'N/A') REL_MODEL, ISNULL(C.MDL_VER, 0) REL_MDL_VER, ISNULL(D.MODEL, 'N/A') APL_MODEL, ISNULL(D.MDL_VER, 0) APL_MDL_VER, &#xD;&#xA;       ISNULL(B.USED_COM, 'N/A') SET_USED_COM, ISNULL(B.COMPONENT, 'N/A') SET_COMPONENT, ISNULL(B.COM_VER, 0) SET_COM_VER, ISNULL(C.USED_COM, 'N/A') REL_USED_COM, ISNULL(C.COMPONENT, 'N/A') REL_COMPONENT, ISNULL(C.COM_VER, 0) REL_COM_VER, ISNULL(D.USED_COM, 'N/A') APL_USED_COM, ISNULL(D.COMPONENT, 'N/A') APL_COMPONENT, ISNULL(D.COM_VER, 0) APL_COM_VER,&#xD;&#xA;       A.NEED_ACTION, A.NEXT_NEED_ACTION, A.LAST_EVENT_TIME, A.LAST_EVENT_ID,&#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME, A.UPDATE_USER_ID, A.UPDATE_TIME&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP              = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP              = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP              = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND B.MODEL            = @model&#xD;&#xA;   AND B.MDL_VER         = @mdl_ver&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'   &#xD;&#xA; ORDER BY EAP">
            <QP N="factory" />
            <QP N="model" />
            <QP N="mdl_ver" />
          </QY>
        </SG>
        <SG _S="894" N="SearchEap">
          <QY P="MsSql" Q="SELECT A.EAP, A.EAP_DESC, &#xD;&#xA;       A.EAP_TYPE, A.OPER_ME, A.SERVER, &#xD;&#xA;       A.UP_DOWN, A.STATUS, A.STEP, &#xD;&#xA;       A.NEED_ACTION, A.NEXT_NEED_ACTION, A.RELOAD_CNT,&#xD;&#xA;       ISNULL(B.PACKAGE, 'N/A') SET_PACKAGE, ISNULL(B.PKG_VER, 0) SET_PKG_VER, ISNULL(B.MODEL, 'N/A') SET_MODEL, ISNULL(B.MDL_VER, 0) SET_MDL_VER, ISNULL(B.USED_COM, 'N/A') SET_USED_COM, ISNULL(B.COMPONENT, 'N/A') SET_COMPONENT, ISNULL(B.COM_VER, 0) SET_COM_VER,&#xD;&#xA;       ISNULL(C.PACKAGE, 'N/A') REL_PACKAGE, ISNULL(C.PKG_VER, 0) REL_PKG_VER, ISNULL(C.MODEL, 'N/A') REL_MODEL, ISNULL(C.MDL_VER, 0) REL_MDL_VER, ISNULL(C.USED_COM, 'N/A') REL_USED_COM, ISNULL(C.COMPONENT, 'N/A') REL_COMPONENT, ISNULL(C.COM_VER, 0) REL_COM_VER,&#xD;&#xA;       ISNULL(D.PACKAGE, 'N/A') APL_PACKAGE, ISNULL(D.PKG_VER, 0) APL_PKG_VER, ISNULL(D.MODEL, 'N/A') APL_MODEL, ISNULL(D.MDL_VER, 0) APL_MDL_VER, ISNULL(D.USED_COM, 'N/A') APL_USED_COM, ISNULL(D.COMPONENT, 'N/A') APL_COMPONENT, ISNULL(D.COM_VER, 0) APL_COM_VER,&#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME,&#xD;&#xA;       A.UPDATE_USER_ID, A.UPDATE_TIME,&#xD;&#xA;       A.LAST_EVENT_TIME, A.LAST_EVENT_ID&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP              = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP              = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP              = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.EAP                 = @eap&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="895" N="SearchModelSheet">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;  SHT_CONTENTS_01,&#xD;&#xA;  SHT_CONTENTS_02,&#xD;&#xA;  SHT_CONTENTS_03,&#xD;&#xA;  SHT_CONTENTS_04,&#xD;&#xA;  SHT_CONTENTS_05,&#xD;&#xA;  SHT_CONTENTS_06,&#xD;&#xA;  SHT_CONTENTS_07,&#xD;&#xA;  SHT_CONTENTS_08,&#xD;&#xA;  SHT_CONTENTS_09,&#xD;&#xA;  SHT_CONTENTS_10,&#xD;&#xA;  SHT_CONTENTS_11,&#xD;&#xA;  SHT_CONTENTS_12,&#xD;&#xA;  SHT_CONTENTS_13,&#xD;&#xA;  SHT_CONTENTS_14,&#xD;&#xA;  SHT_CONTENTS_15,&#xD;&#xA;  SHT_CONTENTS_16,&#xD;&#xA;  SHT_CONTENTS_17,&#xD;&#xA;  SHT_CONTENTS_18,&#xD;&#xA;  SHT_CONTENTS_19,&#xD;&#xA;  SHT_CONTENTS_20&#xD;&#xA;  FROM QSMDLSHT&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND MODEL  = @model">
            <QP N="factory" />
            <QP N="model" />
          </QY>
        </SG>
      </F>
      <F _S="896" N="ModelStatus">
        <SG _S="897" N="ListModelVer">
          <QY P="MsSql" Q="SELECT MDL_VER, MDL_VER_DESC, MDL_RELEASE &#xD;&#xA;  FROM QSYSMDLVER&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND MODEL  = @model&#xD;&#xA; ORDER BY MDL_VER DESC">
            <QP N="factory" />
            <QP N="model" />
          </QY>
        </SG>
        <SG _S="898" N="SearchModel">
          <QY P="MsSql" Q="SELECT A.MODEL, A.MDL_DESC, A.MDL_TYPE,&#xD;&#xA;       A.REL_MDL_VER, A.LAST_MDL_VER,&#xD;&#xA;       B.MDL_VER, B.MDL_RELEASE, B.MDL_VER_DESC,&#xD;&#xA;       B.MDL_VER_PATH, B.MDL_COMMENT,&#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME,&#xD;&#xA;       A.UPDATE_USER_ID, A.UPDATE_TIME&#xD;&#xA;  FROM QSYSMDLDEF A&#xD;&#xA; INNER JOIN QSYSMDLVER B&#xD;&#xA;    ON A.FACTORY = B.FACTORY&#xD;&#xA;   AND A.MODEL   = B.MODEL&#xD;&#xA; WHERE A.FACTORY = @factory &#xD;&#xA;   AND A.MODEL   = @model&#xD;&#xA;   AND B.MDL_VER = @mdl_ver">
            <QP N="factory" />
            <QP N="model" />
            <QP N="mdl_ver" />
          </QY>
        </SG>
        <SG _S="899" N="ListEap">
          <QY P="MsSql" Q="SELECT A.EAP, A.EAP_DESC, A.EAP_TYPE, A.OPER_ME, A.SERVER, A.STEP, A.UP_DOWN, A.STATUS, A.RELOAD_CNT,&#xD;&#xA;       ISNULL(B.PACKAGE, 'N/A') SET_PACKAGE,  ISNULL(B.PKG_VER, 0) SET_PKG_VER, ISNULL(C.PACKAGE, 'N/A') REL_PACKAGE, ISNULL(C.PKG_VER, 0) REL_PKG_VER, ISNULL(D.PACKAGE, 'N/A') APL_PACKAGE, ISNULL(D.PKG_VER, 0) APL_PKG_VER,&#xD;&#xA;       ISNULL(B.MODEL, 'N/A') SET_MODEL, ISNULL(B.MDL_VER, 0) SET_MDL_VER, ISNULL(C.MODEL, 'N/A') REL_MODEL, ISNULL(C.MDL_VER, 0) REL_MDL_VER, ISNULL(D.MODEL, 'N/A') APL_MODEL, ISNULL(D.MDL_VER, 0) APL_MDL_VER, &#xD;&#xA;       ISNULL(B.USED_COM, 'N/A') SET_USED_COM, ISNULL(B.COMPONENT, 'N/A') SET_COMPONENT, ISNULL(B.COM_VER, 0) SET_COM_VER, ISNULL(C.USED_COM, 'N/A') REL_USED_COM, ISNULL(C.COMPONENT, 'N/A') REL_COMPONENT, ISNULL(C.COM_VER, 0) REL_COM_VER, ISNULL(D.USED_COM, 'N/A') APL_USED_COM, ISNULL(D.COMPONENT, 'N/A') APL_COMPONENT, ISNULL(D.COM_VER, 0) APL_COM_VER,&#xD;&#xA;       A.NEED_ACTION, A.NEXT_NEED_ACTION, A.LAST_EVENT_TIME, A.LAST_EVENT_ID,&#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME, A.UPDATE_USER_ID, A.UPDATE_TIME&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP              = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP              = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP              = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND B.MODEL             = @model&#xD;&#xA;   AND B.MDL_VER         = @mdl_ver&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'   &#xD;&#xA; ORDER BY EAP">
            <QP N="factory" />
            <QP N="model" />
            <QP N="mdl_ver" />
          </QY>
        </SG>
        <SG _S="900" N="SearchEap">
          <QY P="MsSql" Q="SELECT A.EAP, A.EAP_DESC, &#xD;&#xA;       A.EAP_TYPE, A.OPER_ME, A.SERVER, &#xD;&#xA;       A.UP_DOWN, A.STATUS, A.STEP, &#xD;&#xA;       A.NEED_ACTION, A.NEXT_NEED_ACTION, A.RELOAD_CNT,&#xD;&#xA;       ISNULL(B.PACKAGE, 'N/A') SET_PACKAGE, ISNULL(B.PKG_VER, 0) SET_PKG_VER, ISNULL(B.MODEL, 'N/A') SET_MODEL, ISNULL(B.MDL_VER, 0) SET_MDL_VER, ISNULL(B.USED_COM, 'N/A') SET_USED_COM, ISNULL(B.COMPONENT, 'N/A') SET_COMPONENT, ISNULL(B.COM_VER, 0) SET_COM_VER,&#xD;&#xA;       ISNULL(C.PACKAGE, 'N/A') REL_PACKAGE, ISNULL(C.PKG_VER, 0) REL_PKG_VER, ISNULL(C.MODEL, 'N/A') REL_MODEL, ISNULL(C.MDL_VER, 0) REL_MDL_VER, ISNULL(C.USED_COM, 'N/A') REL_USED_COM, ISNULL(C.COMPONENT, 'N/A') REL_COMPONENT, ISNULL(C.COM_VER, 0) REL_COM_VER,&#xD;&#xA;       ISNULL(D.PACKAGE, 'N/A') APL_PACKAGE, ISNULL(D.PKG_VER, 0) APL_PKG_VER, ISNULL(D.MODEL, 'N/A') APL_MODEL, ISNULL(D.MDL_VER, 0) APL_MDL_VER, ISNULL(D.USED_COM, 'N/A') APL_USED_COM, ISNULL(D.COMPONENT, 'N/A') APL_COMPONENT, ISNULL(D.COM_VER, 0) APL_COM_VER,&#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME,&#xD;&#xA;       A.UPDATE_USER_ID, A.UPDATE_TIME,&#xD;&#xA;       A.LAST_EVENT_TIME, A.LAST_EVENT_ID&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP              = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP              = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP              = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.EAP                 = @eap&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="901" N="SearchModelSheet">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;  SHT_CONTENTS_01,&#xD;&#xA;  SHT_CONTENTS_02,&#xD;&#xA;  SHT_CONTENTS_03,&#xD;&#xA;  SHT_CONTENTS_04,&#xD;&#xA;  SHT_CONTENTS_05,&#xD;&#xA;  SHT_CONTENTS_06,&#xD;&#xA;  SHT_CONTENTS_07,&#xD;&#xA;  SHT_CONTENTS_08,&#xD;&#xA;  SHT_CONTENTS_09,&#xD;&#xA;  SHT_CONTENTS_10,&#xD;&#xA;  SHT_CONTENTS_11,&#xD;&#xA;  SHT_CONTENTS_12,&#xD;&#xA;  SHT_CONTENTS_13,&#xD;&#xA;  SHT_CONTENTS_14,&#xD;&#xA;  SHT_CONTENTS_15,&#xD;&#xA;  SHT_CONTENTS_16,&#xD;&#xA;  SHT_CONTENTS_17,&#xD;&#xA;  SHT_CONTENTS_18,&#xD;&#xA;  SHT_CONTENTS_19,&#xD;&#xA;  SHT_CONTENTS_20&#xD;&#xA;  FROM QSMDLSHT&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND MODEL  = @model">
            <QP N="factory" />
            <QP N="model" />
          </QY>
        </SG>
      </F>
      <F _S="902" N="ComponentList">
        <SG _S="903" N="ListComponent">
          <QY P="MsSql" Q="SELECT A.COMPONENT, A.COM_DESC, A.COM_TYPE, ISNULL(DATA.SET_COUNT, 0), ISNULL(DATA.REL_COUNT, 0), ISNULL(DATA.APP_COUNT, 0), &#xD;&#xA;       A.REL_COM_VER, A.LAST_COM_VER, A.CREATE_USER_ID, A.CREATE_TIME, A.UPDATE_USER_ID, A.UPDATE_TIME&#xD;&#xA;  FROM QSCOMDEF A&#xD;&#xA;  LEFT JOIN (  &#xD;&#xA;SELECT B.FACTORY, B.COMPONENT,  SUM(B.SETUP) AS SET_COUNT, SUM(B.RELEASED) AS REL_COUNT, SUM(B.APPLIED) AS APP_COUNT &#xD;&#xA;  FROM (&#xD;&#xA;SELECT FACTORY, COMPONENT,&#xD;&#xA;  CASE WHEN ATTR_CATEGORY='Setup' THEN 1 ELSE 0 END AS SETUP,&#xD;&#xA;  CASE WHEN ATTR_CATEGORY='Released' THEN 1 ELSE 0 END AS RELEASED,&#xD;&#xA;  CASE WHEN ATTR_CATEGORY='Applied' THEN 1 ELSE 0 END AS APPLIED&#xD;&#xA;  FROM QRASEAPATR) B&#xD;&#xA; GROUP BY B.FACTORY, B.COMPONENT) DATA&#xD;&#xA;    ON A.FACTORY   = DATA.FACTORY&#xD;&#xA;   AND A.COMPONENT = DATA.COMPONENT&#xD;&#xA; WHERE A.FACTORY   = @factory&#xD;&#xA; ORDER BY A.COMPONENT">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="904" N="ListComponentVer">
          <QY P="MsSql" Q="SELECT A.COM_VER, A.COM_VER_DESC, ISNULL(SET_COUNT, 0), ISNULL(REL_COUNT, 0), ISNULL(APP_COUNT, 0), A.COM_VER_PATH, A.COM_COMMENT, A.COM_RELEASE,&#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME, A.UPDATE_USER_ID, A.UPDATE_TIME &#xD;&#xA;  FROM QSCOMVER A&#xD;&#xA;  LEFT JOIN(&#xD;&#xA;SELECT A.FACTORY, A.COMPONENT, A.COM_VER, SUM(A.SETUP) AS SET_COUNT, SUM(A.RELEASED) AS REL_COUNT, SUM(A.APPLIED) AS APP_COUNT&#xD;&#xA;  FROM (   &#xD;&#xA;SELECT FACTORY, COMPONENT, COM_VER,  &#xD;&#xA;  CASE WHEN ATTR_CATEGORY='Setup' THEN 1 ELSE 0 END AS SETUP,&#xD;&#xA;  CASE WHEN ATTR_CATEGORY='Released' THEN 1 ELSE 0 END AS RELEASED,&#xD;&#xA;  CASE WHEN ATTR_CATEGORY='Applied' THEN 1 ELSE 0 END AS APPLIED&#xD;&#xA;  FROM QRASEAPATR &#xD;&#xA; ) A&#xD;&#xA; GROUP BY FACTORY, COMPONENT, COM_VER&#xD;&#xA;  ) DATA&#xD;&#xA;    ON A.FACTORY    = DATA.FACTORY&#xD;&#xA;   AND A.COMPONENT  = DATA.COMPONENT&#xD;&#xA;   AND A.COM_VER    = DATA.COM_VER&#xD;&#xA; WHERE A.FACTORY    = @factory&#xD;&#xA;   AND A.COMPONENT  = @component&#xD;&#xA; ORDER BY A.COM_VER DESC">
            <QP N="factory" />
            <QP N="component" />
          </QY>
        </SG>
        <SG _S="905" N="ListEap">
          <QY P="MsSql" Q="SELECT A.EAP, A.EAP_DESC, A.EAP_TYPE, A.OPER_ME, A.SERVER, A.STEP, A.UP_DOWN, A.STATUS, A.RELOAD_CNT,&#xD;&#xA;       ISNULL(B.PACKAGE, 'N/A') SET_PACKAGE,  ISNULL(B.PKG_VER, 0) SET_PKG_VER, ISNULL(C.PACKAGE, 'N/A') REL_PACKAGE, ISNULL(C.PKG_VER, 0) REL_PKG_VER, ISNULL(D.PACKAGE, 'N/A') APL_PACKAGE, ISNULL(D.PKG_VER, 0) APL_PKG_VER,&#xD;&#xA;       ISNULL(B.MODEL, 'N/A') SET_MODEL, ISNULL(B.MDL_VER, 0) SET_MDL_VER, ISNULL(C.MODEL, 'N/A') REL_MODEL, ISNULL(C.MDL_VER, 0) REL_MDL_VER, ISNULL(D.MODEL, 'N/A') APL_MODEL, ISNULL(D.MDL_VER, 0) APL_MDL_VER, &#xD;&#xA;       ISNULL(B.USED_COM, 'N/A') SET_USED_COM, ISNULL(B.COMPONENT, 'N/A') SET_COMPONENT, ISNULL(B.COM_VER, 0) SET_COM_VER, ISNULL(C.USED_COM, 'N/A') REL_USED_COM, ISNULL(C.COMPONENT, 'N/A') REL_COMPONENT, ISNULL(C.COM_VER, 0) REL_COM_VER, ISNULL(D.USED_COM, 'N/A') APL_USED_COM, ISNULL(D.COMPONENT, 'N/A') APL_COMPONENT, ISNULL(D.COM_VER, 0) APL_COM_VER,&#xD;&#xA;       A.NEED_ACTION, A.NEXT_NEED_ACTION, A.LAST_EVENT_TIME, A.LAST_EVENT_ID,&#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME, A.UPDATE_USER_ID, A.UPDATE_TIME&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP              = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP              = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP              = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY        = @factory&#xD;&#xA;   AND B.COMPONENT     = @component&#xD;&#xA;   AND B.COM_VER         = @com_ver&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'   &#xD;&#xA; ORDER BY EAP">
            <QP N="factory" />
            <QP N="component" />
            <QP N="com_ver" />
          </QY>
        </SG>
        <SG _S="906" N="SearchEap">
          <QY P="MsSql" Q="SELECT A.EAP, A.EAP_DESC, &#xD;&#xA;       A.EAP_TYPE, A.OPER_ME, A.SERVER, &#xD;&#xA;       A.UP_DOWN, A.STATUS, A.STEP, &#xD;&#xA;       A.NEED_ACTION, A.NEXT_NEED_ACTION, A.RELOAD_CNT,&#xD;&#xA;       ISNULL(B.PACKAGE, 'N/A') SET_PACKAGE, ISNULL(B.PKG_VER, 0) SET_PKG_VER, ISNULL(B.MODEL, 'N/A') SET_MODEL, ISNULL(B.MDL_VER, 0) SET_MDL_VER, ISNULL(B.USED_COM, 'N/A') SET_USED_COM, ISNULL(B.COMPONENT, 'N/A') SET_COMPONENT, ISNULL(B.COM_VER, 0) SET_COM_VER,&#xD;&#xA;       ISNULL(C.PACKAGE, 'N/A') REL_PACKAGE, ISNULL(C.PKG_VER, 0) REL_PKG_VER, ISNULL(C.MODEL, 'N/A') REL_MODEL, ISNULL(C.MDL_VER, 0) REL_MDL_VER, ISNULL(C.USED_COM, 'N/A') REL_USED_COM, ISNULL(C.COMPONENT, 'N/A') REL_COMPONENT, ISNULL(C.COM_VER, 0) REL_COM_VER,&#xD;&#xA;       ISNULL(D.PACKAGE, 'N/A') APL_PACKAGE, ISNULL(D.PKG_VER, 0) APL_PKG_VER, ISNULL(D.MODEL, 'N/A') APL_MODEL, ISNULL(D.MDL_VER, 0) APL_MDL_VER, ISNULL(D.USED_COM, 'N/A') APL_USED_COM, ISNULL(D.COMPONENT, 'N/A') APL_COMPONENT, ISNULL(D.COM_VER, 0) APL_COM_VER,&#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME,&#xD;&#xA;       A.UPDATE_USER_ID, A.UPDATE_TIME,&#xD;&#xA;       A.LAST_EVENT_TIME, A.LAST_EVENT_ID&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP              = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP              = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP              = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.EAP                 = @eap&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
