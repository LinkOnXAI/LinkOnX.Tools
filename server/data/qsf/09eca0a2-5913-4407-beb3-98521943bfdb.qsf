      <F _S="912" N="EapList">
        <SG _S="913" N="HasServer">
          <QY P="MsSql" Q="SELECT SERVER&#xD;&#xA;  FROM QSYSSVRDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SERVER      = @server">
            <QP N="factory" />
            <QP N="server" />
          </QY>
        </SG>
        <SG _S="914" N="ListEap">
          <QY P="MsSql" Q="SELECT A.EAP, A.EAP_DESC, A.EAP_TYPE, A.OPER_ME, A.SERVER, A.STEP, A.UP_DOWN, A.STATUS, A.RELOAD_CNT,&#xD;&#xA;       ISNULL(B.PACKAGE, 'N/A') SET_PACKAGE,  ISNULL(B.PKG_VER, 0) SET_PKG_VER, ISNULL(C.PACKAGE, 'N/A') REL_PACKAGE, ISNULL(C.PKG_VER, 0) REL_PKG_VER, ISNULL(D.PACKAGE, 'N/A') APL_PACKAGE, ISNULL(D.PKG_VER, 0) APL_PKG_VER,&#xD;&#xA;       ISNULL(B.MODEL, 'N/A') SET_MODEL, ISNULL(B.MDL_VER, 0) SET_MDL_VER, ISNULL(C.MODEL, 'N/A') REL_MODEL, ISNULL(C.MDL_VER, 0) REL_MDL_VER, ISNULL(D.MODEL, 'N/A') APL_MODEL, ISNULL(D.MDL_VER, 0) APL_MDL_VER, &#xD;&#xA;       ISNULL(B.USED_COM, 'N/A') SET_USED_COM, ISNULL(B.COMPONENT, 'N/A') SET_COMPONENT, ISNULL(B.COM_VER, 0) SET_COM_VER, ISNULL(C.USED_COM, 'N/A') REL_USED_COM, ISNULL(C.COMPONENT, 'N/A') REL_COMPONENT, ISNULL(C.COM_VER, 0) REL_COM_VER, ISNULL(D.USED_COM, 'N/A') APL_USED_COM, ISNULL(D.COMPONENT, 'N/A') APL_COMPONENT, ISNULL(D.COM_VER, 0) APL_COM_VER,&#xD;&#xA;       A.NEED_ACTION, A.NEXT_NEED_ACTION, A.LAST_EVENT_TIME, A.LAST_EVENT_ID,&#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME, A.UPDATE_USER_ID, A.UPDATE_TIME&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY              = B.FACTORY&#xD;&#xA;   AND A.EAP                     = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C &#xD;&#xA;    ON A.FACTORY              = C.FACTORY&#xD;&#xA;   AND A.EAP                     = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D &#xD;&#xA;    ON A.FACTORY              = D.FACTORY&#xD;&#xA;   AND A.EAP                     = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY           = @factory&#xD;&#xA;   AND A.SERVER               = ISNULL(@server,A.SERVER)&#xD;&#xA;   AND B.PACKAGE             = ISNULL(@package, B.PACKAGE)&#xD;&#xA;   AND B.MODEL                 = ISNULL(@model, B.MODEL)&#xD;&#xA;   AND B.COMPONENT         = ISNULL(@component, B.COMPONENT)&#xD;&#xA;   AND A.DELETE_FLAG        = 'N'&#xD;&#xA; ORDER BY A.EAP">
            <QP N="factory" />
            <QP N="server" />
            <QP N="package" />
            <QP N="model" />
            <QP N="component" />
          </QY>
        </SG>
        <SG _S="915" N="SearchEap">
          <QY P="MsSql" Q="SELECT A.EAP, A.EAP_DESC, &#xD;&#xA;       A.EAP_TYPE, A.OPER_ME, A.SERVER, &#xD;&#xA;       A.UP_DOWN, A.STATUS, A.STEP,&#xD;&#xA;       A.NEED_ACTION, A.NEXT_NEED_ACTION, A.RELOAD_CNT,&#xD;&#xA;       ISNULL(B.PACKAGE, 'N/A') SET_PACKAGE, ISNULL(B.PKG_VER, 0) SET_PKG_VER, ISNULL(B.MODEL, 'N/A') SET_MODEL, ISNULL(B.MDL_VER, 0) SET_MDL_VER, ISNULL(B.USED_COM, 'N/A') SET_USED_COM, ISNULL(B.COMPONENT, 'N/A') SET_COMPONENT, ISNULL(B.COM_VER, 0) SET_COM_VER,&#xD;&#xA;       ISNULL(C.PACKAGE, 'N/A') REL_PACKAGE, ISNULL(C.PKG_VER, 0) REL_PKG_VER, ISNULL(C.MODEL, 'N/A') REL_MODEL, ISNULL(C.MDL_VER, 0) REL_MDL_VER, ISNULL(C.USED_COM, 'N/A') REL_USED_COM, ISNULL(C.COMPONENT, 'N/A') REL_COMPONENT, ISNULL(C.COM_VER, 0) REL_COM_VER,&#xD;&#xA;       ISNULL(D.PACKAGE, 'N/A') APL_PACKAGE, ISNULL(D.PKG_VER, 0) APL_PKG_VER, ISNULL(D.MODEL, 'N/A') APL_MODEL, ISNULL(D.MDL_VER, 0) APL_MDL_VER, ISNULL(D.USED_COM, 'N/A') APL_USED_COM, ISNULL(D.COMPONENT, 'N/A') APL_COMPONENT, ISNULL(D.COM_VER, 0) APL_COM_VER,&#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME,&#xD;&#xA;       A.UPDATE_USER_ID, A.UPDATE_TIME,&#xD;&#xA;       A.LAST_EVENT_TIME, A.LAST_EVENT_ID&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP           = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP           = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.EAP           = @eap&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
      </F>
      <F _S="916" N="EapStatus">
        <SG _S="917" N="HasEap">
          <QY P="MsSql" Q="SELECT *&#xD;&#xA;  FROM QRASEAPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EAP= ISNULL(@eap, EAP)">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="918" N="SearchEap">
          <QY P="MsSql" Q="SELECT A.EAP, A.EAP_DESC, &#xD;&#xA;       A.EAP_TYPE, A.OPER_ME, A.SERVER, &#xD;&#xA;       A.UP_DOWN, A.STATUS, A.STEP, &#xD;&#xA;       A.NEED_ACTION, A.NEXT_NEED_ACTION, A.RELOAD_CNT,&#xD;&#xA;       ISNULL(B.PACKAGE, 'N/A') SET_PACKAGE, ISNULL(B.PKG_VER, 0) SET_PKG_VER, ISNULL(B.MODEL, 'N/A') SET_MODEL, ISNULL(B.MDL_VER, 0) SET_MDL_VER, ISNULL(B.USED_COM, 'N/A') SET_USED_COM, ISNULL(B.COMPONENT, 'N/A') SET_COMPONENT, ISNULL(B.COM_VER, 0) SET_COM_VER,&#xD;&#xA;       ISNULL(C.PACKAGE, 'N/A') REL_PACKAGE, ISNULL(C.PKG_VER, 0) REL_PKG_VER, ISNULL(C.MODEL, 'N/A') REL_MODEL, ISNULL(C.MDL_VER, 0) REL_MDL_VER, ISNULL(C.USED_COM, 'N/A') REL_USED_COM, ISNULL(C.COMPONENT, 'N/A') REL_COMPONENT, ISNULL(C.COM_VER, 0) REL_COM_VER,&#xD;&#xA;       ISNULL(D.PACKAGE, 'N/A') APL_PACKAGE, ISNULL(D.PKG_VER, 0) APL_PKG_VER, ISNULL(D.MODEL, 'N/A') APL_MODEL, ISNULL(D.MDL_VER, 0) APL_MDL_VER, ISNULL(D.USED_COM, 'N/A') APL_USED_COM, ISNULL(D.COMPONENT, 'N/A') APL_COMPONENT, ISNULL(D.COM_VER, 0) APL_COM_VER,&#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME,&#xD;&#xA;       A.UPDATE_USER_ID, A.UPDATE_TIME,&#xD;&#xA;       A.LAST_EVENT_TIME, A.LAST_EVENT_ID&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP           = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP           = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.EAP           = @eap&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
      </F>
      <F _S="919" N="EapHistory">
        <SG _S="920" N="SearchEapHistory">
          <QY P="MsSql" Q="SELECT TRAN_TIME, EAP, EVENT_ID, SERVER, STEP, &#xD;&#xA;       UP_DOWN, STATUS, NEED_ACTION, NEXT_NEED_ACTION, TRAN_USER_ID,&#xD;&#xA;       SET_PACKAGE, SET_PKG_VER, REL_PACKAGE, REL_PKG_VER, APL_PACKAGE, APL_PKG_VER,&#xD;&#xA;       SET_MODEL, SET_MDL_VER, REL_MODEL, REL_MDL_VER, APL_MODEL, APL_MDL_VER,&#xD;&#xA;       SET_LIBRARY, SET_LIB_VER, REL_LIBRARY, REL_LIB_VER, APL_LIBRARY, APL_LIB_VER,&#xD;&#xA;       EVT_H_1, EVT_D_1, EVT_H_2, EVT_D_2, EVT_H_3, EVT_D_3, EVT_H_4, EVT_D_4, EVT_H_5, EVT_D_5, &#xD;&#xA;       EVT_H_6, EVT_D_6, EVT_H_7, EVT_D_7, EVT_H_8, EVT_D_8, EVT_H_9, EVT_D_9, EVT_H_10, EVT_D_10, &#xD;&#xA;       EVT_H_11, EVT_D_11, EVT_H_12, EVT_D_12, EVT_H_13, EVT_D_13, EVT_H_14, EVT_D_14, EVT_H_15, EVT_D_15, &#xD;&#xA;       EVT_H_16, EVT_D_16, EVT_H_17, EVT_D_17, EVT_H_18, EVT_D_18, EVT_H_19, EVT_D_19, EVT_H_20, EVT_D_20,&#xD;&#xA;       TRAN_COMMENT&#xD;&#xA;  FROM QRASEAPHIS&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND EAP          = ISNULL(@eap, EAP)&#xD;&#xA;   AND TRAN_TIME &gt;= @tran_from_time&#xD;&#xA;   AND TRAN_TIME &lt;= ISNULL(@tran_to_time, TRAN_TIME)&#xD;&#xA; ORDER BY TRAN_TIME DESC">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
      </F>
      <F _S="921" N="EapNeedActionList">
        <SG _S="922" N="ListEap">
          <QY P="MsSql" Q="SELECT A.EAP, A.EAP_DESC, A.EAP_TYPE, A.OPER_ME, A.SERVER, A.STEP, A.UP_DOWN, A.STATUS, A.RELOAD_CNT, A.ALARM, A.NEED_ACTION, A.NEXT_NEED_ACTION,&#xD;&#xA;       ISNULL(B.PACKAGE, 'N/A')  SET_PACKAGE,  ISNULL(B.PKG_VER, 0) SET_PKG_VER, ISNULL(C.PACKAGE, 'N/A') REL_PACKAGE, ISNULL(C.PKG_VER, 0) REL_PKG_VER, ISNULL(D.PACKAGE, 'N/A') APL_PACKAGE, ISNULL(D.PKG_VER, 0) APL_PKG_VER,&#xD;&#xA;       ISNULL(B.MODEL, 'N/A') SET_MODEL, ISNULL(B.MDL_VER, 0) SET_MDL_VER, ISNULL(C.MODEL, 'N/A') REL_MODEL, ISNULL(C.MDL_VER, 0) REL_MDL_VER, ISNULL(D.MODEL, 'N/A') APL_MODEL, ISNULL(D.MDL_VER, 0) APL_MDL_VER, &#xD;&#xA;       ISNULL(B.USED_COM, 'N/A') SET_USED_COM, ISNULL(B.COMPONENT, 'N/A') SET_COMPONENT, ISNULL(B.COM_VER, 0) SET_COM_VER, ISNULL(C.USED_COM, 'N/A') REL_USED_COM, ISNULL(C.COMPONENT, 'N/A') REL_COMPONENT, ISNULL(C.COM_VER, 0) REL_COM_VER, ISNULL(D.USED_COM, 'N/A') APL_USED_COM, ISNULL(D.COMPONENT, 'N/A') APL_COMPONENT, ISNULL(D.COM_VER, 0) APL_COM_VER&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP           = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP           = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.DELETE_FLAG = 'N'    &#xD;&#xA;   AND A.NEED_ACTION = @need_action  &#xD;&#xA; ORDER BY A.EAP">
            <QP N="factory" />
            <QP N="need_action" />
          </QY>
        </SG>
      </F>
      <F _S="923" N="EapResourceComparison">
        <SG _S="924" N="ListEap">
          <QY P="MsSql" Q="SELECT A.EAP, A.EAP_DESC&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Applied'&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.SERVER        = ISNULL(@server, A.SERVER)&#xD;&#xA;   AND B.PACKAGE       = ISNULL(@package, B.PACKAGE)&#xD;&#xA;   AND B.MODEL         = ISNULL(@model, B.MODEL)&#xD;&#xA;   AND B.COMPONENT     = ISNULL(@component, B.COMPONENT)  &#xD;&#xA;   AND A.DELETE_FLAG   = 'N'&#xD;&#xA; ORDER BY A.EAP">
            <QP N="factory" />
            <QP N="server" />
            <QP N="package" />
            <QP N="model" />
            <QP N="component" />
          </QY>
        </SG>
        <SG _S="925" N="SearchManagementRate">
          <QY P="MsSql" Q="SELECT EAP_CPU_CAUTION_RATE, EAP_CPU_DANGER_RATE,&#xD;&#xA;       EAP_MEMORY_CAUTION_RATE, EAP_MEMORY_DANGER_RATE,&#xD;&#xA;       EAP_DISK_CAUTION_RATE, EAP_DISK_DANGER_RATE&#xD;&#xA;  FROM QSYSFACDEF&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="926" N="SearchCpuSummary">
          <QY P="MsSql" Q="SELECT A.EAP, A.CPU_USAGE&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Applied'&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.SERVER        = ISNULL(@server, A.SERVER)&#xD;&#xA;   AND B.PACKAGE       = ISNULL(@package, B.PACKAGE)&#xD;&#xA;   AND B.MODEL         = ISNULL(@model, B.MODEL)&#xD;&#xA;   AND B.COMPONENT     = ISNULL(@component, B.COMPONENT)&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'&#xD;&#xA; ORDER BY A.EAP">
            <QP N="factory" />
            <QP N="server" />
            <QP N="package" />
            <QP N="model" />
            <QP N="component" />
          </QY>
        </SG>
        <SG _S="927" N="SearchMemorySummary">
          <QY P="MsSql" Q="SELECT A.EAP, C.MEMORY, A.MEMORY_USAGE&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Applied'&#xD;&#xA;  LEFT JOIN QSYSSVRDEF C&#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.SERVER        = C.SERVER&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.SERVER        = ISNULL(@server, A.SERVER)&#xD;&#xA;   AND B.PACKAGE       = ISNULL(@package, B.PACKAGE)&#xD;&#xA;   AND B.MODEL         = ISNULL(@model, B.MODEL)&#xD;&#xA;   AND B.COMPONENT     = ISNULL(@component, B.COMPONENT)&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'&#xD;&#xA; ORDER BY A.EAP">
            <QP N="factory" />
            <QP N="server" />
            <QP N="package" />
            <QP N="model" />
            <QP N="component" />
          </QY>
        </SG>
        <SG _S="928" N="SearchDiskSummary">
          <QY P="MsSql" Q="SELECT A.EAP, A.DISK_USAGE&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Applied'&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.SERVER        = ISNULL(@server, A.SERVER)&#xD;&#xA;   AND B.PACKAGE       = ISNULL(@package, B.PACKAGE)&#xD;&#xA;   AND B.MODEL         = ISNULL(@model, B.MODEL)&#xD;&#xA;   AND B.COMPONENT     = ISNULL(@component, B.COMPONENT)&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'&#xD;&#xA; ORDER BY A.EAP">
            <QP N="factory" />
            <QP N="server" />
            <QP N="package" />
            <QP N="model" />
            <QP N="component" />
          </QY>
        </SG>
      </F>
      <F _S="929" N="EapResourceHistory">
        <SG _S="930" N="HasEap">
          <QY P="MsSql" Q="SELECT EAP&#xD;&#xA;  FROM QRASEAPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EAP         = @eap&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="931" N="SearchManagementRate">
          <QY P="MsSql" Q="SELECT EAP_CPU_CAUTION_RATE, EAP_CPU_DANGER_RATE,&#xD;&#xA;       EAP_MEMORY_CAUTION_RATE, EAP_MEMORY_DANGER_RATE,&#xD;&#xA;       EAP_DISK_CAUTION_RATE, EAP_DISK_DANGER_RATE&#xD;&#xA;  FROM QSYSFACDEF&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="932" N="SearchResourceHistory">
          <QY P="MsSql" Q="SELECT TRAN_TIME, CPU_USAGE, MEMORY_USAGE, DISK_USAGE&#xD;&#xA;  FROM QRASEAPRHI&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND EAP          = @eap&#xD;&#xA;   AND TRAN_TIME &gt;= @tran_from_time&#xD;&#xA;   AND TRAN_TIME &lt;= ISNULL(@tran_to_time, TRAN_TIME)&#xD;&#xA; ORDER BY TRAN_TIME">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
      </F>
      <F _S="933" N="EapResourceList">
        <SG _S="934" N="ListEap">
          <QY P="MsSql" Q="SELECT A.EAP, A.EAP_DESC, A.SERVER, &#xD;&#xA;       ISNULL(B.PACKAGE, 'N/A') PACKAGE, ISNULL(B.PKG_VER, 0) PKG_VER,&#xD;&#xA;       ISNULL(B.MODEL, 'N/A')   MODEL,   ISNULL(B.MDL_VER, 0) MDL_VER,&#xD;&#xA;       ISNULL(B.LIBRARY, 'N/A') LIBRARY, ISNULL(B.LIB_VER, 0) LIB_VER&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'    &#xD;&#xA;   AND A.SERVER        = ISNULL(@server, A.SERVER) &#xD;&#xA;   AND B.PACKAGE       = ISNULL(@package, B.PACKAGE)&#xD;&#xA;   AND B.MODEL         = ISNULL(@model, B.MODEL)&#xD;&#xA;   AND B.LIBRARY       = ISNULL(@library, B.LIBRARY)&#xD;&#xA; ORDER BY A.EAP">
            <QP N="factory" />
            <QP N="server" />
            <QP N="package" />
            <QP N="model" />
            <QP N="library" />
          </QY>
        </SG>
        <SG _S="935" N="SearchResourceManageRate">
          <QY P="MsSql" Q="SELECT EAP_CPU_CAUTION_RATE, EAP_CPU_DANGER_RATE,&#xD;&#xA;       EAP_MEMORY_CAUTION_RATE, EAP_MEMORY_DANGER_RATE,&#xD;&#xA;	   EAP_DISK_CAUTION_RATE, EAP_DISK_DANGER_RATE&#xD;&#xA;  FROM QSYSFACDEF&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="936" N="SearchResourceHistory">
          <QY P="MsSql" Q="SELECT TRAN_TIME, CPU_USAGE, MEMORY_USAGE, DISK_USAGE&#xD;&#xA;  FROM QRASEAPRHI&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND EAP          = @eap&#xD;&#xA;   AND TRAN_TIME &gt;= @tran_from_time&#xD;&#xA;   AND TRAN_TIME &lt;= ISNULL(@tran_to_time, TRAN_TIME)&#xD;&#xA; ORDER BY TRAN_TIME">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
      </F>
      <F _S="937" N="EquipmentList">
        <SG _S="938" N="ListEquipment">
          <QY P="MsSql" Q="SELECT A.EQP_NAME, A.EQP_DESC, A.TYPE, A.AREA, A.LINE,ISNULL(A.CTRL_MODE,'N/A') CTRL_MODE, ISNULL(A.PRI_STATE,'N/A') PRI_STATE, ISNULL(A.STATE,'N/A') STATE,&#xD;&#xA;       C.EAP, ISNULL(A.MDLN,'N/A') MDLN, ISNULL( A.SOFTREV,'N/A') SOFTREV, ISNULL( A.EVENT_DEFINE,'N/A') EVENT_DEFINE, A.EQP_RCP_ID,&#xD;&#xA;       C.SERVER, C.STEP, C.UP_DOWN, C.STATUS, C.RELOAD_CNT, &#xD;&#xA;       ISNULL(D.PACKAGE, 'N/A'), ISNULL(D.PKG_VER, 0),&#xD;&#xA;       ISNULL(D.MODEL, 'N/A'), ISNULL(D.MDL_VER, 0), &#xD;&#xA;       ISNULL(D.USED_COM, 'N/A'), ISNULL(D.COMPONENT, 'N/A'), ISNULL(D.COM_VER, 0), &#xD;&#xA;       C.NEED_ACTION, C.NEXT_NEED_ACTION, &#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME,&#xD;&#xA;       A.UPDATE_USER_ID, A.UPDATE_TIME,&#xD;&#xA;       A.LAST_EVENT_ID, A.LAST_EVENT_TIME &#xD;&#xA;  FROM QRASEQPDEF  A &#xD;&#xA;  LEFT JOIN  QRASEQPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EQP_NAME      = B.EQP_NAME&#xD;&#xA;   AND B.ATTR_CATEGORY = @category&#xD;&#xA;  LEFT JOIN QRASEAPDEF C&#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND B.EAP           = C.EAP&#xD;&#xA;  LEFT JOIN QRASEAPATR D&#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND B.EAP           = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = @category   &#xD;&#xA; WHERE A.FACTORY       = @factory &#xD;&#xA;   AND A.TYPE          = ISNULL(@type, A.TYPE)&#xD;&#xA;   AND A.AREA          = ISNULL(@area, A.AREA)&#xD;&#xA;   AND A.LINE          = ISNULL(@line, A.LINE)&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'&#xD;&#xA; ORDER BY A.EQP_NAME">
            <QP N="category" />
            <QP N="factory" />
            <QP N="type" />
            <QP N="area" />
            <QP N="line" />
          </QY>
        </SG>
        <SG _S="939" N="SearchEquipment">
          <QY P="MsSql" Q="SELECT A.EQP_NAME, A.EQP_DESC, A.TYPE, A.AREA, A.LINE, ISNULL(A.CTRL_MODE,'N/A'), ISNULL(A.PRI_STATE,'N/A'), ISNULL(A.STATE,'N/A'),&#xD;&#xA;       ISNULL(A.MDLN,'N/A'), ISNULL( A.SOFTREV,'N/A'), ISNULL( A.EVENT_DEFINE,'N/A'),  A.EQP_RCP_ID,&#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME,  &#xD;&#xA;       A.UPDATE_USER_ID, A.UPDATE_TIME, &#xD;&#xA;       A.LAST_EVENT_TIME, A.LAST_EVENT_ID,&#xD;&#xA;       C.EAP, C.EAP_DESC, C.EAP_TYPE, &#xD;&#xA;       C.SERVER, C.UP_DOWN,  C.STATUS, C.STEP, C.NEED_ACTION, C.NEXT_NEED_ACTION, &#xD;&#xA;       ISNULL(D.PACKAGE, 'N/A'), ISNULL(D.PKG_VER, 0),&#xD;&#xA;       ISNULL(D.MODEL, 'N/A'), ISNULL(D.MDL_VER, 0), &#xD;&#xA;       ISNULL(D.USED_COM, 'N/A'), ISNULL(D.COMPONENT, 'N/A'), ISNULL(D.COM_VER, 0),        &#xD;&#xA;       C.RELOAD_CNT,&#xD;&#xA;       C.CREATE_USER_ID, C.CREATE_TIME,&#xD;&#xA;       C.UPDATE_USER_ID, C.UPDATE_TIME,&#xD;&#xA;       C.LAST_EVENT_TIME, C.LAST_EVENT_ID&#xD;&#xA;  FROM QRASEQPDEF  A &#xD;&#xA;  LEFT JOIN  QRASEQPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EQP_NAME      = B.EQP_NAME&#xD;&#xA;   AND B.ATTR_CATEGORY = @category&#xD;&#xA;  LEFT JOIN QRASEAPDEF C&#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND B.EAP           = C.EAP&#xD;&#xA;  LEFT JOIN QRASEAPATR D&#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND B.EAP           = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = @category   &#xD;&#xA; WHERE A.FACTORY       = @factory &#xD;&#xA;   AND A.EQP_NAME      = @eqpName&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="category" />
            <QP N="factory" />
            <QP N="eqpName" />
          </QY>
        </SG>
      </F>
      <F _S="940" N="AlarmStatus">
        <SG _S="941" N="SearchAlarmStatus">
          <QY P="MsSql" Q="SELECT EQP_NAME, SET_TIME, ALARM_ID, ALARM_TEXT&#xD;&#xA; FROM QRASEQPALS&#xD;&#xA;WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="942" N="EquipmentStatus">
        <SG _S="943" N="HasEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME &#xD;&#xA;  FROM QRASEQPDEF &#xD;&#xA; WHERE FACTORY  = @factory &#xD;&#xA;   AND EQP_NAME = @eqp_name">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="944" N="SearchEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME, EQP_DESC, ISNULL(EQP_RCP_ID, 'N/A'),&#xD;&#xA;       TYPE, AREA, LINE, &#xD;&#xA;       ISNULL(CTRL_MODE,'N/A'), ISNULL(PRI_STATE,'N/A'), ISNULL(STATE,'N/A'),&#xD;&#xA;       ISNULL(MDLN,'N/A'), ISNULL(SOFTREV,'N/A'), ISNULL(EVENT_DEFINE,'N/A'), &#xD;&#xA;       CREATE_USER_ID, CREATE_TIME, UPDATE_USER_ID, UPDATE_TIME, &#xD;&#xA;       LAST_EVENT_TIME, LAST_EVENT_ID&#xD;&#xA;  FROM QRASEQPDEF &#xD;&#xA; WHERE FACTORY  = @factory &#xD;&#xA;   AND EQP_NAME = @eqp_name">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="945" N="SearchEap">
          <QY P="MsSql" Q="SELECT A.EAP, B.EAP_DESC, B.EAP_TYPE,&#xD;&#xA;       B.SERVER, B.UP_DOWN, B.STATUS,&#xD;&#xA;       B.STEP, B.NEED_ACTION, B.NEXT_NEED_ACTION,&#xD;&#xA;       ISNULL(C.PACKAGE, 'N/A'), ISNULL(C.PKG_VER, 0), ISNULL(C.MODEL, 'N/A'), ISNULL(C.MDL_VER, 0), ISNULL(C.USED_COM, 'N/A'), ISNULL(C.COMPONENT, 'N/A'), ISNULL(C.COM_VER, 0),&#xD;&#xA;       B.RELOAD_CNT, B.CREATE_USER_ID, B.CREATE_TIME, B.UPDATE_USER_ID, B.UPDATE_TIME,&#xD;&#xA;       B.LAST_EVENT_TIME, B.LAST_EVENT_ID&#xD;&#xA;  FROM QRASEQPATR A&#xD;&#xA;  LEFT JOIN QRASEAPDEF B&#xD;&#xA;    ON A.FACTORY = B.FACTORY&#xD;&#xA;   AND A.EAP     = B.EAP&#xD;&#xA;  LEFT JOIN QRASEAPATR C&#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP           = C.EAP&#xD;&#xA;   AND A.ATTR_CATEGORY = C.ATTR_CATEGORY&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.EQP_NAME      = @eqp_name&#xD;&#xA;   AND A.ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="attr_category" />
          </QY>
        </SG>
      </F>
      <F _S="946" N="EquipmentHistory">
        <SG _S="947" N="SearchEquipmentHistory">
          <QY P="MsSql" Q="SELECT  TRAN_TIME, EQP_NAME, SYSTEM, EVENT_ID, EAP, COMM_STATE, CTRL_MODE, EAP_EVENT_ID, TRAN_USER_ID,&#xD;&#xA;        EVT_H_1, EVT_D_1, EVT_H_2, EVT_D_2, EVT_H_3, EVT_D_3, EVT_H_4, EVT_D_4, EVT_H_5, EVT_D_5, &#xD;&#xA;        EVT_H_6, EVT_D_6, EVT_H_7, EVT_D_7, EVT_H_8, EVT_D_8, EVT_H_9, EVT_D_9, EVT_H_10, EVT_D_10, &#xD;&#xA;        EVT_H_11, EVT_D_11, EVT_H_12, EVT_D_12, EVT_H_13, EVT_D_13, EVT_H_14, EVT_D_14, EVT_H_15, EVT_D_15, &#xD;&#xA;        EVT_H_16, EVT_D_16, EVT_H_17, EVT_D_17, EVT_H_18, EVT_D_18, EVT_H_19, EVT_D_19, EVT_H_20, EVT_D_20,&#xD;&#xA;        TRAN_COMMENT&#xD;&#xA;   FROM QRASEQPHIS&#xD;&#xA;  WHERE FACTORY      = @factory&#xD;&#xA;    AND EQP_NAME     = ISNULL(@eqp_name, EQP_NAME)&#xD;&#xA;   AND TRAN_TIME &gt;= @tran_from_time&#xD;&#xA;   AND TRAN_TIME &lt;= ISNULL(@tran_to_time, TRAN_TIME)&#xD;&#xA; ORDER BY TRAN_TIME">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
      </F>
      <F _S="948" N="UserHistory">
        <SG _S="949" N="SearchUserHistory">
          <QY P="MsSql" Q="SELECT HIS.HIST_SEQ, HIS.TRAN_TIME, HIS.USER_ID, ISNULL(DEF.USER_NAME, ' ') AS USER_NAME,&#xD;&#xA;       HIS.SYSTEM, HIS.EVENT_ID, HIS.ACTION, HIS.HOST_IP, HIS.HOST_NAME,&#xD;&#xA;       HIS.EVT_H_1, HIS.EVT_D_1, HIS.EVT_H_2, HIS.EVT_D_2, HIS.EVT_H_3, HIS.EVT_D_3, HIS.EVT_H_4, HIS.EVT_D_4, HIS.EVT_H_5, HIS.EVT_D_5, &#xD;&#xA;       HIS.EVT_H_6, HIS.EVT_D_6, HIS.EVT_H_7, HIS.EVT_D_7, HIS.EVT_H_8, HIS.EVT_D_8, HIS.EVT_H_9, HIS.EVT_D_9, HIS.EVT_H_10, HIS.EVT_D_10,       &#xD;&#xA;       HIS.EVT_H_11, HIS.EVT_D_11, HIS.EVT_H_12, HIS.EVT_D_12, HIS.EVT_H_13, HIS.EVT_D_13, HIS.EVT_H_14, HIS.EVT_D_14, HIS.EVT_H_15, HIS.EVT_D_15, &#xD;&#xA;       HIS.EVT_H_16, HIS.EVT_D_16, HIS.EVT_H_17, HIS.EVT_D_17, HIS.EVT_H_18, HIS.EVT_D_18, HIS.EVT_H_19, HIS.EVT_D_19, HIS.EVT_H_20, HIS.EVT_D_20,&#xD;&#xA;       HIS.TRAN_COMMENT&#xD;&#xA;  FROM QSECUSRHIS HIS&#xD;&#xA;  LEFT JOIN QSECUSRDEF DEF&#xD;&#xA;    ON HIS.FACTORY      = DEF.FACTORY&#xD;&#xA;   AND HIS.USER_ID      = DEF.USER_ID&#xD;&#xA; WHERE HIS.FACTORY      = @factory&#xD;&#xA;   AND HIS.SYSTEM       = @system&#xD;&#xA;   AND HIS.USER_ID      = ISNULL(@user_id, HIS.USER_ID)&#xD;&#xA;   AND HIS.C_TRAN_TIME &gt;= CONVERT (DATETIME, (STUFF(STUFF(STUFF(STUFF(@tran_from_time, 9, 0, ' '), 12, 0, ':'), 15, 0, ':'), 18, 0, '.'))) &#xD;&#xA;   AND HIS.C_TRAN_TIME &lt;= CONVERT (DATETIME, (STUFF(STUFF(STUFF(STUFF(@tran_to_time, 9, 0, ' '), 12, 0, ':'), 15, 0, ':'), 18, 0, '.')))&#xD;&#xA; ORDER BY HIS.C_TRAN_TIME DESC">
            <QP N="factory" />
            <QP N="system" />
            <QP N="user_id" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
        <SG _S="950" N="SearchUserHistoryCount">
          <QY P="MsSql" Q="SELECT COUNT(*) AS CNT&#xD;&#xA;  FROM QSECUSRHIS&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND SYSTEM       = @system&#xD;&#xA;   AND USER_ID      = ISNULL(@user_id, USER_ID)&#xD;&#xA;   AND C_TRAN_TIME &gt;= CONVERT (DATETIME, (STUFF(STUFF(STUFF(STUFF(@tran_from_time, 9, 0, ' '), 12, 0, ':'), 15, 0, ':'), 18, 0, '.'))) &#xD;&#xA;   AND C_TRAN_TIME &lt;= CONVERT (DATETIME, (STUFF(STUFF(STUFF(STUFF(@tran_to_time, 9, 0, ' '), 12, 0, ':'), 15, 0, ':'), 18, 0, '.')))">
            <QP N="factory" />
            <QP N="system" />
            <QP N="user_id" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
        <SG _S="951" N="SearchUserHistoryPaging">
          <QY P="MsSql" Q="SELECT HIS.HIST_SEQ, HIS.TRAN_TIME, HIS.USER_ID, ISNULL(DEF.USER_NAME, ' ') AS USER_NAME,&#xD;&#xA;       HIS.SYSTEM, HIS.EVENT_ID, HIS.ACTION, HIS.HOST_IP, HIS.HOST_NAME,&#xD;&#xA;       HIS.EVT_H_1, HIS.EVT_D_1, HIS.EVT_H_2, HIS.EVT_D_2, HIS.EVT_H_3, HIS.EVT_D_3, HIS.EVT_H_4, HIS.EVT_D_4, HIS.EVT_H_5, HIS.EVT_D_5, &#xD;&#xA;       HIS.EVT_H_6, HIS.EVT_D_6, HIS.EVT_H_7, HIS.EVT_D_7, HIS.EVT_H_8, HIS.EVT_D_8, HIS.EVT_H_9, HIS.EVT_D_9, HIS.EVT_H_10, HIS.EVT_D_10,       &#xD;&#xA;       HIS.EVT_H_11, HIS.EVT_D_11, HIS.EVT_H_12, HIS.EVT_D_12, HIS.EVT_H_13, HIS.EVT_D_13, HIS.EVT_H_14, HIS.EVT_D_14, HIS.EVT_H_15, HIS.EVT_D_15, &#xD;&#xA;       HIS.EVT_H_16, HIS.EVT_D_16, HIS.EVT_H_17, HIS.EVT_D_17, HIS.EVT_H_18, HIS.EVT_D_18, HIS.EVT_H_19, HIS.EVT_D_19, HIS.EVT_H_20, HIS.EVT_D_20,&#xD;&#xA;       HIS.TRAN_COMMENT&#xD;&#xA;  FROM QSECUSRHIS HIS&#xD;&#xA;  LEFT JOIN QSECUSRDEF DEF&#xD;&#xA;    ON HIS.FACTORY      = DEF.FACTORY&#xD;&#xA;   AND HIS.USER_ID      = DEF.USER_ID&#xD;&#xA; WHERE HIS.FACTORY      = @factory&#xD;&#xA;   AND HIS.SYSTEM       = @system&#xD;&#xA;   AND HIS.USER_ID      = ISNULL(@user_id, HIS.USER_ID)&#xD;&#xA;   AND HIS.C_TRAN_TIME &gt;= CONVERT (DATETIME, (STUFF(STUFF(STUFF(STUFF(@tran_from_time, 9, 0, ' '), 12, 0, ':'), 15, 0, ':'), 18, 0, '.'))) &#xD;&#xA;   AND HIS.C_TRAN_TIME &lt;= CONVERT (DATETIME, (STUFF(STUFF(STUFF(STUFF(@tran_to_time, 9, 0, ' '), 12, 0, ':'), 15, 0, ':'), 18, 0, '.')))&#xD;&#xA; ORDER BY HIS.C_TRAN_TIME DESC&#xD;&#xA;OFFSET (CONVERT(int, @PAGE_NO)-1) * CONVERT(int, @PAGE_SIZE) ROW FETCH NEXT CONVERT(int, @PAGE_SIZE) ROW ONLY">
            <QP N="factory" />
            <QP N="system" />
            <QP N="user_id" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
            <QP N="PAGE_NO" />
            <QP N="PAGE_SIZE" />
          </QY>
        </SG>
      </F>
      <F _S="952" N="EAPState">
        <SG _S="953" N="SearchEAPState">
          <QY P="MsSql" Q=" select EAP,EAP_DESC, EAP_TYPE, SERVER, STEP, UP_DOWN, STATUS, ALARM&#xD;&#xA;  from QRASEAPDEF&#xD;&#xA;  where FACTORY = @factory and UP_DOWN = @up_down">
