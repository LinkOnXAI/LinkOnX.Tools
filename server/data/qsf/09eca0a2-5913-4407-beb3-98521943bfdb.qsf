          <QY P="SQLite" />
        </SG>
        <SG _S="1220" N="HasEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME&#xD;&#xA;  FROM QRASEQPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EQP_NAME    = @eqp_name&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
