      <F _S="567" N="Device">
        <SG _S="568" N="ListDevice">
          <QY P="MsSql" Q="SELECT DVC_ID, DVC_DESC, ACCOUNT_ID, PASSWORD, DOMAIN, COMPUTER_NAME, IP_ADDRESS, MAC_ADDRESS,&#xD;&#xA;       OS, OS_ARCH, MANUFACTURER, MODEL, PROCESSOR, MEMORY&#xD;&#xA;  FROM QEMSDVCDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY DVC_ID ">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="569" N="HasDevice">
          <QY P="MsSql" Q="SELECT DVC_ID, ACCOUNT_ID, PASSWORD, DOMAIN, COMPUTER_NAME, IP_ADDRESS, MAC_ADDRESS&#xD;&#xA;  FROM QEMSDVCDEF&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="570" N="InsertDevice">
          <QY P="MsSql" Q="INSERT INTO QEMSDVCDEF (&#xD;&#xA;   FACTORY,&#xD;&#xA;   DVC_ID,&#xD;&#xA;   DVC_DESC, &#xD;&#xA;   ACCOUNT_ID, &#xD;&#xA;   PASSWORD, &#xD;&#xA;   DOMAIN, &#xD;&#xA;   COMPUTER_NAME, &#xD;&#xA;   IP_ADDRESS, &#xD;&#xA;   MAC_ADDRESS,&#xD;&#xA;   OS, &#xD;&#xA;   OS_ARCH, &#xD;&#xA;   MANUFACTURER, &#xD;&#xA;   MODEL, &#xD;&#xA;   PROCESSOR, &#xD;&#xA;   MEMORY,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;   ) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @dvc_id,&#xD;&#xA;   @dvc_desc,&#xD;&#xA;   @account_id,&#xD;&#xA;   @password,&#xD;&#xA;   @domain,&#xD;&#xA;   @computer_name,&#xD;&#xA;   @ip_address,&#xD;&#xA;   @mac_address,&#xD;&#xA;   @os,&#xD;&#xA;   @os_architecture,&#xD;&#xA;   @manufacturer,&#xD;&#xA;   @model,&#xD;&#xA;   @processor,&#xD;&#xA;   @memory,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="dvc_id" />
            <QP N="dvc_desc" />
            <QP N="account_id" />
            <QP N="password" />
            <QP N="domain" />
            <QP N="computer_name" />
            <QP N="ip_address" />
            <QP N="mac_address" />
            <QP N="os" />
            <QP N="os_architecture" />
            <QP N="manufacturer" />
            <QP N="model" />
            <QP N="processor" />
            <QP N="memory" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="571" N="UpdateDevice">
          <QY P="MsSql" Q="UPDATE QEMSDVCDEF SET&#xD;&#xA;   DVC_DESC       = @dvc_desc, &#xD;&#xA;   ACCOUNT_ID     = @account_id, &#xD;&#xA;   PASSWORD       = @password, &#xD;&#xA;   DOMAIN         = @domain, &#xD;&#xA;   COMPUTER_NAME  = @computer_name,&#xD;&#xA;   IP_ADDRESS     = @ip_address,&#xD;&#xA;   MAC_ADDRESS    = @mac_address,&#xD;&#xA;   OS             = @os,&#xD;&#xA;   OS_ARCH        = @os_architecture, &#xD;&#xA;   MANUFACTURER   = @manufacturer, &#xD;&#xA;   MODEL          = @model,&#xD;&#xA;   PROCESSOR      = @processor, &#xD;&#xA;   MEMORY         = @memory,&#xD;&#xA;   UPDATE_USER_ID = @update_user_id,&#xD;&#xA;   UPDATE_TIME    = @update_time&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND DVC_ID     = @dvc_id">
            <QP N="dvc_desc" />
            <QP N="account_id" />
            <QP N="password" />
            <QP N="domain" />
            <QP N="computer_name" />
            <QP N="ip_address" />
            <QP N="mac_address" />
            <QP N="os" />
            <QP N="os_architecture" />
            <QP N="manufacturer" />
            <QP N="model" />
            <QP N="processor" />
            <QP N="memory" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="dvc_id" />
          </QY>
        </SG>
        <SG _S="572" N="DeleteDevice">
          <QY P="MsSql" Q="DELETE FROM QEMSDVCDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND DVC_ID  = @dvc_id">
            <QP N="factory" />
            <QP N="dvc_id" />
          </QY>
        </SG>
      </F>
      <F _S="573" N="PlcMapParser">
        <SG _S="574" N="ListPlcMapParser">
          <QY P="MsSql" Q="SELECT PLC_MAKER, PLC_MODEL, PARSER_NAME&#xD;&#xA;  FROM QSYSPTMMPS&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY PLC_MAKER, PLC_MODEL">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="575" N="HasPlcMapParser">
          <QY P="MsSql" Q="SELECT PLC_MAKER, PLC_MODEL, PARSER_NAME&#xD;&#xA;  FROM QSYSPTMMPS&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;  AND PLC_MAKER = @plc_maker&#xD;&#xA;  AND PLC_MODEL = @plc_model">
            <QP N="factory" />
            <QP N="plc_maker" />
            <QP N="plc_model" />
          </QY>
        </SG>
        <SG _S="576" N="InsertPlcMapParser">
          <QY P="MsSql" Q="INSERT INTO QSYSPTMMPS (&#xD;&#xA;   FACTORY,&#xD;&#xA;   PLC_MAKER,&#xD;&#xA;   PLC_MODEL,&#xD;&#xA;   PARSER_NAME,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   UPDATE_TIME,&#xD;&#xA;   UPDATE_USER_ID&#xD;&#xA;   ) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @plc_maker,&#xD;&#xA;   @plc_model,&#xD;&#xA;   @parser_name,&#xD;&#xA;   @create_time,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @update_time,&#xD;&#xA;   @update_user_id&#xD;&#xA;   )">
            <QP N="factory" />
            <QP N="plc_maker" />
            <QP N="plc_model" />
            <QP N="parser_name" />
            <QP N="create_time" />
            <QP N="create_user_id" />
            <QP N="update_time" />
            <QP N="update_user_id" />
          </QY>
        </SG>
        <SG _S="577" N="UpdatePlcMapParser">
          <QY P="MsSql" Q="UPDATE QSYSPTMMPS SET&#xD;&#xA;   PARSER_NAME  = @parser_name&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;  AND PLC_MAKER = @plc_maker&#xD;&#xA;  AND PLC_MODEL = @plc_model">
            <QP N="parser_name" />
            <QP N="factory" />
            <QP N="plc_maker" />
            <QP N="plc_model" />
          </QY>
        </SG>
        <SG _S="578" N="DeletePlcMapParser">
          <QY P="MsSql" Q="DELETE &#xD;&#xA;  FROM QSYSPTMMPS&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;  AND PLC_MAKER = @plc_maker&#xD;&#xA;  AND PLC_MODEL = @plc_model">
            <QP N="factory" />
            <QP N="plc_maker" />
            <QP N="plc_model" />
          </QY>
        </SG>
      </F>
      <F _S="579" N="PlcTagPreset">
        <SG _S="580" N="ListPresetGroup">
          <QY P="MsSql" Q="SELECT PRESET_GROUP, PRESET_GROUP_DESC&#xD;&#xA;  FROM QSYSPTMPRG&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY PRESET_GROUP">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="581" N="CountPresetTags">
          <QY P="MsSql" Q="SELECT COUNT(*) AS CNT&#xD;&#xA;  FROM QSYSPTMPTG&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND PRESET_GROUP = @preset_group&#xD;&#xA;   AND PRESET_NAME  = @preset_name">
            <QP N="factory" />
            <QP N="preset_group" />
            <QP N="preset_name" />
          </QY>
        </SG>
        <SG _S="582" N="ListPlcMapConfig">
          <QY P="MsSql" Q="SELECT CONFIG_NAME, CONFIG_VALUE&#xD;&#xA;  FROM QSYSPTMCFG&#xD;&#xA; WHERE FACTORY    = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="583" N="ListPreset">
          <QY P="MsSql" Q="SELECT PRESET_NAME, PRESET_DESC, PRESET_CATEGORY, PRESET_PLC_MAKER, PRESET_PLC_MODEL, ALLOW_EMPTY_ADDRESS, IS_ALARM&#xD;&#xA;  FROM QSYSPTMPRS&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND PRESET_GROUP = @preset_group&#xD;&#xA; ORDER BY PRESET_NAME">
            <QP N="factory" />
            <QP N="preset_group" />
          </QY>
        </SG>
        <SG _S="584" N="ListPresetTags">
          <QY P="MsSql" Q="SELECT TAG_SEQ, TAG_NAME, TAG_DESC, TAG_REGISTER, TAG_DEC_ADDRESS, TAG_FULL_ADDRESS, TAG_INPUT_ADDRESS,&#xD;&#xA;       TAG_PLC_FORMAT, TAG_FORMAT, TAG_LENGTH, TAG_TYPE, TAG_BRANCH,&#xD;&#xA;       CMF_1, CMF_2, CMF_3, CMF_4, CMF_5, CMF_6, CMF_7, CMF_8, CMF_9, CMF_10&#xD;&#xA;  FROM QSYSPTMPTG&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND PRESET_GROUP = @preset_group&#xD;&#xA;   AND PRESET_NAME  = @preset_name&#xD;&#xA; ORDER BY TAG_SEQ">
            <QP N="factory" />
            <QP N="preset_group" />
            <QP N="preset_name" />
          </QY>
        </SG>
        <SG _S="585" N="ListPresetTagsPaging">
          <QY P="MsSql" Q="SELECT TAG_SEQ, TAG_NAME, TAG_DESC, TAG_REGISTER, TAG_DEC_ADDRESS, TAG_FULL_ADDRESS, TAG_INPUT_ADDRESS,&#xD;&#xA;       TAG_PLC_FORMAT, TAG_FORMAT, TAG_LENGTH, TAG_TYPE, TAG_BRANCH,&#xD;&#xA;       CMF_1, CMF_2, CMF_3, CMF_4, CMF_5, CMF_6, CMF_7, CMF_8, CMF_9, CMF_10&#xD;&#xA;  FROM QSYSPTMPTG&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND PRESET_GROUP = @preset_group&#xD;&#xA;   AND PRESET_NAME  = @preset_name&#xD;&#xA; ORDER BY TAG_SEQ&#xD;&#xA; OFFSET (CONVERT(int, @PAGE_NO)-1) * CONVERT(int, @PAGE_SIZE) ROW FETCH NEXT CONVERT(int, @PAGE_SIZE) ROW ONLY">
            <QP N="factory" />
            <QP N="preset_group" />
            <QP N="preset_name" />
            <QP N="PAGE_NO" />
            <QP N="PAGE_SIZE" />
          </QY>
        </SG>
        <SG _S="586" N="HasPresetGroup">
          <QY P="MsSql" Q="SELECT PRESET_GROUP&#xD;&#xA;  FROM QSYSPTMPRG&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND PRESET_GROUP = @preset_group">
            <QP N="factory" />
            <QP N="preset_group" />
          </QY>
        </SG>
        <SG _S="587" N="HasPresetGroupChildEntry">
          <QY P="MsSql" Q="SELECT PRESET_NAME&#xD;&#xA;  FROM QSYSPTMPRS&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND PRESET_GROUP = @preset_group">
            <QP N="factory" />
            <QP N="preset_group" />
          </QY>
        </SG>
        <SG _S="588" N="InsertPresetGroup">
          <QY P="MsSql" Q="INSERT INTO QSYSPTMPRG(&#xD;&#xA;	FACTORY,&#xD;&#xA;	PRESET_GROUP,&#xD;&#xA;	PRESET_GROUP_DESC,&#xD;&#xA;	CREATE_USER_ID,&#xD;&#xA;	CREATE_TIME,&#xD;&#xA;	UPDATE_USER_ID,&#xD;&#xA;	UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;	@factory,&#xD;&#xA;	@preset_group,&#xD;&#xA;	@preset_group_desc,&#xD;&#xA;	@create_user_id,&#xD;&#xA;	@create_time,&#xD;&#xA;	@update_user_id,&#xD;&#xA;	@update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="preset_group" />
            <QP N="preset_group_desc" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="589" N="UpdatePresetGroup">
          <QY P="MsSql" Q="UPDATE QSYSPTMPRG SET &#xD;&#xA;   PRESET_GROUP_DESC = @preset_group_desc&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND PRESET_GROUP  = @preset_group">
            <QP N="preset_group_desc" />
            <QP N="factory" />
            <QP N="preset_group" />
          </QY>
        </SG>
        <SG _S="590" N="DeletePresetGroup">
          <QY P="MsSql" Q="DELETE &#xD;&#xA;  FROM QSYSPTMPRG&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND PRESET_GROUP = @preset_group">
            <QP N="factory" />
            <QP N="preset_group" />
          </QY>
        </SG>
        <SG _S="591" N="HasPreset">
          <QY P="MsSql" Q="SELECT PRESET_NAME&#xD;&#xA;  FROM QSYSPTMPRS&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND PRESET_GROUP = @preset_group&#xD;&#xA;   AND PRESET_NAME  = @preset_name">
            <QP N="factory" />
            <QP N="preset_group" />
            <QP N="preset_name" />
          </QY>
        </SG>
        <SG _S="592" N="InsertPreset">
          <QY P="MsSql" Q="INSERT INTO QSYSPTMPRS (&#xD;&#xA;   FACTORY,&#xD;&#xA;   PRESET_GROUP,&#xD;&#xA;   PRESET_NAME,&#xD;&#xA;   PRESET_DESC,&#xD;&#xA;   PRESET_CATEGORY,&#xD;&#xA;   PRESET_PLC_MAKER,&#xD;&#xA;   PRESET_PLC_MODEL,&#xD;&#xA;   ALLOW_EMPTY_ADDRESS,&#xD;&#xA;   IS_ALARM,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;   ) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @preset_group,&#xD;&#xA;   @preset_name,&#xD;&#xA;   @preset_desc,&#xD;&#xA;   @preset_category,&#xD;&#xA;   @preset_plc_maker,&#xD;&#xA;   @preset_plc_model,&#xD;&#xA;   @allow_empty_address,&#xD;&#xA;   @is_alarm,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;   )">
            <QP N="factory" />
            <QP N="preset_group" />
            <QP N="preset_name" />
            <QP N="preset_desc" />
            <QP N="preset_category" />
            <QP N="preset_plc_maker" />
            <QP N="preset_plc_model" />
            <QP N="allow_empty_address" />
            <QP N="is_alarm" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="593" N="UpdatePreset">
          <QY P="MsSql" Q="UPDATE QSYSPTMPRS SET&#xD;&#xA;   PRESET_DESC         = @preset_desc,&#xD;&#xA;   PRESET_CATEGORY     = @preset_category,&#xD;&#xA;   PRESET_PLC_MAKER    = @preset_plc_maker,&#xD;&#xA;   PRESET_PLC_MODEL    = @preset_plc_model,&#xD;&#xA;   ALLOW_EMPTY_ADDRESS = @allow_empty_address,&#xD;&#xA;   IS_ALARM            = @is_alarm,&#xD;&#xA;   UPDATE_USER_ID      = @update_user_id,&#xD;&#xA;   UPDATE_TIME         = @update_time&#xD;&#xA; WHERE FACTORY         = @factory&#xD;&#xA;   AND PRESET_GROUP    = @preset_group&#xD;&#xA;   AND PRESET_NAME     = @preset_name">
            <QP N="preset_desc" />
            <QP N="preset_category" />
            <QP N="preset_plc_maker" />
            <QP N="preset_plc_model" />
            <QP N="allow_empty_address" />
            <QP N="is_alarm" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="preset_group" />
            <QP N="preset_name" />
          </QY>
        </SG>
        <SG _S="594" N="DeletePreset">
          <QY P="MsSql" Q="DELETE&#xD;&#xA;  FROM QSYSPTMPRS&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND PRESET_GROUP = @preset_group&#xD;&#xA;   AND PRESET_NAME  = @preset_name">
            <QP N="factory" />
            <QP N="preset_group" />
            <QP N="preset_name" />
          </QY>
        </SG>
        <SG _S="595" N="DeletePresetTag">
          <QY P="MsSql" Q="DELETE&#xD;&#xA;  FROM QSYSPTMPTG&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND PRESET_GROUP = @preset_group&#xD;&#xA;   AND PRESET_NAME  = @preset_name">
            <QP N="factory" />
            <QP N="preset_group" />
            <QP N="preset_name" />
          </QY>
        </SG>
        <SG _S="596" N="InsertPresetTag">
          <QY P="MsSql" Q="INSERT INTO QSYSPTMPTG(&#xD;&#xA;   FACTORY,&#xD;&#xA;   PRESET_GROUP,&#xD;&#xA;   PRESET_NAME,&#xD;&#xA;   TAG_SEQ,&#xD;&#xA;   TAG_NAME,&#xD;&#xA;   TAG_DESC,&#xD;&#xA;   TAG_REGISTER,&#xD;&#xA;   TAG_DEC_ADDRESS,&#xD;&#xA;   TAG_FULL_ADDRESS,&#xD;&#xA;   TAG_INPUT_ADDRESS,&#xD;&#xA;   TAG_TYPE,&#xD;&#xA;   TAG_FORMAT,&#xD;&#xA;   TAG_PLC_FORMAT,&#xD;&#xA;   TAG_LENGTH,&#xD;&#xA;   TAG_BRANCH,&#xD;&#xA;   CMF_1,&#xD;&#xA;   CMF_2,&#xD;&#xA;   CMF_3,&#xD;&#xA;   CMF_4,&#xD;&#xA;   CMF_5,&#xD;&#xA;   CMF_6,&#xD;&#xA;   CMF_7,&#xD;&#xA;   CMF_8,&#xD;&#xA;   CMF_9,&#xD;&#xA;   CMF_10,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @preset_group,&#xD;&#xA;   @preset_name,&#xD;&#xA;   @tag_seq,&#xD;&#xA;   @tag_name,&#xD;&#xA;   @tag_desc,&#xD;&#xA;   @tag_register,&#xD;&#xA;   @tag_dec_address,&#xD;&#xA;   @tag_full_address,&#xD;&#xA;   @tag_input_address,&#xD;&#xA;   @tag_type,&#xD;&#xA;   @tag_format,&#xD;&#xA;   @tag_plc_format,&#xD;&#xA;   @tag_length,&#xD;&#xA;   @tag_branch,&#xD;&#xA;   @cmf_1,&#xD;&#xA;   @cmf_2,&#xD;&#xA;   @cmf_3,&#xD;&#xA;   @cmf_4,&#xD;&#xA;   @cmf_5,&#xD;&#xA;   @cmf_6,&#xD;&#xA;   @cmf_7,&#xD;&#xA;   @cmf_8,&#xD;&#xA;   @cmf_9,&#xD;&#xA;   @cmf_10,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;   )">
            <QP N="factory" />
            <QP N="preset_group" />
            <QP N="preset_name" />
            <QP N="tag_seq" />
            <QP N="tag_name" />
            <QP N="tag_desc" />
            <QP N="tag_register" />
            <QP N="tag_dec_address" />
            <QP N="tag_full_address" />
            <QP N="tag_input_address" />
            <QP N="tag_type" />
            <QP N="tag_format" />
            <QP N="tag_plc_format" />
            <QP N="tag_length" />
            <QP N="tag_branch" />
            <QP N="cmf_1" />
            <QP N="cmf_2" />
            <QP N="cmf_3" />
            <QP N="cmf_4" />
            <QP N="cmf_5" />
            <QP N="cmf_6" />
            <QP N="cmf_7" />
            <QP N="cmf_8" />
            <QP N="cmf_9" />
            <QP N="cmf_10" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="597" N="SearchPreset">
          <QY P="MsSql" Q="SELECT PRESET_NAME&#xD;&#xA;  FROM QSYSPTMPRS&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND PRESET_GROUP = @preset_group&#xD;&#xA;   AND PRESET_NAME  = @preset_name">
            <QP N="factory" />
            <QP N="preset_group" />
            <QP N="preset_name" />
          </QY>
        </SG>
      </F>
      <F _S="598" N="PlcMapConfig">
        <SG _S="599" N="ListPlcMapConfig">
          <QY P="MsSql" Q="SELECT CONFIG_NAME, CONFIG_DESC, CONFIG_VALUE&#xD;&#xA;  FROM QSYSPTMCFG&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="600" N="InsertPlcMapConfig">
          <QY P="MsSql" Q="INSERT INTO QSYSPTMCFG (&#xD;&#xA;   FACTORY,&#xD;&#xA;   CONFIG_NAME,&#xD;&#xA;   CONFIG_DESC,&#xD;&#xA;   CONFIG_VALUE,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   UPDATE_TIME,&#xD;&#xA;   UPDATE_USER_ID&#xD;&#xA;   ) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @config_name,&#xD;&#xA;   @config_desc,&#xD;&#xA;   @config_value,&#xD;&#xA;   @create_time,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @update_time,&#xD;&#xA;   @update_user_id&#xD;&#xA;   )">
            <QP N="factory" />
            <QP N="config_name" />
            <QP N="config_desc" />
            <QP N="config_value" />
            <QP N="create_time" />
            <QP N="create_user_id" />
            <QP N="update_time" />
            <QP N="update_user_id" />
          </QY>
        </SG>
        <SG _S="601" N="HasPlcMapConfig">
          <QY P="MsSql" Q="SELECT CONFIG_NAME&#xD;&#xA;  FROM QSYSPTMCFG&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;  AND CONFIG_NAME = @config_name">
            <QP N="factory" />
            <QP N="config_name" />
          </QY>
        </SG>
        <SG _S="602" N="UpdatePlcMapConfig">
          <QY P="MsSql" Q="UPDATE QSYSPTMCFG SET&#xD;&#xA;   CONFIG_DESC     = @config_desc,&#xD;&#xA;   CONFIG_VALUE    = @config_value&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND CONFIG_NAME = @config_name">
            <QP N="config_desc" />
            <QP N="config_value" />
            <QP N="factory" />
            <QP N="config_name" />
          </QY>
        </SG>
      </F>
      <F _S="1274" N="LogicalGroup">
        <SG _S="1275" N="ListLogicalGroup">
          <QY P="MsSql" Q="SELECT LOGICAL_GROUP, LOGICAL_GROUP_DESC&#xD;&#xA;  FROM QSYSPTMLGP&#xD;&#xA; WHERE FACTORY = @factory     &#xD;&#xA; ORDER BY LOGICAL_GROUP">
            <QP N="factory" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="1278" N="HasLogicalGroup">
          <QY P="MsSql" Q="SELECT LOGICAL_GROUP, LOGICAL_GROUP_DESC&#xD;&#xA;  FROM QSYSPTMLGP&#xD;&#xA; WHERE FACTORY       = @factory     &#xD;&#xA;   AND LOGICAL_GROUP = @logical_group">
            <QP N="factory" />
            <QP N="logical_group" />
          </QY>
