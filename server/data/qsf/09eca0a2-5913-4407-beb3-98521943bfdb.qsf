            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="533" N="DeleteBranchEquipmentTag">
          <QY P="MsSql" Q="DELETE &#xD;&#xA;  FROM CEMSIBNPTG&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND IBN_NAME   = @ibn_name&#xD;&#xA;   AND EQP_NAME   = @eqp_name">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="534" N="DeleteBranchEquipmentVersion">
          <QY P="MsSql" Q="DELETE &#xD;&#xA;  FROM CEMSIBNVER&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND IBN_NAME   = @ibn_name&#xD;&#xA;   AND EQP_NAME   = @eqp_name">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="535" N="HasBranch">
          <QY P="MsSql" Q="SELECT IBN_NAME&#xD;&#xA;  FROM QEMSIBNDEF&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND IBN_NAME = @ibn_name">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
        <SG _S="536" N="HasBranchTagAlias">
          <QY P="MsSql" Q="SELECT TAG_ADDR, TAG_ADDR_ALIAS&#xD;&#xA;  FROM QEMSIBNPTA&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND IBN_NAME = @ibn_name">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
        <SG _S="537" N="HasEquipment">
          <QY P="MsSql" Q="SELECT EQP.EQP_NAME, EQP.EAP, &#xD;&#xA;       (CASE WHEN IBN.EQP_NAME IS NOT NULL THEN 'Yes' ELSE 'No' END) AS IS_REG, ISNULL(IBN.ENABLE, 'No') AS IS_ENABLE,&#xD;&#xA;        IBN.IBN_STATE,&#xD;&#xA;	   ISNULL(IBN.NEED_ACTION, ' ') AS NEED_ACTION,&#xD;&#xA;	   ISNULL(IBN.ACTIVE_VER, 0) AS ACTIVE_VER, ISNULL(IBN.LAST_VER, 0) AS LAST_VER, ISNULL(IBN.APPLIED_VER, 0) AS APPLIED_VER&#xD;&#xA;  FROM QRASEQPDEF EQP&#xD;&#xA;  LEFT JOIN QEMSIBNEQP IBN&#xD;&#xA;    ON EQP.FACTORY     = IBN.FACTORY&#xD;&#xA;   AND EQP.EQP_NAME    = IBN.EQP_NAME&#xD;&#xA;   AND IBN.IBN_NAME    = @ibn_name&#xD;&#xA; WHERE EQP.FACTORY     = @factory&#xD;&#xA;   AND EQP.EQP_NAME    = @eqp_name&#xD;&#xA;   AND EQP.DELETE_FLAG = 'N'">
            <QP N="ibn_name" />
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
