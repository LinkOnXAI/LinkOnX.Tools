        </SG>
        <SG _S="834" N="UpdateEap">
          <QY P="MsSql" Q="UPDATE QRASEAPDEF SET&#xD;&#xA;  LAST_EVENT_ID   = @last_event_id,&#xD;&#xA;  LAST_EVENT_TIME = @last_event_time,&#xD;&#xA;  LAST_HIST_SEQ   = LAST_HIST_SEQ + 1,&#xD;&#xA;  UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;  UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EAP     = @eap">
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="835" N="UpdateEapEquipment">
          <QY P="MsSql" Q="UPDATE QRASEQPDEF SET&#xD;&#xA;   LAST_HIST_SEQ   = LAST_HIST_SEQ + 1,&#xD;&#xA;   LAST_EVENT_ID   = @last_event_id,&#xD;&#xA;   LAST_EVENT_TIME = @last_event_time,&#xD;&#xA;   UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;   UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EQP_NAME = @eqp_name">
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
      </F>
      <F _S="836" N="RemotePingTest">
        <SG _S="837" N="HasServer">
          <QY P="MsSql" Q="SELECT SERVER, UP_DOWN, EAS_UP_DOWN&#xD;&#xA;  FROM QSYSSVRDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SERVER      = @server&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="server" />
          </QY>
        </SG>
      </F>
      <F _S="838" N="CustomRemoteCommandRequest">
        <SG _S="839" N="HasEap">
          <QY P="MsSql" Q="SELECT EAP, UP_DOWN, STATUS    &#xD;&#xA;  FROM QRASEAPDEF  &#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EAP         = @eap&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="840" N="HasEapAtr">
          <QY P="MsSql" Q="SELECT EAP&#xD;&#xA;  FROM QRASEAPATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP           = @eap&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
          </QY>
        </SG>
        <SG _S="841" N="HasEapEquipment">
          <QY P="MsSql" Q="SELECT A.EQP_NAME, B.COMM_STATE, B.CTRL_MODE&#xD;&#xA;  FROM QRASEQPDEF A&#xD;&#xA;  	LEFT JOIN QRASEQPSTS B&#xD;&#xA;  	ON A.EQP_NAME = B.EQP_NAME&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.EQP_NAME = @eqp_name&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="842" N="SearchEquipment">
          <QY P="MsSql" Q="SELECT D.EQP_NAME, C.EAP&#xD;&#xA;FROM QRASEQPDEF D&#xD;&#xA;LEFT JOIN QRASEAPCFG F ON    &#xD;&#xA;	F.OBJ_TYPE = 'CONTROLLER'&#xD;&#xA;	AND F.ATTR_CATEGORY = 'Applied'&#xD;&#xA;	AND F.DATA = D.EQP_NAME&#xD;&#xA;LEFT JOIN (&#xD;&#xA;       SELECT DISTINCT A.EAP&#xD;&#xA;         FROM QRASEAPDEF A&#xD;&#xA;    LEFT JOIN QRASEAPATR B&#xD;&#xA;           ON A.FACTORY       = B.FACTORY&#xD;&#xA;          AND A.EAP           = B.EAP&#xD;&#xA;        WHERE A.FACTORY       = @factory&#xD;&#xA;          AND A.DELETE_FLAG   = 'N'&#xD;&#xA;          AND B.ATTR_CATEGORY = 'Applied'&#xD;&#xA;          AND B.PACKAGE       = ISNULL(@searchPkg, B.PACKAGE)&#xD;&#xA;          AND B.MODEL         = ISNULL(@searchMdl, B.MODEL)&#xD;&#xA;          AND B.LIBRARY     = ISNULL(@searchLib, B.LIBRARY)&#xD;&#xA;          AND A.SERVER     = ISNULL(@searchSrv, A.SERVER)&#xD;&#xA;       ) C&#xD;&#xA; ON C.EAP = F.EAP &#xD;&#xA; WHERE  C.EAP IS NOT NULL&#xD;&#xA; ORDER BY D.EQP_NAME;">
            <QP N="factory" />
            <QP N="searchPkg" />
            <QP N="searchMdl" />
            <QP N="searchLib" />
            <QP N="searchSrv" />
          </QY>
        </SG>
        <SG _S="843" N="ListCommand">
          <QY P="MsSql" Q="SELECT COMMAND, CMD_DESC, CREATE_TIME&#xD;&#xA;  FROM QRASCUSRCM&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY COMMAND">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="844" N="ListCommandParameter">
          <QY P="MsSql" Q="SELECT DATA_1_PRT,&#xD;&#xA;       DATA_2_PRT,&#xD;&#xA;       DATA_3_PRT,&#xD;&#xA;       DATA_4_PRT,&#xD;&#xA;       DATA_5_PRT,&#xD;&#xA;       DATA_6_PRT,&#xD;&#xA;       DATA_7_PRT,&#xD;&#xA;       DATA_8_PRT,&#xD;&#xA;       DATA_9_PRT,&#xD;&#xA;       DATA_10_PRT,&#xD;&#xA;       DATA_11_PRT,&#xD;&#xA;       DATA_12_PRT,&#xD;&#xA;       DATA_13_PRT,&#xD;&#xA;       DATA_14_PRT,&#xD;&#xA;       DATA_15_PRT,&#xD;&#xA;       DATA_16_PRT,&#xD;&#xA;       DATA_17_PRT,&#xD;&#xA;       DATA_18_PRT,&#xD;&#xA;       DATA_19_PRT,&#xD;&#xA;       DATA_20_PRT&#xD;&#xA;  FROM QRASCUSRCM&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND COMMAND = @command">
            <QP N="factory" />
            <QP N="command" />
          </QY>
        </SG>
        <SG _S="845" N="UpdateEap">
          <QY P="MsSql" Q="UPDATE QRASEAPDEF SET&#xD;&#xA;  LAST_EVENT_ID   = @last_event_id,&#xD;&#xA;  LAST_EVENT_TIME = @last_event_time,&#xD;&#xA;  LAST_HIST_SEQ   = @hist_seq,&#xD;&#xA;  UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;  UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND EAP        = @eap">
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="hist_seq" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="846" N="InsertEapHistory">
          <QY P="MsSql" Q="INSERT INTO QRASEAPHIS (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EAP,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   EVENT_ID,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   SERVER,&#xD;&#xA;   STEP,&#xD;&#xA;   UP_DOWN,&#xD;&#xA;   STATUS,&#xD;&#xA;   NEED_ACTION,&#xD;&#xA;   NEXT_NEED_ACTION,&#xD;&#xA;   SET_PACKAGE,&#xD;&#xA;   SET_PKG_VER,&#xD;&#xA;   REL_PACKAGE,&#xD;&#xA;   REL_PKG_VER,&#xD;&#xA;   APL_PACKAGE,&#xD;&#xA;   APL_PKG_VER,   &#xD;&#xA;   SET_MODEL,&#xD;&#xA;   SET_MDL_VER,&#xD;&#xA;   REL_MODEL,&#xD;&#xA;   REL_MDL_VER,&#xD;&#xA;   APL_MODEL,&#xD;&#xA;   APL_MDL_VER,   &#xD;&#xA;   SET_LIBRARY,&#xD;&#xA;   SET_LIB_VER,   &#xD;&#xA;   REL_LIBRARY,&#xD;&#xA;   REL_LIB_VER,   &#xD;&#xA;   APL_LIBRARY,&#xD;&#xA;   APL_LIB_VER,   &#xD;&#xA;   EVT_H_1,&#xD;&#xA;   EVT_D_1,   &#xD;&#xA;   EVT_H_2,&#xD;&#xA;   EVT_D_2,&#xD;&#xA;   EVT_H_3,&#xD;&#xA;   EVT_D_3,&#xD;&#xA;   EVT_H_4,&#xD;&#xA;   EVT_D_4,&#xD;&#xA;   EVT_H_5,&#xD;&#xA;   EVT_D_5,&#xD;&#xA;   EVT_H_6,&#xD;&#xA;   EVT_D_6,&#xD;&#xA;   EVT_H_7,&#xD;&#xA;   EVT_D_7,&#xD;&#xA;   EVT_H_8,&#xD;&#xA;   EVT_D_8,&#xD;&#xA;   EVT_H_9,&#xD;&#xA;   EVT_D_9,&#xD;&#xA;   EVT_H_10,&#xD;&#xA;   EVT_D_10,&#xD;&#xA;   EVT_H_11,&#xD;&#xA;   EVT_D_11,   &#xD;&#xA;   EVT_H_12,&#xD;&#xA;   EVT_D_12,&#xD;&#xA;   EVT_H_13,&#xD;&#xA;   EVT_D_13,&#xD;&#xA;   EVT_H_14,&#xD;&#xA;   EVT_D_14,&#xD;&#xA;   EVT_H_15,&#xD;&#xA;   EVT_D_15,&#xD;&#xA;   EVT_H_16,&#xD;&#xA;   EVT_D_16,&#xD;&#xA;   EVT_H_17,&#xD;&#xA;   EVT_D_17,&#xD;&#xA;   EVT_H_18,&#xD;&#xA;   EVT_D_18,&#xD;&#xA;   EVT_H_19,&#xD;&#xA;   EVT_D_19,&#xD;&#xA;   EVT_H_20,&#xD;&#xA;   EVT_D_20,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT      &#xD;&#xA;) &#xD;&#xA;SELECT &#xD;&#xA;   A.FACTORY,&#xD;&#xA;   A.EAP,&#xD;&#xA;   @hist_seq,&#xD;&#xA;   @event_id,&#xD;&#xA;   @tran_time,&#xD;&#xA;   A.SERVER,&#xD;&#xA;   A.STEP,&#xD;&#xA;   A.UP_DOWN,&#xD;&#xA;   A.STATUS,&#xD;&#xA;   A.NEED_ACTION,&#xD;&#xA;   A.NEXT_NEED_ACTION,   &#xD;&#xA;   ISNULL(B.PACKAGE, ' '),&#xD;&#xA;   ISNULL(B.PKG_VER, 0),&#xD;&#xA;   ISNULL(C.PACKAGE, ' '),&#xD;&#xA;   ISNULL(C.PKG_VER, 0),&#xD;&#xA;   ISNULL(D.PACKAGE, ' '),&#xD;&#xA;   ISNULL(D.PKG_VER, 0),   &#xD;&#xA;   ISNULL(B.MODEL, ' '),&#xD;&#xA;   ISNULL(B.MDL_VER, 0),&#xD;&#xA;   ISNULL(C.MODEL, ' '),&#xD;&#xA;   ISNULL(C.MDL_VER, 0),&#xD;&#xA;   ISNULL(D.MODEL, ' '),&#xD;&#xA;   ISNULL(D.MDL_VER, 0),   &#xD;&#xA;   ISNULL(B.LIBRARY, ' '),&#xD;&#xA;   ISNULL(B.LIB_VER, 0),&#xD;&#xA;   ISNULL(C.LIBRARY, ' '),&#xD;&#xA;   ISNULL(C.LIB_VER, 0),&#xD;&#xA;   ISNULL(D.LIBRARY, ' '),&#xD;&#xA;   ISNULL(D.LIB_VER, 0),&#xD;&#xA;   @evt_h_1,&#xD;&#xA;   @evt_d_1,   &#xD;&#xA;   @evt_h_2,&#xD;&#xA;   @evt_d_2,&#xD;&#xA;   @evt_h_3,&#xD;&#xA;   @evt_d_3,&#xD;&#xA;   @evt_h_4,&#xD;&#xA;   @evt_d_4,&#xD;&#xA;   @evt_h_5,&#xD;&#xA;   @evt_d_5,&#xD;&#xA;   @evt_h_6,&#xD;&#xA;   @evt_d_6,&#xD;&#xA;   @evt_h_7,&#xD;&#xA;   @evt_d_7,&#xD;&#xA;   @evt_h_8,&#xD;&#xA;   @evt_d_8,&#xD;&#xA;   @evt_h_9,&#xD;&#xA;   @evt_d_9,&#xD;&#xA;   @evt_h_10,&#xD;&#xA;   @evt_d_10,&#xD;&#xA;   @evt_h_11,&#xD;&#xA;   @evt_d_11,   &#xD;&#xA;   @evt_h_12,&#xD;&#xA;   @evt_d_12,&#xD;&#xA;   @evt_h_13,&#xD;&#xA;   @evt_d_13,&#xD;&#xA;   @evt_h_14,&#xD;&#xA;   @evt_d_14,&#xD;&#xA;   @evt_h_15,&#xD;&#xA;   @evt_d_15,&#xD;&#xA;   @evt_h_16,&#xD;&#xA;   @evt_d_16,&#xD;&#xA;   @evt_h_17,&#xD;&#xA;   @evt_d_17,&#xD;&#xA;   @evt_h_18,&#xD;&#xA;   @evt_d_18,&#xD;&#xA;   @evt_h_19,&#xD;&#xA;   @evt_d_19,&#xD;&#xA;   @evt_h_20,&#xD;&#xA;   @evt_d_20,&#xD;&#xA;   @tran_user_id,&#xD;&#xA;   @tran_comment&#xD;&#xA;  FROM QRASEAPDEF A  &#xD;&#xA;  WITH (NOLOCK)&#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C&#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP           = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D&#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP           = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.EAP         = @eap">
            <QP N="hist_seq" />
            <QP N="event_id" />
            <QP N="tran_time" />
            <QP N="evt_h_1" />
            <QP N="evt_d_1" />
            <QP N="evt_h_2" />
            <QP N="evt_d_2" />
            <QP N="evt_h_3" />
            <QP N="evt_d_3" />
            <QP N="evt_h_4" />
            <QP N="evt_d_4" />
            <QP N="evt_h_5" />
            <QP N="evt_d_5" />
            <QP N="evt_h_6" />
            <QP N="evt_d_6" />
            <QP N="evt_h_7" />
            <QP N="evt_d_7" />
            <QP N="evt_h_8" />
            <QP N="evt_d_8" />
            <QP N="evt_h_9" />
            <QP N="evt_d_9" />
            <QP N="evt_h_10" />
            <QP N="evt_d_10" />
            <QP N="evt_h_11" />
            <QP N="evt_d_11" />
            <QP N="evt_h_12" />
            <QP N="evt_d_12" />
            <QP N="evt_h_13" />
            <QP N="evt_d_13" />
            <QP N="evt_h_14" />
            <QP N="evt_d_14" />
            <QP N="evt_h_15" />
            <QP N="evt_d_15" />
            <QP N="evt_h_16" />
            <QP N="evt_d_16" />
            <QP N="evt_h_17" />
            <QP N="evt_d_17" />
            <QP N="evt_h_18" />
            <QP N="evt_d_18" />
            <QP N="evt_h_19" />
            <QP N="evt_d_19" />
            <QP N="evt_h_20" />
            <QP N="evt_d_20" />
            <QP N="tran_user_id" />
            <QP N="tran_comment" />
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="847" N="InsertEapEquipmentHis">
          <QY P="MsSql" Q="INSERT INTO QRASEQPHIS (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   EVENT_ID,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   SYSTEM,&#xD;&#xA;   COMM_STATE,&#xD;&#xA;   CTRL_MODE,&#xD;&#xA;   EAP,&#xD;&#xA;   EAP_EVENT_ID,      &#xD;&#xA;   EVT_H_1,&#xD;&#xA;   EVT_D_1,   &#xD;&#xA;   EVT_H_2,&#xD;&#xA;   EVT_D_2,&#xD;&#xA;   EVT_H_3,&#xD;&#xA;   EVT_D_3,&#xD;&#xA;   EVT_H_4,&#xD;&#xA;   EVT_D_4,&#xD;&#xA;   EVT_H_5,&#xD;&#xA;   EVT_D_5,&#xD;&#xA;   EVT_H_6,&#xD;&#xA;   EVT_D_6,&#xD;&#xA;   EVT_H_7,&#xD;&#xA;   EVT_D_7,&#xD;&#xA;   EVT_H_8,&#xD;&#xA;   EVT_D_8,&#xD;&#xA;   EVT_H_9,&#xD;&#xA;   EVT_D_9,&#xD;&#xA;   EVT_H_10,&#xD;&#xA;   EVT_D_10,&#xD;&#xA;   EVT_H_11,&#xD;&#xA;   EVT_D_11,   &#xD;&#xA;   EVT_H_12,&#xD;&#xA;   EVT_D_12,&#xD;&#xA;   EVT_H_13,&#xD;&#xA;   EVT_D_13,&#xD;&#xA;   EVT_H_14,&#xD;&#xA;   EVT_D_14,&#xD;&#xA;   EVT_H_15,&#xD;&#xA;   EVT_D_15,&#xD;&#xA;   EVT_H_16,&#xD;&#xA;   EVT_D_16,&#xD;&#xA;   EVT_H_17,&#xD;&#xA;   EVT_D_17,&#xD;&#xA;   EVT_H_18,&#xD;&#xA;   EVT_D_18,&#xD;&#xA;   EVT_H_19,&#xD;&#xA;   EVT_D_19,&#xD;&#xA;   EVT_H_20,&#xD;&#xA;   EVT_D_20,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT      &#xD;&#xA;) &#xD;&#xA;VALUES( &#xD;&#xA;   @factory,&#xD;&#xA;   @eqp_name,&#xD;&#xA;   @last_his_seq,&#xD;&#xA;   @event_id,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @SYSTEM,&#xD;&#xA;   @comm_state,&#xD;&#xA;   @ctrl_mode,&#xD;&#xA;   @eap,&#xD;&#xA;   @eap_event_id,&#xD;&#xA;   @evt_h_1,&#xD;&#xA;   @evt_d_1,   &#xD;&#xA;   @evt_h_2,&#xD;&#xA;   @evt_d_2,&#xD;&#xA;   @evt_h_3,&#xD;&#xA;   @evt_d_3,&#xD;&#xA;   @evt_h_4,&#xD;&#xA;   @evt_d_4,&#xD;&#xA;   @evt_h_5,&#xD;&#xA;   @evt_d_5,&#xD;&#xA;   @evt_h_6,&#xD;&#xA;   @evt_d_6,&#xD;&#xA;   @evt_h_7,&#xD;&#xA;   @evt_d_7,&#xD;&#xA;   @evt_h_8,&#xD;&#xA;   @evt_d_8,&#xD;&#xA;   @evt_h_9,&#xD;&#xA;   @evt_d_9,&#xD;&#xA;   @evt_h_10,&#xD;&#xA;   @evt_d_10,&#xD;&#xA;   @evt_h_11,&#xD;&#xA;   @evt_d_11,   &#xD;&#xA;   @evt_h_12,&#xD;&#xA;   @evt_d_12,&#xD;&#xA;   @evt_h_13,&#xD;&#xA;   @evt_d_13,&#xD;&#xA;   @evt_h_14,&#xD;&#xA;   @evt_d_14,&#xD;&#xA;   @evt_h_15,&#xD;&#xA;   @evt_d_15,&#xD;&#xA;   @evt_h_16,&#xD;&#xA;   @evt_d_16,&#xD;&#xA;   @evt_h_17,&#xD;&#xA;   @evt_d_17,&#xD;&#xA;   @evt_h_18,&#xD;&#xA;   @evt_d_18,&#xD;&#xA;   @evt_h_19,&#xD;&#xA;   @evt_d_19,&#xD;&#xA;   @evt_h_20,&#xD;&#xA;   @evt_d_20,&#xD;&#xA;   @tran_user_id,&#xD;&#xA;   @tran_comment)">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="last_his_seq" />
            <QP N="event_id" />
            <QP N="tran_time" />
            <QP N="SYSTEM" />
            <QP N="comm_state" />
            <QP N="ctrl_mode" />
            <QP N="eap" />
            <QP N="eap_event_id" />
            <QP N="evt_h_1" />
            <QP N="evt_d_1" />
            <QP N="evt_h_2" />
            <QP N="evt_d_2" />
            <QP N="evt_h_3" />
            <QP N="evt_d_3" />
            <QP N="evt_h_4" />
            <QP N="evt_d_4" />
            <QP N="evt_h_5" />
            <QP N="evt_d_5" />
            <QP N="evt_h_6" />
            <QP N="evt_d_6" />
            <QP N="evt_h_7" />
            <QP N="evt_d_7" />
            <QP N="evt_h_8" />
            <QP N="evt_d_8" />
            <QP N="evt_h_9" />
            <QP N="evt_d_9" />
            <QP N="evt_h_10" />
