        </SG>
        <SG _S="1001" N="InsertEapAtr">
          <QY P="MsSql" Q="INSERT INTO QRASEAPATR (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EAP,&#xD;&#xA;   ATTR_CATEGORY,&#xD;&#xA;   PACKAGE,&#xD;&#xA;   PKG_VER,&#xD;&#xA;   MODEL,&#xD;&#xA;   MDL_VER,&#xD;&#xA;   LIBRARY,&#xD;&#xA;   LIB_VER,&#xD;&#xA;   EAP_SCHEMA,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) &#xD;&#xA;SELECT &#xD;&#xA;   FACTORY,&#xD;&#xA;   EAP,&#xD;&#xA;   @attr_category2,&#xD;&#xA;   PACKAGE,&#xD;&#xA;   PKG_VER,&#xD;&#xA;   MODEL,&#xD;&#xA;   MDL_VER,&#xD;&#xA;   LIBRARY,&#xD;&#xA;   LIB_VER,&#xD;&#xA;   @eap_schema,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;  FROM QRASEAPATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP           = @eap&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="attr_category2" />
            <QP N="eap_schema" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
          </QY>
        </SG>
        <SG _S="1002" N="InsertEapConfig">
          <QY P="MsSql" Q="INSERT INTO QRASEAPCFG (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EAP,&#xD;&#xA;   ATTR_CATEGORY,&#xD;&#xA;   OBJ_TYPE,&#xD;&#xA;   OBJ_NAME,&#xD;&#xA;   KEY_SEQ,&#xD;&#xA;   KEY_NAME,&#xD;&#xA;   DATA,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) &#xD;&#xA;SELECT &#xD;&#xA;   FACTORY,&#xD;&#xA;   EAP,&#xD;&#xA;   @attr_category2,&#xD;&#xA;   OBJ_TYPE,&#xD;&#xA;   OBJ_NAME,&#xD;&#xA;   KEY_SEQ,&#xD;&#xA;   KEY_NAME,&#xD;&#xA;   DATA,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;  FROM QRASEAPCFG&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP           = @eap&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="attr_category2" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
          </QY>
        </SG>
        <SG _S="1003" N="InsertConnectorSts">
          <QY P="MsSql" Q="INSERT INTO QRASCNTSTS &#xD;&#xA;(&#xD;&#xA;   FACTORY,&#xD;&#xA;   EAP,   &#xD;&#xA;   CNT_SEQ,&#xD;&#xA;   CNT_NAME,   &#xD;&#xA;   STATE,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) &#xD;&#xA;VALUES&#xD;&#xA;(&#xD;&#xA;   @factory,&#xD;&#xA;   @eap,&#xD;&#xA;   @cnt_seq,&#xD;&#xA;   @cnt_name,&#xD;&#xA;   @state,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="cnt_seq" />
            <QP N="cnt_name" />
            <QP N="state" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="1004" N="InsertEapEquipmentHis">
