      <F _S="1044" N="EquipmentDisconnect">
        <SG _S="1045" N="SearchEquipment">
          <QY P="MsSql" Q="SELECT A.EQP_NAME, B.COMM_STATE, B.CTRL_MODE&#xD;&#xA;  FROM QRASEQPDEF A&#xD;&#xA;  	LEFT JOIN QRASEQPSTS B&#xD;&#xA;  	ON A.EQP_NAME = B.EQP_NAME&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="1046" N="InsertEapHistory">
