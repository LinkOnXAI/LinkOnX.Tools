        <SG _S="1376" N="UpdateVariableLink">
          <QY P="MsSql" Q="UPDATE QSYSPTMPVL SET&#xA;   VID              = @vid,&#xA;   IS_LINKED        = @is_linked,&#xA;   UPDATE_USER_ID   = @update_user_id,&#xD;&#xA;   UPDATE_TIME      = @update_time&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME  = @tagset_name&#xA;   AND TAG_NAME     = @tag_name">
            <QP N="vid" />
            <QP N="is_linked" />
