        <SG _S="1054" N="UpdateEap">
          <QY P="MsSql" Q="UPDATE QRASEAPDEF SET&#xD;&#xA;  LAST_EVENT_ID   = @last_event_id,&#xD;&#xA;  LAST_EVENT_TIME = @last_event_time,&#xD;&#xA;  LAST_HIST_SEQ   = @hist_seq,&#xD;&#xA;  UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;  UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EAP     = @eap">
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="hist_seq" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="1055" N="UpdateConnectorSts">
          <QY P="MsSql" Q="UPDATE QRASCNTSTS SET&#xD;&#xA;  STATE          = @state,&#xD;&#xA;  UPDATE_USER_ID = @update_user_id,&#xD;&#xA;  UPDATE_TIME    = @update_time&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EAP     = @eap   &#xD;&#xA;   AND CNT_SEQ = @cnt_seq">
            <QP N="state" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eap" />
            <QP N="cnt_seq" />
          </QY>
        </SG>
      </F>
