          <QY P="SQLite" />
        </SG>
        <SG _S="1373" N="SearchSuggestByAllTagsetGroup">
          <QY P="MsSql" Q="WITH C AS&#xA;(&#xA;    SELECT TAG_NAME, VID, COUNT(*) AS CNT&#xA;      FROM QSYSPTMPVL&#xA;     WHERE FACTORY      = @factory&#xA;       AND TAG_NAME     = @tag_name&#xA;       AND IS_LINKED    = @is_linked&#xA;       AND VID         &lt;&gt; 0&#xA;     GROUP BY TAG_NAME, VID&#xA;),&#xA;R AS&#xA;(&#xA;    SELECT TAG_NAME, VID, CNT,&#xA;           RANK() OVER&#xA;           (&#xA;               PARTITION BY TAG_NAME&#xA;               ORDER BY CNT DESC&#xA;           ) AS RN&#xA;      FROM C&#xA;)&#xA;SELECT VID, CNT&#xA;  FROM R&#xA; WHERE RN = 1&#xA; ORDER BY CNT DESC, VID ASC">
            <QP N="factory&#xA;" />
            <QP N="tag_name&#xA;" />
            <QP N="is_linked&#xA;" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="1374" N="SearchSuggestBySameTagsetGroup">
          <QY P="MsSql" Q="WITH C AS&#xA;(&#xA;    SELECT TAG_NAME, VID, COUNT(*) AS CNT&#xA;      FROM QSYSPTMPVL&#xA;     WHERE FACTORY      = @factory&#xD;&#xA;       AND TAGSET_GROUP = @tagset_group&#xA;       AND TAG_NAME     = @tag_name&#xA;       AND IS_LINKED    = @is_linked&#xA;       AND VID         &lt;&gt; 0&#xA;     GROUP BY TAG_NAME, VID&#xA;),&#xA;R AS&#xA;(&#xA;    SELECT TAG_NAME, VID, CNT,&#xA;           RANK() OVER&#xA;           (&#xA;               PARTITION BY TAG_NAME&#xA;               ORDER BY CNT DESC&#xA;           ) AS RN&#xA;      FROM C&#xA;)&#xA;SELECT VID, CNT&#xA;  FROM R&#xA; WHERE RN = 1&#xA; ORDER BY CNT DESC, VID ASC">
            <QP N="factory" />
            <QP N="tagset_group&#xA;" />
            <QP N="tag_name&#xA;" />
            <QP N="is_linked&#xA;" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="1375" N="SearchSuggestBySelectedTagset">
          <QY P="MsSql" Q="SELECT TAG_NAME, VID&#xA;  FROM QSYSPTMPVL&#xA; WHERE FACTORY      = @factory&#xA;   AND TAGSET_GROUP = @tagset_group&#xA;   AND TAGSET_NAME  = @tagset_name&#xA;   AND IS_LINKED    = @is_linked">
            <QP N="factory&#xA;" />
            <QP N="tagset_group&#xA;" />
            <QP N="tagset_name&#xA;" />
            <QP N="is_linked" />
