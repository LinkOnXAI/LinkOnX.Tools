            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
      </F>
