          <QY P="MsSql" Q="SELECT EAP, SERVER, UP_DOWN, STATUS&#xD;&#xA;  FROM QRASEAPDEF&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP           = @eap&#xD;&#xA;   AND DELETE_FLAG   = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
