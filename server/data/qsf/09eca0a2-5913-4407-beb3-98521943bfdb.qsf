      <F _S="604" N="EapBatchModification">
        <SG _S="605" N="SearchEap">
          <QY P="MsSql" Q="SELECT *&#xD;&#xA;  FROM (&#xD;&#xA;       SELECT A.EAP, A.SERVER, B.PACKAGE, B.PKG_VER, B.MODEL, B.MDL_VER, B.LIBRARY, B.LIB_VER, B.EAP_SCHEMA&#xD;&#xA;         FROM QRASEAPDEF A&#xD;&#xA;    LEFT JOIN QRASEAPATR B&#xD;&#xA;           ON A.FACTORY       = B.FACTORY&#xD;&#xA;          AND A.EAP           = B.EAP&#xD;&#xA;        WHERE A.FACTORY       = @factory&#xD;&#xA;          AND A.DELETE_FLAG   = 'N'&#xD;&#xA;          AND B.ATTR_CATEGORY = 'Setup'&#xD;&#xA;          AND B.PACKAGE       = ISNULL(@searchPkg, B.PACKAGE)&#xD;&#xA;          AND B.MODEL         = ISNULL(@searchMdl, B.MODEL)&#xD;&#xA;          AND B.LIBRARY     = ISNULL(@searchLib, B.LIBRARY)&#xD;&#xA;          AND A.SERVER     = ISNULL(@searchSrv, A.SERVER)&#xD;&#xA;       ) C&#xD;&#xA; ??CONDITION??&#xD;&#xA; ORDER BY EAP">
            <QP N="factory" />
            <QP N="searchPkg" />
            <QP N="searchMdl" />
            <QP N="searchLib" />
            <QP N="searchSrv" />
          </QY>
        </SG>
