        </SG>
        <SG _S="1359" N="HasLogicalLinkVariableId">
          <QY P="MsSql" Q="-- VID_GROUP의 범위 조회&#xD;&#xA;WITH CurrentGroupRange AS&#xA;(&#xA;    SELECT FACTORY, VID_GROUP, CAST(RANGE_FROM AS bigint) AS RANGE_FROM, CAST(RANGE_TO AS bigint) AS RANGE_TO&#xA;      FROM QSYSPTMVGP&#xA;     WHERE FACTORY     = @factory&#xA;       AND VID_GROUP   = @vid_group&#xA;       AND RANGE_FROM &lt;= RANGE_TO&#xA;)&#xA;-- 해당 범위에 포함된 VID 목록 조회&#xA;SELECT V.VID&#xA;  FROM QSYSPTMVLL V&#xA;  JOIN CurrentGroupRange G&#xA;    ON G.FACTORY     = V.FACTORY&#xA;   AND V.VID         BETWEEN G.RANGE_FROM AND G.RANGE_TO">
            <QP N="factory&#xA;" />
            <QP N="vid_group&#xA;" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="1382" N="HasPhysicalLinkVariableId">
          <QY P="MsSql" Q="-- VID_GROUP의 범위 조회&#xD;&#xA;WITH CurrentGroupRange AS&#xD;&#xA;(&#xD;&#xA;    SELECT FACTORY, VID_GROUP, CAST(RANGE_FROM AS bigint) AS RANGE_FROM, CAST(RANGE_TO AS bigint) AS RANGE_TO&#xD;&#xA;      FROM QSYSPTMVGP&#xD;&#xA;     WHERE FACTORY     = @factory&#xD;&#xA;       AND VID_GROUP   = @vid_group&#xD;&#xA;       AND RANGE_FROM &lt;= RANGE_TO&#xD;&#xA;)&#xD;&#xA;-- 해당 범위에 포함된 VID 목록 조회&#xD;&#xA;SELECT V.VID&#xD;&#xA;  FROM QSYSPTMPVL V&#xD;&#xA;  JOIN CurrentGroupRange G&#xD;&#xA;    ON G.FACTORY     = V.FACTORY&#xD;&#xA;   AND V.VID         BETWEEN G.RANGE_FROM AND G.RANGE_TO">
            <QP N="factory" />
            <QP N="vid_group" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
