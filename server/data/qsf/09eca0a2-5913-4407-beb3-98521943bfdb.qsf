        </SG>
        <SG _S="1063" N="UpdateEap">
          <QY P="MsSql" Q="UPDATE QRASEAPDEF SET&#xD;&#xA;  DST_CNT          = @dst_cnt,&#xD;&#xA;  LAST_EVENT_ID    = @last_event_id,&#xD;&#xA;  LAST_EVENT_TIME  = @last_event_time,&#xD;&#xA;  LAST_HIST_SEQ    = @hist_seq,&#xD;&#xA;  UPDATE_USER_ID   = @update_user_id,&#xD;&#xA;  UPDATE_TIME      = @update_time&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EAP     = @eap">
            <QP N="dst_cnt" />
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="hist_seq" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="1064" N="DeleteEapDataStoreState">
          <QY P="MsSql" Q="DELETE&#xD;&#xA;  FROM QRASEAPDST&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EAP     = @eap">
