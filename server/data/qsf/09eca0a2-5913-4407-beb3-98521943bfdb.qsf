      <F _S="45" N="GcmData">
        <SG _S="46" N="SearchGcmData">
          <QY P="MsSql" Q="SELECT DATA_1, DATA_2, DATA_3, DATA_4, DATA_5, DATA_6, DATA_7, DATA_8, DATA_9, DATA_10&#xA;  FROM QGCMTBLDAT&#xA; WHERE FACTORY    = @factory&#xA;   AND TABLE_NAME = @table_name&#xD;&#xA; ORDER BY DATA_KEY">
            <QP N="factory&#xA;" />
            <QP N="table_name" />
          </QY>
        </SG>
        <SG _S="47" N="SearchGcmTable">
          <QY P="MsSql" Q="SELECT DATA_1_USE,  DATA_1_PRT,  DATA_1_FMT,  DATA_1_SIZE,  DATA_1_KEY,&#xD;&#xA;       DATA_2_USE,  DATA_2_PRT,  DATA_2_FMT,  DATA_2_SIZE,  DATA_2_KEY,&#xD;&#xA;       DATA_3_USE,  DATA_3_PRT,  DATA_3_FMT,  DATA_3_SIZE,  DATA_3_KEY,&#xD;&#xA;       DATA_4_USE,  DATA_4_PRT,  DATA_4_FMT,  DATA_4_SIZE,  DATA_4_KEY,&#xD;&#xA;       DATA_5_USE,  DATA_5_PRT,  DATA_5_FMT,  DATA_5_SIZE,  DATA_5_KEY,&#xD;&#xA;       DATA_6_USE,  DATA_6_PRT,  DATA_6_FMT,  DATA_6_SIZE,  DATA_6_KEY,&#xD;&#xA;       DATA_7_USE,  DATA_7_PRT,  DATA_7_FMT,  DATA_7_SIZE,  DATA_7_KEY,&#xD;&#xA;       DATA_8_USE,  DATA_8_PRT,  DATA_8_FMT,  DATA_8_SIZE,  DATA_8_KEY,&#xD;&#xA;       DATA_9_USE,  DATA_9_PRT,  DATA_9_FMT,  DATA_9_SIZE,  DATA_9_KEY,&#xD;&#xA;       DATA_10_USE, DATA_10_PRT, DATA_10_FMT, DATA_10_SIZE, DATA_10_KEY&#xD;&#xA;  FROM QGCMTBLDEF&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND TABLE_NAME = @table_name">
            <QP N="factory" />
            <QP N="table_name" />
          </QY>
        </SG>
        <SG _S="48" N="SearchGcmDataTableCustomField">
          <QY P="MsSql" Q="SELECT DATA_2 AS CMF, DATA_3 AS CAPTION&#xD;&#xA;  FROM QGCMTBLDAT&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND TABLE_NAME = @table_name&#xD;&#xA;   AND DATA_1     = @data_1">
            <QP N="factory" />
            <QP N="table_name" />
            <QP N="data_1" />
          </QY>
        </SG>
      </F>
      <F _S="49" N="PTMHistory">
        <SG _S="50" N="SelectPTMHistorySeq">
          <QY P="MsSql" Q="SELECT NEXT VALUE FOR SEQ_PTM_HIS" />
        </SG>
      </F>
      <F _S="51" N="PTMParser">
        <SG _S="52" N="SearchMapParser">
          <QY P="MsSql" Q="SELECT PARSER_NAME&#xD;&#xA;  FROM QSYSPTMMPS&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND PLC_MAKER = @plc_maker&#xD;&#xA;   AND PLC_MODEL = @plc_model">
            <QP N="factory" />
            <QP N="plc_maker" />
            <QP N="plc_model" />
          </QY>
        </SG>
      </F>
      <F _S="53" N="PTMConfig">
        <SG _S="54" N="SearchPlcMapConfig">
          <QY P="MsSql" Q="SELECT CONFIG_VALUE&#xD;&#xA;  FROM QSYSPTMCFG&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND CONFIG_NAME = @config_name">
            <QP N="factory" />
            <QP N="config_name" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="55" N="Inquiry">
      <F _S="56" N="ModelVerSchema">
        <SG _S="57" N="HasModelVer">
          <QY P="MsSql" Q="SELECT MODEL, MDL_SCHEMA&#xD;&#xA;  FROM QSYSMDLVER&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND MODEL  = @model&#xD;&#xA;   AND MDL_VER = @mdl_ver">
            <QP N="factory" />
            <QP N="model" />
            <QP N="mdl_ver" />
          </QY>
        </SG>
      </F>
      <F _S="58" N="EapModelerFile">
        <SG _S="59" N="HasFactory">
          <QY P="MsSql" Q="SELECT FACTORY, EAP_RELOAD_LIMIT&#xD;&#xA;  FROM QSYSFACDEF&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="60" N="HasServer">
          <QY P="MsSql" Q="SELECT UP_DOWN, STATUS, EAS_UP_DOWN, B_SERVER, B_UP_DOWN, B_STATUS, B_EAS_UP_DOWN &#xD;&#xA;  FROM QSYSSVRDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SERVER      = @server&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="server" />
          </QY>
        </SG>
        <SG _S="61" N="HasEap">
          <QY P="MsSql" Q="SELECT EAP_TYPE, UP_DOWN, SERVER, STATUS&#xD;&#xA;  FROM QRASEAPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EAP         = @eap&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="62" N="Dialog">
      <F _S="63" N="UserGroupSelector">
        <SG _S="64" N="ListUserGroup">
          <QY P="MsSql" Q="SELECT USER_GRP, USER_GRP_DESC&#xD;&#xA;  FROM QSECUSRGRP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY USER_GRP">
            <QP P="factory" />
          </QY>
        </SG>
      </F>
      <F _S="65" N="UserGroupFunctionSelector">
        <SG _S="66" N="ListFunction">
          <QY P="MsSql" Q="SELECT FUN, FUN_DESC, TRAN_USED&#xD;&#xA;  FROM QSECURGFUN&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND APP     = @app&#xD;&#xA; ORDER BY FUN">
            <QP P="factory" />
            <QP P="app" />
          </QY>
        </SG>
      </F>
      <F _S="67" N="UserGroupAuthoritySelector">
        <SG _S="68" N="ListUserGroup">
          <QY P="MsSql" Q="SELECT USER_GRP, USER_GRP_DESC, ALL_AUTHORITY&#xD;&#xA;  FROM QSECUSRGRP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY USER_GRP">
            <QP P="factory" />
          </QY>
        </SG>
        <SG _S="69" N="ListAuthority">
          <QY P="MsSql" Q="SELECT A.FUN, B.FUN_DESC, A.TRAN_ENABLED, B.TRAN_USED&#xD;&#xA;  FROM QSECURGAUT A&#xD;&#xA;  LEFT JOIN QSECURGFUN B&#xD;&#xA;    ON A.FACTORY  = B.FACTORY&#xD;&#xA;   AND A.APP      = B.APP&#xD;&#xA;   AND A.FUN      = B.FUN&#xD;&#xA; WHERE A.FACTORY  = @factory&#xD;&#xA;   AND A.USER_GRP = @user_grp&#xD;&#xA;   AND A.APP      = @app&#xD;&#xA; ORDER BY A.FUN">
            <QP P="factory" />
            <QP P="user_grp" />
            <QP P="app" />
          </QY>
        </SG>
      </F>
      <F _S="70" N="ServerSelector">
        <SG _S="71" N="ListAllServer">
          <QY P="MsSql" Q="SELECT SERVER, SVR_DESC, SVR_IP, UP_DOWN, STATUS, ALARM, DELETE_FLAG&#xD;&#xA;  FROM QSYSSVRDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SVR_TYPE    = ISNULL(@svr_type, SVR_TYPE)&#xD;&#xA;   AND DELETE_FLAG = ISNULL(@delete_flag, DELETE_FLAG)&#xD;&#xA; ORDER BY SERVER">
            <QP P="factory" />
            <QP P="svr_type" />
            <QP P="delete_flag" />
          </QY>
        </SG>
      </F>
      <F _S="72" N="PackageSelector">
        <SG _S="73" N="ListPackage">
          <QY P="MsSql" Q="SELECT PACKAGE, PKG_DESC, REL_PKG_VER, LAST_PKG_VER&#xD;&#xA;  FROM QSYSPKGDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY PACKAGE">
            <QP P="factory" />
          </QY>
        </SG>
      </F>
      <F _S="74" N="PackageVerSelector">
        <SG _S="75" N="ListPackage">
          <QY P="MsSql" Q="SELECT PACKAGE, PKG_DESC, REL_PKG_VER, LAST_PKG_VER&#xD;&#xA;  FROM QSYSPKGDEF&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA; ORDER BY PACKAGE">
            <QP P="factory" />
          </QY>
        </SG>
        <SG _S="76" N="ListPackageVer">
          <QY P="MsSql" Q="SELECT PKG_VER, PKG_VER_DESC, PKG_RELEASE, PKG_COMMENT&#xD;&#xA;  FROM QSYSPKGVER&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND PACKAGE = @package&#xD;&#xA; ORDER BY PKG_VER DESC">
            <QP P="factory" />
            <QP P="package" />
          </QY>
        </SG>
      </F>
      <F _S="77" N="ModelSelector">
        <SG _S="78" N="ListModel">
          <QY P="MsSql" Q="SELECT MODEL, MDL_DESC, REL_MDL_VER, LAST_MDL_VER&#xD;&#xA;  FROM QSYSMDLDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY MODEL">
            <QP P="factory" />
          </QY>
        </SG>
      </F>
      <F _S="79" N="ModelVerSelector">
        <SG _S="80" N="ListModel">
          <QY P="MsSql" Q="SELECT MODEL, MDL_DESC, REL_MDL_VER, LAST_MDL_VER&#xD;&#xA;  FROM QSYSMDLDEF&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA; ORDER BY MODEL">
            <QP P="factory" />
          </QY>
        </SG>
        <SG _S="81" N="ListModelVer">
          <QY P="MsSql" Q="SELECT MDL_VER, MDL_VER_DESC, MDL_RELEASE, MDL_COMMENT&#xD;&#xA;  FROM QSYSMDLVER&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND MODEL   = @model&#xD;&#xA; ORDER BY MDL_VER DESC">
            <QP P="factory" />
            <QP P="model" />
          </QY>
        </SG>
      </F>
      <F _S="82" N="LibrarySelector">
        <SG _S="83" N="ListLibrary">
          <QY P="MsSql" Q="SELECT LIBRARY, LIB_DESC, REL_LIB_VER, LAST_LIB_VER&#xD;&#xA;  FROM QSYSLIBDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY LIBRARY">
            <QP P="factory" />
          </QY>
        </SG>
      </F>
      <F _S="84" N="LibraryVerSelector">
        <SG _S="85" N="ListLibrary">
          <QY P="MsSql" Q="SELECT LIBRARY, LIB_DESC, REL_LIB_VER, LAST_LIB_VER&#xD;&#xA;  FROM QSYSLIBDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY LIBRARY">
            <QP P="factory" />
          </QY>
        </SG>
        <SG _S="86" N="ListLibraryVer">
          <QY P="MsSql" Q="SELECT LIB_VER, LIB_VER_DESC, LIB_RELEASE, LIB_COMMENT&#xD;&#xA;  FROM QSYSLIBVER&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND LIBRARY  = @library&#xD;&#xA; ORDER BY LIB_VER DESC">
            <QP P="factory" />
            <QP P="library" />
          </QY>
        </SG>
      </F>
      <F _S="87" N="EapWizard">
        <SG _S="88" N="HasModelVer">
          <QY P="MsSql" Q="SELECT MODEL, MDL_SCHEMA&#xD;&#xA;  FROM QSYSMDLVER&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND MODEL  = @model&#xD;&#xA;   AND MDL_VER = @mdl_ver">
            <QP N="factory" />
            <QP N="model" />
            <QP N="mdl_ver" />
          </QY>
        </SG>
        <SG _S="89" N="HasEapAtr">
          <QY P="MsSql" Q="SELECT EAP_SCHEMA&#xD;&#xA;  FROM QRASEAPATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP           = @eap&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
          </QY>
        </SG>
      </F>
      <F _S="90" N="EapSelector">
        <SG _S="91" N="ListServer">
          <QY P="MsSql" Q="SELECT SERVER, SVR_DESC, SVR_IP, UP_DOWN, STATUS, EXPLOG_AGENT_PORT&#xD;&#xA;  FROM QSYSSVRDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY SERVER">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="92" N="ListPackage">
          <QY P="MsSql" Q="SELECT A.PACKAGE, A.PKG_DESC, B.PKG_VER, B.PKG_VER_DESC, B.PKG_RELEASE&#xD;&#xA;  FROM QSYSPKGDEF A&#xD;&#xA;  LEFT JOIN QSYSPKGVER B&#xD;&#xA;    ON A.FACTORY = B.FACTORY&#xD;&#xA;   AND A.PACKAGE = B.PACKAGE&#xD;&#xA; WHERE A.FACTORY = @factory&#xD;&#xA; ORDER BY A.PACKAGE, B.PKG_VER DESC">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="93" N="ListModel">
          <QY P="MsSql" Q="SELECT A.MODEL, A.MDL_DESC, B.MDL_VER, B.MDL_VER_DESC, B.MDL_RELEASE&#xD;&#xA;  FROM QSYSMDLDEF A&#xD;&#xA;  LEFT JOIN QSYSMDLVER B&#xD;&#xA;    ON A.FACTORY = B.FACTORY&#xD;&#xA;   AND A.MODEL   = B.MODEL&#xD;&#xA; WHERE A.FACTORY = @factory&#xD;&#xA; ORDER BY A.MODEL, B.MDL_VER DESC">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="94" N="ListLibrary">
          <QY P="MsSql" Q="SELECT A.LIBRARY, A.LIB_DESC, B.LIB_VER, B.LIB_VER_DESC, B.LIB_RELEASE&#xD;&#xA;  FROM QSYSLIBDEF A&#xD;&#xA;  LEFT JOIN QSYSLIBVER B&#xD;&#xA;    ON A.FACTORY   = B.FACTORY&#xD;&#xA;   AND A.LIBRARY   = B.LIBRARY&#xD;&#xA; WHERE A.FACTORY   = @factory&#xD;&#xA; ORDER BY A.LIBRARY, B.LIB_VER DESC">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="95" N="ListEap">
          <QY P="MsSql" Q="SELECT A.EAP, A.EAP_DESC, A.EAP_TYPE, A.SERVER, A.STEP, A.UP_DOWN, A.STATUS, A.NEED_ACTION, A.NEXT_NEED_ACTION,&#xD;&#xA;       ISNULL(B.PACKAGE, 'N/A') AS PACKAGE, ISNULL(B.PKG_VER, 0) AS PKG_VER, &#xD;&#xA;	   ISNULL(B.MODEL, 'N/A') AS MODEL, ISNULL(B.MDL_VER, 0) AS MDL_VER, &#xD;&#xA;	   ISNULL(B.LIBRARY, 'N/A') AS LIBRARY, ISNULL(B.LIB_VER, 0) AS LIB_VER&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP           = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP           = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'    &#xD;&#xA;   AND A.SERVER        = ISNULL(@server, A.SERVER) &#xD;&#xA;   AND ( &#xD;&#xA;       (B.PACKAGE      = ISNULL(@package, B.PACKAGE) AND B.PKG_VER = ISNULL(@pkg_ver, B.PKG_VER))&#xD;&#xA;    OR (C.PACKAGE      = ISNULL(@package, C.PACKAGE) AND C.PKG_VER = ISNULL(@pkg_ver, C.PKG_VER))&#xD;&#xA;    OR (D.PACKAGE      = ISNULL(@package, D.PACKAGE) AND D.PKG_VER = ISNULL(@pkg_ver, D.PKG_VER))&#xD;&#xA;       )&#xD;&#xA;   AND (&#xD;&#xA;       (B.MODEL        = ISNULL(@model, B.MODEL) AND B.MDL_VER = ISNULL(@mdl_ver, B.MDL_VER))&#xD;&#xA;    OR (C.MODEL        = ISNULL(@model, C.MODEL) AND C.MDL_VER = ISNULL(@mdl_ver, C.MDL_VER))&#xD;&#xA;    OR (D.MODEL        = ISNULL(@model, D.MODEL) AND D.MDL_VER = ISNULL(@mdl_ver, D.MDL_VER))&#xD;&#xA;       )&#xD;&#xA;   AND (&#xD;&#xA;       (B.LIBRARY = ISNULL(@library, B.LIBRARY) AND B.LIB_VER = ISNULL(@lib_ver, B.LIB_VER))&#xD;&#xA;    OR (C.LIBRARY = ISNULL(@library, C.LIBRARY) AND C.LIB_VER = ISNULL(@lib_ver, C.LIB_VER))&#xD;&#xA;    OR (D.LIBRARY = ISNULL(@library, D.LIBRARY) AND D.LIB_VER = ISNULL(@lib_ver, D.LIB_VER))&#xD;&#xA;       )&#xD;&#xA; ORDER BY A.EAP">
            <QP N="factory" />
            <QP N="server" />
            <QP N="package" />
            <QP N="pkg_ver" />
            <QP N="model" />
            <QP N="mdl_ver" />
            <QP N="library" />
            <QP N="lib_ver" />
          </QY>
        </SG>
        <SG _S="96" N="ListAllEap">
          <QY P="MsSql" Q="SELECT EAP, EAP_DESC, UP_DOWN, STATUS, DELETE_FLAG&#xD;&#xA;  FROM QRASEAPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND DELETE_FLAG = ISNULL(@delete_flag, DELETE_FLAG)&#xD;&#xA; ORDER BY EAP">
            <QP N="factory" />
            <QP N="delete_flag" />
          </QY>
        </SG>
        <SG _S="97" N="SearchEap">
          <QY P="MsSql" Q="SELECT A.SERVER, B.PACKAGE, B.MODEL, B.COMPONENT&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'&#xD;&#xA;   AND A.EAP           LIKE @eap&#xD;&#xA; ORDER BY &#xD;&#xA; (CASE @target&#xD;&#xA;  WHEN 'Server'    THEN A.SERVER&#xD;&#xA;  WHEN 'Package'   THEN B.PACKAGE&#xD;&#xA;  WHEN 'Model'     THEN B.MODEL&#xD;&#xA;  WHEN 'Component' THEN B.COMPONENT&#xD;&#xA;   END)">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="target" />
          </QY>
        </SG>
      </F>
      <F _S="98" N="SubEquipmentSelector">
        <SG _S="99" N="ListEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME, EQP_ID, EQP_DESC &#xD;&#xA;   FROM QRASEQPDEF&#xD;&#xA;  WHERE FACTORY = @factory&#xD;&#xA;    AND EQP_CLASS = 'InlineSub'&#xD;&#xA;    AND DELETE_FLAG = 'N'&#xD;&#xA;  ORDER BY EQP_NAME">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="100" N="EventSelector">
        <SG _S="101" N="ListEapEvent">
          <QY P="MsSql" Q="SELECT EVENT_ID, EVENT_DESC&#xD;&#xA;  FROM QRASEAPEVT&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY EVENT_ID">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="102" N="ListEquipmentEvent" D="ADM Only">
          <QY P="MsSql" Q="SELECT EVENT_ID, EVENT_DESC&#xD;&#xA;  FROM QRASEQPEVT&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND SYSTEM  = 'ADM'&#xD;&#xA; ORDER BY EVENT_ID">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="103" N="ListServerEvent">
          <QY P="MsSql" Q="SELECT EVENT_ID, EVENT_DESC&#xD;&#xA;  FROM QSYSSVREVT&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY EVENT_ID">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="104" N="EquipmentSelector_Bak">
        <SG _S="105" N="ListEquipmentType">
          <QY P="MsSql" Q="SELECT TYPE, TYPE_DESC&#xD;&#xA;  FROM QRASEQPTYP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY TYPE">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="106" N="ListEquipmentArea">
          <QY P="MsSql" Q="SELECT AREA, AREA_DESC&#xD;&#xA;  FROM QRASEQPARE&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA; ORDER BY AREA">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="107" N="ListEquipmentLine">
          <QY P="MsSql" Q="SELECT LINE, LINE_DESC&#xD;&#xA;  FROM QRASEQPLIN&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY LINE">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="108" N="ListEquipment">
          <QY P="MsSql" Q="SELECT A.EQP_NAME, B.EQP_DESC, A.CTRL_MODE, A.MDLN, A.SOFTREV,&#xD;&#xA;        ISNULL(C.EAP,'N/A'), ISNULL(C.SERVER,'N/A'), ISNULL(C.UP_DOWN,'N/A'), ISNULL(C.STATUS, 'N/A'),&#xD;&#xA;        D.PACKAGE, D.PKG_VER, D.MODEL, D.MDL_VER, D.USED_COM, D.COMPONENT, D.COM_VER, A.CMF_5 AS PLC_IP_ADDRESS&#xD;&#xA;  FROM QRASEQPDEF A&#xD;&#xA;  LEFT JOIN QRASEQPATR B&#xD;&#xA;   ON A.FACTORY  = B.FACTORY&#xD;&#xA;  AND A.EQP_NAME = B.EQP_NAME&#xD;&#xA;  AND B.ATTR_CATEGORY = 'Applied'&#xD;&#xA; LEFT JOIN QRASEAPDEF C&#xD;&#xA;   ON A.FACTORY = C.FACTORY&#xD;&#xA;  AND B.EAP     = C.EAP&#xD;&#xA; LEFT JOIN QRASEAPATR D&#xD;&#xA;   ON A.FACTORY = D.FACTORY&#xD;&#xA;  AND B.EAP     = D.EAP&#xD;&#xA;  AND D.ATTR_CATEGORY = 'Applied'&#xD;&#xA;WHERE A.FACTORY = @factory&#xD;&#xA;  AND (A.TYPE         = @type OR&#xD;&#xA;        A.AREA        = @area OR&#xD;&#xA;        A.LINE        = @line)&#xD;&#xA;  AND A.DELETE_FLAG   &lt;&gt; 'Y'&#xD;&#xA;ORDER BY A.EQP_NAME">
            <QP N="factory" />
            <QP N="type" />
            <QP N="area" />
            <QP N="line" />
          </QY>
        </SG>
        <SG _S="109" N="ListAllEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME, EQP_DESC, CTRL_MODE, DELETE_FLAG&#xD;&#xA;  FROM QRASEQPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND DELETE_FLAG = ISNULL(@delete_flag, DELETE_FLAG)&#xD;&#xA; ORDER BY EQP_NAME">
            <QP N="factory" />
            <QP N="delete_flag" />
          </QY>
        </SG>
        <SG _S="110" N="SearchEquipment">
          <QY P="MsSql" Q="SELECT A.TYPE, A.AREA, A.LINE&#xD;&#xA;  FROM QRASEQPDEF A&#xD;&#xA;  LEFT JOIN QRASEQPATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EQP_NAME      = B.EQP_NAME&#xD;&#xA;  LEFT JOIN QRASEAPDEF C&#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND B.EAP           = C.EAP&#xD;&#xA;  LEFT JOIN QRASEAPATR D&#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND B.EAP           = D.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = D.ATTR_CATEGORY &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Applied'&#xD;&#xA;   AND A.EQP_NAME      LIKE @eqpName&#xD;&#xA;   AND A.DELETE_FLAG   &lt;&gt; 'Y'&#xD;&#xA; ORDER BY &#xD;&#xA; (CASE @target&#xD;&#xA;  WHEN 'Type'  THEN A.TYPE&#xD;&#xA;  WHEN 'Area'  THEN A.AREA&#xD;&#xA;  WHEN 'Line'  THEN A.LINE&#xD;&#xA;   END)">
            <QP N="factory" />
            <QP N="eqpName" />
            <QP N="target" />
          </QY>
        </SG>
      </F>
      <F _S="111" N="EquipmentSelector">
        <SG _S="112" N="ListEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME, EQP_DESC, DELETE_FLAG, IP_ADDRESS&#xD;&#xA;  FROM QRASEQPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND DELETE_FLAG = ISNULL(@delete_flag, DELETE_FLAG)&#xD;&#xA; ORDER BY EQP_NAME">
            <QP N="factory" />
            <QP N="delete_flag" />
          </QY>
        </SG>
      </F>
      <F _S="113" N="EquipmentEapSelector">
        <SG _S="114" N="ListEquipment">
          <QY P="MsSql" Q="SELECT D.EQP_NAME, F.EAP, D.EQP_DESC, D.DELETE_FLAG&#xD;&#xA;FROM QRASEQPDEF D&#xD;&#xA;LEFT JOIN QRASEAPCFG F ON    &#xD;&#xA;	F.OBJ_TYPE = 'CONTROLLER'&#xD;&#xA;	AND F.ATTR_CATEGORY = 'Applied'&#xD;&#xA;	AND F.DATA = D.EQP_NAME&#xD;&#xA; WHERE D.FACTORY = @factory &#xD;&#xA;       AND D.DELETE_FLAG = ISNULL(@delete_flag, D.DELETE_FLAG)&#xD;&#xA;	AND F.EAP IS NOT NULL&#xD;&#xA; ORDER BY D.EQP_NAME;">
            <QP N="factory" />
            <QP N="delete_flag" />
          </QY>
        </SG>
      </F>
      <F _S="115" N="EquipmentTypeSelector">
        <SG _S="116" N="ListEquipmentType">
          <QY P="MsSql" Q="SELECT TYPE, TYPE_DESC&#xD;&#xA;  FROM QRASEQPTYP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY TYPE">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="117" N="EquipmentAreaSelector">
        <SG _S="118" N="ListEquipmentArea">
          <QY P="MsSql" Q="SELECT AREA, AREA_DESC&#xD;&#xA;  FROM QRASEQPARE&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY AREA">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="119" N="EquipmentLineSelector">
        <SG _S="120" N="ListEquipmentLine">
          <QY P="MsSql" Q="SELECT LINE, LINE_DESC&#xD;&#xA;  FROM QRASEQPLIN&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY LINE">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="121" N="EquipmentMapVersionSelector">
        <SG _S="122" N="ListEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME, EQP_DESC&#xD;&#xA;  FROM QRASEQPDEF&#xD;&#xA; WHERE FACTORY     = @factory &#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="123" N="ListMapVersion">
          <QY P="MsSql" Q="SELECT MAP_VER,	MAP_VER_COMMENT&#xD;&#xA;  FROM QRASMAPVER&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EQP_NAME = @eqp_name">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="124" N="SearchMapData">
          <QY P="MsSql" Q="SELECT MAP_DAT_SEQ, MAP_DAT_CATEGORY, MAP_DAT_ITEM, MAP_DAT_ITEM_DESC,&#xD;&#xA;       MAP_DAT_REGISTER, MAP_DAT_ADDRESS, MAP_DAT_FULL_ADDRESS,&#xD;&#xA;	   MAP_DAT_TYPE, MAP_DAT_FORMAT, MAP_DAT_LENGTH,&#xD;&#xA;	   MAP_DAT_CONVERSION, MAP_DAT_REMARK&#xD;&#xA;  FROM QRASMAPDAT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND MAP_VER  = @map_ver">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="map_ver" />
          </QY>
        </SG>
      </F>
      <F _S="125" N="ServerResourceHistoryViewer">
        <SG _S="126" N="SearchManagementRate">
          <QY P="MsSql" Q="SELECT SVR_CPU_CAUTION_RATE, SVR_CPU_DANGER_RATE, &#xD;&#xA;       SVR_MEMORY_CAUTION_RATE, SVR_MEMORY_DANGER_RATE,&#xD;&#xA;       SVR_DISK_CAUTION_RATE, SVR_DISK_DANGER_RATE&#xD;&#xA;  FROM QSYSFACDEF&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="127" N="SearchCpuHistory">
          <QY P="MsSql" Q="SELECT TRAN_TIME, CPU_USAGE&#xD;&#xA;  FROM QSYSSVRRHI&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TRAN_TIME  &gt;= @tran_from_time&#xD;&#xA;   AND TRAN_TIME  &lt;= @tran_to_time&#xD;&#xA;   AND SERVER      = @server &#xD;&#xA; ORDER BY TRAN_TIME">
            <QP N="factory" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
            <QP N="server" />
          </QY>
        </SG>
        <SG _S="128" N="SearchMemoryHistory">
          <QY P="MsSql" Q="SELECT A.TRAN_TIME, B.MEMORY, A.MEMORY_USAGE&#xD;&#xA;  FROM QSYSSVRRHI A &#xD;&#xA;  LEFT JOIN QSYSSVRDEF B&#xD;&#xA;    ON A.FACTORY     = B.FACTORY&#xD;&#xA;   AND A.SERVER      = B.SERVER&#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.TRAN_TIME  &gt;= @tran_from_time&#xD;&#xA;   AND A.TRAN_TIME  &lt;= @tran_to_time&#xD;&#xA;   AND A.SERVER      = @server&#xD;&#xA; ORDER BY A.TRAN_TIME">
            <QP N="factory" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
            <QP N="server" />
          </QY>
        </SG>
        <SG _S="129" N="SearchDiskHistory">
          <QY P="MsSql" Q="SELECT A.TRAN_TIME, A.SERVER,&#xD;&#xA;       B.DISK_1, B.DISK_1_SIZE, A.DISK_1_USAGE,&#xD;&#xA;       B.DISK_2, B.DISK_2_SIZE, A.DISK_2_USAGE,&#xD;&#xA;       B.DISK_3, B.DISK_3_SIZE, A.DISK_3_USAGE,&#xD;&#xA;       B.DISK_4, B.DISK_4_SIZE, A.DISK_4_USAGE,&#xD;&#xA;       B.DISK_5, B.DISK_5_SIZE, A.DISK_5_USAGE,&#xD;&#xA;       B.DISK_6, B.DISK_6_SIZE, A.DISK_6_USAGE,&#xD;&#xA;       B.DISK_7, B.DISK_7_SIZE, A.DISK_7_USAGE,&#xD;&#xA;       B.DISK_8, B.DISK_8_SIZE, A.DISK_8_USAGE,&#xD;&#xA;       B.DISK_9, B.DISK_9_SIZE, A.DISK_9_USAGE,&#xD;&#xA;       B.DISK_10, B.DISK_10_SIZE, A.DISK_10_USAGE&#xD;&#xA;  FROM QSYSSVRRHI A &#xD;&#xA;  LEFT JOIN QSYSSVRDEF B&#xD;&#xA;    ON A.FACTORY     = B.FACTORY&#xD;&#xA;   AND A.SERVER      = B.SERVER&#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.TRAN_TIME  &gt;= @tran_from_time&#xD;&#xA;   AND A.TRAN_TIME  &lt;= @tran_to_time&#xD;&#xA;   AND A.SERVER      = @server&#xD;&#xA; ORDER BY A.TRAN_TIME">
            <QP N="factory" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
            <QP N="server" />
          </QY>
        </SG>
      </F>
      <F _S="130" N="EapNameSelector">
        <SG _S="131" N="ListEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME, EQP_DESC&#xD;&#xA;  FROM QRASEQPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND DELETE_FLAG = ISNULL(@delete_flag, DELETE_FLAG)&#xD;&#xA; ORDER BY EQP_NAME">
            <QP N="factory" />
            <QP N="delete_flag" />
          </QY>
        </SG>
      </F>
      <F _S="132" N="UserSelector">
        <SG _S="133" N="SearchUserList">
          <QY P="MsSql" Q="SELECT USER_ID, USER_DESC&#xD;&#xA;  FROM QSECUSRDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY USER_ID">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="134" N="DataHoundSelector">
        <SG _S="135" N="ListDataHound">
          <QY P="MsSql" Q="SELECT NAME, EAP, SERVER_IP, SERVER_PORT&#xD;&#xA;  FROM QSYSDHDDEF  &#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; 	AND STATUS = 'SUCCESS'&#xD;&#xA; 	AND TYPE = @type&#xD;&#xA;   ORDER BY NAME">
            <QP N="factory" />
            <QP N="type" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
      </F>
      <F _S="136" N="CustomRemoteCommandSelector">
        <SG _S="137" N="ListCustomRemoteCommand">
          <QY P="MsSql" Q="SELECT COMMAND, CMD_DESC, CREATE_TIME&#xD;&#xA;  FROM QRASCUSRCM&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY COMMAND&#xD;&#xA;">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="138" N="ModelPlcTagSelector">
        <SG _S="139" N="ListModelPlcTag">
          <QY P="MsSql" Q="SELECT MODEL, MDL_VER, CNT_NAME, SSN_NAME, TAG_NAME, TAG_DESC, PLC_TAG_ADDR, PLC_TAG_TYPE, PLC_TAG_FORMAT, PLC_TAG_ARRAY, PLC_TAG_ALARM&#xD;&#xA;  FROM QRASMDLPTG&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY MODEL, MDL_VER, CNT_NAME, SSN_NAME, TAG_NAME">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="140" N="BranchReferenceEquipmentVersionSelector">
        <SG _S="141" N="ListEquipment">
          <QY P="MsSql" Q="SELECT A.EQP_NAME, ISNULL(B.EQP_DESC, ' ') AS EQP_DESC, A.ACTIVE_VER, A.APPLIED_VER, A.LAST_VER&#xD;&#xA;  FROM QEMSIBNEQP A&#xD;&#xA;  LEFT JOIN QRASEQPDEF B&#xD;&#xA;    ON A.FACTORY     = B.FACTORY&#xD;&#xA;   AND A.EQP_NAME    = B.EQP_NAME&#xD;&#xA;   AND B.DELETE_FLAG = 'N'&#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.IBN_NAME    = @ibn_name&#xD;&#xA; ORDER BY A.EQP_NAME ">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
        <SG _S="142" N="ListVersion">
          <QY P="MsSql" Q="SELECT TAGSET_VER, TAGSET_VER_DESC, ACTIVE, BUILD_MDL, BUILD_MDL_VER&#xD;&#xA;  FROM QEMSIBNVER&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND IBN_NAME  = @ibn_name&#xD;&#xA;   AND EQP_NAME  = @eqp_name&#xD;&#xA; ORDER BY TAGSET_VER DESC">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="143" N="ListBranch">
          <QY P="MsSql" Q="SELECT IBN_NAME, IBN_DESC, BROKER, TOPIC&#xD;&#xA;  FROM QEMSIBNDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY IBN_NAME">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="144" N="BranchV2ReferenceEquipmentVersionSelector">
        <SG _S="145" N="ListBranch">
          <QY P="MsSql" Q="SELECT IBN_NAME, IBN_DESC, PROTOCOL&#xD;&#xA;  FROM QEMSIBNDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY IBN_NAME">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="146" N="ListEquipment">
          <QY P="MsSql" Q="SELECT A.EQP_NAME, ISNULL(B.EQP_DESC, ' ') AS EQP_DESC, A.ACTIVE_VER, A.APPLIED_VER, A.LAST_VER&#xD;&#xA;  FROM QEMSIBNEQP A&#xD;&#xA;  LEFT JOIN QRASEQPDEF B&#xD;&#xA;    ON A.FACTORY     = B.FACTORY&#xD;&#xA;   AND A.EQP_NAME    = B.EQP_NAME&#xD;&#xA;   AND B.DELETE_FLAG = 'N'&#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.IBN_NAME    = @ibn_name&#xD;&#xA; ORDER BY A.EQP_NAME ">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
        <SG _S="147" N="ListVersion">
          <QY P="MsSql" Q="SELECT EQP_TAGSET_VER, EQP_TAGSET_VER_DESC, ACTIVE, PTM_TAGSET_GROUP, PTM_TAGSET_NAME, PTM_TAGSET_VER&#xD;&#xA;  FROM CEMSIBNVER&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND IBN_NAME  = @ibn_name&#xD;&#xA;   AND EQP_NAME  = @eqp_name&#xD;&#xA; ORDER BY EQP_TAGSET_VER DESC">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
          </QY>
        </SG>
      </F>
      <F _S="148" N="BranchEquipmentSelector">
        <SG _S="149" N="ListBranch">
          <QY P="MsSql" Q="SELECT IBN_NAME, IBN_DESC&#xD;&#xA;  FROM QEMSIBNDEF &#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA; ORDER BY IBN_NAME">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="150" N="ListEquipment">
          <QY P="MsSql" Q="SELECT IBN.EQP_NAME, ISNULL(EQP.EQP_DESC, ' ') EQP_DESC, IBN.IBN_NAME, IBN.ENABLE, IBN.NEED_ACTION, IBN.ACTIVE_VER, IBN.APPLIED_VER, IBN.LAST_VER&#xD;&#xA;  FROM QEMSIBNEQP IBN&#xD;&#xA;  LEFT JOIN QRASEQPDEF EQP&#xD;&#xA;    ON IBN.FACTORY  = EQP.FACTORY&#xD;&#xA;   AND IBN.EQP_NAME =  EQP.EQP_NAME&#xD;&#xA; WHERE IBN.FACTORY  = @factory&#xD;&#xA;   AND IBN.IBN_NAME = ISNULL(@ibn_name, IBN.IBN_NAME)&#xD;&#xA; ORDER BY IBN.EQP_NAME">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
      </F>
      <F _S="1267" N="DatasetEquipmentSelector">
        <SG _S="1268" N="ListDataset">
          <QY P="MsSql" Q="SELECT A.IBN_NAME, B.IBN_DESC&#xD;&#xA;  FROM QEMSIBNEQP A &#xD;&#xA;   LEFT JOIN QEMSIBNDEF B ON&#xD;&#xA;   A.FACTORY = B.FACTORY&#xD;&#xA;   AND A.IBN_NAME = B.IBN_NAME    &#xD;&#xA; WHERE A.FACTORY  = @factory&#xD;&#xA;  AND A.EQP_NAME = @eqp_name&#xD;&#xA;  AND B.TYPE = 'DataSet'&#xD;&#xA;  AND B.PROTOCOL = 'SQLite'&#xD;&#xA; ORDER BY A.IBN_NAME">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="1269" N="ListEquipment">
          <QY P="MsSql" Q="SELECT DISTINCT A.EQP_NAME, ISNULL(B.EQP_DESC, ' ') EQP_DESC&#xD;&#xA;  FROM QEMSIBNEQP A&#xD;&#xA;  LEFT JOIN QRASEQPDEF B&#xD;&#xA;    ON A.FACTORY  = B.FACTORY&#xD;&#xA;   AND A.EQP_NAME =  B.EQP_NAME&#xD;&#xA;  LEFT JOIN QEMSIBNDEF C&#xD;&#xA;    ON A.FACTORY  = C.FACTORY&#xD;&#xA;   AND A.IBN_NAME =  C.IBN_NAME&#xD;&#xA;   AND C.TYPE = 'DataSet'&#xD;&#xA;   AND C.PROTOCOL = 'SQLite'&#xD;&#xA; WHERE A.FACTORY  = @factory&#xD;&#xA;   AND C.IBN_NAME IS NOT NULL&#xD;&#xA; ORDER BY A.EQP_NAME">
            <QP N="factory" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
      </F>
      <F _S="151" N="DeviceSelector">
        <SG _S="152" N="ListDevice">
          <QY P="MsSql" Q="SELECT DVC_ID, DVC_DESC, IP_ADDRESS, MAC_ADDRESS, DOMAIN, COMPUTER_NAME, MANUFACTURER, MODEL&#xD;&#xA;  FROM QEMSDVCDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY DVC_ID">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="153" N="PlcTagSetGroupSelector">
        <SG _S="154" N="ListPlcTagSetGroup">
          <QY P="MsSql" Q="SELECT GROUP_NAME, GROUP_DESC&#xD;&#xA;  FROM QSYSPTMGRP&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="155" N="PlcTagSetSelector">
        <SG _S="156" N="ListPlcTagSet">
          <QY P="MsSql" Q="SELECT TAGSET_NAME, TAGSET_DESC&#xD;&#xA;  FROM QSYSPTMDEF&#xD;&#xA; WHERE FACTORY     = @factory   &#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA; ORDER BY TAGSET_NAME">
            <QP N="factory" />
            <QP N="tagset_group" />
          </QY>
        </SG>
      </F>
      <F _S="157" N="PlcTagSetVerSelector">
        <SG _S="158" N="ListPlcTagSetVer">
          <QY P="MsSql" Q="SELECT VER.TAGSET_VER, VER.TAGSET_VER_DESC,&#xD;&#xA;       VER.CREATE_TIME, CASE WHEN USER_C.USER_NAME IS NULL THEN VER.CREATE_USER_ID ELSE CONCAT(VER.CREATE_USER_ID, ' [', USER_C.USER_NAME, ']') END AS CREATE_USER , &#xD;&#xA;	   VER.UPDATE_TIME, CASE WHEN USER_U.USER_NAME IS NULL THEN VER.UPDATE_USER_ID ELSE CONCAT(VER.UPDATE_USER_ID, ' [', USER_U.USER_NAME, ']') END AS UPDATE_USER&#xD;&#xA;  FROM (&#xD;&#xA;SELECT FACTORY, TAGSET_VER, TAGSET_VER_DESC, CREATE_TIME, CREATE_USER_ID, UPDATE_TIME, UPDATE_USER_ID&#xD;&#xA;  FROM QSYSPTMVER&#xD;&#xA; WHERE FACTORY      = @factory   &#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME  = @tagset_name&#xD;&#xA;   AND DELETE_FLAG  = 'N'&#xD;&#xA;       ) VER&#xD;&#xA;  LEFT JOIN QSECUSRDEF USER_C&#xD;&#xA;    ON VER.FACTORY        = USER_C.FACTORY&#xD;&#xA;   AND VER.CREATE_USER_ID = USER_C.USER_ID&#xD;&#xA;  LEFT JOIN QSECUSRDEF USER_U&#xD;&#xA;    ON VER.FACTORY        = USER_U.FACTORY&#xD;&#xA;   AND VER.UPDATE_USER_ID = USER_U.USER_ID&#xD;&#xA; ORDER BY VER.TAGSET_VER DESC">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
          </QY>
        </SG>
      </F>
      <F _S="159" N="PlcModelSelector">
        <SG _S="160" N="ListPlcModel">
          <QY P="MsSql" Q="SELECT PLC_MAKER, PLC_MODEL&#xD;&#xA;  FROM QSYSPTMMPS&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY PLC_MAKER, PLC_MODEL">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="161" N="PlcPresetSelectorEx">
        <SG _S="162" N="ListPresetGroup">
          <QY P="MsSql" Q="SELECT PRESET_GROUP, PRESET_GROUP_DESC&#xD;&#xA;  FROM QSYSPTMPRG&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY PRESET_GROUP">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="163" N="ListPreset">
          <QY P="MsSql" Q="SELECT PRESET_GROUP, PRESET_NAME, PRESET_DESC, PRESET_PLC_MAKER, PRESET_PLC_MODEL, ALLOW_EMPTY_ADDRESS, IS_ALARM&#xD;&#xA;  FROM QSYSPTMPRS&#xD;&#xA; WHERE FACTORY          = @factory&#xD;&#xA;   AND PRESET_GROUP     = ISNULL(@preset_group, PRESET_GROUP)&#xD;&#xA;   AND PRESET_PLC_MAKER = @preset_plc_maker&#xD;&#xA;   AND PRESET_PLC_MODEL = @preset_plc_model">
            <QP N="factory" />
            <QP N="preset_group" />
            <QP N="preset_plc_maker" />
            <QP N="preset_plc_model" />
          </QY>
        </SG>
      </F>
      <F _S="164" N="PlcPresetSelectorWz">
        <SG _S="165" N="ListPresetGroup">
          <QY P="MsSql" Q="SELECT PRESET_GROUP, PRESET_GROUP_DESC&#xD;&#xA;  FROM QSYSPTMPRG&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY PRESET_GROUP">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="166" N="ListPreset">
          <QY P="MsSql" Q="SELECT PRESET_NAME, PRESET_DESC, PRESET_PLC_MAKER, PRESET_PLC_MODEL, ALLOW_EMPTY_ADDRESS, IS_ALARM&#xD;&#xA;  FROM QSYSPTMPRS&#xD;&#xA; WHERE FACTORY          = @factory&#xD;&#xA;   AND PRESET_GROUP     = @preset_group&#xD;&#xA;   AND PRESET_PLC_MAKER = ISNULL(@preset_plc_maker, PRESET_PLC_MAKER)&#xD;&#xA;   AND PRESET_PLC_MODEL = ISNULL(@preset_plc_model, PRESET_PLC_MODEL)">
            <QP N="factory" />
            <QP N="preset_group" />
            <QP N="preset_plc_maker" />
            <QP N="preset_plc_model" />
          </QY>
        </SG>
      </F>
      <F _S="167" N="PlcTagSetSelectorEx">
        <SG _S="168" N="ListPlcTagSetGroup">
          <QY P="MsSql" Q="SELECT GROUP_NAME, GROUP_DESC&#xD;&#xA;  FROM QSYSPTMGRP&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="169" N="SearchLastPlcTagSetVersion">
          <QY P="MsSql" Q="SELECT ISNULL(V.TAGSET_VER, 0) AS TAGSET_VER, &#xD;&#xA;       ISNULL(V.TAGSET_VER_DESC, ' ') AS TAGSET_VER_DESC&#xD;&#xA;  FROM &#xD;&#xA;     (&#xD;&#xA;SELECT TOP (1) TAGSET_VER, TAGSET_VER_DESC&#xD;&#xA;  FROM QSYSPTMVER&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME  = @tagset_name&#xD;&#xA;   AND DELETE_FLAG  = 'N'&#xD;&#xA; ORDER BY TAGSET_VER DESC&#xD;&#xA;     ) AS V">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
          </QY>
        </SG>
        <SG _S="170" N="ListPlcTagSet">
          <QY P="MsSql" Q="SELECT TAGSET_GROUP, TAGSET_NAME, TAGSET_DESC, TAGSET_PLC_MAKER, TAGSET_PLC_MODEL&#xD;&#xA;  FROM QSYSPTMDEF&#xD;&#xA; WHERE FACTORY          = @factory&#xD;&#xA;   AND TAGSET_GROUP     = ISNULL(@tagset_group, TAGSET_GROUP)&#xD;&#xA;   AND TAGSET_PLC_MAKER = ISNULL(@tagset_plc_maker, TAGSET_PLC_MAKER)&#xD;&#xA;   AND TAGSET_PLC_MODEL = ISNULL(@tagset_plc_model, TAGSET_PLC_MODEL)">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_plc_maker" />
            <QP N="tagset_plc_model" />
          </QY>
        </SG>
        <SG _S="171" N="ListPlcTagSetVersion">
          <QY P="MsSql" Q="SELECT VER.TAGSET_VER, VER.TAGSET_VER_DESC,&#xD;&#xA;       VER.CREATE_TIME, CASE WHEN USER_C.USER_NAME IS NULL THEN VER.CREATE_USER_ID ELSE CONCAT(VER.CREATE_USER_ID, ' [', USER_C.USER_NAME, ']') END AS CREATE_USER , &#xD;&#xA;	   VER.UPDATE_TIME, CASE WHEN USER_U.USER_NAME IS NULL THEN VER.UPDATE_USER_ID ELSE CONCAT(VER.UPDATE_USER_ID, ' [', USER_U.USER_NAME, ']') END AS UPDATE_USER&#xD;&#xA;  FROM (&#xD;&#xA;SELECT FACTORY, TAGSET_VER, TAGSET_VER_DESC, CREATE_TIME, CREATE_USER_ID, UPDATE_TIME, UPDATE_USER_ID&#xD;&#xA;  FROM QSYSPTMVER&#xD;&#xA; WHERE FACTORY      = @factory   &#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME  = @tagset_name&#xD;&#xA;   AND DELETE_FLAG  = 'N'&#xD;&#xA;       ) VER&#xD;&#xA;  LEFT JOIN QSECUSRDEF USER_C&#xD;&#xA;    ON VER.FACTORY        = USER_C.FACTORY&#xD;&#xA;   AND VER.CREATE_USER_ID = USER_C.USER_ID&#xD;&#xA;  LEFT JOIN QSECUSRDEF USER_U&#xD;&#xA;    ON VER.FACTORY        = USER_U.FACTORY&#xD;&#xA;   AND VER.UPDATE_USER_ID = USER_U.USER_ID&#xD;&#xA; ORDER BY VER.TAGSET_VER DESC">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
          </QY>
        </SG>
      </F>
      <F _S="172" N="PlcTagSetSelectorWz">
        <SG _S="173" N="ListPlcTagSetGroup">
          <QY P="MsSql" Q="SELECT GROUP_NAME, GROUP_DESC&#xD;&#xA;  FROM QSYSPTMGRP&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="174" N="ListPlcTagSet">
          <QY P="MsSql" Q="SELECT TAGSET_NAME, TAGSET_DESC, TAGSET_PLC_MAKER, TAGSET_PLC_MODEL&#xD;&#xA;  FROM QSYSPTMDEF&#xD;&#xA; WHERE FACTORY          = @factory&#xD;&#xA;   AND TAGSET_GROUP     = @tagset_group&#xD;&#xA;   AND TAGSET_PLC_MAKER = ISNULL(@tagset_plc_maker, TAGSET_PLC_MAKER)&#xD;&#xA;   AND TAGSET_PLC_MODEL = ISNULL(@tagset_plc_model, TAGSET_PLC_MODEL)">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_plc_maker" />
            <QP N="tagset_plc_model" />
          </QY>
        </SG>
        <SG _S="175" N="ListPlcTagSetVersion">
          <QY P="MsSql" Q="SELECT VER.TAGSET_VER, VER.TAGSET_VER_DESC,&#xD;&#xA;       VER.CREATE_TIME, CASE WHEN USER_C.USER_NAME IS NULL THEN VER.CREATE_USER_ID ELSE CONCAT(VER.CREATE_USER_ID, ' [', USER_C.USER_NAME, ']') END AS CREATE_USER , &#xD;&#xA;	   VER.UPDATE_TIME, CASE WHEN USER_U.USER_NAME IS NULL THEN VER.UPDATE_USER_ID ELSE CONCAT(VER.UPDATE_USER_ID, ' [', USER_U.USER_NAME, ']') END AS UPDATE_USER&#xD;&#xA;  FROM (&#xD;&#xA;SELECT FACTORY, TAGSET_VER, TAGSET_VER_DESC, CREATE_TIME, CREATE_USER_ID, UPDATE_TIME, UPDATE_USER_ID&#xD;&#xA;  FROM QSYSPTMVER&#xD;&#xA; WHERE FACTORY      = @factory   &#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME  = @tagset_name&#xD;&#xA;   AND DELETE_FLAG  = 'N'&#xD;&#xA;       ) VER&#xD;&#xA;  LEFT JOIN QSECUSRDEF USER_C&#xD;&#xA;    ON VER.FACTORY        = USER_C.FACTORY&#xD;&#xA;   AND VER.CREATE_USER_ID = USER_C.USER_ID&#xD;&#xA;  LEFT JOIN QSECUSRDEF USER_U&#xD;&#xA;    ON VER.FACTORY        = USER_U.FACTORY&#xD;&#xA;   AND VER.UPDATE_USER_ID = USER_U.USER_ID&#xD;&#xA; ORDER BY VER.TAGSET_VER DESC">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
          </QY>
        </SG>
      </F>
      <F _S="1211" N="EquipmentPlcTagSelector">
        <SG _S="1212" N="ListPlcTag">
          <QY P="MsSql" Q="WITH RASEQP AS&#xD;&#xA;(&#xD;&#xA;    SELECT FACTORY, EQP_NAME, TYPE&#xD;&#xA;      FROM QRASEQPDEF&#xD;&#xA;     WHERE FACTORY     = @factory&#xD;&#xA;       AND EQP_NAME    = @eqp_name&#xD;&#xA;       AND DELETE_FLAG = 'N'&#xD;&#xA;),&#xD;&#xA;RASTYP AS&#xD;&#xA;(&#xD;&#xA;    SELECT T.FACTORY, T.TYPE, T.PTM_TAGSET_GROUP, T.PTM_TAGSET_NAME&#xD;&#xA;      FROM QRASEQPTYP T&#xD;&#xA;     INNER JOIN RASEQP E&#xD;&#xA;        ON E.FACTORY = T.FACTORY&#xD;&#xA;       AND E.TYPE    = T.TYPE&#xD;&#xA;),&#xD;&#xA;PTMVER AS&#xD;&#xA;(&#xD;&#xA;    SELECT V.FACTORY, V.TAGSET_GROUP, V.TAGSET_NAME, MAX(V.TAGSET_VER) AS LAST_TAGSET_VER&#xD;&#xA;      FROM QSYSPTMVER V&#xD;&#xA;     INNER JOIN RASTYP T&#xD;&#xA;        ON T.FACTORY          = V.FACTORY&#xD;&#xA;       AND T.PTM_TAGSET_GROUP = V.TAGSET_GROUP&#xD;&#xA;       AND T.PTM_TAGSET_NAME  = V.TAGSET_NAME&#xD;&#xA;     WHERE V.DELETE_FLAG = 'N'&#xD;&#xA;     GROUP BY V.FACTORY, V.TAGSET_GROUP, V.TAGSET_NAME&#xD;&#xA;)&#xD;&#xA;SELECT G.TAG_CATEGORY, G.TAG_NAME, G.TAG_DESC, G.TAG_FULL_ADDRESS, G.TAG_INPUT_ADDRESS, G.TAG_FORMAT, G.TAG_PLC_FORMAT&#xD;&#xA;  FROM QSYSPTMTAG G&#xD;&#xA; INNER JOIN PTMVER V&#xD;&#xA;    ON V.FACTORY         = G.FACTORY&#xD;&#xA;   AND V.TAGSET_GROUP    = G.TAGSET_GROUP&#xD;&#xA;   AND V.TAGSET_NAME     = G.TAGSET_NAME&#xD;&#xA;   AND V.LAST_TAGSET_VER = G.TAGSET_VER&#xD;&#xA; WHERE G.FACTORY         = @factory&#xD;&#xA; ORDER BY G.TAG_SEQ, G.TAG_NAME">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
      </F>
      <F _S="1299" N="LogicalTagSelectorExForPLL">
        <SG _S="1301" N="ListLogicalGroup">
          <QY P="MsSql" Q="SELECT LOGICAL_GROUP, LOGICAL_GROUP_DESC&#xD;&#xA;  FROM QSYSPTMLGP&#xD;&#xA; WHERE FACTORY = @factory     &#xD;&#xA; ORDER BY LOGICAL_GROUP">
            <QP N="factory" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="1302" N="ListLogicalTag">
          <QY P="MsSql" Q="SELECT LOGICAL_GROUP, LOGICAL_TAG, LOGICAL_TAG_DESC&#xD;&#xA;  FROM QSYSPTMLGT&#xD;&#xA; WHERE FACTORY       = @factory    &#xD;&#xA;   AND LOGICAL_GROUP = ISNULL(@logical_group, LOGICAL_GROUP)&#xD;&#xA; ORDER BY LOGICAL_TAG">
            <QP N="factory" />
            <QP N="logical_group" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
      </F>
      <F _S="1352" N="LogicalTagSelectorExForLVL">
        <SG _S="1353" N="ListLogicalGroup">
          <QY P="MsSql" Q="SELECT LOGICAL_GROUP, LOGICAL_GROUP_DESC&#xD;&#xA;  FROM QSYSPTMLGP&#xD;&#xA; WHERE FACTORY = @factory     &#xD;&#xA; ORDER BY LOGICAL_GROUP">
            <QP N="factory" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="1354" N="ListLogicalTag">
          <QY P="MsSql" Q="-- 현재 선택된 VID_GROUP의 VID 범위 (RANGE_FROM~RANGE_TO)&#xD;&#xA;WITH CurrentGroupRange AS&#xD;&#xA;(&#xD;&#xA;    SELECT FACTORY, VID_GROUP, CAST(RANGE_FROM AS bigint) AS RANGE_FROM, CAST(RANGE_TO AS bigint) AS RANGE_TO&#xD;&#xA;      FROM QSYSPTMVGP&#xD;&#xA;     WHERE FACTORY     = @factory&#xD;&#xA;       AND VID_GROUP   = @vid_group&#xD;&#xA;       AND RANGE_FROM &lt;= RANGE_TO&#xD;&#xA;),&#xD;&#xA;-- 현재 그룹 범위 안에 이미 등록된 LOGICAL_TAG 목록 (소스의 현재 그룹 필터에서 처리)&#xD;&#xA;LinkedInCurrentGroup AS&#xD;&#xA;(&#xD;&#xA;    SELECT DISTINCT V.FACTORY, V.LOGICAL_TAG&#xD;&#xA;      FROM QSYSPTMVLL V&#xD;&#xA;      JOIN CurrentGroupRange G&#xD;&#xA;        ON G.FACTORY   = V.FACTORY&#xD;&#xA;       AND V.VID       BETWEEN G.RANGE_FROM AND G.RANGE_TO&#xD;&#xA;     WHERE LTRIM(RTRIM(V.LOGICAL_TAG)) &lt;&gt; ''&#xD;&#xA;),&#xD;&#xA;-- 현재 그룹 범위 밖에 등록된 LOGICAL_TAG 목록 (다른 그룹 등록으로 취급하여 제외)&#xD;&#xA;LinkedOutsideCurrentGroup AS&#xD;&#xA;(&#xD;&#xA;    SELECT DISTINCT V.FACTORY, V.LOGICAL_TAG&#xD;&#xA;      FROM QSYSPTMVLL V&#xD;&#xA;      JOIN CurrentGroupRange G&#xD;&#xA;        ON G.FACTORY   = V.FACTORY&#xD;&#xA;     WHERE LTRIM(RTRIM(V.LOGICAL_TAG)) &lt;&gt; ''&#xD;&#xA;       AND V.VID      NOT BETWEEN G.RANGE_FROM AND G.RANGE_TO&#xD;&#xA;)&#xD;&#xA;SELECT L.LOGICAL_GROUP, L.LOGICAL_TAG, L.LOGICAL_TAG_DESC&#xD;&#xA;  FROM QSYSPTMLGT L&#xD;&#xA;  JOIN CurrentGroupRange G&#xD;&#xA;    ON G.FACTORY       = L.FACTORY&#xD;&#xA;  LEFT JOIN LinkedInCurrentGroup C&#xD;&#xA;    ON C.FACTORY       = L.FACTORY&#xD;&#xA;   AND C.LOGICAL_TAG   = L.LOGICAL_TAG&#xD;&#xA;  LEFT JOIN LinkedOutsideCurrentGroup O&#xD;&#xA;    ON O.FACTORY       = L.FACTORY&#xD;&#xA;   AND O.LOGICAL_TAG   = L.LOGICAL_TAG&#xD;&#xA; WHERE L.FACTORY       = @factory&#xD;&#xA;   AND L.LOGICAL_GROUP = ISNULL(@logical_group, LOGICAL_GROUP)&#xD;&#xA;   AND O.LOGICAL_TAG IS NULL&#xD;&#xA; ORDER BY L.LOGICAL_GROUP, L.LOGICAL_TAG">
            <QP N="factory" />
            <QP N="vid_group" />
            <QP N="logical_group" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
      </F>
      <F _S="1310" N="PlcTagSelector">
        <SG _S="1311" N="ListPlcTag">
          <QY P="MsSql" Q="SELECT TAG_CATEGORY, TAG_NAME, TAG_DESC, TAG_REGISTER, TAG_DEC_ADDRESS, TAG_FULL_ADDRESS, TAG_INPUT_ADDRESS,&#xD;&#xA;       TAG_PLC_FORMAT, TAG_FORMAT, TAG_LENGTH, TAG_ALARM, TAG_TYPE, TAG_BRANCH&#xD;&#xA;  FROM QSYSPTMTAG T&#xD;&#xA; WHERE T.FACTORY      = @factory&#xD;&#xA;   AND T.TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND T.TAGSET_NAME  = @tagset_name&#xD;&#xA;   AND T.TAGSET_VER =&#xD;&#xA;   (&#xD;&#xA;      SELECT TOP (1) TAGSET_VER&#xD;&#xA;        FROM QSYSPTMVER&#xD;&#xA;       WHERE FACTORY      = @factory&#xD;&#xA;         AND TAGSET_GROUP = @tagset_group&#xD;&#xA;         AND TAGSET_NAME  = @tagset_name&#xD;&#xA;         AND DELETE_FLAG  = 'N'&#xD;&#xA;       ORDER BY TAGSET_VER DESC&#xD;&#xA;   )&#xD;&#xA; ORDER BY TAG_CATEGORY ASC, TAG_NAME ASC">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
      </F>
      <F _S="1347" N="VariableIdGroupSelector">
        <SG _S="1349" N="ListVariableIdGroup">
          <QY P="MsSql" Q="SELECT VID_GROUP, VID_GROUP_DESC, RANGE_FROM, RANGE_TO, VID_CURSOR&#xD;&#xA;  FROM QSYSPTMVGP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY VID_GROUP">
            <QP N="factory" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
      </F>
      <F _S="1378" N="VariableIdSelectorExForPVL">
        <SG _S="1379" N="ListVariableId">
          <QY P="MsSql" Q=";WITH TB_GRP AS&#xD;&#xA;(&#xD;&#xA;    -- 조회 대상 VID 그룹 범위 목록&#xD;&#xA;    SELECT DISTINCT VID_GROUP,&#xD;&#xA;           RANGE_FROM,&#xD;&#xA;           RANGE_TO&#xD;&#xA;      FROM dbo.QSYSPTMVGP&#xD;&#xA;     WHERE FACTORY     = @factory&#xD;&#xA;       AND VID_GROUP   = ISNULL(@vid_group, VID_GROUP)&#xD;&#xA;       AND RANGE_FROM  &gt; 0&#xD;&#xA;       AND RANGE_FROM &lt;= RANGE_TO&#xD;&#xA;),&#xD;&#xA;TB_LEN AS&#xD;&#xA;(&#xD;&#xA;    -- 가장 긴 VID 범위 길이 계산&#xD;&#xA;    SELECT ISNULL(MAX(RANGE_TO - RANGE_FROM + 1), 0) AS MAX_LEN&#xD;&#xA;      FROM TB_GRP&#xD;&#xA;),&#xD;&#xA;TB_SEQ AS&#xD;&#xA;(&#xD;&#xA;    -- VID 생성에 사용할 연속 번호 생성&#xD;&#xA;    SELECT TOP (SELECT MAX_LEN FROM TB_LEN)&#xD;&#xA;           ROW_NUMBER() OVER (ORDER BY (SELECT NULL)) - 1 AS N&#xD;&#xA;      FROM SYS.ALL_OBJECTS A&#xD;&#xA;     CROSS JOIN SYS.ALL_OBJECTS B&#xD;&#xA;)&#xD;&#xA;-- 범위를 개별 VID 목록으로 변환&#xD;&#xA;SELECT DISTINCT R.VID_GROUP, R.RANGE_FROM + S.N AS VID&#xD;&#xA;  FROM TB_GRP R&#xD;&#xA;  JOIN TB_SEQ S&#xD;&#xA;    ON S.N &lt; (R.RANGE_TO - R.RANGE_FROM + 1)&#xD;&#xA; ORDER BY VID&#xD;&#xA;;">
            <QP N="factory" />
            <QP N="vid_group" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="1380" N="ListVariableIdGroup">
          <QY P="MsSql" Q="SELECT VID_GROUP, VID_GROUP_DESC, RANGE_FROM, RANGE_TO&#xD;&#xA;  FROM QSYSPTMVGP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY VID_GROUP">
            <QP N="factory" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
      </F>
    </M>
    <M _S="176" N="System">
      <F _S="177" N="UserLogIn" D="Q">
        <SG _S="178" N="SearchUserGrp" D="O">
          <QY P="MsSql" Q="SELECT USER_GRP, ALL_AUTHORITY&#xD;&#xA;  FROM QSECUSRGRP&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND USER_GRP = @user_grp">
            <QP N="factory" />
            <QP N="user_grp" />
          </QY>
        </SG>
        <SG _S="179" N="ListAuthority" D="O">
          <QY P="MsSql" Q="SELECT APP, FUN, TRAN_ENABLED&#xD;&#xA;  FROM QSECURGAUT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND USER_GRP = @user_grp&#xD;&#xA; ORDER BY FUN">
            <QP N="factory" />
            <QP N="user_grp" />
          </QY>
        </SG>
        <SG _S="180" N="UserValidation" D="O">
          <QY P="MsSql" Q="SELECT USER_ID, PASSWORD, USER_NAME, USER_GRP, SYS_AUTHORITY, ISNULL(DELETE_FLAG, 'N')  DEL_FLAG, CMF_10 AS IS_LS&#xD;&#xA;  FROM QSECUSRDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND USER_ID    = @user_id">
            <QP N="factory" />
            <QP N="user_id" />
          </QY>
        </SG>
        <SG _S="181" N="LsInsertUser">
          <QY P="MsSql" Q="INSERT INTO QSECUSRDEF(&#xD;&#xA;   FACTORY,&#xD;&#xA;   USER_ID,&#xD;&#xA;   USER_NAME,&#xD;&#xA;   USER_DESC,&#xD;&#xA;   PASSWORD,&#xD;&#xA;   USER_GRP, &#xD;&#xA;   PHONE_OFFICE,&#xD;&#xA;   PHONE_MOBILE, &#xD;&#xA;   EMAIL_ID,&#xD;&#xA;   DELETE_FLAG,&#xD;&#xA;   CMF_10,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @user_id,&#xD;&#xA;   @user_name,&#xD;&#xA;   @user_desc,&#xD;&#xA;   @password,&#xD;&#xA;   @user_grp,&#xD;&#xA;   @phone_office,&#xD;&#xA;   @phone_mobile,&#xD;&#xA;   @email_id,&#xD;&#xA;   'N',&#xD;&#xA;   'Y',&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="user_id" />
            <QP N="user_name" />
            <QP N="user_desc" />
            <QP N="password" />
            <QP N="user_grp" />
            <QP N="phone_office" />
            <QP N="phone_mobile" />
            <QP N="email_id" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="182" N="CallUserValidationFunction" D="LSE에서만 사용">
          <QY P="MsSql" Q="SELECT dbo.FN_CHK_SSO(@user_id, @password, 'RPMS') as RESULT">
            <QP N="user_id" />
            <QP N="password" />
          </QY>
        </SG>
      </F>
      <F _S="183" N="PasswordChange">
        <SG _S="184" N="SearchUser">
          <QY P="MsSql" Q="SELECT USER_ID, PASSWORD, SYS_AUTHORITY&#xD;&#xA;  FROM QSECUSRDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND USER_ID = @user_id">
            <QP N="factory" />
            <QP N="user_id" />
          </QY>
        </SG>
        <SG _S="185" N="UpdateUser">
          <QY P="MsSql" Q="UPDATE QSECUSRDEF SET&#xD;&#xA;   PASSWORD       = @password,&#xD;&#xA;   UPDATE_USER_ID = @update_user_id,&#xD;&#xA;   UPDATE_TIME    = @update_time&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND USER_ID = @user_id">
            <QP N="password" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="user_id" />
          </QY>
        </SG>
      </F>
      <F _S="186" N="PlugInDriverDownload">
        <SG _S="187" N="ListPlugInDriver">
          <QY P="MsSql" Q="SELECT DRIVER&#xD;&#xA;  FROM QSYSPIDDEF&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="188" N="Setup">
      <F _S="189" N="Factory" D="Q">
        <SG _S="190" N="HasFactory" D="Q">
          <QY P="MsSql" Q="SELECT FACTORY&#xD;&#xA;  FROM QSYSFACDEF&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="191" N="ListFactory" D="Q">
          <QY P="MsSql" Q="SELECT FACTORY, FAC_DESC, CREATE_TIME&#xD;&#xA;  FROM QSYSFACDEF&#xD;&#xA; ORDER BY FACTORY" />
        </SG>
        <SG _S="192" N="SearchFactory" D="O">
          <QY P="MsSql" Q="SELECT FACTORY, FAC_DESC,&#xD;&#xA;       SVR_CPU_DANGER_RATE, SVR_CPU_CAUTION_RATE, SVR_MEMORY_DANGER_RATE, SVR_MEMORY_CAUTION_RATE, SVR_DISK_DANGER_RATE, SVR_DISK_CAUTION_RATE,&#xD;&#xA;       EAP_CPU_DANGER_RATE, EAP_CPU_CAUTION_RATE, EAP_MEMORY_DANGER_RATE, EAP_MEMORY_CAUTION_RATE, EAP_DISK_DANGER_RATE, EAP_DISK_CAUTION_RATE,&#xD;&#xA;       EAP_RELOAD_LIMIT&#xD;&#xA;  FROM QSYSFACDEF&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="193" N="CountUserEvent" D="Q">
          <QY P="MsSql" Q="SELECT COUNT(EVENT_ID) AS COUNT&#xD;&#xA;  FROM QSECUSREVT&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="194" N="CountServerEvent" D="Q">
          <QY P="MsSql" Q="SELECT COUNT(EVENT_ID) AS COUNT&#xD;&#xA;  FROM QSYSSVREVT&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="195" N="CountEapEvent" D="Q">
          <QY P="MsSql" Q="SELECT COUNT(EVENT_ID) AS COUNT&#xD;&#xA;  FROM QRASEAPEVT&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="196" N="CountApplication" D="Q">
          <QY P="MsSql" Q="SELECT COUNT(APP) AS COUNT&#xD;&#xA;  FROM QSECURGAPP&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="197" N="CountServer" D="Q">
          <QY P="MsSql" Q="SELECT COUNT(SERVER) AS COUNT&#xD;&#xA;  FROM QSYSSVRDEF&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="198" N="CountPackage" D="Q">
          <QY P="MsSql" Q="SELECT COUNT(PACKAGE) AS COUNT&#xD;&#xA;  FROM QSYSPKGDEF&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="199" N="CountModel" D="Q">
          <QY P="MsSql" Q="SELECT COUNT(MODEL) AS COUNT&#xD;&#xA;  FROM QSYSMDLDEF&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="200" N="CountLibrary" D="Q">
          <QY P="MsSql" Q="SELECT COUNT(LIBRARY) AS COUNT&#xD;&#xA;  FROM QSYSLIBDEF&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="201" N="InsertFactory" D="Q">
          <QY P="MsSql" Q="INSERT INTO QSYSFACDEF (&#xD;&#xA;   FACTORY,&#xD;&#xA;   FAC_DESC,&#xD;&#xA;   SVR_CPU_DANGER_RATE,&#xD;&#xA;   SVR_CPU_CAUTION_RATE,&#xD;&#xA;   SVR_MEMORY_DANGER_RATE,&#xD;&#xA;   SVR_MEMORY_CAUTION_RATE,&#xD;&#xA;   SVR_DISK_DANGER_RATE,&#xD;&#xA;   SVR_DISK_CAUTION_RATE,   &#xD;&#xA;   EAP_CPU_DANGER_RATE,&#xD;&#xA;   EAP_CPU_CAUTION_RATE,&#xD;&#xA;   EAP_MEMORY_DANGER_RATE,&#xD;&#xA;   EAP_MEMORY_CAUTION_RATE,&#xD;&#xA;   EAP_DISK_DANGER_RATE,&#xD;&#xA;   EAP_DISK_CAUTION_RATE,&#xD;&#xA;   EAP_RELOAD_LIMIT,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @fac_desc,&#xD;&#xA;   @svr_cpu_danger_rate,&#xD;&#xA;   @svr_cpu_caution_rate,&#xD;&#xA;   @svr_memory_danger_rate,&#xD;&#xA;   @svr_memory_caution_rate,&#xD;&#xA;   @svr_disk_danger_rate,&#xD;&#xA;   @svr_disk_caution_rate,&#xD;&#xA;   @eap_cpu_danger_rate,&#xD;&#xA;   @eap_cpu_caution_rate,&#xD;&#xA;   @eap_memory_danger_rate,&#xD;&#xA;   @eap_memory_caution_rate,&#xD;&#xA;   @eap_disk_danger_rate,&#xD;&#xA;   @eap_disk_caution_rate,&#xD;&#xA;   @eap_reload_limit,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="fac_desc" />
            <QP N="svr_cpu_danger_rate" />
            <QP N="svr_cpu_caution_rate" />
            <QP N="svr_memory_danger_rate" />
            <QP N="svr_memory_caution_rate" />
            <QP N="svr_disk_danger_rate" />
            <QP N="svr_disk_caution_rate" />
            <QP N="eap_cpu_danger_rate" />
            <QP N="eap_cpu_caution_rate" />
            <QP N="eap_memory_danger_rate" />
            <QP N="eap_memory_caution_rate" />
            <QP N="eap_disk_danger_rate" />
            <QP N="eap_disk_caution_rate" />
            <QP N="eap_reload_limit" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="202" N="InsertUserGroup" D="Q">
          <QY P="MsSql" Q="INSERT INTO QSECUSRGRP(&#xD;&#xA;   FACTORY,&#xD;&#xA;   USER_GRP,&#xD;&#xA;   USER_GRP_DESC,&#xD;&#xA;   ALL_AUTHORITY,   &#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @user_grp,&#xD;&#xA;   @user_grp_desc,&#xD;&#xA;   @all_authority,   &#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="user_grp" />
            <QP N="user_grp_desc" />
            <QP N="all_authority" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="203" N="InsertUser" D="Q">
          <QY P="MsSql" Q="INSERT INTO QSECUSRDEF(&#xD;&#xA;   FACTORY,&#xD;&#xA;   USER_ID,&#xD;&#xA;   USER_DESC,&#xD;&#xA;   PASSWORD,&#xD;&#xA;   USER_GRP, &#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @user_id,&#xD;&#xA;   @user_desc,&#xD;&#xA;   @password,&#xD;&#xA;   @user_grp,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="user_id" />
            <QP N="user_desc" />
            <QP N="password" />
            <QP N="user_grp" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="204" N="UpdateFactory" D="Q">
