            <QP N="user_grp" />
            <QP N="event_type" />
            <QP N="event_id" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
