        <SG _S="1024" N="InsertEapConfig">
          <QY P="MsSql" Q="INSERT INTO QRASEAPCFG (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EAP,&#xD;&#xA;   ATTR_CATEGORY,&#xD;&#xA;   OBJ_TYPE,&#xD;&#xA;   OBJ_NAME,&#xD;&#xA;   KEY_SEQ,&#xD;&#xA;   KEY_NAME,&#xD;&#xA;   DATA,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) &#xD;&#xA;SELECT &#xD;&#xA;   FACTORY,&#xD;&#xA;   EAP,&#xD;&#xA;   @attr_category2,&#xD;&#xA;   OBJ_TYPE,&#xD;&#xA;   OBJ_NAME,&#xD;&#xA;   KEY_SEQ,&#xD;&#xA;   KEY_NAME,&#xD;&#xA;   DATA,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;  FROM QRASEAPCFG&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP           = @eap&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="attr_category2" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
          </QY>
        </SG>
        <SG _S="1025" N="UpdateEap">
          <QY P="MsSql" Q="UPDATE QRASEAPDEF SET&#xD;&#xA;  STEP             = @step,&#xD;&#xA;  NEED_ACTION      = @need_action,&#xD;&#xA;  NEXT_NEED_ACTION = @next_need_action,&#xD;&#xA;  RELOAD_CNT       = RELOAD_CNT + 1,&#xD;&#xA;  LAST_EVENT_ID    = @last_event_id,&#xD;&#xA;  LAST_EVENT_TIME  = @last_event_time,&#xD;&#xA;  LAST_HIST_SEQ    = @hist_seq,&#xD;&#xA;  UPDATE_USER_ID   = @update_user_id,&#xD;&#xA;  UPDATE_TIME      = @update_time&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EAP         = @eap">
            <QP N="step" />
            <QP N="need_action" />
            <QP N="next_need_action" />
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="hist_seq" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="1026" N="DeleteEapAtr">
          <QY P="MsSql" Q="DELETE &#xD;&#xA;  FROM QRASEAPATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP           = @eap&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
          </QY>
        </SG>
        <SG _S="1027" N="DeleteEapConfig">
          <QY P="MsSql" Q="DELETE &#xD;&#xA;  FROM QRASEAPCFG&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP           = @eap&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
          </QY>
        </SG>
      </F>
      <F _S="1028" N="EapReloadFail">
