            <QP N="ibn_name" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="516" N="InsertBranchEquipment">
          <QY P="MsSql" Q="INSERT INTO QEMSIBNEQP(&#xD;&#xA;   FACTORY,&#xD;&#xA;   IBN_NAME,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   ENABLE,&#xD;&#xA;   NEED_ACTION,&#xD;&#xA;   APPLIED_VER,&#xD;&#xA;   ACTIVE_VER,&#xD;&#xA;   LAST_VER,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @ibn_name,&#xD;&#xA;   @eqp_name,&#xD;&#xA;   @enable,&#xD;&#xA;   @need_action,&#xD;&#xA;   @applied_ver,&#xD;&#xA;   @active_ver,&#xD;&#xA;   @last_ver,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
            <QP N="enable" />
            <QP N="need_action" />
            <QP N="applied_ver" />
            <QP N="active_ver" />
            <QP N="last_ver" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="517" N="InsertBranchTagAlias">
          <QY P="MsSql" Q="INSERT INTO QEMSIBNPTA(&#xD;&#xA;   FACTORY,&#xD;&#xA;   IBN_NAME,&#xD;&#xA;   TAG_ADDR,&#xD;&#xA;   TAG_ADDR_ALIAS,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @ibn_name,&#xD;&#xA;   @tag_addr,&#xD;&#xA;   @tag_addr_alias,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
