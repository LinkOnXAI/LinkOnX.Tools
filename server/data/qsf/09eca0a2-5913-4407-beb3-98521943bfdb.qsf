<?xml version="1.0"?>
<Q QN="QSF" QV="1.0.0.0" QC="2019.09.15 14:33:23.406" QU="2026-03-11 17:04:07.637" QD="LinkOn SQL File" QS="1386">
  <S _S="1" N="LinkOnEMService" D="LinkOn EMS" _RK="09eca0a2-5913-4407-beb3-98521943bfdb">
    <M _S="2" N="Common">
      <F _S="3" N="Validation" D="Q">
        <SG _S="4" N="HasFactory" D="O">
          <QY P="MsSql" Q="SELECT FACTORY, EAP_RELOAD_LIMIT&#xD;&#xA;  FROM QSYSFACDEF&#xD;&#xA;  WITH (NOLOCK)&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="5" N="EventSearch" D="Q">
        <SG _S="6" N="SearchUserEvent" D="O">
          <QY P="MsSql" Q="SELECT EVENT_DESC, &#xD;&#xA;       DATA_1_PRT, DATA_2_PRT, DATA_3_PRT, DATA_4_PRT, DATA_5_PRT,&#xD;&#xA;       DATA_6_PRT, DATA_7_PRT, DATA_8_PRT, DATA_9_PRT, DATA_10_PRT,&#xD;&#xA;       DATA_11_PRT, DATA_12_PRT, DATA_13_PRT, DATA_14_PRT, DATA_15_PRT,&#xD;&#xA;       DATA_16_PRT, DATA_17_PRT, DATA_18_PRT, DATA_19_PRT, DATA_20_PRT&#xD;&#xA;  FROM QSECUSREVT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND SYSTEM   = @system&#xD;&#xA;   AND EVENT_ID = @event_id&#xD;&#xA;   AND ACTION   = @action">
            <QP N="factory" />
            <QP N="system" />
            <QP N="event_id" />
            <QP N="action" />
          </QY>
        </SG>
        <SG _S="7" N="SearchUserEventAll" D="O">
          <QY P="MsSql" Q="SELECT EVENT_ID, EVENT_DESC, ACTION&#xD;&#xA;  FROM QSECUSREVT&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="8" N="SearchServerEvent" D="O">
          <QY P="MsSql" Q="SELECT EVENT_DESC,&#xD;&#xA;       DATA_1_PRT, DATA_2_PRT, DATA_3_PRT, DATA_4_PRT, DATA_5_PRT,&#xD;&#xA;       DATA_6_PRT, DATA_7_PRT, DATA_8_PRT, DATA_9_PRT, DATA_10_PRT,    &#xD;&#xA;       DATA_11_PRT, DATA_12_PRT, DATA_13_PRT, DATA_14_PRT, DATA_15_PRT,&#xD;&#xA;       DATA_16_PRT, DATA_17_PRT, DATA_18_PRT, DATA_19_PRT, DATA_20_PRT,&#xD;&#xA;       ALT_COMMENT&#xD;&#xA;  FROM QSYSSVREVT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EVENT_ID = @event_id">
            <QP N="factory" />
            <QP N="event_id" />
          </QY>
        </SG>
        <SG _S="9" N="SearchServerEventAll" D="O">
          <QY P="MsSql" Q="SELECT EVENT_ID, EVENT_DESC&#xD;&#xA;  FROM QSYSSVREVT&#xD;&#xA; WHERE FACTORY  = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="10" N="SearchEapEvent" D="O">
          <QY P="MsSql" Q="SELECT EVENT_DESC,&#xD;&#xA;       DATA_1_PRT, DATA_2_PRT, DATA_3_PRT, DATA_4_PRT, DATA_5_PRT,&#xD;&#xA;       DATA_6_PRT, DATA_7_PRT, DATA_8_PRT, DATA_9_PRT, DATA_10_PRT,    &#xD;&#xA;       DATA_11_PRT, DATA_12_PRT, DATA_13_PRT, DATA_14_PRT, DATA_15_PRT,&#xD;&#xA;       DATA_16_PRT, DATA_17_PRT, DATA_18_PRT, DATA_19_PRT, DATA_20_PRT,&#xD;&#xA;       ALT_COMMENT&#xD;&#xA;  FROM QRASEAPEVT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EVENT_ID = @event_id">
            <QP N="factory" />
            <QP N="event_id" />
          </QY>
        </SG>
        <SG _S="11" N="SearchEapEventAll" D="O">
          <QY P="MsSql" Q="SELECT EVENT_ID, EVENT_DESC&#xD;&#xA;  FROM QRASEAPEVT&#xD;&#xA; WHERE FACTORY  = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="12" N="SearchEquipmentEvent" D="O">
          <QY P="MsSql" Q="SELECT EVENT_DESC,&#xD;&#xA;       DATA_1_PRT, DATA_2_PRT, DATA_3_PRT, DATA_4_PRT, DATA_5_PRT,&#xD;&#xA;       DATA_6_PRT, DATA_7_PRT, DATA_8_PRT, DATA_9_PRT, DATA_10_PRT,    &#xD;&#xA;       DATA_11_PRT, DATA_12_PRT, DATA_13_PRT, DATA_14_PRT, DATA_15_PRT,&#xD;&#xA;       DATA_16_PRT, DATA_17_PRT, DATA_18_PRT, DATA_19_PRT, DATA_20_PRT,&#xD;&#xA;       ALT_COMMENT&#xD;&#xA;  FROM QRASEQPEVT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EVENT_ID = @event_id">
            <QP N="factory" />
            <QP N="event_id" />
          </QY>
        </SG>
        <SG _S="13" N="SearchEquipmentEventAll" D="Q">
          <QY P="MsSql" Q="SELECT EVENT_ID, EVENT_DESC&#xD;&#xA;  FROM QRASEQPEVT&#xD;&#xA; WHERE FACTORY  = @factory">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="14" N="UserHistory" D="Q">
        <SG _S="15" N="InsertUserHistory" D="O">
          <QY P="MsSql" Q="INSERT INTO QSECUSRHIS(&#xD;&#xA;   FACTORY,&#xD;&#xA;   USER_ID,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   EVENT_ID,&#xD;&#xA;   ACTION,&#xD;&#xA;   SYSTEM,&#xD;&#xA;   HOST_IP,&#xD;&#xA;   HOST_NAME,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   EVT_H_1,&#xD;&#xA;   EVT_D_1,&#xD;&#xA;   EVT_H_2,&#xD;&#xA;   EVT_D_2,&#xD;&#xA;   EVT_H_3,&#xD;&#xA;   EVT_D_3,&#xD;&#xA;   EVT_H_4,&#xD;&#xA;   EVT_D_4,&#xD;&#xA;   EVT_H_5,&#xD;&#xA;   EVT_D_5,&#xD;&#xA;   EVT_H_6,&#xD;&#xA;   EVT_D_6,&#xD;&#xA;   EVT_H_7,&#xD;&#xA;   EVT_D_7,&#xD;&#xA;   EVT_H_8,&#xD;&#xA;   EVT_D_8,&#xD;&#xA;   EVT_H_9,&#xD;&#xA;   EVT_D_9,&#xD;&#xA;   EVT_H_10,&#xD;&#xA;   EVT_D_10,    &#xD;&#xA;   EVT_H_11,&#xD;&#xA;   EVT_D_11,&#xD;&#xA;   EVT_H_12,&#xD;&#xA;   EVT_D_12,&#xD;&#xA;   EVT_H_13,&#xD;&#xA;   EVT_D_13,&#xD;&#xA;   EVT_H_14,&#xD;&#xA;   EVT_D_14,&#xD;&#xA;   EVT_H_15,&#xD;&#xA;   EVT_D_15,&#xD;&#xA;   EVT_H_16,&#xD;&#xA;   EVT_D_16,&#xD;&#xA;   EVT_H_17,&#xD;&#xA;   EVT_D_17,&#xD;&#xA;   EVT_H_18,&#xD;&#xA;   EVT_D_18,&#xD;&#xA;   EVT_H_19,&#xD;&#xA;   EVT_D_19,&#xD;&#xA;   EVT_H_20,&#xD;&#xA;   EVT_D_20,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @user_id,&#xD;&#xA;   (NEXT VALUE FOR SEQ_USR_HIS),&#xD;&#xA;   @event_id, &#xD;&#xA;   @action, &#xD;&#xA;   @system,&#xD;&#xA;   @host_ip,&#xD;&#xA;   @host_name,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @evt_h_1,&#xD;&#xA;   @evt_d_1,   &#xD;&#xA;   @evt_h_2,&#xD;&#xA;   @evt_d_2,&#xD;&#xA;   @evt_h_3,&#xD;&#xA;   @evt_d_3,&#xD;&#xA;   @evt_h_4,&#xD;&#xA;   @evt_d_4,&#xD;&#xA;   @evt_h_5,&#xD;&#xA;   @evt_d_5,&#xD;&#xA;   @evt_h_6,&#xD;&#xA;   @evt_d_6,&#xD;&#xA;   @evt_h_7,&#xD;&#xA;   @evt_d_7,&#xD;&#xA;   @evt_h_8,&#xD;&#xA;   @evt_d_8,&#xD;&#xA;   @evt_h_9,&#xD;&#xA;   @evt_d_9,&#xD;&#xA;   @evt_h_10,&#xD;&#xA;   @evt_d_10,&#xD;&#xA;   @evt_h_11,&#xD;&#xA;   @evt_d_11,   &#xD;&#xA;   @evt_h_12,&#xD;&#xA;   @evt_d_12,&#xD;&#xA;   @evt_h_13,&#xD;&#xA;   @evt_d_13,&#xD;&#xA;   @evt_h_14,&#xD;&#xA;   @evt_d_14,&#xD;&#xA;   @evt_h_15,&#xD;&#xA;   @evt_d_15,&#xD;&#xA;   @evt_h_16,&#xD;&#xA;   @evt_d_16,&#xD;&#xA;   @evt_h_17,&#xD;&#xA;   @evt_d_17,&#xD;&#xA;   @evt_h_18,&#xD;&#xA;   @evt_d_18,&#xD;&#xA;   @evt_h_19,&#xD;&#xA;   @evt_d_19,&#xD;&#xA;   @evt_h_20,&#xD;&#xA;   @evt_d_20,   &#xD;&#xA;   @tran_user_id,&#xD;&#xA;   @tran_comment&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="user_id" />
            <QP N="event_id" />
            <QP N="action" />
            <QP N="system" />
            <QP N="host_ip" />
            <QP N="host_name" />
            <QP N="tran_time" />
            <QP N="evt_h_1" />
            <QP N="evt_d_1" />
            <QP N="evt_h_2" />
            <QP N="evt_d_2" />
            <QP N="evt_h_3" />
            <QP N="evt_d_3" />
            <QP N="evt_h_4" />
            <QP N="evt_d_4" />
            <QP N="evt_h_5" />
            <QP N="evt_d_5" />
            <QP N="evt_h_6" />
            <QP N="evt_d_6" />
            <QP N="evt_h_7" />
            <QP N="evt_d_7" />
            <QP N="evt_h_8" />
            <QP N="evt_d_8" />
            <QP N="evt_h_9" />
            <QP N="evt_d_9" />
            <QP N="evt_h_10" />
            <QP N="evt_d_10" />
            <QP N="evt_h_11" />
            <QP N="evt_d_11" />
            <QP N="evt_h_12" />
            <QP N="evt_d_12" />
            <QP N="evt_h_13" />
            <QP N="evt_d_13" />
            <QP N="evt_h_14" />
            <QP N="evt_d_14" />
            <QP N="evt_h_15" />
            <QP N="evt_d_15" />
            <QP N="evt_h_16" />
            <QP N="evt_d_16" />
            <QP N="evt_h_17" />
            <QP N="evt_d_17" />
            <QP N="evt_h_18" />
            <QP N="evt_d_18" />
            <QP N="evt_h_19" />
            <QP N="evt_d_19" />
            <QP N="evt_h_20" />
            <QP N="evt_d_20" />
            <QP N="tran_user_id" />
            <QP N="tran_comment" />
          </QY>
        </SG>
      </F>
      <F _S="16" N="EapSchemaSearch">
        <SG _S="17" N="SearchEap">
          <QY P="MsSql" Q="SELECT EAP_TYPE&#xD;&#xA;  FROM QRASEAPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EAP         = @eap&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="18" N="SearchEapEquipmentAtr">
          <QY P="MsSql" Q="SELECT A.EQP_SEQ, A.EQP_NAME, A.EQP_DESC, ISNULL(B.CTRL_MODE, 'Unknown') CTRL_MODE, B.PRI_STATE, B.STATE, B.ALARM, B.CMF_5 AS PLC_IP_ADDRESS&#xD;&#xA;  FROM QRASEQPATR A&#xD;&#xA;  LEFT JOIN QRASEQPDEF B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EQP_NAME      = B.EQP_NAME&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.EAP           = @eap&#xD;&#xA;   AND A.ATTR_CATEGORY = @attr_category&#xD;&#xA; ORDER BY A.EQP_SEQ">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
          </QY>
        </SG>
      </F>
      <F _S="19" N="EapFilePack">
        <SG _S="20" N="HasPackageVer">
          <QY P="MsSql" Q="SELECT PKG_VER_PATH, PKG_RELEASE&#xD;&#xA;  FROM QSYSPKGVER  &#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND PACKAGE = @package&#xD;&#xA;   AND PKG_VER = @pkg_ver">
            <QP N="factory" />
            <QP N="package" />
            <QP N="pkg_ver" />
          </QY>
        </SG>
        <SG _S="21" N="HasModelVer">
          <QY P="MsSql" Q="SELECT MDL_VER_PATH, MDL_RELEASE&#xD;&#xA;  FROM QSYSMDLVER  &#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND MODEL  = @model&#xD;&#xA;   AND MDL_VER = @mdl_ver">
            <QP N="factory" />
            <QP N="model" />
            <QP N="mdl_ver" />
          </QY>
        </SG>
        <SG _S="22" N="HasLibraryVer">
          <QY P="MsSql" Q="SELECT LIB_VER_PATH, LIB_RELEASE&#xD;&#xA;  FROM QSYSLIBVER&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND LIBRARY  = @library&#xD;&#xA;   AND LIB_VER  = @lib_ver">
            <QP N="factory" />
            <QP N="library" />
            <QP N="lib_ver" />
          </QY>
        </SG>
      </F>
      <F _S="23" N="EapServerAlarmSet">
        <SG _S="24" N="SearchServer">
          <QY P="MsSql" Q="SELECT UP_DOWN, STATUS, EAS_UP_DOWN, OPC_SVR_UP_DOWN, ALARM&#xD;&#xA;  FROM QSYSSVRDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SERVER      = @server&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="server" />
          </QY>
        </SG>
        <SG _S="25" N="SearchEap">
          <QY P="MsSql" Q="SELECT EAP&#xD;&#xA;  FROM QRASEAPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SERVER      = @server&#xD;&#xA;   AND ALARM       = @alarm&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="server" />
            <QP N="alarm" />
          </QY>
        </SG>
        <SG _S="26" N="UpdateServer">
          <QY P="MsSql" Q="UPDATE QSYSSVRDEF SET  &#xD;&#xA;  ALARM = @alarm  &#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND SERVER  = @server">
            <QP N="alarm" />
            <QP N="factory" />
            <QP N="server" />
          </QY>
        </SG>
      </F>
      <F _S="27" N="EapAlarmSet">
        <SG _S="28" N="SearchEap">
          <QY P="MsSql" Q="SELECT UP_DOWN, STATUS, ALARM&#xD;&#xA;  FROM QRASEAPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EAP         = @eap&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="29" N="SearchConnectorState">
          <QY P="MsSql" Q="SELECT CNT_NAME&#xD;&#xA;  FROM QRASCNTSTS&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EAP     = @eap&#xD;&#xA;   AND STATE  &lt;&gt; @state">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="state" />
          </QY>
        </SG>
        <SG _S="30" N="UpdateEap">
          <QY P="MsSql" Q="UPDATE QRASEAPDEF SET  &#xD;&#xA;  ALARM = @alarm  &#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EAP     = @eap">
            <QP N="alarm" />
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
      </F>
      <F _S="31" N="Equipment">
        <SG _S="32" N="SearchEquipmentSeq">
          <QY P="MsSql" />
        </SG>
      </F>
      <F _S="33" N="EquipmentHistory">
        <SG _S="34" N="SelectEquipmentHistorySeq">
          <QY P="MsSql" Q="SELECT NEXT VALUE FOR SEQ_EQP_HIS" />
        </SG>
      </F>
      <F _S="35" N="EapHistory">
        <SG _S="36" N="SelectEapHistorySeq">
          <QY P="MsSql" Q="SELECT NEXT VALUE FOR SEQ_EAP_HIS" />
        </SG>
        <SG _S="37" N="SelectEapInfoForHistory">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;   A.FACTORY,&#xD;&#xA;   A.EAP,   &#xD;&#xA;   A.EAP_TYPE,&#xD;&#xA;   A.SERVER,&#xD;&#xA;   A.STEP,&#xD;&#xA;   A.ALARM,&#xD;&#xA;   A.UP_DOWN,&#xD;&#xA;   A.STATUS,&#xD;&#xA;   A.NEED_ACTION,&#xD;&#xA;   A.NEXT_NEED_ACTION,   &#xD;&#xA;   A.RELOAD_CNT,&#xD;&#xA;   A.BRANCH_VER,&#xD;&#xA;   A.DELETE_FLAG,&#xD;&#xA;   ISNULL(B.PACKAGE, ' ') AS SET_PKG,&#xD;&#xA;   ISNULL(B.PKG_VER, 0) AS SET_PKG_VER,&#xD;&#xA;   ISNULL(C.PACKAGE, ' ') AS REL_PKG,&#xD;&#xA;   ISNULL(C.PKG_VER, 0) AS REL_PKG_VER,&#xD;&#xA;   ISNULL(D.PACKAGE, ' ') AS APL_PKG,&#xD;&#xA;   ISNULL(D.PKG_VER, 0) AS APL_PKG_VER,   &#xD;&#xA;   ISNULL(B.MODEL, ' ') AS SET_MDL,&#xD;&#xA;   ISNULL(B.MDL_VER, 0) AS SET_MDL_VER,&#xD;&#xA;   ISNULL(C.MODEL, ' ') AS REL_MDL,&#xD;&#xA;   ISNULL(C.MDL_VER, 0) AS REL_MDL_VER,&#xD;&#xA;   ISNULL(D.MODEL, ' ') AS APL_MDL,&#xD;&#xA;   ISNULL(D.MDL_VER, 0) AS APL_MDL_VER,   &#xD;&#xA;   ISNULL(B.LIBRARY, ' ') AS SET_LIB,&#xD;&#xA;   ISNULL(B.LIB_VER, 0) AS SET_LIB_VER,&#xD;&#xA;   ISNULL(C.LIBRARY, ' ') AS REL_LIB,&#xD;&#xA;   ISNULL(C.LIB_VER, 0) AS REL_LIB_VER,&#xD;&#xA;   ISNULL(D.LIBRARY, ' ') AS APL_LIB,&#xD;&#xA;   ISNULL(D.LIB_VER, 0) AS APL_LIB_VER&#xD;&#xA;  FROM QRASEAPDEF A  &#xD;&#xA;  WITH (NOLOCK)&#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C&#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP           = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D&#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP           = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.EAP           = @eap&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="38" N="SelectEapInfoForHistory_new">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;    A.FACTORY, A.EAP, A.EAP_TYPE, A.SERVER, A.STEP, A.ALARM,&#xD;&#xA;    A.UP_DOWN, A.STATUS, A.NEED_ACTION, A.NEXT_NEED_ACTION,&#xD;&#xA;    A.RELOAD_CNT, A.BRANCH_VER, A.DELETE_FLAG,&#xD;&#xA;    ISNULL(B.PACKAGE,' ') AS SET_PKG, ISNULL(B.PKG_VER,0) AS SET_PKG_VER,&#xD;&#xA;    ISNULL(C.PACKAGE,' ') AS REL_PKG, ISNULL(C.PKG_VER,0) AS REL_PKG_VER,&#xD;&#xA;    ISNULL(D.PACKAGE,' ') AS APL_PKG, ISNULL(D.PKG_VER,0) AS APL_PKG_VER,&#xD;&#xA;    ISNULL(B.MODEL,' ')   AS SET_MDL, ISNULL(B.MDL_VER,0) AS SET_MDL_VER,&#xD;&#xA;    ISNULL(C.MODEL,' ')   AS REL_MDL, ISNULL(C.MDL_VER,0) AS REL_MDL_VER,&#xD;&#xA;    ISNULL(D.MODEL,' ')   AS APL_MDL, ISNULL(D.MDL_VER,0) AS APL_MDL_VER,&#xD;&#xA;    ISNULL(B.LIBRARY,' ') AS SET_LIB, ISNULL(B.LIB_VER,0) AS SET_LIB_VER,&#xD;&#xA;    ISNULL(C.LIBRARY,' ') AS REL_LIB, ISNULL(C.LIB_VER,0) AS REL_LIB_VER,&#xD;&#xA;    ISNULL(D.LIBRARY,' ') AS APL_LIB, ISNULL(D.LIB_VER,0) AS APL_LIB_VER&#xD;&#xA;FROM dbo.QRASEAPDEF A WITH (NOLOCK)&#xD;&#xA;LEFT JOIN dbo.QRASEAPATR B WITH (NOLOCK)&#xD;&#xA;  ON B.FACTORY = A.FACTORY AND B.EAP = A.EAP AND B.ATTR_CATEGORY = 'Setup'&#xD;&#xA;LEFT JOIN dbo.QRASEAPATR C WITH (NOLOCK)&#xD;&#xA;  ON C.FACTORY = A.FACTORY AND C.EAP = A.EAP AND C.ATTR_CATEGORY = 'Released'&#xD;&#xA;LEFT JOIN dbo.QRASEAPATR D WITH (NOLOCK)&#xD;&#xA;  ON D.FACTORY = A.FACTORY AND D.EAP = A.EAP AND D.ATTR_CATEGORY = 'Applied'&#xD;&#xA;WHERE A.FACTORY     = @factory&#xD;&#xA;  AND A.EAP         = @eap&#xD;&#xA;  AND A.DELETE_FLAG = 'N';">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="39" N="InsertEapHistory">
          <QY P="MsSql" Q="INSERT INTO QRASEAPHIS (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EAP,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   EVENT_ID,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   SERVER,&#xD;&#xA;   STEP,&#xD;&#xA;   UP_DOWN,&#xD;&#xA;   STATUS,&#xD;&#xA;   NEED_ACTION,&#xD;&#xA;   NEXT_NEED_ACTION,&#xD;&#xA;   SET_PACKAGE,&#xD;&#xA;   SET_PKG_VER,&#xD;&#xA;   REL_PACKAGE,&#xD;&#xA;   REL_PKG_VER,&#xD;&#xA;   APL_PACKAGE,&#xD;&#xA;   APL_PKG_VER,   &#xD;&#xA;   SET_MODEL,&#xD;&#xA;   SET_MDL_VER,&#xD;&#xA;   REL_MODEL,&#xD;&#xA;   REL_MDL_VER,&#xD;&#xA;   APL_MODEL,&#xD;&#xA;   APL_MDL_VER,   &#xD;&#xA;   SET_LIBRARY,&#xD;&#xA;   SET_LIB_VER,   &#xD;&#xA;   REL_LIBRARY,&#xD;&#xA;   REL_LIB_VER,   &#xD;&#xA;   APL_LIBRARY,&#xD;&#xA;   APL_LIB_VER,   &#xD;&#xA;   EVT_H_1,&#xD;&#xA;   EVT_D_1,   &#xD;&#xA;   EVT_H_2,&#xD;&#xA;   EVT_D_2,&#xD;&#xA;   EVT_H_3,&#xD;&#xA;   EVT_D_3,&#xD;&#xA;   EVT_H_4,&#xD;&#xA;   EVT_D_4,&#xD;&#xA;   EVT_H_5,&#xD;&#xA;   EVT_D_5,&#xD;&#xA;   EVT_H_6,&#xD;&#xA;   EVT_D_6,&#xD;&#xA;   EVT_H_7,&#xD;&#xA;   EVT_D_7,&#xD;&#xA;   EVT_H_8,&#xD;&#xA;   EVT_D_8,&#xD;&#xA;   EVT_H_9,&#xD;&#xA;   EVT_D_9,&#xD;&#xA;   EVT_H_10,&#xD;&#xA;   EVT_D_10,&#xD;&#xA;   EVT_H_11,&#xD;&#xA;   EVT_D_11,   &#xD;&#xA;   EVT_H_12,&#xD;&#xA;   EVT_D_12,&#xD;&#xA;   EVT_H_13,&#xD;&#xA;   EVT_D_13,&#xD;&#xA;   EVT_H_14,&#xD;&#xA;   EVT_D_14,&#xD;&#xA;   EVT_H_15,&#xD;&#xA;   EVT_D_15,&#xD;&#xA;   EVT_H_16,&#xD;&#xA;   EVT_D_16,&#xD;&#xA;   EVT_H_17,&#xD;&#xA;   EVT_D_17,&#xD;&#xA;   EVT_H_18,&#xD;&#xA;   EVT_D_18,&#xD;&#xA;   EVT_H_19,&#xD;&#xA;   EVT_D_19,&#xD;&#xA;   EVT_H_20,&#xD;&#xA;   EVT_D_20,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT      &#xD;&#xA;) &#xD;&#xA;VALUES( &#xD;&#xA;   @factory,&#xD;&#xA;   @eap,&#xD;&#xA;   @hist_seq,&#xD;&#xA;   @event_id,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @server,&#xD;&#xA;   @step,&#xD;&#xA;   @up_down,&#xD;&#xA;   @eap_status,&#xD;&#xA;   @eap_need_action,&#xD;&#xA;   @eap_next_action,   &#xD;&#xA;   @set_pkg,&#xD;&#xA;   @set_pkg_ver,&#xD;&#xA;   @rel_pkg,&#xD;&#xA;   @rel_pkg_ver,&#xD;&#xA;   @apl_pkg,&#xD;&#xA;   @apl_pkg_ver,   &#xD;&#xA;   @set_mdl,&#xD;&#xA;   @set_mdl_ver,&#xD;&#xA;   @rel_mdl,&#xD;&#xA;   @rel_mdl_ver,&#xD;&#xA;   @apl_mdl,&#xD;&#xA;   @apl_mdl_ver,   &#xD;&#xA;   @set_lib,&#xD;&#xA;   @set_lib_ver,&#xD;&#xA;   @rel_lib,&#xD;&#xA;   @rel_lib_ver,&#xD;&#xA;   @apl_lib,&#xD;&#xA;   @apl_lib_ver,&#xD;&#xA;   @evt_h_1,&#xD;&#xA;   @evt_d_1,   &#xD;&#xA;   @evt_h_2,&#xD;&#xA;   @evt_d_2,&#xD;&#xA;   @evt_h_3,&#xD;&#xA;   @evt_d_3,&#xD;&#xA;   @evt_h_4,&#xD;&#xA;   @evt_d_4,&#xD;&#xA;   @evt_h_5,&#xD;&#xA;   @evt_d_5,&#xD;&#xA;   @evt_h_6,&#xD;&#xA;   @evt_d_6,&#xD;&#xA;   @evt_h_7,&#xD;&#xA;   @evt_d_7,&#xD;&#xA;   @evt_h_8,&#xD;&#xA;   @evt_d_8,&#xD;&#xA;   @evt_h_9,&#xD;&#xA;   @evt_d_9,&#xD;&#xA;   @evt_h_10,&#xD;&#xA;   @evt_d_10,&#xD;&#xA;   @evt_h_11,&#xD;&#xA;   @evt_d_11,   &#xD;&#xA;   @evt_h_12,&#xD;&#xA;   @evt_d_12,&#xD;&#xA;   @evt_h_13,&#xD;&#xA;   @evt_d_13,&#xD;&#xA;   @evt_h_14,&#xD;&#xA;   @evt_d_14,&#xD;&#xA;   @evt_h_15,&#xD;&#xA;   @evt_d_15,&#xD;&#xA;   @evt_h_16,&#xD;&#xA;   @evt_d_16,&#xD;&#xA;   @evt_h_17,&#xD;&#xA;   @evt_d_17,&#xD;&#xA;   @evt_h_18,&#xD;&#xA;   @evt_d_18,&#xD;&#xA;   @evt_h_19,&#xD;&#xA;   @evt_d_19,&#xD;&#xA;   @evt_h_20,&#xD;&#xA;   @evt_d_20,&#xD;&#xA;   @tran_user_id,&#xD;&#xA;   @tran_comment&#xD;&#xA;);">
            <QP N="factory" />
