        <SG _S="1192" N="HasBranchEquipmentVersion">
          <QY P="MsSql" Q="SELECT EQP_TAGSET_VER&#xD;&#xA;  FROM CEMSIBNVER&#xD;&#xA; WHERE FACTORY        = @factory&#xD;&#xA;   AND IBN_NAME       = @ibn_name&#xD;&#xA;   AND EQP_NAME       = @eqp_name&#xD;&#xA;   AND EQP_TAGSET_VER = @eqp_tagset_ver">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
            <QP N="eqp_tagset_ver" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="1189" N="HasEap">
          <QY P="MsSql" Q="SELECT EAP&#xD;&#xA;  FROM QRASEAPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EAP         = @eap&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="1190" N="HasEquipment">
          <QY P="MsSql" Q="SELECT A.EQP_NAME, &#xD;&#xA;       ISNULL(B.COMM_STATE, '') AS COMM_STATE, &#xD;&#xA;	   ISNULL(B.CTRL_MODE, '') AS CTRL_MODE, &#xD;&#xA;	   ISNULL(B.PROC_STATE, '') AS PROC_STATE&#xD;&#xA;  FROM QRASEQPDEF A&#xD;&#xA;  LEFT JOIN QRASEQPSTS B&#xD;&#xA;  	ON A.FACTORY     = B.FACTORY&#xD;&#xA;   AND A.EQP_NAME    = B.EQP_NAME&#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.EQP_NAME    = @eqp_name&#xD;&#xA;   AND A.DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="1191" N="UpdateBranchEquipment">
          <QY P="MsSql" Q="UPDATE QEMSIBNEQP SET&#xD;&#xA;  ENABLE         = @enable,&#xD;&#xA;  NEED_ACTION    = @need_action,&#xD;&#xA;  APPLIED_VER    = @applied_ver,&#xD;&#xA;  UPDATE_USER_ID = @update_user_id,&#xD;&#xA;  UPDATE_TIME    = @update_time&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND IBN_NAME  = @ibn_name&#xD;&#xA;   AND EQP_NAME  = @eqp_name">
            <QP N="enable" />
            <QP N="need_action" />
            <QP N="applied_ver" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="1194" N="InsertEquipmentHis">
          <QY P="MsSql" Q="INSERT INTO QRASEQPHIS (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   EVENT_ID,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   SYSTEM,&#xD;&#xA;   COMM_STATE,&#xD;&#xA;   CTRL_MODE,&#xD;&#xA;   EAP,&#xD;&#xA;   EAP_EVENT_ID,      &#xD;&#xA;   EVT_H_1,&#xD;&#xA;   EVT_D_1,   &#xD;&#xA;   EVT_H_2,&#xD;&#xA;   EVT_D_2,&#xD;&#xA;   EVT_H_3,&#xD;&#xA;   EVT_D_3,&#xD;&#xA;   EVT_H_4,&#xD;&#xA;   EVT_D_4,&#xD;&#xA;   EVT_H_5,&#xD;&#xA;   EVT_D_5,&#xD;&#xA;   EVT_H_6,&#xD;&#xA;   EVT_D_6,&#xD;&#xA;   EVT_H_7,&#xD;&#xA;   EVT_D_7,&#xD;&#xA;   EVT_H_8,&#xD;&#xA;   EVT_D_8,&#xD;&#xA;   EVT_H_9,&#xD;&#xA;   EVT_D_9,&#xD;&#xA;   EVT_H_10,&#xD;&#xA;   EVT_D_10,&#xD;&#xA;   EVT_H_11,&#xD;&#xA;   EVT_D_11,   &#xD;&#xA;   EVT_H_12,&#xD;&#xA;   EVT_D_12,&#xD;&#xA;   EVT_H_13,&#xD;&#xA;   EVT_D_13,&#xD;&#xA;   EVT_H_14,&#xD;&#xA;   EVT_D_14,&#xD;&#xA;   EVT_H_15,&#xD;&#xA;   EVT_D_15,&#xD;&#xA;   EVT_H_16,&#xD;&#xA;   EVT_D_16,&#xD;&#xA;   EVT_H_17,&#xD;&#xA;   EVT_D_17,&#xD;&#xA;   EVT_H_18,&#xD;&#xA;   EVT_D_18,&#xD;&#xA;   EVT_H_19,&#xD;&#xA;   EVT_D_19,&#xD;&#xA;   EVT_H_20,&#xD;&#xA;   EVT_D_20,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT      &#xD;&#xA;) &#xD;&#xA;VALUES( &#xD;&#xA;   @factory,&#xD;&#xA;   @eqp_name,&#xD;&#xA;   @last_his_seq,&#xD;&#xA;   @event_id,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @system,&#xD;&#xA;   @comm_state,&#xD;&#xA;   @ctrl_mode,&#xD;&#xA;   @eap,&#xD;&#xA;   @eap_event_id,&#xD;&#xA;   @evt_h_1,&#xD;&#xA;   @evt_d_1,   &#xD;&#xA;   @evt_h_2,&#xD;&#xA;   @evt_d_2,&#xD;&#xA;   @evt_h_3,&#xD;&#xA;   @evt_d_3,&#xD;&#xA;   @evt_h_4,&#xD;&#xA;   @evt_d_4,&#xD;&#xA;   @evt_h_5,&#xD;&#xA;   @evt_d_5,&#xD;&#xA;   @evt_h_6,&#xD;&#xA;   @evt_d_6,&#xD;&#xA;   @evt_h_7,&#xD;&#xA;   @evt_d_7,&#xD;&#xA;   @evt_h_8,&#xD;&#xA;   @evt_d_8,&#xD;&#xA;   @evt_h_9,&#xD;&#xA;   @evt_d_9,&#xD;&#xA;   @evt_h_10,&#xD;&#xA;   @evt_d_10,&#xD;&#xA;   @evt_h_11,&#xD;&#xA;   @evt_d_11,   &#xD;&#xA;   @evt_h_12,&#xD;&#xA;   @evt_d_12,&#xD;&#xA;   @evt_h_13,&#xD;&#xA;   @evt_d_13,&#xD;&#xA;   @evt_h_14,&#xD;&#xA;   @evt_d_14,&#xD;&#xA;   @evt_h_15,&#xD;&#xA;   @evt_d_15,&#xD;&#xA;   @evt_h_16,&#xD;&#xA;   @evt_d_16,&#xD;&#xA;   @evt_h_17,&#xD;&#xA;   @evt_d_17,&#xD;&#xA;   @evt_h_18,&#xD;&#xA;   @evt_d_18,&#xD;&#xA;   @evt_h_19,&#xD;&#xA;   @evt_d_19,&#xD;&#xA;   @evt_h_20,&#xD;&#xA;   @evt_d_20,&#xD;&#xA;   @tran_user_id,&#xD;&#xA;   @tran_comment)">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="last_his_seq" />
            <QP N="event_id" />
            <QP N="tran_time" />
            <QP N="system" />
            <QP N="comm_state" />
            <QP N="ctrl_mode" />
            <QP N="eap" />
            <QP N="eap_event_id" />
            <QP N="evt_h_1" />
            <QP N="evt_d_1" />
            <QP N="evt_h_2" />
            <QP N="evt_d_2" />
            <QP N="evt_h_3" />
            <QP N="evt_d_3" />
