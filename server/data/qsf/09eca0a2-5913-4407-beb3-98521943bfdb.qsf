      <F _S="1075" N="EapStateSync" D="Eap State Sync">
        <SG _S="1076" N="SearchEap">
          <QY P="MsSql" Q="SELECT SERVER, STATUS, UP_DOWN, STEP&#xD;&#xA;  FROM QRASEAPDEF  &#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EAP         = @eap&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="1077" N="SearchConnectorSts_new">
          <QY P="MsSql" Q="SELECT EAP, CNT_SEQ, CNT_NAME, STATE&#xD;&#xA;  FROM QRASCNTSTS&#xD;&#xA;  WITH (NOLOCK)&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EAP     = @eap">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="1078" N="SearchConnectorSts">
          <QY P="MsSql" Q="SELECT EAP, CNT_NAME, STATE&#xD;&#xA;  FROM QRASCNTSTS&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EAP     = @eap&#xD;&#xA;   AND CNT_SEQ = @cnt_seq">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="cnt_seq" />
          </QY>
        </SG>
        <SG _S="1246" N="HasBranchEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME, IBN_STATE,  NEED_ACTION, ACTIVE_VER&#xD;&#xA;  FROM QEMSIBNEQP&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND IBN_NAME  = @ibn_name&#xD;&#xA;   AND EQP_NAME  = @eqp_name">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="1079" N="UpdateEapUpDown">
          <QY P="MsSql" Q="UPDATE QRASEAPDEF SET&#xD;&#xA;  UP_DOWN          = @up_down,&#xD;&#xA;  LAST_ALIVE_TIME  = @last_alive_time,&#xD;&#xA;  LAST_EVENT_ID    = @last_event_id,&#xD;&#xA;  LAST_EVENT_TIME  = @last_event_time,&#xD;&#xA;  LAST_HIST_SEQ    = @hist_seq,&#xD;&#xA;  UPDATE_USER_ID   = @update_user_id,&#xD;&#xA;  UPDATE_TIME      = @update_time&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EAP     = @eap">
            <QP N="up_down" />
            <QP N="last_alive_time" />
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="hist_seq" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="1080" N="UpdateEapEventId">
          <QY P="MsSql" Q="UPDATE QRASEAPDEF SET&#xD;&#xA;  LAST_EVENT_ID    = @last_event_id,&#xD;&#xA;  LAST_EVENT_TIME  = @last_event_time,&#xD;&#xA;  LAST_HIST_SEQ    = @hist_seq,&#xD;&#xA;  UPDATE_USER_ID   = @update_user_id,&#xD;&#xA;  UPDATE_TIME      = @update_time&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EAP     = @eap">
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="hist_seq" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="1081" N="InsertEapHistory">
          <QY P="MsSql" Q="INSERT INTO QRASEAPHIS (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EAP,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   EVENT_ID,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   SERVER,&#xD;&#xA;   STEP,&#xD;&#xA;   UP_DOWN,&#xD;&#xA;   STATUS,&#xD;&#xA;   NEED_ACTION,&#xD;&#xA;   NEXT_NEED_ACTION,&#xD;&#xA;   SET_PACKAGE,&#xD;&#xA;   SET_PKG_VER,&#xD;&#xA;   REL_PACKAGE,&#xD;&#xA;   REL_PKG_VER,&#xD;&#xA;   APL_PACKAGE,&#xD;&#xA;   APL_PKG_VER,   &#xD;&#xA;   SET_MODEL,&#xD;&#xA;   SET_MDL_VER,&#xD;&#xA;   REL_MODEL,&#xD;&#xA;   REL_MDL_VER,&#xD;&#xA;   APL_MODEL,&#xD;&#xA;   APL_MDL_VER,   &#xD;&#xA;   SET_LIBRARY,&#xD;&#xA;   SET_LIB_VER,   &#xD;&#xA;   REL_LIBRARY,&#xD;&#xA;   REL_LIB_VER,   &#xD;&#xA;   APL_LIBRARY,&#xD;&#xA;   APL_LIB_VER,   &#xD;&#xA;   EVT_H_1,&#xD;&#xA;   EVT_D_1,   &#xD;&#xA;   EVT_H_2,&#xD;&#xA;   EVT_D_2,&#xD;&#xA;   EVT_H_3,&#xD;&#xA;   EVT_D_3,&#xD;&#xA;   EVT_H_4,&#xD;&#xA;   EVT_D_4,&#xD;&#xA;   EVT_H_5,&#xD;&#xA;   EVT_D_5,&#xD;&#xA;   EVT_H_6,&#xD;&#xA;   EVT_D_6,&#xD;&#xA;   EVT_H_7,&#xD;&#xA;   EVT_D_7,&#xD;&#xA;   EVT_H_8,&#xD;&#xA;   EVT_D_8,&#xD;&#xA;   EVT_H_9,&#xD;&#xA;   EVT_D_9,&#xD;&#xA;   EVT_H_10,&#xD;&#xA;   EVT_D_10,&#xD;&#xA;   EVT_H_11,&#xD;&#xA;   EVT_D_11,   &#xD;&#xA;   EVT_H_12,&#xD;&#xA;   EVT_D_12,&#xD;&#xA;   EVT_H_13,&#xD;&#xA;   EVT_D_13,&#xD;&#xA;   EVT_H_14,&#xD;&#xA;   EVT_D_14,&#xD;&#xA;   EVT_H_15,&#xD;&#xA;   EVT_D_15,&#xD;&#xA;   EVT_H_16,&#xD;&#xA;   EVT_D_16,&#xD;&#xA;   EVT_H_17,&#xD;&#xA;   EVT_D_17,&#xD;&#xA;   EVT_H_18,&#xD;&#xA;   EVT_D_18,&#xD;&#xA;   EVT_H_19,&#xD;&#xA;   EVT_D_19,&#xD;&#xA;   EVT_H_20,&#xD;&#xA;   EVT_D_20,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT      &#xD;&#xA;) &#xD;&#xA;VALUES( &#xD;&#xA;   @factory,&#xD;&#xA;   @eap,&#xD;&#xA;   @hist_seq,&#xD;&#xA;   @event_id,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @server,&#xD;&#xA;   @step,&#xD;&#xA;   @up_down,&#xD;&#xA;   @eap_status,&#xD;&#xA;   @eap_need_action,&#xD;&#xA;   @eap_next_action,   &#xD;&#xA;   @set_pkg,&#xD;&#xA;   @set_pkg_ver,&#xD;&#xA;   @rel_pkg,&#xD;&#xA;   @rel_pkg_ver,&#xD;&#xA;   @apl_pkg,&#xD;&#xA;   @apl_pkg_ver,   &#xD;&#xA;   @set_mdl,&#xD;&#xA;   @set_mdl_ver,&#xD;&#xA;   @rel_mdl,&#xD;&#xA;   @rel_mdl_ver,&#xD;&#xA;   @apl_mdl,&#xD;&#xA;   @apl_mdl_ver,   &#xD;&#xA;   @set_lib,&#xD;&#xA;   @set_lib_ver,&#xD;&#xA;   @rel_lib,&#xD;&#xA;   @rel_lib_ver,&#xD;&#xA;   @apl_lib,&#xD;&#xA;   @apl_lib_ver,&#xD;&#xA;   @evt_h_1,&#xD;&#xA;   @evt_d_1,   &#xD;&#xA;   @evt_h_2,&#xD;&#xA;   @evt_d_2,&#xD;&#xA;   @evt_h_3,&#xD;&#xA;   @evt_d_3,&#xD;&#xA;   @evt_h_4,&#xD;&#xA;   @evt_d_4,&#xD;&#xA;   @evt_h_5,&#xD;&#xA;   @evt_d_5,&#xD;&#xA;   @evt_h_6,&#xD;&#xA;   @evt_d_6,&#xD;&#xA;   @evt_h_7,&#xD;&#xA;   @evt_d_7,&#xD;&#xA;   @evt_h_8,&#xD;&#xA;   @evt_d_8,&#xD;&#xA;   @evt_h_9,&#xD;&#xA;   @evt_d_9,&#xD;&#xA;   @evt_h_10,&#xD;&#xA;   @evt_d_10,&#xD;&#xA;   @evt_h_11,&#xD;&#xA;   @evt_d_11,   &#xD;&#xA;   @evt_h_12,&#xD;&#xA;   @evt_d_12,&#xD;&#xA;   @evt_h_13,&#xD;&#xA;   @evt_d_13,&#xD;&#xA;   @evt_h_14,&#xD;&#xA;   @evt_d_14,&#xD;&#xA;   @evt_h_15,&#xD;&#xA;   @evt_d_15,&#xD;&#xA;   @evt_h_16,&#xD;&#xA;   @evt_d_16,&#xD;&#xA;   @evt_h_17,&#xD;&#xA;   @evt_d_17,&#xD;&#xA;   @evt_h_18,&#xD;&#xA;   @evt_d_18,&#xD;&#xA;   @evt_h_19,&#xD;&#xA;   @evt_d_19,&#xD;&#xA;   @evt_h_20,&#xD;&#xA;   @evt_d_20,&#xD;&#xA;   @tran_user_id,&#xD;&#xA;   @tran_comment&#xD;&#xA;);">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="hist_seq" />
            <QP N="event_id" />
            <QP N="tran_time" />
            <QP N="server" />
            <QP N="step" />
            <QP N="up_down" />
            <QP N="eap_status" />
            <QP N="eap_need_action" />
            <QP N="eap_next_action" />
            <QP N="set_pkg" />
            <QP N="set_pkg_ver" />
            <QP N="rel_pkg" />
            <QP N="rel_pkg_ver" />
            <QP N="apl_pkg" />
            <QP N="apl_pkg_ver" />
            <QP N="set_mdl" />
            <QP N="set_mdl_ver" />
            <QP N="rel_mdl" />
            <QP N="rel_mdl_ver" />
            <QP N="apl_mdl" />
            <QP N="apl_mdl_ver" />
            <QP N="set_lib" />
            <QP N="set_lib_ver" />
            <QP N="rel_lib" />
            <QP N="rel_lib_ver" />
            <QP N="apl_lib" />
            <QP N="apl_lib_ver" />
            <QP N="evt_h_1" />
            <QP N="evt_d_1" />
            <QP N="evt_h_2" />
            <QP N="evt_d_2" />
            <QP N="evt_h_3" />
            <QP N="evt_d_3" />
            <QP N="evt_h_4" />
