        <SG _S="1346" N="UpdateVariableIdGroup">
          <QY P="MsSql" Q="UPDATE QSYSPTMVGP SET&#xD;&#xA;  VID_GROUP_DESC = @vid_group_desc,&#xD;&#xA;  RANGE_FROM     = @range_from,&#xD;&#xA;  RANGE_TO       = @range_to,&#xD;&#xA;  UPDATE_USER_ID = @update_user_id,&#xD;&#xA;  UPDATE_TIME    = @update_time&#xD;&#xA; WHERE FACTORY   = @factory    &#xD;&#xA;   AND VID_GROUP = @vid_group">
