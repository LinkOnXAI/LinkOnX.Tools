      <F _S="40" N="ServerHistory">
        <SG _S="41" N="SelectServerHistorySeq">
          <QY P="MsSql" Q="SELECT NEXT VALUE FOR SEQ_SRV_HIS" />
        </SG>
        <SG _S="42" N="SelectServerInfoForHistory">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;   FACTORY,&#xD;&#xA;   SERVER,&#xD;&#xA;   SVR_TYPE,&#xD;&#xA;   SVR_IP,&#xD;&#xA;   B_USED,&#xD;&#xA;   B_MODE,&#xD;&#xA;   UP_DOWN,   &#xD;&#xA;   STATUS,&#xD;&#xA;   EAS_UP_DOWN,&#xD;&#xA;   B_SERVER,&#xD;&#xA;   B_UP_DOWN,&#xD;&#xA;   B_STATUS,&#xD;&#xA;   B_EAS_UP_DOWN,&#xD;&#xA;   OPC_SVR_MON,&#xD;&#xA;   OPC_SVR_UP_DOWN   &#xD;&#xA;  FROM QSYSSVRDEF&#xD;&#xA;  WITH (NOLOCK)&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND SERVER  = @server">
            <QP N="factory" />
            <QP N="server" />
          </QY>
        </SG>
        <SG _S="43" N="SelectBServerInfoForHistory">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;   FACTORY,&#xD;&#xA;   SERVER,&#xD;&#xA;   SVR_TYPE,&#xD;&#xA;   SVR_IP,&#xD;&#xA;   B_USED,&#xD;&#xA;   B_MODE,&#xD;&#xA;   UP_DOWN,   &#xD;&#xA;   STATUS,&#xD;&#xA;   EAS_UP_DOWN,&#xD;&#xA;   B_SERVER,&#xD;&#xA;   B_UP_DOWN,&#xD;&#xA;   B_STATUS,&#xD;&#xA;   B_EAS_UP_DOWN,&#xD;&#xA;   OPC_SVR_MON,&#xD;&#xA;   OPC_SVR_UP_DOWN   &#xD;&#xA;  FROM QSYSSVRDEF&#xD;&#xA;  WITH (NOLOCK)&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND B_SERVER  = @server">
            <QP N="factory" />
            <QP N="server" />
          </QY>
        </SG>
        <SG _S="44" N="InsertServerHistory">
          <QY P="MsSql" Q="INSERT INTO QSYSSVRHIS (&#xD;&#xA;   FACTORY,&#xD;&#xA;   SERVER,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   EVENT_ID,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   SVR_TYPE,&#xD;&#xA;   SVR_IP,&#xD;&#xA;   B_USED,&#xD;&#xA;   B_MODE,&#xD;&#xA;   UP_DOWN,&#xD;&#xA;   STATUS,&#xD;&#xA;   EAS_UP_DOWN,&#xD;&#xA;   B_SERVER,&#xD;&#xA;   B_UP_DOWN,&#xD;&#xA;   B_STATUS,&#xD;&#xA;   B_EAS_UP_DOWN,&#xD;&#xA;   OPC_SVR_MON,&#xD;&#xA;   OPC_SVR_UP_DOWN,&#xD;&#xA;   EVT_H_1,&#xD;&#xA;   EVT_D_1,   &#xD;&#xA;   EVT_H_2,&#xD;&#xA;   EVT_D_2,&#xD;&#xA;   EVT_H_3,&#xD;&#xA;   EVT_D_3,&#xD;&#xA;   EVT_H_4,&#xD;&#xA;   EVT_D_4,&#xD;&#xA;   EVT_H_5,&#xD;&#xA;   EVT_D_5,&#xD;&#xA;   EVT_H_6,&#xD;&#xA;   EVT_D_6,&#xD;&#xA;   EVT_H_7,&#xD;&#xA;   EVT_D_7,&#xD;&#xA;   EVT_H_8,&#xD;&#xA;   EVT_D_8,&#xD;&#xA;   EVT_H_9,&#xD;&#xA;   EVT_D_9,&#xD;&#xA;   EVT_H_10,&#xD;&#xA;   EVT_D_10,&#xD;&#xA;   EVT_H_11,&#xD;&#xA;   EVT_D_11,   &#xD;&#xA;   EVT_H_12,&#xD;&#xA;   EVT_D_12,&#xD;&#xA;   EVT_H_13,&#xD;&#xA;   EVT_D_13,&#xD;&#xA;   EVT_H_14,&#xD;&#xA;   EVT_D_14,&#xD;&#xA;   EVT_H_15,&#xD;&#xA;   EVT_D_15,&#xD;&#xA;   EVT_H_16,&#xD;&#xA;   EVT_D_16,&#xD;&#xA;   EVT_H_17,&#xD;&#xA;   EVT_D_17,&#xD;&#xA;   EVT_H_18,&#xD;&#xA;   EVT_D_18,&#xD;&#xA;   EVT_H_19,&#xD;&#xA;   EVT_D_19,&#xD;&#xA;   EVT_H_20,&#xD;&#xA;   EVT_D_20,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT      &#xD;&#xA;) &#xD;&#xA;VALUES (&#xD;&#xA;@factory,&#xD;&#xA;@server,&#xD;&#xA;@hist_seq,&#xD;&#xA;@event_id,&#xD;&#xA;@tran_time,&#xD;&#xA;@svr_type,&#xD;&#xA;@svr_ip,&#xD;&#xA;@b_used,&#xD;&#xA;@b_mode,&#xD;&#xA;@up_down,&#xD;&#xA;@status,&#xD;&#xA;@eap_up_down,&#xD;&#xA;@b_server,&#xD;&#xA;@b_up_down,&#xD;&#xA;@b_status,&#xD;&#xA;@b_eas_up_down,&#xD;&#xA;@opc_svr_mon,&#xD;&#xA;@opc_svr_up_down,&#xD;&#xA;@evt_h_1,&#xD;&#xA;@evt_d_1,&#xD;&#xA;@evt_h_2,&#xD;&#xA;@evt_d_2,&#xD;&#xA;@evt_h_3,&#xD;&#xA;@evt_d_3,&#xD;&#xA;@evt_h_4,&#xD;&#xA;@evt_d_4,&#xD;&#xA;@evt_h_5,&#xD;&#xA;@evt_d_5,&#xD;&#xA;@evt_h_6,&#xD;&#xA;@evt_d_6,&#xD;&#xA;@evt_h_7,&#xD;&#xA;@evt_d_7,&#xD;&#xA;@evt_h_8,&#xD;&#xA;@evt_d_8,&#xD;&#xA;@evt_h_9,&#xD;&#xA;@evt_d_9,&#xD;&#xA;@evt_h_10,&#xD;&#xA;@evt_d_10,&#xD;&#xA;@evt_h_11,&#xD;&#xA;@evt_d_11,&#xD;&#xA;@evt_h_12,&#xD;&#xA;@evt_d_12,&#xD;&#xA;@evt_h_13,&#xD;&#xA;@evt_d_13,&#xD;&#xA;@evt_h_14,&#xD;&#xA;@evt_d_14,&#xD;&#xA;@evt_h_15,&#xD;&#xA;@evt_d_15,&#xD;&#xA;@evt_h_16,&#xD;&#xA;@evt_d_16,&#xD;&#xA;@evt_h_17,&#xD;&#xA;@evt_d_17,&#xD;&#xA;@evt_h_18,&#xD;&#xA;@evt_d_18,&#xD;&#xA;@evt_h_19,&#xD;&#xA;@evt_d_19,&#xD;&#xA;@evt_h_20,&#xD;&#xA;@evt_d_20,&#xD;&#xA;@tran_user_id,&#xD;&#xA;@tran_comment&#xD;&#xA;);">
            <QP N="factory" />
            <QP N="server" />
            <QP N="hist_seq" />
            <QP N="event_id" />
            <QP N="tran_time" />
            <QP N="svr_type" />
