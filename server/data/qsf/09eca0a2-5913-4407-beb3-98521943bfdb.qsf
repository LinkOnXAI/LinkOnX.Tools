        </SG>
        <SG _S="1082" N="UpdateConnectorSts">
          <QY P="MsSql" Q="UPDATE QRASCNTSTS SET&#xD;&#xA;  STATE          = @state,&#xD;&#xA;  UPDATE_USER_ID = @update_user_id,&#xD;&#xA;  UPDATE_TIME    = @update_time&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EAP     = @eap   &#xD;&#xA;   AND CNT_SEQ = @cnt_seq">
            <QP N="state" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eap" />
            <QP N="cnt_seq" />
          </QY>
        </SG>
        <SG _S="1247" N="UpdateBranchEquipment">
          <QY P="MsSql" Q="UPDATE QEMSIBNEQP SET&#xD;&#xA;  IBN_STATE         = @state,&#xD;&#xA;  PRT_CONNECT_STATE = @prt_state,&#xD;&#xA;  PLC_CONNECT_STATE = @plc_state,&#xD;&#xA;  LAST_PVAL_TIME    = @pval_time,&#xD;&#xA;  LAST_SEND_TIME    = @send_time,&#xD;&#xA;  UPDATE_USER_ID = @update_user_id,&#xD;&#xA;  UPDATE_TIME    = @update_time&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND IBN_NAME  = @ibn_name&#xD;&#xA;   AND EQP_NAME  = @eqp_name">
            <QP N="state" />
            <QP N="prt_state" />
            <QP N="plc_state" />
            <QP N="pval_time" />
            <QP N="send_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
      </F>
      <F _S="1083" N="EdgeReleaseModel">
        <SG _S="1084" N="HasEapAtr">
          <QY P="MsSql" Q="SELECT EAP, MODEL, MDL_VER, EAP_SCHEMA&#xD;&#xA;  FROM QRASEAPATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP           = @eap&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
          </QY>
        </SG>
      </F>
      <F _S="1085" N="EdgeResourceCollect">
        <SG _S="1086" N="HasFactory">
          <QY P="MsSql" Q="SELECT EAP_CPU_DANGER_RATE, EAP_CPU_CAUTION_RATE,&#xD;&#xA;       EAP_MEMORY_DANGER_RATE, EAP_MEMORY_CAUTION_RATE,&#xD;&#xA;       EAP_DISK_DANGER_RATE, EAP_DISK_CAUTION_RATE&#xD;&#xA;  FROM QSYSFACDEF&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="1087" N="UpdateEapResource">
          <QY P="MsSql" Q="UPDATE QRASEAPDEF SET&#xD;&#xA;  CPU_USAGE      = @cpu_usage,&#xD;&#xA;  MEMORY_USAGE   = @memory_usage,&#xD;&#xA;  DISK_USAGE     = @disk_usage,&#xD;&#xA;  UPDATE_USER_ID = @update_user_id,&#xD;&#xA;  UPDATE_TIME    = @update_time&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND EAP       = @eap">
            <QP N="cpu_usage" />
            <QP N="memory_usage" />
            <QP N="disk_usage" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="1088" N="InsertEapResourceHistory">
          <QY P="MsSql" Q="INSERT INTO QRASEAPRHI (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EAP,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   CPU_USAGE,&#xD;&#xA;   MEMORY_USAGE,&#xD;&#xA;   DISK_USAGE,&#xD;&#xA;   TRAN_USER_ID&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @eap,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @cpu_usage,&#xD;&#xA;   @memory_usage,&#xD;&#xA;   @disk_usage,&#xD;&#xA;   @tran_user_id&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="tran_time" />
            <QP N="cpu_usage" />
            <QP N="memory_usage" />
            <QP N="disk_usage" />
            <QP N="tran_user_id" />
          </QY>
        </SG>
        <SG _S="1089" N="HasEap">
          <QY P="MsSql" Q="SELECT EAP, EAP_TYPE&#xD;&#xA;  FROM QRASEAPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EAP         = @eap&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
      </F>
      <F _S="1090" N="BranchInit">
        <SG _S="1091" N="HasEquipment">
          <QY P="MsSql" Q="SELECT EQP.EQP_NAME, EQP.EAP, EAP.SERVER, EAP.EAP_TYPE, EAP.STATUS, EQP.IP_ADDRESS, EQP.CONN_MODE&#xD;&#xA;  FROM QRASEQPDEF AS EQP&#xD;&#xA;   LEFT JOIN QRASEAPDEF AS EAP&#xD;&#xA;    ON EQP.FACTORY     = EAP.FACTORY&#xD;&#xA;   AND EQP.EAP         = EAP.EAP&#xD;&#xA;   AND EAP.DELETE_FLAG = 'N'&#xD;&#xA; WHERE EQP.FACTORY     = @factory&#xD;&#xA;   AND EQP.EQP_NAME    = @eqp_name&#xD;&#xA;   AND EQP.DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="1092" N="HasServer">
          <QY P="MsSql" Q="SELECT A.SVR_IP, A.UP_DOWN, A.STATUS, A.EAS_UP_DOWN,&#xD;&#xA;       A.B_SERVER, A.B_UP_DOWN, A.B_STATUS, A.B_EAS_UP_DOWN, ISNULL(B.SVR_IP, '') B_SVR_IP&#xD;&#xA;  FROM QSYSSVRDEF A&#xD;&#xA;  LEFT JOIN QSYSSVRDEF B&#xD;&#xA;    ON A.FACTORY     = B.FACTORY&#xD;&#xA;   AND A.B_SERVER    = B.SERVER&#xD;&#xA;   AND B.DELETE_FLAG = 'N'&#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.SERVER      = @server&#xD;&#xA;   AND A.DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="server" />
          </QY>
        </SG>
        <SG _S="1093" N="HasBranchEquipment">
          <QY P="MsSql" Q="SELECT IBN_NAME, ENABLE, ACTIVE_VER, ACT_DS_VER&#xD;&#xA;  FROM QEMSIBNEQP&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EQP_NAME    = @eqp_name">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="1094" N="HasBranch">
          <QY P="MsSql" Q="SELECT PROTOCOL, PROTOCOL_ATTR, TYPE&#xD;&#xA;  FROM QEMSIBNDEF&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND IBN_NAME = @ibn_name">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="1095" N="HasEap">
          <QY P="MsSql" Q="SELECT EAP, BRANCH_VER&#xD;&#xA;  FROM QRASEAPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EAP         = @eap&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="1096" N="HasBranchTag">
          <QY P="MsSql" Q="WITH VersionData AS (&#xD;&#xA; SELECT V.FACTORY, V.BUILD_MDL, V.BUILD_MDL_VER, T.CNT_RK, T.CNT_NAME, T.TAG_ADDR, T.TAG_ADDR_ALIAS&#xD;&#xA;   FROM QEMSIBNVER V&#xD;&#xA;   LEFT JOIN QEMSIBNPTG T&#xD;&#xA;     ON V.FACTORY    = T.FACTORY&#xD;&#xA;    AND V.IBN_NAME   = T.IBN_NAME&#xD;&#xA;    AND V.EQP_NAME   = T.EQP_NAME&#xD;&#xA;    AND V.TAGSET_VER = T.TAGSET_VER&#xA;  WHERE V.FACTORY    = @factory&#xD;&#xA;    AND V.IBN_NAME   = @ibn_name&#xD;&#xA;    AND V.EQP_NAME   = @eqp_name&#xD;&#xA;    AND V.TAGSET_VER = @tagset_ver&#xA;)&#xD;&#xA;SELECT IBN.CNT_RK, IBN.CNT_NAME, IBN.TAG_ADDR, IBN.TAG_ADDR_ALIAS, MDL.PLC_TAG_FORMAT, MDL.TAG_FORMAT&#xD;&#xA;  FROM VersionData IBN&#xD;&#xA;  LEFT JOIN QRASMDLPTG MDL&#xD;&#xA;    ON IBN.FACTORY       = MDL.FACTORY&#xD;&#xA;   AND IBN.BUILD_MDL     = MDL.MODEL&#xD;&#xA;   AND IBN.BUILD_MDL_VER = MDL.MDL_VER&#xD;&#xA;   AND IBN.CNT_RK        = MDL.CNT_RK&#xD;&#xA;   AND IBN.TAG_ADDR      = MDL.PLC_TAG_ADDR">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
            <QP N="tagset_ver&#xA;" />
          </QY>
        </SG>
        <SG _S="1097" N="HasBranchV2Tag">
          <QY P="MsSql" Q="WITH VersionData AS (&#xD;&#xA; SELECT V.FACTORY, V.PTM_TAGSET_GROUP, V.PTM_TAGSET_NAME, V.PTM_TAGSET_VER, T.TAG_NAME, T.TAG_ADDR_ALIAS, T.TAG_VALUE_FILTER, T.TAG_CONDITION&#xD;&#xA;   FROM CEMSIBNVER V&#xD;&#xA;   LEFT JOIN CEMSIBNPTG T&#xD;&#xA;     ON V.FACTORY        = T.FACTORY&#xD;&#xA;    AND V.IBN_NAME       = T.IBN_NAME&#xD;&#xA;    AND V.EQP_NAME       = T.EQP_NAME&#xD;&#xA;    AND V.EQP_TAGSET_VER = T.EQP_TAGSET_VER&#xA;  WHERE V.FACTORY        = @factory&#xD;&#xA;    AND V.IBN_NAME       = @ibn_name&#xD;&#xA;    AND V.EQP_NAME       = @eqp_name&#xD;&#xA;    AND V.EQP_TAGSET_VER = @eqp_tagset_ver&#xA;)&#xD;&#xA;SELECT IBN.TAG_ADDR_ALIAS, IBN.TAG_VALUE_FILTER, IBN.TAG_CONDITION,  PTM.TAG_FULL_ADDRESS, PTM.TAG_PLC_FORMAT, PTM.TAG_FORMAT&#xD;&#xA;  FROM VersionData IBN&#xD;&#xA;  LEFT JOIN QSYSPTMTAG PTM&#xD;&#xA;    ON IBN.FACTORY          = PTM.FACTORY&#xD;&#xA;   AND IBN.PTM_TAGSET_GROUP = PTM.TAGSET_GROUP&#xD;&#xA;   AND IBN.PTM_TAGSET_NAME  = PTM.TAGSET_NAME&#xD;&#xA;   AND IBN.PTM_TAGSET_VER   = PTM.TAGSET_VER&#xD;&#xA;   AND IBN.TAG_NAME         = PTM.TAG_NAME">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
            <QP N="eqp_tagset_ver&#xA;" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="1255" N="HasBranchKeyTag">
          <QY P="MsSql" Q="SELECT TAG_NAME, LINKED_TAG_NAME &#xD;&#xA;FROM QEMSIBNTLM &#xD;&#xA;WHERE FACTORY = @factory&#xD;&#xA; AND IBN_NAME = @ibn_name&#xD;&#xA; AND EQP_NAME = @eqp_name&#xD;&#xA; AND EQP_TAGSET_VER = @eqp_tagset_ver">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
            <QP N="eqp_tagset_ver" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="1259" N="HasBranchDataSetMap">
          <QY P="MsSql" Q="SELECT COL_NAME, LINKED_TAG_NAME &#xD;&#xA;FROM QEMSIBNDSM &#xD;&#xA;WHERE FACTORY = @factory&#xD;&#xA; AND IBN_NAME = @ibn_name&#xD;&#xA; AND EQP_NAME = @eqp_name&#xD;&#xA; AND EQP_TAGSET_VER = @eqp_tagset_ver">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
            <QP N="eqp_tagset_ver" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="1098" N="UpdateBranchEquipment">
          <QY P="MsSql" Q="UPDATE QEMSIBNEQP SET&#xD;&#xA;  APPLIED_VER    = @applied_ver,&#xD;&#xA;  UPDATE_USER_ID = @update_user_id,&#xD;&#xA;  UPDATE_TIME    = @update_time&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND IBN_NAME  = @ibn_name&#xD;&#xA;   AND EQP_NAME  = @eqp_name">
            <QP N="applied_ver" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
          </QY>
        </SG>
      </F>
      <F _S="1185" N="BranchEnabled">
        <SG _S="1187" N="HasBranch">
          <QY P="MsSql" Q="SELECT IBN_NAME&#xD;&#xA;  FROM QEMSIBNDEF&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND IBN_NAME = @ibn_name">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="1188" N="HasBranchEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME, NEED_ACTION, ACTIVE_VER&#xD;&#xA;  FROM QEMSIBNEQP&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND IBN_NAME  = @ibn_name&#xD;&#xA;   AND EQP_NAME  = @eqp_name">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
