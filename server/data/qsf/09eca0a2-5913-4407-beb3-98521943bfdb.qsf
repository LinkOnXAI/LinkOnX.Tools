      <F _S="439" N="Eap">
        <SG _S="440" N="EapCount">
          <QY P="MsSql" Q="SELECT COUNT(EAP) AS CNT &#xD;&#xA;  FROM QRASEAPDEF &#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND EAP_TYPE     = @eap_type&#xD;&#xA;   AND DELETE_FLAG &lt;&gt; 'Y'">
            <QP N="factory" />
            <QP N="eap_type" />
          </QY>
        </SG>
        <SG _S="441" N="HasEapAtr">
          <QY P="MsSql" Q="SELECT EAP, PACKAGE, PKG_VER, MODEL, MDL_VER, LIBRARY, LIB_VER, EAP_SCHEMA&#xD;&#xA;  FROM QRASEAPATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP           = @eap&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
          </QY>
        </SG>
        <SG _S="442" N="HasEap">
          <QY P="MsSql" Q="SELECT A.EAP, A.EAP_TYPE, A.SERVER, A.STEP, A.UP_DOWN, A.STATUS,&#xD;&#xA;       A.DELETE_FLAG, A.NEED_ACTION, A.NEXT_NEED_ACTION, ALARM,&#xD;&#xA;       B.PACKAGE, B.PKG_VER, B.MODEL, B.MDL_VER, B.LIBRARY, B.LIB_VER,&#xD;&#xA;       B.EAP_SCHEMA&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B&#xD;&#xA;    ON A.FACTORY        = B.FACTORY&#xD;&#xA;   AND A.EAP            = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY  = @attr_category&#xD;&#xA; WHERE A.FACTORY        = @factory&#xD;&#xA;   AND A.EAP            = @eap">
            <QP N="attr_category" />
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="443" N="HasServer">
          <QY P="MsSql" Q="SELECT SVR_TYPE, SVR_IP, UP_DOWN, STATUS, EAS_UP_DOWN, B_SERVER, B_UP_DOWN, B_STATUS, B_EAS_UP_DOWN&#xD;&#xA;  FROM QSYSSVRDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SERVER      = @server&#xD;&#xA;   AND DELETE_FLAG = @delete_flag">
            <QP N="factory" />
            <QP N="server" />
            <QP N="delete_flag" />
          </QY>
        </SG>
        <SG _S="444" N="HasPackageVer">
          <QY P="MsSql" Q="SELECT PACKAGE&#xD;&#xA;  FROM QSYSPKGVER&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND PACKAGE = @package&#xD;&#xA;   AND PKG_VER = @pkg_ver">
            <QP N="factory" />
            <QP N="package" />
            <QP N="pkg_ver" />
          </QY>
        </SG>
        <SG _S="445" N="HasModelVer">
          <QY P="MsSql" Q="SELECT MODEL&#xD;&#xA;  FROM QSYSMDLVER&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND MODEL  = @model&#xD;&#xA;   AND MDL_VER = @mdl_ver">
            <QP N="factory" />
            <QP N="model" />
            <QP N="mdl_ver" />
          </QY>
        </SG>
        <SG _S="446" N="HasLibraryVer">
          <QY P="MsSql" Q="SELECT LIBRARY &#xD;&#xA;  FROM QSYSLIBVER&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND LIBRARY  = @library&#xD;&#xA;   AND LIB_VER  = @lib_ver">
            <QP N="factory" />
            <QP N="library" />
            <QP N="lib_ver" />
          </QY>
        </SG>
        <SG _S="447" N="HasDuplicateOfEquipmentName">
          <QY P="MsSql" Q="SELECT EAP&#xD;&#xA;  FROM QRASEAPCFG&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP          &lt;&gt; @eap&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category&#xD;&#xA;   AND OBJ_TYPE      = @obj_type&#xD;&#xA;   AND KEY_NAME      = @eqp_name_key&#xD;&#xA;   AND DATA          = @eqp_name">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
            <QP N="obj_type" />
            <QP N="eqp_name_key" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="448" N="HasEapEquipment">
          <QY P="MsSql" Q="SELECT EQP_DESC&#xD;&#xA;  FROM QRASEQPDEF&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND EQP_NAME     = @eqp_name&#xD;&#xA;   AND DELETE_FLAG  = 'N'">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="449" N="HasEapEquipmentAtr">
          <QY P="MsSql" Q="SELECT EQP_NAME&#xD;&#xA;  FROM QRASEQPATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP           = @eap&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category&#xD;&#xA; ORDER BY EQP_SEQ">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
          </QY>
        </SG>
        <SG _S="450" N="ListEap">
          <QY P="MsSql" Q="SELECT A.EAP, A.EAP_DESC, A.SERVER, A.STEP,&#xD;&#xA;       B.PACKAGE, B.PKG_VER, B.MODEL, B.MDL_VER, B.LIBRARY, B.LIB_VER&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = @attr_category&#xD;&#xA; WHERE A.FACTORY       = @factory   &#xD;&#xA;   AND A.DELETE_FLAG   = 'N'&#xD;&#xA; ORDER BY A.EAP">
            <QP N="attr_category" />
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="451" N="SearchEap">
          <QY P="MsSql" Q="SELECT A.EAP, A.EAP_DESC, A.EAP_TYPE, A.SERVER, A.STEP,&#xD;&#xA;       B.PACKAGE, B.PKG_VER, B.MODEL, B.MDL_VER, B.LIBRARY, B.LIB_VER&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = @attr_category&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.EAP           = @eap&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="attr_category" />
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="452" N="InsertEap">
          <QY P="MsSql" Q="INSERT INTO QRASEAPDEF (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EAP,&#xD;&#xA;   EAP_DESC,  &#xD;&#xA;   EAP_TYPE,&#xD;&#xA;   SERVER,&#xD;&#xA;   STEP,&#xD;&#xA;   UP_DOWN,&#xD;&#xA;   STATUS,&#xD;&#xA;   NEED_ACTION,&#xD;&#xA;   NEXT_NEED_ACTION,&#xD;&#xA;   ALARM,&#xD;&#xA;   LAST_EVENT_ID,&#xD;&#xA;   LAST_EVENT_TIME,&#xD;&#xA;   LAST_HIST_SEQ,&#xD;&#xA;   DELETE_FLAG,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @eap,&#xD;&#xA;   @eap_desc,&#xD;&#xA;   @eap_type,&#xD;&#xA;   @server,&#xD;&#xA;   @step,&#xD;&#xA;   @up_down,&#xD;&#xA;   @status,&#xD;&#xA;   @need_action,&#xD;&#xA;   @next_need_action,&#xD;&#xA;   @alarm,&#xD;&#xA;   @last_event_id,&#xD;&#xA;   @last_event_time,&#xD;&#xA;   @last_hist_seq,&#xD;&#xA;   @delete_flag,   &#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="eap_desc" />
            <QP N="eap_type" />
            <QP N="server" />
            <QP N="step" />
            <QP N="up_down" />
            <QP N="status" />
            <QP N="need_action" />
            <QP N="next_need_action" />
            <QP N="alarm" />
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="last_hist_seq" />
            <QP N="delete_flag" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="453" N="InsertEapAtr">
          <QY P="MsSql" Q="INSERT INTO QRASEAPATR (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EAP,&#xD;&#xA;   ATTR_CATEGORY,&#xD;&#xA;   PACKAGE,&#xD;&#xA;   PKG_VER,&#xD;&#xA;   MODEL,&#xD;&#xA;   MDL_VER,&#xD;&#xA;   LIBRARY,&#xD;&#xA;   LIB_VER,&#xD;&#xA;   EAP_SCHEMA,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @eap,&#xD;&#xA;   @attr_category,&#xD;&#xA;   @package,&#xD;&#xA;   @pkg_ver,&#xD;&#xA;   @model,&#xD;&#xA;   @mdl_ver,&#xD;&#xA;   @library,&#xD;&#xA;   @lib_ver,&#xD;&#xA;   @eap_schema,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
            <QP N="package" />
            <QP N="pkg_ver" />
            <QP N="model" />
            <QP N="mdl_ver" />
            <QP N="library" />
            <QP N="lib_ver" />
            <QP N="eap_schema" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="454" N="InsertEapConfig">
          <QY P="MsSql" Q="INSERT INTO QRASEAPCFG (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EAP,&#xD;&#xA;   ATTR_CATEGORY,&#xD;&#xA;   OBJ_TYPE,&#xD;&#xA;   OBJ_NAME,&#xD;&#xA;   KEY_SEQ,&#xD;&#xA;   KEY_NAME,&#xD;&#xA;   DATA,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @eap,&#xD;&#xA;   @attr_category,&#xD;&#xA;   @obj_type,&#xD;&#xA;   @obj_name,&#xD;&#xA;   @key_seq,&#xD;&#xA;   @key_name,&#xD;&#xA;   @data,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
            <QP N="obj_type" />
            <QP N="obj_name" />
            <QP N="key_seq" />
            <QP N="key_name" />
            <QP N="data" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="455" N="UpdateEap">
          <QY P="MsSql" Q="UPDATE QRASEAPDEF SET&#xD;&#xA;  EAP_DESC         = @eap_desc,&#xD;&#xA;  EAP_TYPE         = @eap_type,&#xD;&#xA;  SERVER           = @server,&#xD;&#xA;  STEP             = @step,&#xD;&#xA;  UP_DOWN          = @up_down,&#xD;&#xA;  STATUS           = @status, &#xD;&#xA;  NEED_ACTION	   = @need_action,&#xD;&#xA;  NEXT_NEED_ACTION = @next_need_action,&#xD;&#xA;  ALARM            = @alarm,&#xD;&#xA;  LAST_EVENT_ID    = @last_event_id,&#xD;&#xA;  LAST_EVENT_TIME  = @last_event_time,&#xD;&#xA;  LAST_HIST_SEQ    = @hist_seq,&#xD;&#xA;  DELETE_FLAG      = @delete_flag,&#xD;&#xA;  UPDATE_USER_ID   = @update_user_id,&#xD;&#xA;  UPDATE_TIME      = @update_time&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EAP     = @eap">
            <QP N="eap_desc" />
            <QP N="eap_type" />
            <QP N="server" />
            <QP N="step" />
            <QP N="up_down" />
            <QP N="status" />
            <QP N="need_action" />
            <QP N="next_need_action" />
            <QP N="alarm" />
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="hist_seq" />
            <QP N="delete_flag" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="456" N="UpdateEapAtr">
          <QY P="MsSql" Q="UPDATE QRASEAPATR SET&#xD;&#xA;  PACKAGE      	               = @package,&#xD;&#xA;  PKG_VER                      = @pkg_ver,&#xD;&#xA;  MODEL = @model,&#xD;&#xA;  MDL_VER                      = @mdl_ver,&#xD;&#xA;  LIBRARY                      = @library,&#xD;&#xA;  LIB_VER                      = @lib_ver,&#xD;&#xA;  EAP_SCHEMA                   = @eap_schema,&#xD;&#xA;  UPDATE_USER_ID               = @update_user_id,&#xD;&#xA;  UPDATE_TIME                  = @update_time&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP           = @eap&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="package" />
            <QP N="pkg_ver" />
            <QP N="model" />
            <QP N="mdl_ver" />
            <QP N="library" />
            <QP N="lib_ver" />
            <QP N="eap_schema" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
          </QY>
        </SG>
        <SG _S="457" N="DeleteEap">
          <QY P="MsSql" Q="UPDATE QRASEAPDEF SET&#xD;&#xA;  LAST_EVENT_ID   = @last_event_id,&#xD;&#xA;  LAST_EVENT_TIME = @last_event_time,&#xD;&#xA;  LAST_HIST_SEQ   = @hist_seq,&#xD;&#xA;  DELETE_FLAG     = @delete_flag,&#xD;&#xA;  UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;  UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EAP     = @eap">
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="hist_seq" />
            <QP N="delete_flag" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="458" N="DeleteEapAtr">
          <QY P="MsSql" Q="DELETE FROM QRASEAPATR&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EAP     = @eap">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="459" N="DeleteEapConfigForUpdate">
          <QY P="MsSql" Q="DELETE FROM QRASEAPCFG&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP           = @eap&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
          </QY>
        </SG>
        <SG _S="460" N="DeleteEapConfig">
          <QY P="MsSql" Q="DELETE FROM QRASEAPCFG&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP           = @eap">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="461" N="DeleteEapConnectorSts">
          <QY P="MsSql" Q="DELETE FROM QRASCNTSTS&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EAP     = @eap">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="1184" N="DeleteEapBranchConnectorSts">
          <QY P="MsSql" Q="DELETE FROM QEMSBNTSTS&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EAP     = @eap">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
