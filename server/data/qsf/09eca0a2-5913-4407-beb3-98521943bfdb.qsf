          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="1296" N="HasPlcTagSetPreviousVersionTags">
          <QY P="MsSql" Q="WITH V AS&#xA;(&#xA;    SELECT ISNULL(MAX(TAGSET_VER), 0) AS PREV_TAGSET_VER&#xA;      FROM QSYSPTMVER&#xA;     WHERE FACTORY      = @factory&#xA;       AND TAGSET_GROUP = @tagset_group&#xA;       AND TAGSET_NAME  = @tagset_name&#xA;       AND TAGSET_VER   &lt; @tagset_ver&#xA;       AND DELETE_FLAG  = 'N'&#xA;)&#xA;SELECT T.TAG_CATEGORY, T.TAG_NAME, T.TAG_DESC, &#xA;       T.TAG_REGISTER, T.TAG_DEC_ADDRESS, T.TAG_FULL_ADDRESS, T.TAG_INPUT_ADDRESS,&#xA;	   T.TAG_PLC_FORMAT, T.TAG_FORMAT, T.TAG_LENGTH, T.TAG_ALARM, T.TAG_TYPE, T.TAG_BRANCH&#xA;  FROM V&#xA;  JOIN dbo.QSYSPTMTAG T&#xA;    ON T.FACTORY         = @factory&#xA;   AND T.TAGSET_GROUP    = @tagset_group&#xA;   AND T.TAGSET_NAME     = @tagset_name&#xA;   AND T.TAGSET_VER      = V.PREV_TAGSET_VER&#xA; WHERE V.PREV_TAGSET_VER &gt; 0">
            <QP N="factory&#xA;" />
            <QP N="tagset_group&#xA;" />
            <QP N="tagset_name&#xA;" />
            <QP N="tagset_ver&#xA;" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="1288" N="HasLinkLogicalTag">
          <QY P="MsSql" Q="SELECT TAG_NAME&#xD;&#xA;  FROM QSYSPTMPLL&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME  = @tagset_name">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="1360" N="HasLinkVariableId">
          <QY P="MsSql" Q="SELECT TAG_NAME&#xD;&#xA;  FROM QSYSPTMPVL&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME  = @tagset_name">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="417" N="CountPlcTagSet">
          <QY P="MsSql" Q="SELECT COUNT(*) AS CNT&#xD;&#xA;  FROM QSYSPTMDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TAGSET_GROUP = @tagset_group">
            <QP N="factory" />
            <QP N="tagset_group" />
          </QY>
        </SG>
        <SG _S="418" N="CountPlcTagSetVersion">
          <QY P="MsSql" Q="SELECT COUNT(*) AS CNT&#xD;&#xA;  FROM QSYSPTMVER&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME = @tagset_name&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="419" N="CountPlcTagSetTags">
          <QY P="MsSql" Q="SELECT COUNT(*) AS CNT&#xD;&#xA;  FROM QSYSPTMTAG&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME = @tagset_name&#xD;&#xA;   AND TAGSET_VER = @tagset_ver">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
            <QP N="tagset_ver" />
          </QY>
        </SG>
        <SG _S="420" N="SearchLastPlcTagSetVersion">
          <QY P="MsSql" Q="SELECT ISNULL(V.TAGSET_VER, 0) AS TAGSET_VER, &#xD;&#xA;       ISNULL(V.TAGSET_VER_DESC, ' ') AS TAGSET_VER_DESC&#xD;&#xA;  FROM &#xD;&#xA;     (&#xD;&#xA;SELECT TOP (1) TAGSET_VER, TAGSET_VER_DESC&#xD;&#xA;  FROM QSYSPTMVER&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME  = @tagset_name&#xD;&#xA;   AND DELETE_FLAG  = 'N'&#xD;&#xA; ORDER BY TAGSET_VER DESC&#xD;&#xA;     ) AS V">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="421" N="ListPlcTagSetGroup">
          <QY P="MsSql" Q="SELECT GROUP_NAME, GROUP_DESC&#xD;&#xA;  FROM QSYSPTMGRP&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="422" N="ListPlcTagSet">
          <QY P="MsSql" Q="SELECT A.TAGSET_NAME, A.TAGSET_DESC, A.TAGSET_LAST_VER, &#xD;&#xA;       A.TAGSET_PLC_MAKER, A.TAGSET_PLC_MODEL,&#xD;&#xA;	   A.TAGSET_OPER, A.TAGSET_AREA, A.TAGSET_LINE,&#xD;&#xA;	   A.CMF_1, A.CMF_2, A.CMF_3, A.CMF_4, A.CMF_5, &#xD;&#xA;	   A.CMF_6, A.CMF_7, A.CMF_8, A.CMF_9, A.CMF_10, &#xD;&#xA;       A.CREATE_TIME, CASE WHEN USER_C.USER_NAME IS NULL THEN A.CREATE_USER_ID ELSE CONCAT(A.CREATE_USER_ID, ' [', USER_C.USER_NAME, ']') END AS CREATE_USER , &#xD;&#xA;       A.UPDATE_TIME, CASE WHEN USER_U.USER_NAME IS NULL THEN A.UPDATE_USER_ID ELSE CONCAT(A.UPDATE_USER_ID, ' [', USER_U.USER_NAME, ']') END AS UPDATE_USER&#xD;&#xA;  FROM (&#xD;&#xA;SELECT *&#xD;&#xA;  FROM QSYSPTMDEF&#xD;&#xA; WHERE FACTORY      = @factory   &#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;       )  A&#xD;&#xA;  LEFT JOIN QSECUSRDEF USER_C&#xD;&#xA;    ON A.FACTORY        = USER_C.FACTORY&#xD;&#xA;   AND A.CREATE_USER_ID = USER_C.USER_ID&#xD;&#xA;  LEFT JOIN QSECUSRDEF USER_U&#xD;&#xA;    ON A.FACTORY        = USER_U.FACTORY&#xD;&#xA;   AND A.UPDATE_USER_ID = USER_U.USER_ID&#xD;&#xA; ORDER BY A.TAGSET_NAME">
            <QP N="factory" />
            <QP N="tagset_group" />
          </QY>
        </SG>
        <SG _S="423" N="ListPlcPresetTags">
          <QY P="MsSql" Q="SELECT A.PRESET_CATEGORY, B.TAG_SEQ, B.TAG_NAME, B.TAG_DESC, &#xD;&#xA;       B.TAG_REGISTER, B.TAG_DEC_ADDRESS, B.TAG_FULL_ADDRESS, B.TAG_INPUT_ADDRESS,&#xD;&#xA;       B.TAG_PLC_FORMAT, B.TAG_FORMAT, B.TAG_LENGTH, A.IS_ALARM, B.TAG_TYPE, B.TAG_BRANCH,&#xD;&#xA;	   B.CMF_1, B.CMF_2, B.CMF_3, B.CMF_4, B.CMF_5, B.CMF_6, B.CMF_7, B.CMF_8, B.CMF_9, B.CMF_10 &#xD;&#xA;  FROM QSYSPTMPRS A&#xD;&#xA;  LEFT JOIN QSYSPTMPTG B&#xD;&#xA;    ON A.FACTORY      = B.FACTORY&#xD;&#xA;   AND A.PRESET_GROUP = B.PRESET_GROUP&#xD;&#xA;   AND A.PRESET_NAME  = B.PRESET_NAME&#xD;&#xA; WHERE A.FACTORY      = @factory&#xD;&#xA;   AND A.PRESET_GROUP = @preset_group&#xD;&#xA;   AND A.PRESET_NAME  = @preset_name&#xD;&#xA; ORDER BY B.TAG_SEQ">
            <QP N="factory" />
            <QP N="preset_group" />
            <QP N="preset_name" />
          </QY>
        </SG>
        <SG _S="424" N="ListPlcTagSetVersion">
          <QY P="MsSql" Q="SELECT VER.TAGSET_VER, VER.TAGSET_VER_DESC,&#xD;&#xA;       VER.CREATE_TIME, CASE WHEN USER_C.USER_NAME IS NULL THEN VER.CREATE_USER_ID ELSE CONCAT(VER.CREATE_USER_ID, ' [', USER_C.USER_NAME, ']') END AS CREATE_USER , &#xD;&#xA;	   VER.UPDATE_TIME, CASE WHEN USER_U.USER_NAME IS NULL THEN VER.UPDATE_USER_ID ELSE CONCAT(VER.UPDATE_USER_ID, ' [', USER_U.USER_NAME, ']') END AS UPDATE_USER&#xD;&#xA;  FROM (&#xD;&#xA;SELECT FACTORY, TAGSET_VER, TAGSET_VER_DESC, CREATE_TIME, CREATE_USER_ID, UPDATE_TIME, UPDATE_USER_ID&#xD;&#xA;  FROM QSYSPTMVER&#xD;&#xA; WHERE FACTORY      = @factory   &#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME  = @tagset_name&#xD;&#xA;   AND DELETE_FLAG  = 'N'&#xD;&#xA;       ) VER&#xD;&#xA;  LEFT JOIN QSECUSRDEF USER_C&#xD;&#xA;    ON VER.FACTORY        = USER_C.FACTORY&#xD;&#xA;   AND VER.CREATE_USER_ID = USER_C.USER_ID&#xD;&#xA;  LEFT JOIN QSECUSRDEF USER_U&#xD;&#xA;    ON VER.FACTORY        = USER_U.FACTORY&#xD;&#xA;   AND VER.UPDATE_USER_ID = USER_U.USER_ID&#xD;&#xA; ORDER BY VER.TAGSET_VER DESC">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="425" N="ListPlcTagSetVersionPaging">
          <QY P="MsSql" Q="SELECT VER.TAGSET_VER, VER.TAGSET_VER_DESC,&#xD;&#xA;       VER.CREATE_TIME, CASE WHEN USER_C.USER_NAME IS NULL THEN VER.CREATE_USER_ID ELSE CONCAT(VER.CREATE_USER_ID, ' [', USER_C.USER_NAME, ']') END AS CREATE_USER , &#xD;&#xA;	   VER.UPDATE_TIME, CASE WHEN USER_U.USER_NAME IS NULL THEN VER.UPDATE_USER_ID ELSE CONCAT(VER.UPDATE_USER_ID, ' [', USER_U.USER_NAME, ']') END AS UPDATE_USER&#xD;&#xA;  FROM (&#xD;&#xA;SELECT FACTORY, TAGSET_VER, TAGSET_VER_DESC, CREATE_TIME, CREATE_USER_ID, UPDATE_TIME, UPDATE_USER_ID&#xD;&#xA;  FROM QSYSPTMVER&#xD;&#xA; WHERE FACTORY      = @factory   &#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME  = @tagset_name&#xD;&#xA;   AND DELETE_FLAG  = 'N'&#xD;&#xA;   ORDER BY TAGSET_VER DESC&#xD;&#xA;   OFFSET (CONVERT(int, @PAGE_NO)-1) * CONVERT(int, @PAGE_SIZE) ROW FETCH NEXT CONVERT(int, @PAGE_SIZE) ROW ONLY&#xD;&#xA;       ) VER&#xD;&#xA;  LEFT JOIN QSECUSRDEF USER_C&#xD;&#xA;    ON VER.FACTORY        = USER_C.FACTORY&#xD;&#xA;   AND VER.CREATE_USER_ID = USER_C.USER_ID&#xD;&#xA;  LEFT JOIN QSECUSRDEF USER_U&#xD;&#xA;    ON VER.FACTORY        = USER_U.FACTORY&#xD;&#xA;   AND VER.UPDATE_USER_ID = USER_U.USER_ID&#xD;&#xA; ORDER BY VER.TAGSET_VER DESC">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
            <QP N="PAGE_NO" />
            <QP N="PAGE_SIZE" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="426" N="SearchPlcTagSetList">
          <QY P="MsSql" Q="SELECT TAGSET_NAME, TAGSET_DESC, TAGSET_LAST_VER&#xD;&#xA; FROM QSYSPTMDEF&#xD;&#xA;WHERE FACTORY = @factory &#xD;&#xA; AND TAGSET_GROUP = @tagset_group">
            <QP N="factory" />
            <QP N="tagset_group" />
          </QY>
        </SG>
        <SG _S="427" N="ListPlcTagSetTags">
          <QY P="MsSql" Q="SELECT TAG_CATEGORY, TAG_SEQ, TAG_NAME, TAG_DESC, &#xD;&#xA;       TAG_REGISTER, TAG_DEC_ADDRESS, TAG_FULL_ADDRESS,	TAG_INPUT_ADDRESS,&#xD;&#xA;       TAG_PLC_FORMAT, TAG_FORMAT, TAG_LENGTH, TAG_ALARM, TAG_TYPE, TAG_BRANCH,&#xD;&#xA;	   CMF_1, CMF_2, CMF_3, CMF_4, CMF_5, CMF_6, CMF_7, CMF_8, CMF_9, CMF_10 &#xD;&#xA;  FROM QSYSPTMTAG&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME  = @tagset_name&#xD;&#xA;   AND TAGSET_VER   = @tagset_ver&#xD;&#xA; ORDER BY TAG_SEQ">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
            <QP N="tagset_ver" />
          </QY>
        </SG>
        <SG _S="428" N="ListPlcTagSetTagsPaging">
          <QY P="MsSql" Q="SELECT TAG_CATEGORY, TAG_SEQ, TAG_NAME, TAG_DESC, &#xD;&#xA;       TAG_REGISTER, TAG_DEC_ADDRESS, TAG_FULL_ADDRESS,	TAG_INPUT_ADDRESS,&#xD;&#xA;       TAG_PLC_FORMAT, TAG_FORMAT, TAG_LENGTH, TAG_ALARM, TAG_TYPE, TAG_BRANCH,&#xD;&#xA;	   CMF_1, CMF_2, CMF_3, CMF_4, CMF_5, CMF_6, CMF_7, CMF_8, CMF_9, CMF_10 &#xD;&#xA;  FROM QSYSPTMTAG&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME = @tagset_name&#xD;&#xA;   AND TAGSET_VER  = @tagset_ver&#xD;&#xA; ORDER BY TAG_SEQ&#xD;&#xA; OFFSET (CONVERT(int, @PAGE_NO)-1) * CONVERT(int, @PAGE_SIZE) ROW FETCH NEXT CONVERT(int, @PAGE_SIZE) ROW ONLY">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
            <QP N="tagset_ver" />
            <QP N="PAGE_NO" />
            <QP N="PAGE_SIZE" />
          </QY>
        </SG>
        <SG _S="429" N="InsertPlcTagSetVersion">
          <QY P="MsSql" Q="INSERT INTO QSYSPTMVER(&#xD;&#xA;   FACTORY,   &#xD;&#xA;   TAGSET_VER,&#xD;&#xA;   TAGSET_VER_DESC,&#xD;&#xA;   TAGSET_GROUP,&#xD;&#xA;   TAGSET_NAME,&#xD;&#xA;   DELETE_FLAG,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @tagset_ver,&#xD;&#xA;   @tagset_ver_desc,&#xD;&#xA;   @tagset_group,&#xD;&#xA;   @tagset_name,&#xD;&#xA;   'N',&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;   )">
            <QP N="factory" />
            <QP N="tagset_ver" />
            <QP N="tagset_ver_desc" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="430" N="InsertPlcTagSetTag">
          <QY P="MsSql" Q="INSERT INTO QSYSPTMTAG (&#xD;&#xA;   FACTORY,&#xD;&#xA;   TAGSET_GROUP,&#xD;&#xA;   TAGSET_NAME,&#xD;&#xA;   TAGSET_VER,&#xD;&#xA;   TAG_SEQ,&#xD;&#xA;   TAG_CATEGORY,&#xD;&#xA;   TAG_NAME,&#xD;&#xA;   TAG_DESC,&#xD;&#xA;   TAG_REGISTER,&#xD;&#xA;   TAG_DEC_ADDRESS,&#xD;&#xA;   TAG_FULL_ADDRESS,&#xD;&#xA;   TAG_INPUT_ADDRESS,&#xD;&#xA;   TAG_TYPE,&#xD;&#xA;   TAG_FORMAT,&#xD;&#xA;   TAG_PLC_FORMAT,&#xD;&#xA;   TAG_LENGTH,&#xD;&#xA;   TAG_ALARM,&#xD;&#xA;   TAG_BRANCH,&#xD;&#xA;   CMF_1,&#xD;&#xA;   CMF_2,&#xD;&#xA;   CMF_3,&#xD;&#xA;   CMF_4,&#xD;&#xA;   CMF_5,&#xD;&#xA;   CMF_6,&#xD;&#xA;   CMF_7,&#xD;&#xA;   CMF_8,&#xD;&#xA;   CMF_9,&#xD;&#xA;   CMF_10,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @tagset_group,&#xD;&#xA;   @tagset_name,&#xD;&#xA;   @tagset_ver,&#xD;&#xA;   @tag_seq,&#xD;&#xA;   @tag_category,&#xD;&#xA;   @tag_name,&#xD;&#xA;   @tag_desc,&#xD;&#xA;   @tag_register,&#xD;&#xA;   @tag_dec_address,&#xD;&#xA;   @tag_full_address,&#xD;&#xA;   @tag_input_address,&#xD;&#xA;   @tag_type,&#xD;&#xA;   @tag_format,&#xD;&#xA;   @tag_plc_format,&#xD;&#xA;   @tag_length,&#xD;&#xA;   @tag_alarm,&#xD;&#xA;   @tag_branch,&#xD;&#xA;   @cmf_1,&#xD;&#xA;   @cmf_2,&#xD;&#xA;   @cmf_3,&#xD;&#xA;   @cmf_4,&#xD;&#xA;   @cmf_5,&#xD;&#xA;   @cmf_6,&#xD;&#xA;   @cmf_7,&#xD;&#xA;   @cmf_8,&#xD;&#xA;   @cmf_9,&#xD;&#xA;   @cmf_10,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time&#xD;&#xA;   )">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
            <QP N="tagset_ver" />
            <QP N="tag_seq" />
            <QP N="tag_category" />
            <QP N="tag_name" />
            <QP N="tag_desc" />
            <QP N="tag_register" />
            <QP N="tag_dec_address" />
            <QP N="tag_full_address" />
            <QP N="tag_input_address" />
            <QP N="tag_type" />
            <QP N="tag_format" />
            <QP N="tag_plc_format" />
            <QP N="tag_length" />
            <QP N="tag_alarm" />
            <QP N="tag_branch" />
            <QP N="cmf_1" />
            <QP N="cmf_2" />
            <QP N="cmf_3" />
            <QP N="cmf_4" />
            <QP N="cmf_5" />
            <QP N="cmf_6" />
            <QP N="cmf_7" />
            <QP N="cmf_8" />
            <QP N="cmf_9" />
            <QP N="cmf_10" />
            <QP N="create_user_id" />
            <QP N="create_time" />
          </QY>
        </SG>
        <SG _S="431" N="UpdateLastPlcTagSetVersion">
          <QY P="MsSql" Q="UPDATE QSYSPTMDEF SET&#xD;&#xA;   TAGSET_LAST_VER        = @last_ver&#xD;&#xA; WHERE FACTORY            = @factory&#xD;&#xA;   AND TAGSET_GROUP       = @tagset_group&#xD;&#xA;   AND TAGSET_NAME        = @tagset_name">
            <QP N="last_ver" />
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
          </QY>
        </SG>
        <SG _S="432" N="InsertPtmHistory">
          <QY P="MsSql" Q="INSERT INTO QSYSPTMHIS (&#xD;&#xA;   FACTORY,&#xD;&#xA;   TAGSET_VER,&#xD;&#xA;   TAGSET_GROUP,	&#xD;&#xA;   TAGSET_NAME,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   EVENT_ID,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT      &#xD;&#xA;) &#xD;&#xA;VALUES( &#xD;&#xA;   @factory,&#xD;&#xA;   @tagset_ver,&#xD;&#xA;   @tagset_group,&#xD;&#xA;   @tagset_name,&#xD;&#xA;   @hist_seq,&#xD;&#xA;   @event_id,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @tran_user_id,&#xD;&#xA;   @tran_comment&#xD;&#xA;);">
            <QP N="factory" />
            <QP N="tagset_ver" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
            <QP N="hist_seq" />
            <QP N="event_id" />
            <QP N="tran_time" />
            <QP N="tran_user_id" />
            <QP N="tran_comment" />
          </QY>
        </SG>
        <SG _S="433" N="InsertPlcTagSetTagHistory">
          <QY P="MsSql" Q="INSERT INTO QSYSPTMTHS (&#xD;&#xA;   FACTORY,&#xD;&#xA;   TAGSET_GROUP,&#xD;&#xA;   TAGSET_NAME,&#xD;&#xA;   TAGSET_VER,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   TAG_SEQ,&#xD;&#xA;   TAG_CATEGORY,&#xD;&#xA;   TAG_NAME,&#xD;&#xA;   TAG_DESC,&#xD;&#xA;   TAG_REGISTER,&#xD;&#xA;   TAG_DEC_ADDRESS,&#xD;&#xA;   TAG_FULL_ADDRESS,&#xD;&#xA;   TAG_TYPE,&#xD;&#xA;   TAG_FORMAT,&#xD;&#xA;   TAG_PLC_FORMAT,&#xD;&#xA;   TAG_LENGTH,&#xD;&#xA;   TAG_ALARM,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @tagset_group,&#xD;&#xA;   @tagset_name,&#xD;&#xA;   @tagset_ver,&#xD;&#xA;   @hist_seq,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @tag_seq,&#xD;&#xA;   @tag_category,&#xD;&#xA;   @tag_name,&#xD;&#xA;   @tag_desc,&#xD;&#xA;   @tag_register,&#xD;&#xA;   @tag_dec_address,&#xD;&#xA;   @tag_full_address,&#xD;&#xA;   @tag_type,&#xD;&#xA;   @tag_format,&#xD;&#xA;   @tag_plc_format,&#xD;&#xA;   @tag_length,&#xD;&#xA;   @tag_alarm,&#xD;&#xA;   @tran_user_id,&#xD;&#xA;   @tran_comment&#xD;&#xA;   )">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
            <QP N="tagset_ver" />
            <QP N="hist_seq" />
            <QP N="tran_time" />
            <QP N="tag_seq" />
            <QP N="tag_category" />
            <QP N="tag_name" />
            <QP N="tag_desc" />
            <QP N="tag_register" />
            <QP N="tag_dec_address" />
            <QP N="tag_full_address" />
            <QP N="tag_type" />
            <QP N="tag_format" />
            <QP N="tag_plc_format" />
