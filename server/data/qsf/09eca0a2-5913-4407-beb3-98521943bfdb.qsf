          <QY P="SQLite" />
        </SG>
      </F>
    </M>
    <M _S="1099" N="EapServerWatcher">
      <F _S="1100" N="Init">
        <SG _S="1101" N="ListFactory">
          <QY P="MsSql" Q="SELECT FACTORY&#xD;&#xA;  FROM QSYSFACDEF" />
        </SG>
        <SG _S="1102" N="ListServer">
          <QY P="MsSql" Q="SELECT SERVER, SVR_IP, B_USED, B_MODE, B_SERVER, UP_DOWN &#xD;&#xA;  FROM QSYSSVRDEF&#xD;&#xA;  WITH (NOLOCK)&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SVR_TYPE    = @svr_type&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="svr_type" />
          </QY>
        </SG>
      </F>
      <F _S="1103" N="EapServerWatcherControl">
        <SG _S="1104" N="ListServer">
          <QY P="MsSql" Q="SELECT FACTORY, SERVER, SVR_IP, B_USED, B_MODE, B_SERVER, DELETE_FLAG&#xD;&#xA;  FROM QSYSSVRDEF&#xD;&#xA;  WITH (NOLOCK)&#xD;&#xA; WHERE SVR_TYPE = @svr_type">
            <QP N="svr_type" />
          </QY>
        </SG>
        <SG _S="1105" N="HasServer">
          <QY P="MsSql" Q="SELECT FACTORY, SERVER, SVR_IP, B_USED, B_MODE, B_SERVER, DELETE_FLAG&#xD;&#xA;  FROM QSYSSVRDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND SERVER  = @server ">
            <QP N="factory" />
            <QP N="server" />
          </QY>
        </SG>
      </F>
      <F _S="1106" N="EapServerUp">
        <SG _S="1107" N="SearchServer">
          <QY P="MsSql" Q="SELECT UP_DOWN, STATUS, EAS_UP_DOWN&#xD;&#xA;  FROM QSYSSVRDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SERVER      = @server&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="server" />
          </QY>
        </SG>
        <SG _S="1108" N="UpdateServer">
          <QY P="MsSql" Q="UPDATE QSYSSVRDEF SET&#xD;&#xA;  UP_DOWN         = @up_down,&#xD;&#xA;  LAST_EVENT_ID   = @last_event_id,&#xD;&#xA;  LAST_EVENT_TIME = @last_event_time,&#xD;&#xA;  LAST_HIST_SEQ   = @hist_seq,&#xD;&#xA;  UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;  UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND SERVER  = @server">
            <QP N="up_down" />
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="hist_seq" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="server" />
          </QY>
        </SG>
        <SG _S="1109" N="UpdateMainServer">
          <QY P="MsSql" Q="UPDATE QSYSSVRDEF SET&#xD;&#xA;  B_UP_DOWN       = @b_up_down,&#xD;&#xA;  LAST_EVENT_ID   = @last_event_id,&#xD;&#xA;  LAST_EVENT_TIME = @last_event_time,&#xD;&#xA;  LAST_HIST_SEQ   = @hist_seq,&#xD;&#xA;  UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;  UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND B_SERVER    = @b_server&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="b_up_down" />
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="hist_seq" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="b_server" />
          </QY>
        </SG>
      </F>
      <F _S="1110" N="EapServerDown">
        <SG _S="1111" N="SearchServer">
          <QY P="MsSql" Q="SELECT UP_DOWN, STATUS, EAS_UP_DOWN&#xD;&#xA;  FROM QSYSSVRDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SERVER      = @server&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="server" />
          </QY>
        </SG>
        <SG _S="1112" N="UpdateServer">
          <QY P="MsSql" Q="UPDATE QSYSSVRDEF SET&#xD;&#xA;  UP_DOWN         = @up_down,&#xD;&#xA;  EAS_UP_DOWN     = @eas_up_down,&#xD;&#xA;  LAST_EVENT_ID   = @last_event_id,&#xD;&#xA;  LAST_EVENT_TIME = @last_event_time,&#xD;&#xA;  LAST_HIST_SEQ   = @hist_seq,&#xD;&#xA;  UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;  UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND SERVER  = @server">
            <QP N="up_down" />
            <QP N="eas_up_down" />
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="hist_seq" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="server" />
          </QY>
        </SG>
        <SG _S="1113" N="UpdateMainServer">
          <QY P="MsSql" Q="UPDATE QSYSSVRDEF SET&#xD;&#xA;  B_UP_DOWN       = @b_up_down,&#xD;&#xA;  B_EAS_UP_DOWN   = @b_eas_up_down,&#xD;&#xA;  LAST_EVENT_ID   = @last_event_id,&#xD;&#xA;  LAST_EVENT_TIME = @last_event_time,&#xD;&#xA;  LAST_HIST_SEQ   = @hist_seq,&#xD;&#xA;  UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;  UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND B_SERVER    = @b_server&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="b_up_down" />
            <QP N="b_eas_up_down" />
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="hist_seq" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="b_server" />
          </QY>
        </SG>
      </F>
      <F _S="1114" N="EapServerAutoFailOver">
        <SG _S="1115" N="HasBackupServer">
          <QY P="MsSql" Q="SELECT SVR_IP, UP_DOWN, STATUS, EAS_UP_DOWN&#xD;&#xA;  FROM QSYSSVRDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SERVER      = @b_server&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="b_server" />
          </QY>
        </SG>
        <SG _S="1116" N="ListEap">
          <QY P="MsSql" Q="SELECT A.EAP, A.STEP, A.UP_DOWN,&#xD;&#xA;       B.PACKAGE, B.PKG_VER, B.MODEL, B.MDL_VER, B.LIBRARY, B.LIB_VER&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  LEFT JOIN QRASEAPATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Applied'  &#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.SERVER      = @server&#xD;&#xA;   AND A.DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="server" />
          </QY>
        </SG>
        <SG _S="1117" N="UpdateEap">
          <QY P="MsSql" Q="UPDATE QRASEAPDEF SET&#xD;&#xA;  STATUS          = @status,&#xD;&#xA;  LAST_EVENT_ID   = @last_event_id,&#xD;&#xA;  LAST_EVENT_TIME = @last_event_time,&#xD;&#xA;  LAST_HIST_SEQ   = @hist_seq,&#xD;&#xA;  UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;  UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EAP     = @eap">
            <QP N="status" />
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="hist_seq" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="1118" N="UpdateServer">
          <QY P="MsSql" Q="UPDATE QSYSSVRDEF SET&#xD;&#xA;  STATUS          = @status,&#xD;&#xA;  LAST_EVENT_ID   = @last_event_id,&#xD;&#xA;  LAST_EVENT_TIME = @last_event_time,&#xD;&#xA;  LAST_HIST_SEQ   = @hist_seq,&#xD;&#xA;  UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;  UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND SERVER  = @server">
            <QP N="status" />
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="hist_seq" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="server" />
          </QY>
        </SG>
        <SG _S="1119" N="UpdateMainServer">
          <QY P="MsSql" Q="UPDATE QSYSSVRDEF SET&#xD;&#xA;  B_STATUS        = @b_status,&#xD;&#xA;  LAST_EVENT_ID   = @last_event_id,&#xD;&#xA;  LAST_EVENT_TIME = @last_event_time,&#xD;&#xA;  LAST_HIST_SEQ   = @hist_seq,&#xD;&#xA;  UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;  UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND B_SERVER    = @b_server&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="b_status" />
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="hist_seq" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="b_server" />
          </QY>
        </SG>
      </F>
      <F _S="1120" N="EAServiceDown">
        <SG _S="1121" N="SearchServer">
          <QY P="MsSql" Q="SELECT EAS_UP_DOWN&#xD;&#xA;  FROM QSYSSVRDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SERVER      = @server&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="server" />
          </QY>
        </SG>
        <SG _S="1122" N="SearchMainServer">
          <QY P="MsSql" Q="SELECT SERVER&#xD;&#xA;  FROM QSYSSVRDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND B_SERVER    = @b_server&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="b_server" />
          </QY>
        </SG>
        <SG _S="1123" N="UpdateServer">
          <QY P="MsSql" Q="UPDATE QSYSSVRDEF SET&#xD;&#xA;  EAS_UP_DOWN     = @eas_up_down,&#xD;&#xA;  LAST_EVENT_ID   = @last_event_id,&#xD;&#xA;  LAST_EVENT_TIME = @last_event_time,&#xD;&#xA;  LAST_HIST_SEQ   = @hist_seq,   &#xD;&#xA;  UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;  UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND SERVER  = @server">
            <QP N="eas_up_down" />
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="hist_seq" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="server" />
          </QY>
        </SG>
        <SG _S="1124" N="UpdateMainServer">
          <QY P="MsSql" Q="UPDATE QSYSSVRDEF SET&#xD;&#xA;  B_EAS_UP_DOWN   = @b_eas_up_down,&#xD;&#xA;  LAST_EVENT_ID   = @last_event_id,&#xD;&#xA;  LAST_EVENT_TIME = @last_event_time,&#xD;&#xA;  LAST_HIST_SEQ   = @hist_seq,&#xD;&#xA;  UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;  UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND B_SERVER    = @b_server&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="b_eas_up_down" />
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="hist_seq" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="b_server" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="1125" N="EdgeClientWatcher">
      <F _S="1126" N="EdgeClientWatcherControl">
        <SG _S="1127" N="ListEdge">
          <QY P="MsSql" Q="SELECT FACTORY, EAP, DELETE_FLAG&#xD;&#xA;  FROM QRASEAPDEF&#xD;&#xA;  WITH (NOLOCK)&#xD;&#xA; WHERE EAP_TYPE = @eap_type">
            <QP N="eap_type" />
          </QY>
        </SG>
        <SG _S="1128" N="HasEdge">
          <QY P="MsSql" Q="SELECT FACTORY, EAP, DELETE_FLAG&#xD;&#xA;  FROM QRASEAPDEF&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EAP_TYPE = @eap_type&#xD;&#xA;   AND EAP      = @eap">
            <QP N="factory" />
            <QP N="eap_type" />
            <QP N="eap" />
          </QY>
        </SG>
      </F>
      <F _S="1129" N="Init">
        <SG _S="1130" N="ListFactory">
          <QY P="MsSql" Q="SELECT FACTORY&#xD;&#xA;  FROM QSYSFACDEF" />
        </SG>
        <SG _S="1131" N="ListEdge">
          <QY P="MsSql" Q="SELECT EAP, UP_DOWN&#xD;&#xA;  FROM QRASEAPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EAP_TYPE    = @eap_type&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eap_type" />
          </QY>
        </SG>
      </F>
      <F _S="1132" N="EdgeClientDown">
        <SG _S="1133" N="SearchEapAtr">
          <QY P="MsSql" Q="SELECT EAP, PACKAGE, PKG_VER, MODEL, MDL_VER, LIBRARY, LIB_VER&#xD;&#xA;  FROM QRASEAPATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP           = @eap&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
          </QY>
        </SG>
        <SG _S="1134" N="SearchEapEquipment">
          <QY P="MsSql" Q="SELECT DATA&#xD;&#xA;  FROM QRASEAPCFG&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP           = @eap&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category&#xD;&#xA;   AND OBJ_TYPE      = @obj_type&#xD;&#xA;   AND KEY_NAME      = @eqp_name_key">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
            <QP N="obj_type" />
            <QP N="eqp_name_key" />
          </QY>
        </SG>
        <SG _S="1135" N="UpdateEap">
          <QY P="MsSql" Q="UPDATE QRASEAPDEF SET&#xD;&#xA;  UP_DOWN          = @up_down,&#xD;&#xA;  RELOAD_CNT       = 0,&#xD;&#xA;  LAST_EVENT_ID    = @last_event_id,&#xD;&#xA;  LAST_EVENT_TIME  = @last_event_time,&#xD;&#xA;  LAST_HIST_SEQ    = @hist_seq,&#xD;&#xA;  UPDATE_USER_ID   = @update_user_id,&#xD;&#xA;  UPDATE_TIME      = @update_time&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EAP     = @eap">
            <QP N="up_down" />
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="hist_seq" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="1136" N="UpdateEapEquipment">
          <QY P="MsSql" Q="UPDATE QRASEQPDEF SET&#xD;&#xA;   EAP             = @eap,&#xD;&#xA;   UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;   UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EQP_NAME = @eqp_name">
            <QP N="eap" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="1137" N="UpdateEapEquipmentStatus">
          <QY P="MsSql" Q="UPDATE QRASEQPSTS SET&#xD;&#xA;   LAST_HIST_SEQ   = @last_his_seq,&#xD;&#xA;   COMM_STATE      = @comm_state,&#xD;&#xA;   CTRL_MODE       = @ctrl_mode,&#xD;&#xA;   PROC_STATE       = @proc_state,&#xD;&#xA;   LAST_EVENT_ID   = @last_event_id,&#xD;&#xA;   LAST_EVENT_TIME = @last_event_time,&#xD;&#xA;   UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;   UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EQP_NAME = @eqp_name">
            <QP N="last_his_seq" />
            <QP N="comm_state" />
            <QP N="ctrl_mode" />
            <QP N="proc_state" />
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="1138" N="UpdateConnectorSts">
          <QY P="MsSql" Q="UPDATE QRASCNTSTS SET&#xD;&#xA;  STATE          = @state,&#xD;&#xA;  UPDATE_USER_ID = @update_user_id,&#xD;&#xA;  UPDATE_TIME    = @update_time&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND EAP       = @eap">
            <QP N="state" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="1139" N="InsertEapEquipmentHis">
          <QY P="MsSql" Q="INSERT INTO QRASEQPHIS (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   EVENT_ID,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   SYSTEM,&#xD;&#xA;   COMM_STATE,&#xD;&#xA;   CTRL_MODE,&#xD;&#xA;   EAP,&#xD;&#xA;   EAP_EVENT_ID,      &#xD;&#xA;   EVT_H_1,&#xD;&#xA;   EVT_D_1,   &#xD;&#xA;   EVT_H_2,&#xD;&#xA;   EVT_D_2,&#xD;&#xA;   EVT_H_3,&#xD;&#xA;   EVT_D_3,&#xD;&#xA;   EVT_H_4,&#xD;&#xA;   EVT_D_4,&#xD;&#xA;   EVT_H_5,&#xD;&#xA;   EVT_D_5,&#xD;&#xA;   EVT_H_6,&#xD;&#xA;   EVT_D_6,&#xD;&#xA;   EVT_H_7,&#xD;&#xA;   EVT_D_7,&#xD;&#xA;   EVT_H_8,&#xD;&#xA;   EVT_D_8,&#xD;&#xA;   EVT_H_9,&#xD;&#xA;   EVT_D_9,&#xD;&#xA;   EVT_H_10,&#xD;&#xA;   EVT_D_10,&#xD;&#xA;   EVT_H_11,&#xD;&#xA;   EVT_D_11,   &#xD;&#xA;   EVT_H_12,&#xD;&#xA;   EVT_D_12,&#xD;&#xA;   EVT_H_13,&#xD;&#xA;   EVT_D_13,&#xD;&#xA;   EVT_H_14,&#xD;&#xA;   EVT_D_14,&#xD;&#xA;   EVT_H_15,&#xD;&#xA;   EVT_D_15,&#xD;&#xA;   EVT_H_16,&#xD;&#xA;   EVT_D_16,&#xD;&#xA;   EVT_H_17,&#xD;&#xA;   EVT_D_17,&#xD;&#xA;   EVT_H_18,&#xD;&#xA;   EVT_D_18,&#xD;&#xA;   EVT_H_19,&#xD;&#xA;   EVT_D_19,&#xD;&#xA;   EVT_H_20,&#xD;&#xA;   EVT_D_20,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT      &#xD;&#xA;) &#xD;&#xA;VALUES( &#xD;&#xA;   @factory,&#xD;&#xA;   @eqp_name,&#xD;&#xA;   @last_his_seq,&#xD;&#xA;   @event_id,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @SYSTEM,&#xD;&#xA;   @comm_state,&#xD;&#xA;   @ctrl_mode,&#xD;&#xA;   @eap,&#xD;&#xA;   @eap_event_id,&#xD;&#xA;   @evt_h_1,&#xD;&#xA;   @evt_d_1,   &#xD;&#xA;   @evt_h_2,&#xD;&#xA;   @evt_d_2,&#xD;&#xA;   @evt_h_3,&#xD;&#xA;   @evt_d_3,&#xD;&#xA;   @evt_h_4,&#xD;&#xA;   @evt_d_4,&#xD;&#xA;   @evt_h_5,&#xD;&#xA;   @evt_d_5,&#xD;&#xA;   @evt_h_6,&#xD;&#xA;   @evt_d_6,&#xD;&#xA;   @evt_h_7,&#xD;&#xA;   @evt_d_7,&#xD;&#xA;   @evt_h_8,&#xD;&#xA;   @evt_d_8,&#xD;&#xA;   @evt_h_9,&#xD;&#xA;   @evt_d_9,&#xD;&#xA;   @evt_h_10,&#xD;&#xA;   @evt_d_10,&#xD;&#xA;   @evt_h_11,&#xD;&#xA;   @evt_d_11,   &#xD;&#xA;   @evt_h_12,&#xD;&#xA;   @evt_d_12,&#xD;&#xA;   @evt_h_13,&#xD;&#xA;   @evt_d_13,&#xD;&#xA;   @evt_h_14,&#xD;&#xA;   @evt_d_14,&#xD;&#xA;   @evt_h_15,&#xD;&#xA;   @evt_d_15,&#xD;&#xA;   @evt_h_16,&#xD;&#xA;   @evt_d_16,&#xD;&#xA;   @evt_h_17,&#xD;&#xA;   @evt_d_17,&#xD;&#xA;   @evt_h_18,&#xD;&#xA;   @evt_d_18,&#xD;&#xA;   @evt_h_19,&#xD;&#xA;   @evt_d_19,&#xD;&#xA;   @evt_h_20,&#xD;&#xA;   @evt_d_20,&#xD;&#xA;   @tran_user_id,&#xD;&#xA;   @tran_comment)">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="last_his_seq" />
            <QP N="event_id" />
            <QP N="tran_time" />
            <QP N="SYSTEM" />
            <QP N="comm_state" />
            <QP N="ctrl_mode" />
            <QP N="eap" />
            <QP N="eap_event_id" />
            <QP N="evt_h_1" />
            <QP N="evt_d_1" />
            <QP N="evt_h_2" />
            <QP N="evt_d_2" />
            <QP N="evt_h_3" />
            <QP N="evt_d_3" />
            <QP N="evt_h_4" />
            <QP N="evt_d_4" />
            <QP N="evt_h_5" />
            <QP N="evt_d_5" />
            <QP N="evt_h_6" />
            <QP N="evt_d_6" />
            <QP N="evt_h_7" />
            <QP N="evt_d_7" />
            <QP N="evt_h_8" />
            <QP N="evt_d_8" />
            <QP N="evt_h_9" />
            <QP N="evt_d_9" />
            <QP N="evt_h_10" />
            <QP N="evt_d_10" />
            <QP N="evt_h_11" />
            <QP N="evt_d_11" />
            <QP N="evt_h_12" />
            <QP N="evt_d_12" />
            <QP N="evt_h_13" />
            <QP N="evt_d_13" />
            <QP N="evt_h_14" />
            <QP N="evt_d_14" />
            <QP N="evt_h_15" />
            <QP N="evt_d_15" />
            <QP N="evt_h_16" />
            <QP N="evt_d_16" />
            <QP N="evt_h_17" />
            <QP N="evt_d_17" />
            <QP N="evt_h_18" />
            <QP N="evt_d_18" />
            <QP N="evt_h_19" />
            <QP N="evt_d_19" />
            <QP N="evt_h_20" />
            <QP N="evt_d_20" />
            <QP N="tran_user_id" />
            <QP N="tran_comment" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="1140" N="DataPusher">
      <F _S="1141" N="ServerDataPush">
        <SG _S="1142" N="SearchServer">
          <QY P="MsSql" Q="SELECT SVR_DESC, SVR_TYPE, SVR_IP, UP_DOWN, STATUS, EAS_UP_DOWN, OPC_SVR_UP_DOWN, ALARM, LAST_EVENT_ID&#xD;&#xA;  FROM QSYSSVRDEF&#xD;&#xA;  WITH (NOLOCK)&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SERVER      = @server&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="server" />
          </QY>
        </SG>
      </F>
      <F _S="1143" N="PackageDataPush">
        <SG _S="1144" N="SearchPackage">
          <QY P="MsSql" Q="SELECT PKG_DESC&#xD;&#xA;  FROM QSYSPKGDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND PACKAGE = @package">
            <QP N="factory" />
            <QP N="package" />
          </QY>
        </SG>
      </F>
      <F _S="1145" N="PackageVerDataPush">
        <SG _S="1146" N="SearchPackageVer">
          <QY P="MsSql" Q="SELECT PKG_VER_DESC, PKG_RELEASE&#xD;&#xA;  FROM QSYSPKGVER&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND PACKAGE = @package&#xD;&#xA;   AND PKG_VER = @pkg_ver">
            <QP N="factory" />
            <QP N="package" />
            <QP N="pkg_ver" />
          </QY>
        </SG>
      </F>
      <F _S="1147" N="ModelDataPush">
        <SG _S="1148" N="SearchModel">
          <QY P="MsSql" Q="SELECT MDL_DESC&#xD;&#xA;  FROM QSYSMDLDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND MODEL  = @model">
            <QP N="factory" />
            <QP N="model" />
          </QY>
        </SG>
      </F>
      <F _S="1149" N="ModelVerDataPush">
        <SG _S="1150" N="SearchModelVer">
          <QY P="MsSql" Q="SELECT MDL_VER_DESC, MDL_RELEASE&#xD;&#xA;  FROM QSYSMDLVER&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND MODEL  = @model&#xD;&#xA;   AND MDL_VER = @mdl_ver">
            <QP N="factory" />
            <QP N="model" />
            <QP N="mdl_ver" />
          </QY>
        </SG>
      </F>
      <F _S="1151" N="LibraryDataPush">
        <SG _S="1152" N="SearchLibrary">
          <QY P="MsSql" Q="SELECT LIB_DESC&#xD;&#xA;  FROM QSYSLIBDEF&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND LIBRARY   = @library">
            <QP N="factory" />
            <QP N="library" />
          </QY>
        </SG>
      </F>
      <F _S="1153" N="LibraryVerDataPush">
        <SG _S="1154" N="SearchLibraryVer">
          <QY P="MsSql" Q="SELECT LIB_VER_DESC, LIB_RELEASE&#xD;&#xA;  FROM QSYSLIBVER&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND LIBRARY   = @library&#xD;&#xA;   AND LIB_VER   = @lib_ver">
            <QP N="factory" />
            <QP N="library" />
            <QP N="lib_ver" />
          </QY>
        </SG>
      </F>
      <F _S="1155" N="EapDataPush">
        <SG _S="1156" N="SearchEap">
          <QY P="MsSql" Q="SELECT A.EAP, A.EAP_DESC, A.SERVER, A.STEP, A.UP_DOWN, A.STATUS, A.RELOAD_CNT, A.NEED_ACTION, A.NEXT_NEED_ACTION, ALARM,&#xD;&#xA;       ISNULL(B.PACKAGE, 'N/A') SET_PACKAGE, ISNULL(B.PKG_VER, 0) SET_PKG_VER, ISNULL(C.PACKAGE, 'N/A') REL_PACKAGE, ISNULL(C.PKG_VER, 0) REL_PKG_VER, ISNULL(D.PACKAGE, 'N/A') APL_PACKAGE, ISNULL(D.PKG_VER, 0) APL_PKG_VER,&#xD;&#xA;       ISNULL(B.MODEL, 'N/A') SET_MODEL, ISNULL(B.MDL_VER, 0) SET_MDL_VER, ISNULL(C.MODEL, 'N/A') REL_MODEL, ISNULL(C.MDL_VER, 0) REL_MDL_VER, ISNULL(D.MODEL, 'N/A') APL_MODEL, ISNULL(D.MDL_VER, 0) APL_MDL_VER, &#xD;&#xA;       ISNULL(B.LIBRARY, 'N/A') SET_LIBRARY, ISNULL(B.LIB_VER, 0) SET_LIB_VER, ISNULL(C.LIBRARY, 'N/A') REL_LIBRARY, ISNULL(C.LIB_VER, 0) REL_LIB_VER, ISNULL(D.LIBRARY, 'N/A') APL_LIBRARY, ISNULL(D.LIB_VER, 0) APL_LIB_VER,  &#xD;&#xA;       A.LAST_EVENT_ID,&#xD;&#xA;       D.EAP_SCHEMA&#xD;&#xA;  FROM QRASEAPDEF A&#xD;&#xA;  WITH (NOLOCK)&#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP           = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP           = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.EAP           = @eap&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="1157" N="SearchConnectorSts">
          <QY P="MsSql" Q="SELECT CNT_SEQ, CNT_NAME, STATE&#xD;&#xA;  FROM QRASCNTSTS&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EAP     = @eap">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="1158" N="SearchEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME, COMM_STATE, CTRL_MODE&#xD;&#xA;  FROM QRASEQPSTS&#xD;&#xA;  WITH (NOLOCK)&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EQP_NAME IN&#xD;&#xA;       (&#xD;&#xA;SELECT DATA&#xD;&#xA;  FROM QRASEAPCFG&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP           = @eap&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category&#xD;&#xA;   AND KEY_NAME      = @key_eqp_name&#xD;&#xA;       )">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
            <QP N="key_eqp_name" />
          </QY>
        </SG>
      </F>
      <F _S="1159" N="DataHoundDataPush">
        <SG _S="1160" N="SearchDataHound">
          <QY P="MsSql" Q="SELECT NAME, EAP, TYPE, STATUS, SERVER_IP, SERVER_PORT, RESULT_MESSAGE&#xD;&#xA;  FROM QSYSDHDDEF  &#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND NAME = @hound">
            <QP N="factory" />
            <QP N="hound" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
      </F>
      <F _S="1161" N="EquipmentDataPush" D="cleanup needed">
        <SG _S="1162" N="SearchEquipment">
          <QY P="MsSql" Q="SELECT A.EQP_NAME, A.EQP_DESC, ISNULL(C.SERVER, 'N/A') SERVER, ISNULL(C.EAP, 'N/A') EAP, ISNULL(C.UP_DOWN, 'N/A') UP_DOWN, ISNULL(C.STATUS, 'N/A') STATUS,&#xD;&#xA;       A.TYPE, A.AREA, A.LINE, A.MDLN, A.SOFTREV, A.CTRL_MODE, A.PRI_STATE, A.STATE, A.ALARM, A.EVENT_DEFINE&#xD;&#xA;  FROM QRASEQPDEF A&#xD;&#xA;  WITH (NOLOCK)&#xD;&#xA;  LEFT JOIN QRASEQPATR B&#xD;&#xA;    ON A.FACTORY         = B.FACTORY&#xD;&#xA;   AND A.EQP_NAME        = B.EQP_NAME&#xD;&#xA;   AND B.ATTR_CATEGORY   = @attr_category&#xD;&#xA;  LEFT JOIN QRASEAPDEF C&#xD;&#xA;    ON A.FACTORY         = C.FACTORY&#xD;&#xA;   AND B.EAP             = C.EAP&#xD;&#xA; WHERE A.FACTORY         = @factory&#xD;&#xA;   AND A.EQP_NAME        = @eqp_name&#xD;&#xA;   AND A.DELETE_FLAG     = 'N'">
            <QP N="attr_category" />
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
      </F>
      <F _S="1163" N="BranchDataPush">
        <SG _S="1164" N="SearchBranch">
          <QY P="MsSql" Q="SELECT IBN_NAME, IBN_DESC, PROTOCOL, PROTOCOL_ATTR&#xD;&#xA;  FROM QEMSIBNDEF&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND IBN_NAME = @ibn_name">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
        <SG _S="1165" N="SearchBranchEquipment">
          <QY P="MsSql" Q="SELECT IBN.EQP_NAME, ISNULL(EQP.EQP_DESC, ' ') EQP_DESC, IBN.ENABLE, IBN.IBN_STATE, IBN.NEED_ACTION, IBN.ACTIVE_VER, IBN.APPLIED_VER, IBN.LAST_VER&#xD;&#xA;  FROM QEMSIBNEQP IBN&#xD;&#xA;  LEFT JOIN QRASEQPDEF EQP&#xD;&#xA;    ON IBN.FACTORY  = EQP.FACTORY&#xD;&#xA;   AND IBN.EQP_NAME =  EQP.EQP_NAME&#xD;&#xA; WHERE IBN.FACTORY  = @factory&#xD;&#xA;   AND IBN.IBN_NAME = @ibn_name&#xD;&#xA;ORDER BY IBN.EQP_NAME">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
      </F>
      <F _S="1166" N="BranchEquipmentDataPush">
        <SG _S="1167" N="SearchBranchEquipment">
          <QY P="MsSql" Q="SELECT A.EQP_NAME, ISNULL(C.EQP_DESC, ' ') EQP_DESC, B.PROTOCOL, A.ENABLE, A.IBN_STATE, A.NEED_ACTION, A.ACTIVE_VER, A.APPLIED_VER, A.LAST_VER&#xD;&#xA;  FROM QEMSIBNEQP A&#xD;&#xA;  LEFT JOIN QEMSIBNDEF B&#xD;&#xA;    ON A.FACTORY  = B.FACTORY&#xD;&#xA;   AND A.IBN_NAME = B.IBN_NAME&#xD;&#xA;  LEFT JOIN QRASEQPDEF C&#xD;&#xA;    ON A.FACTORY  = C.FACTORY&#xD;&#xA;   AND A.EQP_NAME = C.EQP_NAME&#xD;&#xA; WHERE A.FACTORY  = @factory&#xD;&#xA;   AND A.IBN_NAME = @ibn_name&#xD;&#xA;   AND A.EQP_NAME = @eqp_name">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
      </F>
    </M>
    <M _S="1168" N="DataPurge">
      <F _S="1169" N="DataPurge">
        <SG _S="1170" N="SearchFactory">
          <QY P="MsSql" Q="SELECT FACTORY&#xD;&#xA; FROM QSYSFACDEF" />
        </SG>
        <SG _S="1171" N="DeleteUserHistory" UMG="No">
          <QY P="MsSql" Q="WITH TMP_DELETE AS (&#xD;&#xA;	SELECT TRAN_TIME, ROW_NUMBER() OVER(ORDER BY TRAN_TIME) AS ROWNUM &#xD;&#xA;		FROM QSECUSRHIS&#xD;&#xA;		WHERE FACTORY = @factory&#xD;&#xA;		AND TRAN_TIME &lt; @tran_time&#xD;&#xA;)&#xD;&#xA;DELETE FROM TMP_DELETE WHERE ROWNUM &lt;= @delete_cnt">
            <QP N="factory" />
            <QP N="tran_time" />
            <QP N="delete_cnt" />
          </QY>
        </SG>
        <SG _S="1172" N="DeleteServerHistory" UMG="No">
          <QY P="MsSql" Q="WITH TMP_DELETE AS (&#xD;&#xA;	SELECT TRAN_TIME, ROW_NUMBER() OVER(ORDER BY TRAN_TIME) AS ROWNUM &#xD;&#xA;		FROM QSYSSVRHIS&#xD;&#xA;		WHERE FACTORY = @factory&#xD;&#xA;		AND TRAN_TIME &lt; @tran_time&#xD;&#xA;)&#xD;&#xA;DELETE FROM TMP_DELETE WHERE ROWNUM &lt;= @delete_cnt">
            <QP N="factory" />
            <QP N="tran_time" />
            <QP N="delete_cnt" />
          </QY>
        </SG>
        <SG _S="1173" N="DeleteEapHistory" UMG="No">
          <QY P="MsSql" Q="WITH TMP_DELETE AS (&#xD;&#xA;	SELECT TRAN_TIME, ROW_NUMBER() OVER(ORDER BY TRAN_TIME) AS ROWNUM &#xD;&#xA;		FROM QRASEAPHIS&#xD;&#xA;		WHERE FACTORY = @factory&#xD;&#xA;		AND TRAN_TIME &lt; @tran_time&#xD;&#xA;)&#xD;&#xA;DELETE FROM TMP_DELETE WHERE ROWNUM &lt;= @delete_cnt">
            <QP N="factory" />
            <QP N="tran_time" />
            <QP N="delete_cnt" />
          </QY>
        </SG>
        <SG _S="1174" N="DeleteEquipmentHistory" UMG="No">
          <QY P="MsSql" Q="WITH TMP_DELETE AS (&#xD;&#xA;	SELECT TRAN_TIME, ROW_NUMBER() OVER(ORDER BY TRAN_TIME) AS ROWNUM &#xD;&#xA;		FROM QRASEQPHIS&#xD;&#xA;		WHERE FACTORY = @factory&#xD;&#xA;		AND TRAN_TIME &lt; @tran_time&#xD;&#xA;)&#xD;&#xA;DELETE FROM TMP_DELETE WHERE ROWNUM &lt;= @delete_cnt">
            <QP N="factory" />
            <QP N="tran_time" />
            <QP N="delete_cnt" />
          </QY>
        </SG>
        <SG _S="1175" N="DeleteServerResourceHistory" UMG="No">
          <QY P="MsSql" Q="WITH TMP_DELETE AS (&#xD;&#xA;	SELECT TRAN_TIME, ROW_NUMBER() OVER(ORDER BY TRAN_TIME) AS ROWNUM &#xD;&#xA;		FROM QSYSSVRRHI&#xD;&#xA;		WHERE FACTORY = @factory&#xD;&#xA;		AND TRAN_TIME &lt; @tran_time&#xD;&#xA;)&#xD;&#xA;DELETE FROM TMP_DELETE WHERE ROWNUM &lt;= @delete_cnt">
            <QP N="factory" />
            <QP N="tran_time" />
            <QP N="delete_cnt" />
          </QY>
        </SG>
        <SG _S="1176" N="DeleteEapResourceHistory" UMG="No">
          <QY P="MsSql" Q="WITH TMP_DELETE AS (&#xD;&#xA;	SELECT TRAN_TIME, ROW_NUMBER() OVER(ORDER BY TRAN_TIME) AS ROWNUM&#xD;&#xA;		FROM QRASEAPRHI&#xD;&#xA;		WHERE FACTORY = @factory&#xD;&#xA;		AND TRAN_TIME &lt; @tran_time&#xD;&#xA;)&#xD;&#xA;DELETE FROM TMP_DELETE WHERE ROWNUM &lt;= @delete_cnt">
            <QP N="factory" />
            <QP N="tran_time" />
            <QP N="delete_cnt" />
          </QY>
        </SG>
      </F>
    </M>
  </S>
</Q>