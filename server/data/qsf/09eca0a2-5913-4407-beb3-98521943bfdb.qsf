        <SG _S="1022" N="InsertEapAtr">
          <QY P="MsSql" Q="INSERT INTO QRASEAPATR (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EAP,&#xD;&#xA;   ATTR_CATEGORY,&#xD;&#xA;   PACKAGE,&#xD;&#xA;   PKG_VER,&#xD;&#xA;   MODEL,&#xD;&#xA;   MDL_VER,&#xD;&#xA;   LIBRARY,&#xD;&#xA;   LIB_VER,&#xD;&#xA;   EAP_SCHEMA,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) &#xD;&#xA;SELECT &#xD;&#xA;   FACTORY,&#xD;&#xA;   EAP,&#xD;&#xA;   @attr_category2,&#xD;&#xA;   @package,&#xD;&#xA;   @pkg_ver,&#xD;&#xA;   MODEL,&#xD;&#xA;   MDL_VER,&#xD;&#xA;   LIBRARY,&#xD;&#xA;   LIB_VER,&#xD;&#xA;   @eap_schema,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;  FROM QRASEAPATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP           = @eap&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="attr_category2" />
            <QP N="package" />
