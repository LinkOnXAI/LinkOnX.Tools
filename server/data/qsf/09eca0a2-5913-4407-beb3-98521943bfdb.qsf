        <SG _S="1048" N="UpdateEap">
          <QY P="MsSql" Q="UPDATE QRASEAPDEF SET&#xD;&#xA;  LAST_EVENT_ID    = @last_event_id,&#xD;&#xA;  LAST_EVENT_TIME  = @last_event_time,&#xD;&#xA;  LAST_HIST_SEQ    = @hist_seq,&#xD;&#xA;  UPDATE_USER_ID   = @update_user_id,&#xD;&#xA;  UPDATE_TIME      = @update_time&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EAP     = @eap">
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="hist_seq" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="1049" N="UpdateEquipmentStatus">
          <QY P="MsSql" Q="UPDATE QRASEQPSTS SET&#xD;&#xA;   LAST_HIST_SEQ   = @last_his_seq,&#xD;&#xA;   COMM_STATE      = @comm_state,&#xD;&#xA;   CTRL_MODE       = @ctrl_mode,&#xD;&#xA;   PROC_STATE       = @proc_state,&#xD;&#xA;   LAST_EVENT_ID   = @last_event_id,&#xD;&#xA;   LAST_EVENT_TIME = @last_event_time,&#xD;&#xA;   UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;   UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EQP_NAME = @eqp_name">
            <QP N="last_his_seq" />
            <QP N="comm_state" />
            <QP N="ctrl_mode" />
            <QP N="proc_state" />
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
      </F>
      <F _S="1050" N="ConnectorState">
        <SG _S="1051" N="SearchEapAtr">
          <QY P="MsSql" Q="SELECT EAP&#xD;&#xA;  FROM QRASEAPATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP           = @eap&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="attr_category" />
          </QY>
        </SG>
        <SG _S="1052" N="SearchConnectorSts">
          <QY P="MsSql" Q="SELECT EAP, CNT_NAME, STATE&#xD;&#xA;  FROM QRASCNTSTS&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EAP     = @eap&#xD;&#xA;   AND CNT_SEQ = @cnt_seq">
            <QP N="factory" />
            <QP N="eap" />
            <QP N="cnt_seq" />
          </QY>
        </SG>
        <SG _S="1053" N="InsertEapHistory">
