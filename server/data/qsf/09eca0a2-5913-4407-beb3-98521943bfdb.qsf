        <SG _S="969" N="UpdateServerResource">
          <QY P="MsSql" Q="UPDATE QSYSSVRDEF SET&#xD;&#xA;  COMPUTER_NAME   = @computer_name,&#xD;&#xA;  WORK_GROUP      = @work_group,&#xD;&#xA;  USER_NAME       = @user_name,&#xD;&#xA;  OS              = @os,&#xD;&#xA;  CPU             = @cpu,&#xD;&#xA;  MEMORY          = @memory,&#xD;&#xA;  DISK_CNT        = @disk_cnt,&#xD;&#xA;  DISK_1          = @disk_1,&#xD;&#xA;  DISK_1_SIZE     = @disk_1_size,&#xD;&#xA;  DISK_2          = @disk_2,&#xD;&#xA;  DISK_2_SIZE     = @disk_2_size,&#xD;&#xA;  DISK_3          = @disk_3,&#xD;&#xA;  DISK_3_SIZE     = @disk_3_size,&#xD;&#xA;  DISK_4          = @disk_4,&#xD;&#xA;  DISK_4_SIZE     = @disk_4_size,&#xD;&#xA;  DISK_5          = @disk_5,&#xD;&#xA;  DISK_5_SIZE     = @disk_5_size,&#xD;&#xA;  DISK_6          = @disk_6,&#xD;&#xA;  DISK_6_SIZE     = @disk_6_size,&#xD;&#xA;  DISK_7          = @disk_7,&#xD;&#xA;  DISK_7_SIZE     = @disk_7_size,&#xD;&#xA;  DISK_8          = @disk_8,&#xD;&#xA;  DISK_8_SIZE     = @disk_8_size,&#xD;&#xA;  DISK_9          = @disk_9,&#xD;&#xA;  DISK_9_SIZE     = @disk_9_size,&#xD;&#xA;  DISK_10         = @disk_10,&#xD;&#xA;  DISK_10_SIZE    = @disk_10_size,&#xD;&#xA;  CPU_USAGE       = @cpu_usage,&#xD;&#xA;  MEMORY_USAGE    = @memory_usage,&#xD;&#xA;  DISK_1_USAGE    = @disk_1_usage,&#xD;&#xA;  DISK_2_USAGE    = @disk_2_usage,&#xD;&#xA;  DISK_3_USAGE    = @disk_3_usage,&#xD;&#xA;  DISK_4_USAGE    = @disk_4_usage,&#xD;&#xA;  DISK_5_USAGE    = @disk_5_usage,&#xD;&#xA;  DISK_6_USAGE    = @disk_6_usage,&#xD;&#xA;  DISK_7_USAGE    = @disk_7_usage,&#xD;&#xA;  DISK_8_USAGE    = @disk_8_usage,&#xD;&#xA;  DISK_9_USAGE    = @disk_9_usage,&#xD;&#xA;  DISK_10_USAGE   = @disk_10_usage,&#xD;&#xA;  UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;  UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND SERVER   = @server">
