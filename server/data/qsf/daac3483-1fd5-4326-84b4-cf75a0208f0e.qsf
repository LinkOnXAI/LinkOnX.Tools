      <F _S="795" N="SndDataPush">
        <SG _S="796" N="SearchSnd">
          <QY P="MsSql" Q="SELECT A.SVS_NODE, A.SVS_NODE_DESC, A.CONTAINER, A.SVS_NODE_GROUP, A.AUTO_START,  A.STEP, A.UP_DOWN, A.STATUS, A.RELOAD_CNT, A.NEED_ACTION, A.NEXT_NEED_ACTION, ALARM,&#xD;&#xA;       ISNULL(B.MODEL, 'N/A') SET_MODEL, ISNULL(B.MODEL_VER, 0) SET_MODEL_VER, ISNULL(C.MODEL, 'N/A') REL_MODEL, ISNULL(C.MODEL_VER, 0) REL_MODEL_VER, ISNULL(D.MODEL, 'N/A') APL_MODEL, ISNULL(D.MODEL_VER, 0) APL_MODEL_VER, &#xD;&#xA;       A.LAST_EVENT_ID,&#xD;&#xA;       D.SVS_NODE_SCHEMA&#xD;&#xA;  FROM QEESSNDDEF A&#xD;&#xA;  WITH (NOLOCK)&#xD;&#xA;  LEFT JOIN QEESSNDATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = B.SVS_NODE&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QEESSNDATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = C.SVS_NODE&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QEESSNDATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = D.SVS_NODE&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.SVS_NODE           = @svs_node&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="factory" />
            <QP N="svs_node" />
          </QY>
        </SG>
        <SG _S="3384" N="SearchControllerSts">
          <QY P="MsSql" Q="SELECT CTRL_NAME, COMM_STATE, CTRL_MODE&#xD;&#xA;  FROM QEESSNDCTL&#xD;&#xA;  WITH (NOLOCK)&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND CTRL_NAME IN&#xD;&#xA;       (&#xD;&#xA;		SELECT DATA&#xD;&#xA;		  FROM QEESSNDCFG&#xD;&#xA;		 WHERE FACTORY       = @factory&#xD;&#xA;		   AND SVS_NODE           = @svs_node&#xD;&#xA;		   AND ATTR_CATEGORY = @attr_category&#xD;&#xA;		   AND KEY_NAME      = @key_eqp_name&#xD;&#xA;       )">
            <QP N="factory" />
            <QP N="svs_node" />
            <QP N="attr_category" />
            <QP N="key_eqp_name" />
          </QY>
        </SG>
        <SG _S="3150" N="SearchConnectorSts">
          <QY P="MsSql" Q="SELECT CNT_SEQ, CNT_NAME, STATE&#xD;&#xA;  FROM QEESSNDCTS&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND SVS_NODE     = @svs_node">
            <QP N="factory" />
            <QP N="svs_node" />
          </QY>
        </SG>
      </F>
      <F _S="3713" N="BaseNodeDataPush">
        <SG _S="3715" N="SearchBaseNode">
          <QY P="MsSql" Q="SELECT A.NODE_NAME, &#xD;&#xA;A.NODE_DESC, &#xD;&#xA;A.CONTAINER,&#xD;&#xA;A.STEP, &#xD;&#xA;A.UP_DOWN, &#xD;&#xA;A.STATUS,&#xD;&#xA;A.ALARM, &#xD;&#xA;A.AUTO_START,&#xD;&#xA;A.AUTO_RELEASE, &#xD;&#xA;A.NEED_ACTION,&#xD;&#xA; A.NEXT_NEED_ACTION, &#xD;&#xA; ISNULL(B.MODEL, 'N/A') SET_MODEL, &#xD;&#xA;ISNULL(B.MODEL_VER, 0) SET_MODEL_VER, &#xD;&#xA;ISNULL(C.MODEL, 'N/A') REL_MODEL, &#xD;&#xA;ISNULL(C.MODEL_VER, 0) REL_MODEL_VER, &#xD;&#xA;ISNULL(D.MODEL, 'N/A') APL_MODEL, &#xD;&#xA;ISNULL(D.MODEL_VER, 0) APL_MODEL_VER, &#xD;&#xA;       A.LAST_EVENT_ID,&#xD;&#xA;       D.NODE_SCHEMA&#xD;&#xA;  FROM QEESBNDDEF A&#xD;&#xA;  WITH (NOLOCK)&#xD;&#xA;  LEFT JOIN QEESBNDATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.NODE_NAME           = B.NODE_NAME&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QEESBNDATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.NODE_NAME           = C.NODE_NAME&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QEESBNDATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.NODE_NAME           = D.NODE_NAME&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.NODE_NAME           = @node_name&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="factory" />
            <QP N="node_name" />
          </QY>
        </SG>
        <SG _S="3716" N="SearchConnectorSts">
          <QY P="MsSql" Q="SELECT CNT_SEQ, CNT_NAME, STATE&#xD;&#xA;  FROM QEESBNDCTS&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND NODE_NAME= @node_name">
            <QP N="factory" />
            <QP N="node_name" />
          </QY>
        </SG>
      </F>
    </M>
  </S>
</Q>