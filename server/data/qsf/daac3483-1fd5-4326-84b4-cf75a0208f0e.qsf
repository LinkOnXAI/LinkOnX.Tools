      <F _S="3797" N="SndAutoStart">
        <SG _S="3799" N="HasStartableSnd">
          <QY P="MsSql" Q="SELECT A.FACTORY, A.SVS_NODE, A.SVS_NODE_GROUP, B.MODEL, B.MODEL_VER, B.SVS_NODE_SCHEMA&#xD;&#xA;  FROM QEESSNDDEF  A&#xD;&#xA;           LEFT JOIN QEESSNDATR B ON &#xD;&#xA;           B.FACTORY = A.FACTORY&#xD;&#xA;           AND B.SVS_NODE = A.SVS_NODE           &#xD;&#xA;           AND B.ATTR_CATEGORY = @attr_category&#xD;&#xA; WHERE A.UP_DOWN  != 'Up'&#xD;&#xA;   AND A.DELETE_FLAG = 'N'&#xD;&#xA;   AND A.SVS_NODE_GROUP = 'EQP_EVENT_GROUP'">
            <QP N="attr_category" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="688" N="View">
      <F _S="2583" N="SndSchemaSearch">
        <SG _S="2584" N="SearchSnd">
          <QY P="MsSql" Q="SELECT SVS_NODE&#xD;&#xA;  FROM QEESSNDDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SVS_NODE         = @svs_node&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="svs_node" />
          </QY>
        </SG>
        <SG _S="3139" N="SearchSndAtr">
          <QY P="MsSql" Q="SELECT SVS_NODE_SCHEMA&#xD;&#xA;  FROM QEESSNDATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND SVS_NODE           = @svs_node&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="svs_node" />
            <QP N="attr_category" />
          </QY>
        </SG>
        <SG _S="3141" N="SearchConnectorSts">
          <QY P="MsSql" Q="SELECT CNT_SEQ, CNT_NAME, STATE&#xD;&#xA;  FROM QEESSNDCTS&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND SVS_NODE     = @svs_node">
            <QP N="factory" />
            <QP N="svs_node" />
          </QY>
        </SG>
        <SG _S="3140" N="SearchController">
          <QY P="MsSql" Q="SELECT CTRL_NAME, COMM_STATE, CTRL_MODE&#xD;&#xA;  FROM QEESSNDCTL&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND CTRL_NAME IN&#xD;&#xA;  (&#xD;&#xA;	SELECT DATA&#xD;&#xA;	  FROM QEESSNDCFG&#xD;&#xA;	 WHERE FACTORY       = @factory&#xD;&#xA;	   AND SVS_NODE           = @svs_node&#xD;&#xA;	   AND ATTR_CATEGORY = @attr_category&#xD;&#xA;	   AND OBJ_TYPE      = @obj_type&#xD;&#xA;	   AND KEY_NAME      = @key_eqp_name&#xD;&#xA;   )">
            <QP N="factory" />
            <QP N="svs_node" />
            <QP N="attr_category" />
            <QP N="obj_type" />
            <QP N="key_eqp_name" />
          </QY>
        </SG>
      </F>
      <F _S="3708" N="BndSchemaSearch">
        <SG _S="3710" N="SearchBnd">
          <QY P="MsSql" Q="SELECT NODE_NAME&#xD;&#xA;  FROM QEESBNDDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND NODE_NAME = @node_name&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="node_name" />
          </QY>
        </SG>
        <SG _S="3711" N="SearchBndAtr">
          <QY P="MsSql" Q="SELECT NODE_SCHEMA&#xD;&#xA;  FROM QEESBNDATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND NODE_NAME           = @node_name&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="node_name" />
            <QP N="attr_category" />
          </QY>
        </SG>
        <SG _S="3712" N="SearchBndConnectorSts">
          <QY P="MsSql" Q="SELECT CNT_SEQ, CNT_NAME, STATE&#xD;&#xA;  FROM QEESBNDCTS&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND NODE_NAME  = @node_name">
            <QP N="factory" />
            <QP N="node_name" />
          </QY>
        </SG>
      </F>
      <F _S="2560" N="SndViewer">
        <SG _S="2563" N="ListModel">
          <QY P="MsSql" Q="SELECT A.MODEL, A.MODEL_DESC, B.MODEL_VER, B.MODEL_VER_DESC, B.MODEL_RELEASE&#xD;&#xA;  FROM QEESMDLDEF A&#xD;&#xA;  LEFT JOIN QEESMDLVER B&#xD;&#xA;    ON A.FACTORY = B.FACTORY&#xD;&#xA;   AND A.MODEL   = B.MODEL&#xD;&#xA; WHERE A.FACTORY = @factory&#xD;&#xA; ORDER BY A.MODEL, B.MODEL_VER DESC">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="2565" N="ListSnd">
          <QY P="MsSql" Q="SELECT A.SVS_NODE, A.SVS_NODE_DESC, A.SVS_NODE_GROUP,  A.STEP, A.UP_DOWN, A.STATUS, A.RELOAD_CNT, A.ALARM, A.NEED_ACTION, A.NEXT_NEED_ACTION,&#xD;&#xA; ISNULL(B.MODEL, 'N/A') SET_MODEL, ISNULL(B.MODEL_VER, 0) SET_MODEL_VER, ISNULL(C.MODEL, 'N/A') REL_MODEL, ISNULL(C.MODEL_VER, 0) REL_MODEL_VER, ISNULL(D.MODEL, 'N/A') APL_MODEL, ISNULL(D.MODEL_VER, 0) APL_MODEL_VER&#xD;&#xA;         FROM QEESSNDDEF A&#xD;&#xA;  LEFT JOIN QEESSNDATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = B.SVS_NODE&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QEESSNDATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = C.SVS_NODE&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QEESSNDATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = D.SVS_NODE&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'    &#xD;&#xA;   AND A.SVS_NODE_GROUP        = ISNULL(@svs_node_group, A.SVS_NODE_GROUP) &#xD;&#xA;   AND ( &#xD;&#xA;       (B.MODEL        = ISNULL(@model, B.MODEL) AND B.MODEL_VER = ISNULL(@mdl_ver, B.MODEL_VER))&#xD;&#xA;    OR (C.MODEL        = ISNULL(@model, C.MODEL) AND C.MODEL_VER = ISNULL(@mdl_ver, C.MODEL_VER))&#xD;&#xA;    OR (D.MODEL        = ISNULL(@model, D.MODEL) AND D.MODEL_VER = ISNULL(@mdl_ver, D.MODEL_VER))&#xD;&#xA;       )&#xD;&#xA;  ORDER BY A.SVS_NODE">
            <QP N="factory" />
            <QP N="svs_node_group" />
            <QP N="model" />
            <QP N="mdl_ver" />
          </QY>
        </SG>
        <SG _S="3404" N="ListSndGroup">
          <QY P="MsSql" Q="SELECT SVS_NODE_GROUP,&#xD;&#xA;	SVS_NODE_GROUP_DESC&#xD;&#xA;  FROM QEESSNDGRP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY SVS_NODE_GROUP">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="2566" N="SearchSnd">
          <QY P="MsSql" Q="SELECT A.SVS_NODE_GROUP,  B.MODEL FROM QEESSNDDEF A&#xD;&#xA;  LEFT JOIN QEESSNDATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = B.SVS_NODE&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.SVS_NODE           LIKE @svs_node&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'&#xD;&#xA; ORDER BY &#xD;&#xA; (CASE @target&#xD;&#xA;  WHEN 'Group'  THEN A.SVS_NODE_GROUP&#xD;&#xA;  WHEN 'Model'   THEN B.MODEL&#xD;&#xA;   END)">
            <QP N="factory" />
            <QP N="svs_node" />
            <QP N="target" />
          </QY>
        </SG>
        <SG _S="2567" N="SearchSndForUpdate">
          <QY P="MsSql" Q="SELECT A.SVS_NODE, A.SVS_NODE_DESC, A.SVS_NODE_GROUP,  A.STEP,&#xD;&#xA;       B.MODEL, B.MODEL_VER&#xD;&#xA;  FROM QEESSNDDEF A&#xD;&#xA;  LEFT JOIN QEESSNDATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = B.SVS_NODE&#xD;&#xA;   AND B.ATTR_CATEGORY = @attr_category&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.SVS_NODE           = @svs_node&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="attr_category" />
            <QP N="factory" />
            <QP N="svs_node" />
          </QY>
        </SG>
        <SG _S="2568" N="SearchSndForClone">
          <QY P="MsSql" Q="SELECT A.SVS_NODE_GROUP,  A.STEP,   B.MODEL, B.MODEL_VER&#xD;&#xA;  FROM QEESSNDDEF A&#xD;&#xA;  LEFT JOIN QEESSNDATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = B.SVS_NODE&#xD;&#xA;   AND B.ATTR_CATEGORY = @attr_category&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.SVS_NODE           = @svs_node&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="attr_category" />
            <QP N="factory" />
            <QP N="svs_node" />
          </QY>
        </SG>
      </F>
      <F _S="3704" N="BaseNodeViewer">
        <SG _S="3706" N="ListBaseNode">
          <QY P="MsSql" Q="SELECT A.NODE_NAME, &#xD;&#xA;A.NODE_DESC, &#xD;&#xA;A.STEP, &#xD;&#xA;A.UP_DOWN, &#xD;&#xA;A.STATUS, &#xD;&#xA;A.ALARM, &#xD;&#xA;A.AUTO_RELEASE, &#xD;&#xA;A.NEED_ACTION, &#xD;&#xA;A.NEXT_NEED_ACTION,&#xD;&#xA;ISNULL(B.MODEL, 'N/A') SET_MODEL, &#xD;&#xA;ISNULL(B.MODEL_VER, 0) SET_MODEL_VER, &#xD;&#xA;ISNULL(C.MODEL, 'N/A') REL_MODEL, &#xD;&#xA;ISNULL(C.MODEL_VER, 0) REL_MODEL_VER, &#xD;&#xA;ISNULL(D.MODEL, 'N/A') APL_MODEL, &#xD;&#xA;ISNULL(D.MODEL_VER, 0) APL_MODEL_VER&#xD;&#xA;         FROM QEESBNDDEF A&#xD;&#xA;  LEFT JOIN QEESBNDATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.NODE_NAME           = B.NODE_NAME&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QEESBNDATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.NODE_NAME           = C.NODE_NAME&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QEESBNDATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.NODE_NAME           = D.NODE_NAME&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'&#xD;&#xA;  ORDER BY A.NODE_NAME">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="3773" N="ServiceUI">
        <SG _S="3774" N="ListFactory">
          <QY P="MsSql" Q="SELECT FACTORY&#xD;&#xA;  FROM QSYSFACDEF" />
        </SG>
        <SG _S="3775" N="ListBaseNode">
          <QY P="MsSql" Q="SELECT A.NODE_NAME, &#xD;&#xA;A.NODE_DESC, &#xD;&#xA;A.STEP, &#xD;&#xA;A.UP_DOWN, &#xD;&#xA;A.STATUS, &#xD;&#xA;A.ALARM, &#xD;&#xA;A.NEED_ACTION, &#xD;&#xA;A.NEXT_NEED_ACTION,&#xD;&#xA;ISNULL(B.MODEL, 'N/A') SET_MODEL, &#xD;&#xA;ISNULL(B.MODEL_VER, 0) SET_MODEL_VER, &#xD;&#xA;ISNULL(C.MODEL, 'N/A') REL_MODEL, &#xD;&#xA;ISNULL(C.MODEL_VER, 0) REL_MODEL_VER, &#xD;&#xA;ISNULL(D.MODEL, 'N/A') APL_MODEL, &#xD;&#xA;ISNULL(D.MODEL_VER, 0) APL_MODEL_VER&#xD;&#xA;         FROM QEESBNDDEF A&#xD;&#xA;  LEFT JOIN QEESBNDATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.NODE_NAME           = B.NODE_NAME&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QEESBNDATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.NODE_NAME           = C.NODE_NAME&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QEESBNDATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.NODE_NAME           = D.NODE_NAME&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'&#xD;&#xA;  ORDER BY A.NODE_NAME">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3776" N="ListServiceNode">
          <QY P="MsSql" Q="SELECT A.SVS_NODE AS NODE_NAME, &#xD;&#xA;	A.SVS_NODE_DESC AS NODE_DESC, &#xD;&#xA;	A.STEP, &#xD;&#xA;	A.UP_DOWN, &#xD;&#xA;	A.STATUS, &#xD;&#xA;	A.ALARM, &#xD;&#xA;	A.NEED_ACTION, &#xD;&#xA;	A.NEXT_NEED_ACTION,&#xD;&#xA;      ISNULL(B.MODEL, 'N/A') SET_MODEL, &#xD;&#xA;      ISNULL(B.MODEL_VER, 0) SET_MODEL_VER, &#xD;&#xA;      ISNULL(C.MODEL, 'N/A') REL_MODEL, &#xD;&#xA;      ISNULL(C.MODEL_VER, 0) REL_MODEL_VER, &#xD;&#xA;      ISNULL(D.MODEL, 'N/A') APL_MODEL, &#xD;&#xA;      ISNULL(D.MODEL_VER, 0) APL_MODEL_VER&#xD;&#xA;         FROM QEESSNDDEF A&#xD;&#xA;  LEFT JOIN QEESSNDATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = B.SVS_NODE&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QEESSNDATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = C.SVS_NODE&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QEESSNDATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = D.SVS_NODE&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'&#xD;&#xA;  ORDER BY A.SVS_NODE">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="411" N="SndTransaction">
      <F _S="8095" N="EquipmentEvent">
        <SG _S="8096" N="SearchSnd">
          <QY P="MsSql" Q="SELECT SVS_NODE&#xD;&#xA;  FROM QEESSNDDEF  &#xD;&#xA;  WITH (UPDLOCK)&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SVS_NODE         = @svs_node&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="svs_node" />
          </QY>
        </SG>
        <SG _S="8097" N="SearchEquipment">
          <QY P="MsSql" Q="SELECT A.EQP_NAME, B.COMM_STATE, B.CTRL_MODE&#xD;&#xA;  FROM QEESEQPDEF A&#xD;&#xA;  	LEFT JOIN QRASEQPSTS B&#xD;&#xA;  	ON A.EQP_NAME = B.EQP_NAME&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.EQP_NAME = @eqp_name&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="8099" N="InsertEquipmentHis">
          <QY P="MsSql" Q="INSERT INTO QEESEQPHIS (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   EVENT_ID,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   COMM_STATE,&#xD;&#xA;   CTRL_MODE,&#xD;&#xA;   SVS_NODE,&#xD;&#xA;   SVS_NODE_EVENT_ID,      &#xD;&#xA;   EVT_H_1,&#xD;&#xA;   EVT_D_1,   &#xD;&#xA;   EVT_H_2,&#xD;&#xA;   EVT_D_2,&#xD;&#xA;   EVT_H_3,&#xD;&#xA;   EVT_D_3,&#xD;&#xA;   EVT_H_4,&#xD;&#xA;   EVT_D_4,&#xD;&#xA;   EVT_H_5,&#xD;&#xA;   EVT_D_5,&#xD;&#xA;   EVT_H_6,&#xD;&#xA;   EVT_D_6,&#xD;&#xA;   EVT_H_7,&#xD;&#xA;   EVT_D_7,&#xD;&#xA;   EVT_H_8,&#xD;&#xA;   EVT_D_8,&#xD;&#xA;   EVT_H_9,&#xD;&#xA;   EVT_D_9,&#xD;&#xA;   EVT_H_10,&#xD;&#xA;   EVT_D_10,&#xD;&#xA;   EVT_H_11,&#xD;&#xA;   EVT_D_11,   &#xD;&#xA;   EVT_H_12,&#xD;&#xA;   EVT_D_12,&#xD;&#xA;   EVT_H_13,&#xD;&#xA;   EVT_D_13,&#xD;&#xA;   EVT_H_14,&#xD;&#xA;   EVT_D_14,&#xD;&#xA;   EVT_H_15,&#xD;&#xA;   EVT_D_15,&#xD;&#xA;   EVT_H_16,&#xD;&#xA;   EVT_D_16,&#xD;&#xA;   EVT_H_17,&#xD;&#xA;   EVT_D_17,&#xD;&#xA;   EVT_H_18,&#xD;&#xA;   EVT_D_18,&#xD;&#xA;   EVT_H_19,&#xD;&#xA;   EVT_D_19,&#xD;&#xA;   EVT_H_20,&#xD;&#xA;   EVT_D_20,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT      &#xD;&#xA;) &#xD;&#xA;VALUES( &#xD;&#xA;   @factory,&#xD;&#xA;   @eqp_name,&#xD;&#xA;   @last_his_seq,&#xD;&#xA;   @event_id,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @comm_state,&#xD;&#xA;   @ctrl_mode,&#xD;&#xA;   @svs_node,&#xD;&#xA;   @svs_node_event_id,&#xD;&#xA;   @evt_h_1,&#xD;&#xA;   @evt_d_1,   &#xD;&#xA;   @evt_h_2,&#xD;&#xA;   @evt_d_2,&#xD;&#xA;   @evt_h_3,&#xD;&#xA;   @evt_d_3,&#xD;&#xA;   @evt_h_4,&#xD;&#xA;   @evt_d_4,&#xD;&#xA;   @evt_h_5,&#xD;&#xA;   @evt_d_5,&#xD;&#xA;   @evt_h_6,&#xD;&#xA;   @evt_d_6,&#xD;&#xA;   @evt_h_7,&#xD;&#xA;   @evt_d_7,&#xD;&#xA;   @evt_h_8,&#xD;&#xA;   @evt_d_8,&#xD;&#xA;   @evt_h_9,&#xD;&#xA;   @evt_d_9,&#xD;&#xA;   @evt_h_10,&#xD;&#xA;   @evt_d_10,&#xD;&#xA;   @evt_h_11,&#xD;&#xA;   @evt_d_11,   &#xD;&#xA;   @evt_h_12,&#xD;&#xA;   @evt_d_12,&#xD;&#xA;   @evt_h_13,&#xD;&#xA;   @evt_d_13,&#xD;&#xA;   @evt_h_14,&#xD;&#xA;   @evt_d_14,&#xD;&#xA;   @evt_h_15,&#xD;&#xA;   @evt_d_15,&#xD;&#xA;   @evt_h_16,&#xD;&#xA;   @evt_d_16,&#xD;&#xA;   @evt_h_17,&#xD;&#xA;   @evt_d_17,&#xD;&#xA;   @evt_h_18,&#xD;&#xA;   @evt_d_18,&#xD;&#xA;   @evt_h_19,&#xD;&#xA;   @evt_d_19,&#xD;&#xA;   @evt_h_20,&#xD;&#xA;   @evt_d_20,&#xD;&#xA;   @tran_user_id,&#xD;&#xA;   @tran_comment)">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="last_his_seq" />
            <QP N="event_id" />
            <QP N="tran_time" />
            <QP N="comm_state" />
            <QP N="ctrl_mode" />
            <QP N="svs_node" />
            <QP N="svs_node_event_id" />
            <QP N="evt_h_1" />
            <QP N="evt_d_1" />
            <QP N="evt_h_2" />
            <QP N="evt_d_2" />
            <QP N="evt_h_3" />
            <QP N="evt_d_3" />
            <QP N="evt_h_4" />
            <QP N="evt_d_4" />
            <QP N="evt_h_5" />
            <QP N="evt_d_5" />
            <QP N="evt_h_6" />
            <QP N="evt_d_6" />
            <QP N="evt_h_7" />
            <QP N="evt_d_7" />
            <QP N="evt_h_8" />
            <QP N="evt_d_8" />
            <QP N="evt_h_9" />
            <QP N="evt_d_9" />
            <QP N="evt_h_10" />
            <QP N="evt_d_10" />
            <QP N="evt_h_11" />
            <QP N="evt_d_11" />
            <QP N="evt_h_12" />
            <QP N="evt_d_12" />
            <QP N="evt_h_13" />
            <QP N="evt_d_13" />
            <QP N="evt_h_14" />
