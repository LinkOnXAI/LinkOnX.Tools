            <QP N="factory" />
            <QP N="node_name" />
            <QP N="attr_category" />
            <QP N="obj_type" />
            <QP N="obj_name" />
            <QP N="key_seq" />
            <QP N="key_name" />
            <QP N="data" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="3699" N="InsertBaseNodeControllerSts">
