          <QY P="MsSql" Q="INSERT INTO QEESBNDATR (&#xD;&#xA;   FACTORY,&#xD;&#xA;   NODE_NAME,&#xD;&#xA;   ATTR_CATEGORY,&#xD;&#xA;   MODEL,&#xD;&#xA;   MODEL_VER,&#xD;&#xA;   NODE_SCHEMA,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @node_name,&#xD;&#xA;   @attr_category,&#xD;&#xA;   @model,&#xD;&#xA;   @mdl_ver,&#xD;&#xA;   @node_schema,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="node_name" />
            <QP N="attr_category" />
            <QP N="model" />
            <QP N="mdl_ver" />
            <QP N="node_schema" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
