        <SG _S="3761" N="HasBaseNodeAtr">
          <QY P="MsSql" Q="SELECT NODE_NAME, MODEL, MODEL_VER, NODE_SCHEMA&#xD;&#xA;  FROM QEESBNDATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND NODE_NAME           = @node_name&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
