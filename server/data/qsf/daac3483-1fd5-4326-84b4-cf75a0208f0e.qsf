        <SG _S="3178" N="UpdateEquipmentStatus">
          <QY P="MsSql" Q="UPDATE QEESEQPSTS SET&#xD;&#xA;   LAST_HIST_SEQ   = @last_his_seq,&#xD;&#xA;   LAST_EVENT_ID   = @last_event_id,&#xD;&#xA;   LAST_EVENT_TIME = @last_event_time,&#xD;&#xA;   UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;   UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EQP_NAME = @eqp_name">
            <QP N="last_his_seq" />
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
      </F>
      <F _S="412" N="SndUp">
        <SG _S="413" N="SearchSnd">
          <QY P="MsSql" Q="SELECT SVS_NODE, STEP, UP_DOWN, STATUS, NEED_ACTION, NEXT_NEED_ACTION&#xD;&#xA;  FROM QEESSNDDEF  &#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SVS_NODE         = @svs_node&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="svs_node" />
          </QY>
        </SG>
        <SG _S="414" N="SearchSndAtr">
          <QY P="MsSql" Q="SELECT SVS_NODE, MODEL, MODEL_VER, SVS_NODE_SCHEMA&#xD;&#xA;  FROM QEESSNDATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND SVS_NODE           = @svs_node&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="svs_node" />
            <QP N="attr_category" />
          </QY>
        </SG>
        <SG _S="1547" N="SearchSndControllerAtr">
          <QY P="MsSql" Q="SELECT DATA&#xD;&#xA;  FROM QEESSNDCFG&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND SVS_NODE           = @svs_node&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category&#xD;&#xA;   AND OBJ_TYPE      = @obj_type&#xD;&#xA;   AND KEY_NAME      = @eqp_name_key">
            <QP N="factory" />
            <QP N="svs_node" />
            <QP N="attr_category" />
            <QP N="obj_type" />
            <QP N="eqp_name_key" />
          </QY>
        </SG>
        <SG _S="427" N="UpdateSnd">
          <QY P="MsSql" Q="UPDATE QEESSNDDEF SET&#xD;&#xA;  STEP             = @step,&#xD;&#xA;  UP_DOWN          = @up_down,  &#xD;&#xA;  DOWN_FLAG   = @down_flag,&#xD;&#xA;  NEED_ACTION      = @need_action,&#xD;&#xA;  NEXT_NEED_ACTION = @next_need_action,&#xD;&#xA;  RELOAD_CNT       = 0,&#xD;&#xA;  LAST_EVENT_ID    = @last_event_id,&#xD;&#xA;  LAST_EVENT_TIME  = @last_event_time,&#xD;&#xA;  LAST_HIST_SEQ    = @hist_seq,&#xD;&#xA;  UPDATE_USER_ID   = @update_user_id,&#xD;&#xA;  UPDATE_TIME      = @update_time&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND SVS_NODE     = @svs_node">
            <QP N="step" />
            <QP N="up_down" />
            <QP N="down_flag" />
            <QP N="need_action" />
            <QP N="next_need_action" />
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="hist_seq" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="svs_node" />
          </QY>
        </SG>
        <SG _S="3498" N="UpdateControllerSts">
          <QY P="MsSql" Q="UPDATE QEESSNDCTL SET&#xD;&#xA;  COMM_STATE          = @comm_state,&#xD;&#xA;  CTRL_MODE          = @ctrl_mode,&#xD;&#xA;  UPDATE_USER_ID = @update_user_id,&#xD;&#xA;  UPDATE_TIME    = @update_time&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND SVS_NODE       = @svs_node">
            <QP N="comm_state" />
            <QP N="ctrl_mode" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="svs_node" />
          </QY>
        </SG>
        <SG _S="428" N="InsertSndAtr">
          <QY P="MsSql" Q="INSERT INTO QEESSNDATR (&#xD;&#xA;   FACTORY,&#xD;&#xA;   SVS_NODE,&#xD;&#xA;   ATTR_CATEGORY,&#xD;&#xA;   MODEL,&#xD;&#xA;   MODEL_VER,&#xD;&#xA;   SVS_NODE_SCHEMA,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) &#xD;&#xA;SELECT &#xD;&#xA;   FACTORY,&#xD;&#xA;   SVS_NODE,&#xD;&#xA;   @attr_category2,&#xD;&#xA;   MODEL,&#xD;&#xA;   MODEL_VER,&#xD;&#xA;   @svs_node_schema,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;  FROM QEESSNDATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND SVS_NODE           = @svs_node&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="attr_category2" />
            <QP N="svs_node_schema" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="svs_node" />
            <QP N="attr_category" />
          </QY>
        </SG>
        <SG _S="3136" N="InsertSndConfig">
          <QY P="MsSql" Q="INSERT INTO QEESSNDCFG (&#xD;&#xA;   FACTORY,&#xD;&#xA;   SVS_NODE,&#xD;&#xA;   ATTR_CATEGORY,&#xD;&#xA;   OBJ_TYPE,&#xD;&#xA;   OBJ_NAME,&#xD;&#xA;   KEY_SEQ,&#xD;&#xA;   KEY_NAME,&#xD;&#xA;   DATA,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) &#xD;&#xA;SELECT &#xD;&#xA;   FACTORY,&#xD;&#xA;   SVS_NODE,&#xD;&#xA;   @attr_category2,&#xD;&#xA;   OBJ_TYPE,&#xD;&#xA;   OBJ_NAME,&#xD;&#xA;   KEY_SEQ,&#xD;&#xA;   KEY_NAME,&#xD;&#xA;   DATA,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;  FROM QEESSNDCFG&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND SVS_NODE           = @svs_node&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="attr_category2" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="svs_node" />
            <QP N="attr_category" />
          </QY>
        </SG>
        <SG _S="440" N="InsertConnectorSts">
          <QY P="MsSql" Q="INSERT INTO QEESSNDCTS &#xD;&#xA;(&#xD;&#xA;   FACTORY,&#xD;&#xA;   SVS_NODE,   &#xD;&#xA;   CNT_SEQ,&#xD;&#xA;   CNT_NAME,   &#xD;&#xA;   STATE,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) &#xD;&#xA;VALUES&#xD;&#xA;(&#xD;&#xA;   @factory,&#xD;&#xA;   @svs_node,&#xD;&#xA;   @cnt_seq,&#xD;&#xA;   @cnt_name,&#xD;&#xA;   @state,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="svs_node" />
            <QP N="cnt_seq" />
            <QP N="cnt_name" />
            <QP N="state" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="429" N="DeleteSndAtr">
          <QY P="MsSql" Q="DELETE FROM QEESSNDATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND SVS_NODE           = @svs_node&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="svs_node" />
            <QP N="attr_category" />
          </QY>
        </SG>
        <SG _S="439" N="DeleteConnectorSts">
          <QY P="MsSql" Q="DELETE FROM QEESSNDCTS&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND SVS_NODE     = @svs_node">
            <QP N="factory" />
            <QP N="svs_node" />
          </QY>
        </SG>
        <SG _S="426" N="DeleteSndConfig">
          <QY P="MsSql" Q="DELETE&#xD;&#xA;  FROM QEESSNDCFG&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND SVS_NODE           = @svs_node&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="svs_node" />
            <QP N="attr_category" />
          </QY>
        </SG>
      </F>
      <F _S="430" N="SndDown">
        <SG _S="431" N="SearchSnd">
          <QY P="MsSql" Q="SELECT SVS_NODE, STEP, UP_DOWN, STATUS, NEED_ACTION, NEXT_NEED_ACTION&#xD;&#xA;  FROM QEESSNDDEF  &#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SVS_NODE         = @svs_node&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="svs_node" />
          </QY>
        </SG>
        <SG _S="432" N="SearchSndAtr">
          <QY P="MsSql" Q="SELECT SVS_NODE, MODEL, MODEL_VER&#xD;&#xA;  FROM QEESSNDATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND SVS_NODE           = @svs_node&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="svs_node" />
            <QP N="attr_category" />
          </QY>
        </SG>
        <SG _S="1553" N="SearchSndControllerAtr">
          <QY P="MsSql" Q="SELECT DATA&#xD;&#xA;  FROM QEESSNDCFG&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND SVS_NODE           = @svs_node&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category&#xD;&#xA;   AND OBJ_TYPE      = @obj_type&#xD;&#xA;   AND KEY_NAME      = @eqp_name_key">
            <QP N="factory" />
            <QP N="svs_node" />
            <QP N="attr_category" />
            <QP N="obj_type" />
            <QP N="eqp_name_key" />
          </QY>
