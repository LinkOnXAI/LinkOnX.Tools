      <F _S="3783" N="InterlockLoader">
        <SG _S="3784" N="SearchInterlock">
          <QY P="MsSql" Q="SELECT ITL_FILE, ITL_VER&#xD;&#xA;  FROM QEESITLDEF&#xD;&#xA; WHERE FACTORY     = @factory &#xD;&#xA;   AND ITL_NAME = @itl_name">
            <QP N="factory" />
            <QP N="itl_name" />
          </QY>
        </SG>
        <SG _S="3816" N="SearchInterlockByAlarm">
          <QY P="MsSql" Q="SELECT ITL_NAME&#xD;&#xA;  FROM QEESEQPAIL&#xD;&#xA; WHERE FACTORY      = @factory     &#xD;&#xA;   AND EQP_NAME     = @eqp_name &#xD;&#xA;   AND ALARM_NAME   = @alarm_name&#xD;&#xA;   AND ALARM_STATUS = @alarm_status">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="alarm_name" />
            <QP N="alarm_status" />
          </QY>
        </SG>
      </F>
      <F _S="3785" N="ConditionLoader">
        <SG _S="3786" N="SearchCondition">
          <QY P="MsSql" Q="SELECT CDT_FILE&#xD;&#xA; FROM QEESCDTDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;  AND CDT_NAME = @cdt_name">
            <QP N="factory" />
            <QP N="cdt_name" />
          </QY>
        </SG>
        <SG _S="3788" N="SearchConditionInterlock">
          <QY P="MsSql" Q="SELECT A.ITL_NAME, B.ITL_VER&#xD;&#xA; FROM QEESCDTITL A&#xD;&#xA;      LEFT JOIN QEESITLDEF B ON &#xD;&#xA;           A.FACTORY = B.FACTORY &#xD;&#xA;           AND  A.ITL_NAME = B.ITL_NAME&#xD;&#xA; WHERE A.FACTORY = @factory&#xD;&#xA;  AND A.CDT_NAME = @cdt_name">
            <QP N="factory" />
            <QP N="cdt_name" />
          </QY>
        </SG>
        <SG _S="3787" N="SearchEventCondition">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;CONDITION_NAME&#xD;&#xA;  FROM QEESEQPEFL&#xD;&#xA; WHERE FACTORY     = @factory &#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND EVENT_ID = @event_id&#xD;&#xA;   AND USED_CONDITION = 'Yes'">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="event_id" />
          </QY>
        </SG>
      </F>
      <F _S="3801" N="SndInit">
        <SG _S="3802" N="ListSnd">
          <QY P="MsSql" Q="SELECT A.SVS_NODE, A.PROTOCOL,  A.AUTO_START, B.MODEL, B.MODEL_VER&#xD;&#xA;FROM QEESSNDDEF A &#xD;&#xA;   LEFT JOIN QEESSNDATR B &#xD;&#xA;   ON A.FACTORY = B.FACTORY&#xD;&#xA;   AND A.SVS_NODE = B.SVS_NODE&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Released'&#xD;&#xA;WHERE A.FACTORY = @factory&#xD;&#xA;AND A.CONTAINER = @ctn_name&#xD;&#xA;AND A.DELETE_FLAG &lt;&gt;  'Y'    &#xD;&#xA;ORDER BY SVS_NODE">
            <QP N="factory" />
            <QP N="ctn_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
      </F>
      <F _S="3803" N="BaseNodeInit">
        <SG _S="3804" N="ListBaseNode">
          <QY P="MsSql" Q="SELECT NODE_NAME, AUTO_START&#xD;&#xA;FROM QEESBNDDEF&#xD;&#xA;WHERE FACTORY = @factory&#xD;&#xA;AND CONTAINER = @ctn_name&#xD;&#xA;AND  DELETE_FLAG &lt;&gt;  'Y'    &#xD;&#xA;ORDER BY NODE_NAME">
            <QP N="factory" />
            <QP N="ctn_name" />
          </QY>
        </SG>
      </F>
      <F _S="3813" N="InitDataSource">
        <SG _S="3814" N="ListDataSource">
          <QY P="MsSql" Q="SELECT NAME, &#xD;&#xA;   PROVIDER,&#xD;&#xA;   CNT_STRING,&#xD;&#xA;   CNT_PASSWORD,&#xD;&#xA;   DRV_VERSION,&#xD;&#xA;   TIMEOUT,&#xD;&#xA;   USED_CONPOOL,&#xD;&#xA;   QURY_POOL_COUNT,&#xD;&#xA;   TRAN_POOL_COUNT&#xD;&#xA;  FROM QEESDSRDEF&#xD;&#xA; WHERE FACTORY = @factory &#xD;&#xA; ORDER BY NAME">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3815" N="SearchDataSource">
          <QY P="MsSql" Q="SELECT  &#xD;&#xA;   PROVIDER,&#xD;&#xA;   CNT_STRING,&#xD;&#xA;   CNT_PASSWORD,&#xD;&#xA;   DRV_VERSION,&#xD;&#xA;   TIMEOUT,&#xD;&#xA;   USED_CONPOOL,&#xD;&#xA;   QURY_POOL_COUNT,&#xD;&#xA;   TRAN_POOL_COUNT&#xD;&#xA;  FROM QEESDSRDEF&#xD;&#xA; WHERE FACTORY = @factory &#xD;&#xA;  AND NAME = @ds_name">
            <QP N="factory" />
            <QP N="ds_name" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="3279" N="Inquiry">
      <F _S="3281" N="ModelVerSchema">
        <SG _S="3282" N="HasModelVer">
          <QY P="MsSql" Q="SELECT MODEL, MODEL_SCHEMA&#xD;&#xA;  FROM QEESMDLVER&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND MODEL  = @model&#xD;&#xA;   AND MODEL_VER = @mdl_ver">
            <QP N="factory" />
            <QP N="model" />
            <QP N="mdl_ver" />
          </QY>
        </SG>
      </F>
      <F _S="3363" N="SndModelerFile">
        <SG _S="3364" N="HasFactory">
          <QY P="MsSql" Q="SELECT FACTORY, SVS_RELOAD_LIMIT&#xD;&#xA;  FROM QSYSFACDEF&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3366" N="HasSnd">
          <QY P="MsSql" Q="SELECT SVS_NODE_GROUP, UP_DOWN, STATUS&#xD;&#xA;  FROM QEESSNDDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SVS_NODE         = @svs_node&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="svs_node" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="486" N="Dialog">
      <F _S="2933" N="ModelSelector">
        <SG _S="2938" N="ListModel">
          <QY P="MsSql" Q="SELECT MODEL, MODEL_DESC, REL_MODEL_VER, LAST_MODEL_VER&#xD;&#xA;  FROM QEESMDLDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY MODEL">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="565" N="ModelVerSelector">
        <SG _S="566" N="ListModel">
          <QY P="MsSql" Q="SELECT MODEL, MODEL_DESC, REL_MODEL_VER, LAST_MODEL_VER&#xD;&#xA;  FROM QEESMDLDEF&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA; ORDER BY MODEL">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="567" N="ListModelVer">
          <QY P="MsSql" Q="SELECT MODEL_VER, MODEL_VER_DESC, MODEL_RELEASE, MODEL_COMMENT&#xD;&#xA;  FROM QEESMDLVER&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND MODEL   = @model&#xD;&#xA; ORDER BY MODEL_VER DESC">
            <QP N="factory" />
            <QP N="model" />
          </QY>
        </SG>
      </F>
      <F _S="544" N="SndWizard">
        <SG _S="549" N="HasModelVer">
          <QY P="MsSql" Q="SELECT MODEL, MODEL_SCHEMA&#xD;&#xA;  FROM QEESMDLVER&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND MODEL  = @model&#xD;&#xA;   AND MODEL_VER = @mdl_ver">
            <QP N="factory" />
            <QP N="model" />
            <QP N="mdl_ver" />
          </QY>
        </SG>
        <SG _S="3117" N="HasSndAtr">
          <QY P="MsSql" Q="SELECT SVS_NODE_SCHEMA&#xD;&#xA;  FROM QEESSNDATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND SVS_NODE           = @svs_node&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="svs_node" />
            <QP N="attr_category" />
          </QY>
        </SG>
      </F>
      <F _S="3499" N="UserSelector">
        <SG _S="3500" N="SearchUserList">
          <QY P="MsSql" Q="SELECT USER_ID, USER_DESC&#xD;&#xA;  FROM QSECUSRDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY USER_ID">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="3402" N="EquipmentSelector">
        <SG _S="3403" N="ListEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME, EQP_DESC, DELETE_FLAG&#xD;&#xA;  FROM QEESEQPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND DELETE_FLAG = ISNULL(@delete_flag, DELETE_FLAG)&#xD;&#xA; ORDER BY EQP_NAME">
            <QP N="factory" />
            <QP N="delete_flag" />
          </QY>
        </SG>
      </F>
      <F _S="3515" N="EquipmentLineSelector">
        <SG _S="3516" N="ListEquipmentLine">
          <QY P="MsSql" Q="SELECT LINE_NAME, LINE_DESC&#xD;&#xA;  FROM QEESEQPLIN&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY LINE_NAME">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="3517" N="EquipmentTypeSelector">
        <SG _S="3518" N="ListEquipmentType">
          <QY P="MsSql" Q="SELECT EQP_TYPE, EQP_TYPE_DESC&#xD;&#xA;  FROM QEESEQPTYP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY EQP_TYPE">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="609" N="SndSelector">
        <SG _S="615" N="ListModel">
          <QY P="MsSql" Q="SELECT A.MODEL, A.MODEL_DESC, B.MODEL_VER, B.MODEL_VER_DESC, B.MODEL_RELEASE&#xD;&#xA;  FROM QEESMDLDEF A&#xD;&#xA;  LEFT JOIN QEESMDLVER B&#xD;&#xA;    ON A.FACTORY = B.FACTORY&#xD;&#xA;   AND A.MODEL   = B.MODEL&#xD;&#xA; WHERE A.FACTORY = @factory&#xD;&#xA; ORDER BY A.MODEL, B.MODEL_VER DESC">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3414" N="ListSndGroup">
          <QY P="MsSql" Q="SELECT SVS_NODE_GROUP,&#xD;&#xA;	SVS_NODE_GROUP_DESC&#xD;&#xA;  FROM QEESSNDGRP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY SVS_NODE_GROUP">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="616" N="ListSnd">
          <QY P="MsSql" Q="SELECT A.SVS_NODE AS NODE_NAME, A.SVS_NODE_DESC AS NODE_DESC, A.SVS_NODE_GROUP,  A.STEP, A.UP_DOWN, A.NEED_ACTION, A.NEXT_NEED_ACTION,&#xD;&#xA;       B.MODEL, B.MODEL_VER&#xD;&#xA;  FROM QEESSNDDEF A&#xD;&#xA; INNER JOIN QEESSNDATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = B.SVS_NODE&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'   &#xD;&#xA;   AND B.ATTR_CATEGORY = @attr_category   &#xD;&#xA;  AND A.SVS_NODE_GROUP        = ISNULL(@svs_node_group, A.SVS_NODE_GROUP) &#xD;&#xA;   AND ( &#xD;&#xA;       (B.MODEL        = ISNULL(@model, B.MODEL))&#xD;&#xA;       )&#xD;&#xA; ORDER BY A.SVS_NODE">
            <QP N="factory" />
            <QP N="attr_category" />
            <QP N="svs_node_group" />
            <QP N="model" />
          </QY>
        </SG>
        <SG _S="2908" N="ListAllSnd">
          <QY P="MsSql" Q="SELECT SVS_NODE, SVS_NODE_DESC, UP_DOWN, STATUS, DELETE_FLAG&#xD;&#xA;  FROM QEESSNDDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND DELETE_FLAG = ISNULL(@delete_flag, DELETE_FLAG)&#xD;&#xA; ORDER BY SVS_NODE">
            <QP N="factory" />
            <QP N="delete_flag" />
          </QY>
        </SG>
        <SG _S="1378" N="SearchSnd">
          <QY P="MsSql" Q="SELECT  B.MODEL&#xD;&#xA;  FROM QEESSNDDEF A&#xD;&#xA;  LEFT JOIN QEESSNDATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.SVS_NODE           = B.SVS_NODE&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'&#xD;&#xA;   AND A.SVS_NODE           LIKE @svs_node&#xD;&#xA; ORDER BY B.MODEL">
            <QP N="factory" />
            <QP N="svs_node" />
          </QY>
        </SG>
      </F>
      <F _S="3727" N="BaseNodeSelector">
        <SG _S="3728" N="ListBaseNode">
          <QY P="MsSql" Q="SELECT A.NODE_NAME, A.NODE_DESC, A.STEP, A.UP_DOWN, A.NEED_ACTION, A.NEXT_NEED_ACTION,&#xD;&#xA;       B.MODEL, B.MODEL_VER&#xD;&#xA; FROM QEESBNDDEF A&#xD;&#xA; INNER JOIN QEESBNDATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.NODE_NAME = B.NODE_NAME&#xD;&#xA; WHERE A.FACTORY = @factory&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'   &#xD;&#xA;   AND B.ATTR_CATEGORY = @attr_category   &#xD;&#xA; ORDER BY A.NODE_NAME">
            <QP N="factory" />
            <QP N="attr_category" />
          </QY>
        </SG>
      </F>
      <F _S="1767" N="EventSelector">
        <SG _S="1768" N="ListSndEvent">
          <QY P="MsSql" Q="SELECT EVENT_ID, EVENT_DESC&#xD;&#xA;  FROM QEESSNDEVT&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY EVENT_ID">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="3359" N="EquipmentSndSelector">
        <SG _S="3360" N="ListEquipment">
          <QY P="MsSql" Q="SELECT D.EQP_NAME, F.SVS_NODE, D.EQP_DESC, D.DELETE_FLAG&#xD;&#xA;FROM QRASEQPDEF D&#xD;&#xA;LEFT JOIN QEESSNDCFG F ON    &#xD;&#xA;	F.OBJ_TYPE = 'CONTROLLER'&#xD;&#xA;	AND F.ATTR_CATEGORY = 'Applied'&#xD;&#xA;	AND F.DATA = D.EQP_NAME&#xD;&#xA; WHERE D.FACTORY = @factory &#xD;&#xA;       AND D.DELETE_FLAG = ISNULL(@delete_flag, D.DELETE_FLAG)&#xD;&#xA;	AND F.SVS_NODE IS NOT NULL&#xD;&#xA; ORDER BY D.EQP_NAME;">
            <QP N="factory" />
            <QP N="delete_flag" />
          </QY>
        </SG>
      </F>
      <F _S="2194" N="SndGroupSelector">
        <SG _S="2197" N="ListSndGroup">
          <QY P="MsSql" Q="SELECT SVS_NODE_GROUP, SVS_NODE_GROUP_DESC&#xD;&#xA;  FROM QEESSNDGRP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY SVS_NODE_GROUP">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="3457" N="LineEquipmentSelector">
        <SG _S="3458" N="ListEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME, EQP_DESC&#xD;&#xA;FROM QEESEQPDEF&#xD;&#xA;WHERE FACTORY = @factory&#xD;&#xA;AND EQP_NAME NOT IN (SELECT EQP_NAME FROM QEESLINEQP WHERE FACTORY = @factory)&#xD;&#xA;AND DELETE_FLAG &lt;&gt; 'Y'&#xD;&#xA;ORDER BY EQP_NAME ASC">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="3610" N="EquipmentEventSelector">
        <SG _S="3611" N="ListEquipmentEvent">
          <QY P="MsSql" Q="SELECT EVENT_ID, EVENT_DESC&#xD;&#xA;FROM QEESEQPEVT&#xD;&#xA;WHERE FACTORY = @factory&#xD;&#xA;AND EVENT_ID NOT IN (SELECT EVENT_ID FROM QEESEQPEFL WHERE FACTORY = @factory AND EQP_NAME = @eqp_name)&#xD;&#xA;ORDER BY EVENT_ID ASC">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
      </F>
      <F _S="3602" N="InterlockSelector">
        <SG _S="3603" N="ListInterlock">
          <QY P="MsSql" Q="SELECT ITL_NAME, ITL_DESC&#xD;&#xA;FROM QEESITLDEF&#xD;&#xA;WHERE FACTORY = @factory&#xD;&#xA;AND ITL_NAME NOT IN (SELECT ITL_NAME &#xD;&#xA;	FROM QEESCDTITL &#xD;&#xA;	WHERE FACTORY = @factory AND CDT_NAME = @cdt_name)&#xD;&#xA;ORDER BY ITL_NAME ASC">
            <QP N="factory" />
            <QP N="cdt_name" />
          </QY>
        </SG>
        <SG _S="3614" N="ListInterlockByAll">
          <QY P="MsSql" Q="SELECT ITL_NAME, ITL_DESC&#xD;&#xA;FROM QEESITLDEF&#xD;&#xA;WHERE FACTORY = @factory&#xD;&#xA;ORDER BY ITL_NAME ASC">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="3615" N="ConditionSelector">
        <SG _S="3616" N="ListConditionGroup">
          <QY P="MsSql" Q="SELECT CDG_NAME, CDG_DESC&#xD;&#xA;  FROM QEESCDGDEF&#xD;&#xA; WHERE FACTORY     = @factory &#xD;&#xA; ORDER BY CDG_NAME">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3617" N="ListCondition">
          <QY P="MsSql" Q="SELECT  CDT_NAME, CDT_DESC&#xD;&#xA;  FROM QEESCDTDEF&#xD;&#xA; WHERE FACTORY     = @factory &#xD;&#xA; 	AND CDT_GROUP = @cdt_group&#xD;&#xA; ORDER BY CDT_NAME">
            <QP N="factory" />
            <QP N="cdt_group" />
          </QY>
        </SG>
      </F>
      <F _S="3779" N="LineSelector">
        <SG _S="3780" N="ListLine">
          <QY P="MsSql" Q="SELECT LINE_NAME, LINE_DESC&#xD;&#xA;  FROM QEESLINDEF&#xD;&#xA;  WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="2" N="Setup">
      <F _S="3477" N="Transaction">
        <SG _S="3478" N="SearchTransactionGroup">
          <QY P="MsSql" Q="SELECT TXN_GRP_NAME, TXN_GRP_DESC&#xD;&#xA;  FROM QEESTXNGRP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TXN_GRP_NAME     = @transaction_group">
            <QP N="factory" />
            <QP N="transaction_group" />
          </QY>
        </SG>
        <SG _S="3479" N="SearchTransaction">
          <QY P="MsSql" Q="SELECT TXN_GRP_NAME, TXN_NAME, TXN_DESC&#xD;&#xA;  FROM QEESTXNDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TXN_GRP_NAME     = @transaction_group&#xD;&#xA;   AND TXN_NAME = @transaction">
            <QP N="factory" />
            <QP N="transaction_group" />
            <QP N="transaction" />
          </QY>
        </SG>
        <SG _S="3480" N="ListTransactionGroup">
          <QY P="MsSql" Q="SELECT TXN_GRP_NAME, TXN_GRP_DESC&#xD;&#xA;  FROM QEESTXNGRP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY TXN_GRP_NAME">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3481" N="ListTransaction">
          <QY P="MsSql" Q="SELECT TXN_NAME, TXN_DESC&#xD;&#xA;  FROM QEESTXNDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TXN_GRP_NAME     = @transaction_group&#xD;&#xA; ORDER BY TXN_NAME">
            <QP N="factory" />
            <QP N="transaction_group" />
          </QY>
        </SG>
        <SG _S="3482" N="CountTransaction">
          <QY P="MsSql" Q="SELECT COUNT(TXN_GRP_NAME) AS COUNT&#xD;&#xA;  FROM QEESTXNDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TXN_GRP_NAME         = @transaction_group">
            <QP N="factory" />
            <QP N="transaction_group" />
          </QY>
        </SG>
        <SG _S="3490" N="UpdateTransaction">
          <QY P="MsSql" Q="UPDATE QEESTXNDEF SET&#xD;&#xA;  TXN_DESC       = @transaction_desc,&#xD;&#xA;  UPDATE_USER_ID = @update_user_id,&#xD;&#xA;  UPDATE_TIME    = @update_time&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND TXN_GRP_NAME       = @transaction_group&#xD;&#xA;   AND TXN_NAME = @transaction">
            <QP N="transaction_desc" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="transaction_group" />
            <QP N="transaction" />
          </QY>
        </SG>
        <SG _S="3489" N="InsertTransaction">
          <QY P="MsSql" Q="INSERT INTO QEESTXNDEF (&#xD;&#xA;   FACTORY,&#xD;&#xA;   TXN_GRP_NAME,&#xD;&#xA;   TXN_NAME,&#xD;&#xA;   TXN_DESC,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @transaction_group,&#xD;&#xA;   @transaction,&#xD;&#xA;   @transaction_desc,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="transaction_group" />
            <QP N="transaction" />
            <QP N="transaction_desc" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="3488" N="HasTransaction">
          <QY P="MsSql" Q="SELECT TXN_NAME&#xD;&#xA;  FROM QEESTXNDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TXN_GRP_NAME     = @transaction_group&#xD;&#xA;   AND TXN_NAME  = @transaction">
            <QP N="factory" />
            <QP N="transaction_group" />
            <QP N="transaction" />
          </QY>
        </SG>
        <SG _S="3487" N="DeleteTransaction">
          <QY P="MsSql" Q="DELETE &#xD;&#xA;  FROM QEESTXNDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TXN_GRP_NAME     = @transaction_group&#xD;&#xA;   AND TXN_NAME  = @transaction">
            <QP N="factory" />
            <QP N="transaction_group" />
            <QP N="transaction" />
          </QY>
        </SG>
        <SG _S="3486" N="UpdateTransactionGroup">
          <QY P="MsSql" Q="UPDATE QEESTXNGRP SET&#xD;&#xA;  TXN_GRP_DESC       = @transaction_group_desc,&#xD;&#xA;  UPDATE_USER_ID = @update_user_id,&#xD;&#xA;  UPDATE_TIME    = @update_time&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND TXN_GRP_NAME       = @transaction_group">
            <QP N="transaction_group_desc" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="transaction_group" />
          </QY>
        </SG>
        <SG _S="3485" N="InsertTransactionGroup">
