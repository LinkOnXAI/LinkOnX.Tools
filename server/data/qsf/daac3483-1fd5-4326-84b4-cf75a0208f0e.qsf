<?xml version="1.0"?>
<Q QN="QSF" QV="1.0.0.0" QC="2019.09.15 14:33:23.406" QU="2026-01-12 10:09:09.552" QD="LinkOn SQL File" QS="3820">
  <S _S="0" N="NOVAOnNDService" D="NOVAOn Node Service" _RK="daac3483-1fd5-4326-84b4-cf75a0208f0e">
    <M _S="100" N="Common">
      <F _S="3817" N="FactoryConfig">
        <SG _S="3819" N="SearchFactoryConfigAttr">
          <QY P="MsSql" Q="SELECT PROTOCOL_ATTR&#xD;&#xA;  FROM QSYSFACCFG&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND SYSTEM = @system">
            <QP N="factory" />
            <QP N="system" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
      </F>
      <F _S="101" N="Validation" D="Q">
        <SG _S="102" N="HasFactory" D="O">
          <QY P="MsSql" Q="SELECT FACTORY, EAP_RELOAD_LIMIT&#xD;&#xA;  FROM QSYSFACDEF&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3796" N="HasInterlock">
          <QY P="MsSql" Q="SELECT ITL_NAME, ITL_FILE&#xD;&#xA;  FROM QEESITLDEF&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND ITL_NAME = @itl_name">
            <QP N="factory" />
            <QP N="itl_name" />
          </QY>
        </SG>
        <SG _S="3795" N="HasCondition">
          <QY P="MsSql" Q="SELECT CDT_NAME, CDT_DESC, CDT_FILE&#xD;&#xA;  FROM QEESCDTDEF&#xD;&#xA; WHERE FACTORY     = @factory &#xD;&#xA;  AND CDT_NAME = @cdt_name">
            <QP N="factory" />
            <QP N="cdt_name" />
          </QY>
        </SG>
      </F>
      <F _S="738" N="EventSearch" D="Q">
        <SG _S="763" N="SearchUserEvent" D="O">
          <QY P="MsSql" Q="SELECT EVENT_DESC, &#xD;&#xA;       DATA_1_PRT, DATA_2_PRT, DATA_3_PRT, DATA_4_PRT, DATA_5_PRT,&#xD;&#xA;       DATA_6_PRT, DATA_7_PRT, DATA_8_PRT, DATA_9_PRT, DATA_10_PRT,&#xD;&#xA;       DATA_11_PRT, DATA_12_PRT, DATA_13_PRT, DATA_14_PRT, DATA_15_PRT,&#xD;&#xA;       DATA_16_PRT, DATA_17_PRT, DATA_18_PRT, DATA_19_PRT, DATA_20_PRT&#xD;&#xA;  FROM QSECUSREVT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND SYSTEM   = @system&#xD;&#xA;   AND EVENT_ID = @event_id&#xD;&#xA;   AND ACTION   = @action">
            <QP N="factory" />
            <QP N="system" />
            <QP N="event_id" />
            <QP N="action" />
          </QY>
        </SG>
        <SG _S="3549" N="SearchModelingEvent">
          <QY P="MsSql" Q="SELECT EVENT_DESC, &#xD;&#xA;       DATA_1_PRT, DATA_2_PRT, DATA_3_PRT, DATA_4_PRT, DATA_5_PRT,&#xD;&#xA;       DATA_6_PRT, DATA_7_PRT, DATA_8_PRT, DATA_9_PRT, DATA_10_PRT,&#xD;&#xA;       DATA_11_PRT, DATA_12_PRT, DATA_13_PRT, DATA_14_PRT, DATA_15_PRT,&#xD;&#xA;       DATA_16_PRT, DATA_17_PRT, DATA_18_PRT, DATA_19_PRT, DATA_20_PRT&#xD;&#xA;  FROM QEESBMLEVT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EVENT_ID = @event_id">
            <QP N="factory" />
            <QP N="event_id" />
          </QY>
        </SG>
        <SG _S="2830" N="SearchUserEventAll" D="O">
          <QY P="MsSql" Q="SELECT EVENT_ID, EVENT_DESC, ACTION&#xD;&#xA;  FROM QSECUSREVT&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3409" N="SearchEquipmentEvent">
          <QY P="MsSql" Q="SELECT EVENT_DESC,&#xD;&#xA;       DATA_1_PRT, DATA_2_PRT, DATA_3_PRT, DATA_4_PRT, DATA_5_PRT,&#xD;&#xA;       DATA_6_PRT, DATA_7_PRT, DATA_8_PRT, DATA_9_PRT, DATA_10_PRT,    &#xD;&#xA;       DATA_11_PRT, DATA_12_PRT, DATA_13_PRT, DATA_14_PRT, DATA_15_PRT,&#xD;&#xA;       DATA_16_PRT, DATA_17_PRT, DATA_18_PRT, DATA_19_PRT, DATA_20_PRT,&#xD;&#xA;       ALT_COMMENT&#xD;&#xA;  FROM QEESEQPEVT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EVENT_ID = @event_id">
            <QP N="factory" />
            <QP N="event_id" />
          </QY>
        </SG>
        <SG _S="816" N="SearchSndEvent" D="O">
          <QY P="MsSql" Q="SELECT EVENT_DESC,&#xD;&#xA;       DATA_1_PRT, DATA_2_PRT, DATA_3_PRT, DATA_4_PRT, DATA_5_PRT,&#xD;&#xA;       DATA_6_PRT, DATA_7_PRT, DATA_8_PRT, DATA_9_PRT, DATA_10_PRT,    &#xD;&#xA;       DATA_11_PRT, DATA_12_PRT, DATA_13_PRT, DATA_14_PRT, DATA_15_PRT,&#xD;&#xA;       DATA_16_PRT, DATA_17_PRT, DATA_18_PRT, DATA_19_PRT, DATA_20_PRT,&#xD;&#xA;       ALT_COMMENT&#xD;&#xA;  FROM QEESSNDEVT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EVENT_ID = @event_id">
            <QP N="factory" />
            <QP N="event_id" />
          </QY>
        </SG>
        <SG _S="2833" N="SearchSndEventAll" D="O">
          <QY P="MsSql" Q="SELECT EVENT_ID, EVENT_DESC&#xD;&#xA;  FROM QEESSNDEVT&#xD;&#xA; WHERE FACTORY  = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3410" N="SearchEquipmentEventAll">
          <QY P="MsSql" Q="SELECT EVENT_ID, EVENT_DESC&#xD;&#xA;  FROM QEESEQPEVT&#xD;&#xA; WHERE FACTORY  = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3749" N="SearchInterlockEvent">
          <QY P="MsSql" Q="SELECT EVENT_DESC,&#xD;&#xA;       DATA_1_PRT, DATA_2_PRT, DATA_3_PRT, DATA_4_PRT, DATA_5_PRT,&#xD;&#xA;       DATA_6_PRT, DATA_7_PRT, DATA_8_PRT, DATA_9_PRT, DATA_10_PRT,    &#xD;&#xA;       DATA_11_PRT, DATA_12_PRT, DATA_13_PRT, DATA_14_PRT, DATA_15_PRT,&#xD;&#xA;       DATA_16_PRT, DATA_17_PRT, DATA_18_PRT, DATA_19_PRT, DATA_20_PRT,&#xD;&#xA;       ALT_COMMENT&#xD;&#xA;  FROM QEESITLEVT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EVENT_ID = @event_id">
            <QP N="factory" />
            <QP N="event_id" />
          </QY>
        </SG>
      </F>
      <F _S="764" N="UserHistory" D="Q">
        <SG _S="1295" N="InsertUserHistory" D="O">
          <QY P="MsSql" Q="INSERT INTO QSECUSRHIS(&#xD;&#xA;   FACTORY,&#xD;&#xA;   USER_ID,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   EVENT_ID,&#xD;&#xA;   ACTION,&#xD;&#xA;   SYSTEM,&#xD;&#xA;   HOST_IP,&#xD;&#xA;   HOST_NAME,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   EVT_H_1,&#xD;&#xA;   EVT_D_1,&#xD;&#xA;   EVT_H_2,&#xD;&#xA;   EVT_D_2,&#xD;&#xA;   EVT_H_3,&#xD;&#xA;   EVT_D_3,&#xD;&#xA;   EVT_H_4,&#xD;&#xA;   EVT_D_4,&#xD;&#xA;   EVT_H_5,&#xD;&#xA;   EVT_D_5,&#xD;&#xA;   EVT_H_6,&#xD;&#xA;   EVT_D_6,&#xD;&#xA;   EVT_H_7,&#xD;&#xA;   EVT_D_7,&#xD;&#xA;   EVT_H_8,&#xD;&#xA;   EVT_D_8,&#xD;&#xA;   EVT_H_9,&#xD;&#xA;   EVT_D_9,&#xD;&#xA;   EVT_H_10,&#xD;&#xA;   EVT_D_10,    &#xD;&#xA;   EVT_H_11,&#xD;&#xA;   EVT_D_11,&#xD;&#xA;   EVT_H_12,&#xD;&#xA;   EVT_D_12,&#xD;&#xA;   EVT_H_13,&#xD;&#xA;   EVT_D_13,&#xD;&#xA;   EVT_H_14,&#xD;&#xA;   EVT_D_14,&#xD;&#xA;   EVT_H_15,&#xD;&#xA;   EVT_D_15,&#xD;&#xA;   EVT_H_16,&#xD;&#xA;   EVT_D_16,&#xD;&#xA;   EVT_H_17,&#xD;&#xA;   EVT_D_17,&#xD;&#xA;   EVT_H_18,&#xD;&#xA;   EVT_D_18,&#xD;&#xA;   EVT_H_19,&#xD;&#xA;   EVT_D_19,&#xD;&#xA;   EVT_H_20,&#xD;&#xA;   EVT_D_20,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @user_id,&#xD;&#xA;   (NEXT VALUE FOR SEQ_USR_HIS),&#xD;&#xA;   @event_id, &#xD;&#xA;   @action, &#xD;&#xA;   @SYSTEM,&#xD;&#xA;   @host_ip,&#xD;&#xA;   @host_name,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @evt_h_1,&#xD;&#xA;   @evt_d_1,   &#xD;&#xA;   @evt_h_2,&#xD;&#xA;   @evt_d_2,&#xD;&#xA;   @evt_h_3,&#xD;&#xA;   @evt_d_3,&#xD;&#xA;   @evt_h_4,&#xD;&#xA;   @evt_d_4,&#xD;&#xA;   @evt_h_5,&#xD;&#xA;   @evt_d_5,&#xD;&#xA;   @evt_h_6,&#xD;&#xA;   @evt_d_6,&#xD;&#xA;   @evt_h_7,&#xD;&#xA;   @evt_d_7,&#xD;&#xA;   @evt_h_8,&#xD;&#xA;   @evt_d_8,&#xD;&#xA;   @evt_h_9,&#xD;&#xA;   @evt_d_9,&#xD;&#xA;   @evt_h_10,&#xD;&#xA;   @evt_d_10,&#xD;&#xA;   @evt_h_11,&#xD;&#xA;   @evt_d_11,   &#xD;&#xA;   @evt_h_12,&#xD;&#xA;   @evt_d_12,&#xD;&#xA;   @evt_h_13,&#xD;&#xA;   @evt_d_13,&#xD;&#xA;   @evt_h_14,&#xD;&#xA;   @evt_d_14,&#xD;&#xA;   @evt_h_15,&#xD;&#xA;   @evt_d_15,&#xD;&#xA;   @evt_h_16,&#xD;&#xA;   @evt_d_16,&#xD;&#xA;   @evt_h_17,&#xD;&#xA;   @evt_d_17,&#xD;&#xA;   @evt_h_18,&#xD;&#xA;   @evt_d_18,&#xD;&#xA;   @evt_h_19,&#xD;&#xA;   @evt_d_19,&#xD;&#xA;   @evt_h_20,&#xD;&#xA;   @evt_d_20,   &#xD;&#xA;   @tran_user_id,&#xD;&#xA;   @tran_comment&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="user_id" />
            <QP N="event_id" />
            <QP N="action" />
            <QP N="SYSTEM" />
            <QP N="host_ip" />
            <QP N="host_name" />
            <QP N="tran_time" />
            <QP N="evt_h_1" />
            <QP N="evt_d_1" />
            <QP N="evt_h_2" />
            <QP N="evt_d_2" />
            <QP N="evt_h_3" />
            <QP N="evt_d_3" />
            <QP N="evt_h_4" />
            <QP N="evt_d_4" />
            <QP N="evt_h_5" />
            <QP N="evt_d_5" />
            <QP N="evt_h_6" />
            <QP N="evt_d_6" />
            <QP N="evt_h_7" />
            <QP N="evt_d_7" />
            <QP N="evt_h_8" />
            <QP N="evt_d_8" />
            <QP N="evt_h_9" />
            <QP N="evt_d_9" />
            <QP N="evt_h_10" />
            <QP N="evt_d_10" />
            <QP N="evt_h_11" />
            <QP N="evt_d_11" />
            <QP N="evt_h_12" />
            <QP N="evt_d_12" />
            <QP N="evt_h_13" />
            <QP N="evt_d_13" />
            <QP N="evt_h_14" />
            <QP N="evt_d_14" />
            <QP N="evt_h_15" />
            <QP N="evt_d_15" />
            <QP N="evt_h_16" />
            <QP N="evt_d_16" />
            <QP N="evt_h_17" />
            <QP N="evt_d_17" />
            <QP N="evt_h_18" />
            <QP N="evt_d_18" />
            <QP N="evt_h_19" />
            <QP N="evt_d_19" />
            <QP N="evt_h_20" />
            <QP N="evt_d_20" />
            <QP N="tran_user_id" />
            <QP N="tran_comment" />
          </QY>
        </SG>
      </F>
      <F _S="483" N="SndSchemaSearch">
        <SG _S="489" N="SearchSnd">
          <QY P="MsSql" Q="SELECT SVS_NODE_GROUP&#xD;&#xA;  FROM QEESSNDDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SVS_NODE         = @svs_node&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="svs_node" />
          </QY>
        </SG>
        <SG _S="496" N="SearchSndEquipmentAtr">
          <QY P="MsSql" Q="SELECT A.EQP_SEQ, A.EQP_NAME, A.EQP_DESC, ISNULL(B.CTRL_MODE, 'Unknown') CTRL_MODE, B.PRI_STATE, B.STATE, B.ALARM, B.CMF_5 AS PLC_IP_ADDRESS&#xD;&#xA;  FROM QRASEQPATR A&#xD;&#xA;  LEFT JOIN QRASEQPDEF B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EQP_NAME      = B.EQP_NAME&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.SVS_NODE           = @svs_node&#xD;&#xA;   AND A.ATTR_CATEGORY = @attr_category&#xD;&#xA; ORDER BY A.EQP_SEQ">
            <QP N="factory" />
            <QP N="svs_node" />
            <QP N="attr_category" />
          </QY>
        </SG>
      </F>
      <F _S="1100" N="SndFilePack">
        <SG _S="1102" N="HasModelVer">
          <QY P="MsSql" Q="SELECT MODEL_VER_PATH, MODEL_RELEASE&#xD;&#xA;  FROM QEESMDLVER  &#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND MODEL  = @model&#xD;&#xA;   AND MODEL_VER = @mdl_ver">
            <QP N="factory" />
            <QP N="model" />
            <QP N="mdl_ver" />
          </QY>
        </SG>
      </F>
      <F _S="1083" N="SndAlarmSet">
        <SG _S="1084" N="SearchSnd">
          <QY P="MsSql" Q="SELECT UP_DOWN, STATUS, ALARM&#xD;&#xA;  FROM QEESSNDDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SVS_NODE         = @svs_node&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="svs_node" />
          </QY>
        </SG>
        <SG _S="1086" N="SearchConnectorState">
          <QY P="MsSql" Q="SELECT CNT_NAME&#xD;&#xA;  FROM QEESSNDCTS&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND SVS_NODE     = @svs_node&#xD;&#xA;   AND STATE  &lt;&gt; @state">
            <QP N="factory" />
            <QP N="svs_node" />
            <QP N="state" />
          </QY>
        </SG>
        <SG _S="1085" N="UpdateSnd">
          <QY P="MsSql" Q="UPDATE QEESSNDDEF SET  &#xD;&#xA;  ALARM = @alarm  &#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND SVS_NODE     = @svs_node">
            <QP N="alarm" />
            <QP N="factory" />
            <QP N="svs_node" />
          </QY>
        </SG>
      </F>
      <F _S="3624" N="BaseNodeAlarmSet">
        <SG _S="3626" N="SearchBaseNode">
          <QY P="MsSql" Q="SELECT UP_DOWN, STATUS, ALARM&#xD;&#xA;  FROM QEESBNDDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND NODE_NAME = @node_name&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="node_name" />
          </QY>
        </SG>
        <SG _S="3627" N="SearchConnectorState">
          <QY P="MsSql" Q="SELECT CNT_NAME&#xD;&#xA;  FROM QEESBNDCTS&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND NODE_NAME     = @node_name&#xD;&#xA;   AND STATE  &lt;&gt; @state">
            <QP N="factory" />
            <QP N="node_name" />
            <QP N="state" />
          </QY>
        </SG>
        <SG _S="3628" N="UpdateBaseNode">
          <QY P="MsSql" Q="UPDATE QEESBNDDEF SET  &#xD;&#xA;  ALARM = @alarm  &#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND NODE_NAME  = @node_name">
            <QP N="alarm" />
            <QP N="factory" />
            <QP N="node_name" />
          </QY>
        </SG>
      </F>
      <F _S="3629" N="BaseNodeHistory">
        <SG _S="3631" N="SelectHistorySeq">
          <QY P="MsSql" Q="SELECT NEXT VALUE FOR SEQ_BASE_NODE_HIS" />
        </SG>
        <SG _S="3650" N="SelectNodeInfoForHistory">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;   A.FACTORY,&#xD;&#xA;   A.NODE_NAME,&#xD;&#xA;   A.STEP,&#xD;&#xA;   A.ALARM,&#xD;&#xA;   A.UP_DOWN,&#xD;&#xA;   A.STATUS,&#xD;&#xA;   A.NEED_ACTION,&#xD;&#xA;   A.NEXT_NEED_ACTION,   &#xD;&#xA;   A.AUTO_RELEASE,&#xD;&#xA;   A.DELETE_FLAG,&#xD;&#xA;   ISNULL(B.MODEL, ' ') AS SET_MODEL,&#xD;&#xA;   ISNULL(B.MODEL_VER, 0) AS SET_MODEL_VER,&#xD;&#xA;   ISNULL(C.MODEL, ' ') AS REL_MODEL,&#xD;&#xA;   ISNULL(C.MODEL_VER, 0) AS REL_MODEL_VER,&#xD;&#xA;   ISNULL(D.MODEL, ' ') AS APL_MODEL,&#xD;&#xA;   ISNULL(D.MODEL_VER, 0) AS APL_MODEL_VER&#xD;&#xA;  FROM QEESBNDDEF A  &#xD;&#xA;  WITH (NOLOCK)&#xD;&#xA;  LEFT JOIN QEESBNDATR B &#xD;&#xA;    ON A.FACTORY = B.FACTORY&#xD;&#xA;   AND A.NODE_NAME = B.NODE_NAME&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QEESBNDATR C&#xD;&#xA;    ON A.FACTORY = C.FACTORY&#xD;&#xA;   AND A.NODE_NAME = C.NODE_NAME&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QEESBNDATR D&#xD;&#xA;    ON A.FACTORY = D.FACTORY&#xD;&#xA;   AND A.NODE_NAME = D.NODE_NAME&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY = @factory&#xD;&#xA;   AND A.NODE_NAME = @node_name">
            <QP N="factory" />
            <QP N="node_name" />
          </QY>
        </SG>
        <SG _S="3632" N="InsertHistory">
          <QY P="MsSql" Q="INSERT INTO QEESBNDHIS (&#xD;&#xA;   FACTORY,&#xD;&#xA;   NODE_NAME,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   EVENT_ID,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   STEP,&#xD;&#xA;   UP_DOWN,&#xD;&#xA;   STATUS,&#xD;&#xA;   NEED_ACTION,&#xD;&#xA;   NEXT_NEED_ACTION,&#xD;&#xA;   SET_MODEL,&#xD;&#xA;   SET_MODEL_VER,&#xD;&#xA;   REL_MODEL,&#xD;&#xA;   REL_MODEL_VER,&#xD;&#xA;   APL_MODEL,&#xD;&#xA;   APL_MODEL_VER,   &#xD;&#xA;   EVT_H_1,&#xD;&#xA;   EVT_D_1,   &#xD;&#xA;   EVT_H_2,&#xD;&#xA;   EVT_D_2,&#xD;&#xA;   EVT_H_3,&#xD;&#xA;   EVT_D_3,&#xD;&#xA;   EVT_H_4,&#xD;&#xA;   EVT_D_4,&#xD;&#xA;   EVT_H_5,&#xD;&#xA;   EVT_D_5,&#xD;&#xA;   EVT_H_6,&#xD;&#xA;   EVT_D_6,&#xD;&#xA;   EVT_H_7,&#xD;&#xA;   EVT_D_7,&#xD;&#xA;   EVT_H_8,&#xD;&#xA;   EVT_D_8,&#xD;&#xA;   EVT_H_9,&#xD;&#xA;   EVT_D_9,&#xD;&#xA;   EVT_H_10,&#xD;&#xA;   EVT_D_10,&#xD;&#xA;   EVT_H_11,&#xD;&#xA;   EVT_D_11,   &#xD;&#xA;   EVT_H_12,&#xD;&#xA;   EVT_D_12,&#xD;&#xA;   EVT_H_13,&#xD;&#xA;   EVT_D_13,&#xD;&#xA;   EVT_H_14,&#xD;&#xA;   EVT_D_14,&#xD;&#xA;   EVT_H_15,&#xD;&#xA;   EVT_D_15,&#xD;&#xA;   EVT_H_16,&#xD;&#xA;   EVT_D_16,&#xD;&#xA;   EVT_H_17,&#xD;&#xA;   EVT_D_17,&#xD;&#xA;   EVT_H_18,&#xD;&#xA;   EVT_D_18,&#xD;&#xA;   EVT_H_19,&#xD;&#xA;   EVT_D_19,&#xD;&#xA;   EVT_H_20,&#xD;&#xA;   EVT_D_20,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT      &#xD;&#xA;) &#xD;&#xA;VALUES( &#xD;&#xA;   @factory,&#xD;&#xA;   @node_name,&#xD;&#xA;   @hist_seq,&#xD;&#xA;   @event_id,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @step,&#xD;&#xA;   @up_down,&#xD;&#xA;   @node_status,&#xD;&#xA;   @node_need_action,&#xD;&#xA;   @node_next_action,   &#xD;&#xA;   @set_mdl,&#xD;&#xA;   @set_mdl_ver,&#xD;&#xA;   @rel_mdl,&#xD;&#xA;   @rel_mdl_ver,&#xD;&#xA;   @apl_mdl,&#xD;&#xA;   @apl_mdl_ver,   &#xD;&#xA;   @evt_h_1,&#xD;&#xA;   @evt_d_1,   &#xD;&#xA;   @evt_h_2,&#xD;&#xA;   @evt_d_2,&#xD;&#xA;   @evt_h_3,&#xD;&#xA;   @evt_d_3,&#xD;&#xA;   @evt_h_4,&#xD;&#xA;   @evt_d_4,&#xD;&#xA;   @evt_h_5,&#xD;&#xA;   @evt_d_