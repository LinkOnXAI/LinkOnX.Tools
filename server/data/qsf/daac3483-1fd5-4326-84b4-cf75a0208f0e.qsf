          <QY P="MsSql" Q="UPDATE QEESBNDCTS SET&#xD;&#xA;  STATE          = @state,&#xD;&#xA;  UPDATE_USER_ID = @update_user_id,&#xD;&#xA;  UPDATE_TIME    = @update_time&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND NODE_NAME = @node_name">
            <QP N="state" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="node_name" />
          </QY>
        </SG>
      </F>
      <F _S="3764" N="BaseNodeRestart">
        <SG _S="3765" N="HasBaseNode">
          <QY P="MsSql" Q="SELECT NODE_NAME, UP_DOWN, STATUS    &#xD;&#xA;  FROM QEESBNDDEF  &#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND NODE_NAME = @node_name&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="node_name" />
          </QY>
        </SG>
        <SG _S="3766" N="HasBaseNodeAtr">
          <QY P="MsSql" Q="SELECT NODE_NAME, MODEL, MODEL_VER, NODE_SCHEMA&#xD;&#xA;  FROM QEESBNDATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND NODE_NAME           = @node_name&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="node_name" />
            <QP N="attr_category" />
          </QY>
        </SG>
        <SG _S="3767" N="UpdateBaseNode">
          <QY P="MsSql" Q="UPDATE QEESBNDDEF SET&#xD;&#xA;  LAST_EVENT_ID   = @last_event_id,&#xD;&#xA;  LAST_EVENT_TIME = @last_event_time,&#xD;&#xA;  LAST_HIST_SEQ   = @hist_seq,&#xD;&#xA;  UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;  UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND NODE_NAME     = @node_name">
            <QP N="last_event_id" />
