          </QY>
        </SG>
        <SG _S="3768" N="HasMatchDataVersion">
          <QY P="MsSql" Q="SELECT TYPE, RCP_ID, MDT_VER&#xD;&#xA;  FROM QTMSMDTVER&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND APR_SEQ = @apr_seq&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="apr_seq" />
          </QY>
        </SG>
        <SG _S="4042" N="InsertApprovalResult">
          <QY P="MsSql" Q="INSERT INTO QTMSAPRRST (&#xD;&#xA;   FACTORY,&#xD;&#xA;   APR_SEQ,&#xD;&#xA;   APR_TYPE,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   APQ_TIME,&#xD;&#xA;   APQ_USER_ID,&#xD;&#xA;   STEPS,&#xD;&#xA;   RESULT,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT&#xD;&#xA;   )&#xD;&#xA;SELECT&#xD;&#xA;   FACTORY,&#xD;&#xA;   APR_SEQ,&#xD;&#xA;   APR_TYPE,&#xD;&#xA;   @tran_time,&#xD;&#xA;   APQ_TIME,&#xD;&#xA;   APQ_USER_ID,&#xD;&#xA;   APR_LAST_STEP,&#xD;&#xA;   STATUS,&#xD;&#xA;   @tran_user_id,&#xD;&#xA;   @tran_comment&#xD;&#xA;  FROM QTMSAPRITM&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND APR_SEQ       = @apr_seq&#xD;&#xA;   AND APR_TYPE      = @apr_type">
            <QP N="tran_time" />
            <QP N="tran_user_id" />
            <QP N="tran_comment" />
            <QP N="factory" />
            <QP N="apr_seq" />
            <QP N="apr_type" />
          </QY>
        </SG>
        <SG _S="3772" N="UpdateMasterRecipeVersion">
          <QY P="MsSql" Q="UPDATE QTMSMASRVR SET&#xD;&#xA;   APR_SEQ         = @apr_seq,&#xD;&#xA;   RCP_VER_STATUS  = @rcp_ver_status,&#xD;&#xA;   UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;   UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND RCP_ID      = @rcp_id&#xD;&#xA;   AND RCP_VER     = @rcp_ver">
            <QP N="apr_seq" />
            <QP N="rcp_ver_status" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="rcp_ver" />
          </QY>
        </SG>
        <SG _S="3773" N="UpdateMasterParameterVersion">
          <QY P="MsSql" Q="UPDATE QTMSMASSVR SET&#xD;&#xA;   STATUS         = @status,&#xD;&#xA;   APR_SEQ        = @apr_seq,&#xD;&#xA;   UPDATE_USER_ID = @update_user_id,&#xD;&#xA;   UPDATE_TIME    = @update_time&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND TYPE       = @type&#xD;&#xA;   AND RCP_ID     = @rcp_id&#xD;&#xA;   AND SPEC_VER   = @spec_ver">
            <QP N="status" />
            <QP N="apr_seq" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="spec_ver" />
          </QY>
        </SG>
        <SG _S="3774" N="UpdateEquipmentParameterVersion">
          <QY P="MsSql" Q="UPDATE QTMSEQPSVR SET&#xD;&#xA;   STATUS         = @status,&#xD;&#xA;   APR_SEQ        = @apr_seq,&#xD;&#xA;   UPDATE_USER_ID = @update_user_id,&#xD;&#xA;   UPDATE_TIME    = @update_time&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND TYPE       = @type&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;   AND RCP_ID     = @rcp_id&#xD;&#xA;   AND SPEC_VER   = @spec_ver">
            <QP N="status" />
            <QP N="apr_seq" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="spec_ver" />
          </QY>
        </SG>
        <SG _S="3775" N="UpdateMatchDataVersion">
          <QY P="MsSql" Q="UPDATE QTMSMDTVER SET&#xD;&#xA;   STATUS         = @status,&#xD;&#xA;   APR_SEQ        = @apr_seq,&#xD;&#xA;   UPDATE_USER_ID = @update_user_id,&#xD;&#xA;   UPDATE_TIME    = @update_time&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND TYPE       = @type&#xD;&#xA;   AND RCP_ID     = @rcp_id&#xD;&#xA;   AND MDT_VER    = @mdt_ver">
            <QP N="status" />
            <QP N="apr_seq" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="mdt_ver" />
          </QY>
        </SG>
        <SG _S="4041" N="DeleteApprovalItem">
          <QY P="MsSql" Q="DELETE &#xD;&#xA;  FROM QTMSAPRITM&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND APR_SEQ       = @apr_seq&#xD;&#xA;   AND APR_TYPE      = @apr_type">
            <QP N="factory" />
            <QP N="apr_seq" />
            <QP N="apr_type" />
          </QY>
        </SG>
