          <QY P="MsSql" Q="SELECT A.TYPE, A.EQP_NAME, A.RECIPE_CONTROL, A.EAP_CHANNEL, C.TRAN_TIMEOUT,&#xD;&#xA;       ISNULL(B.CTRL_MODE, ' ') AS CTRL_MODE, &#xD;&#xA;       ISNULL(B.COMM_STATE, ' ') AS COMM_STATE,&#xD;&#xA;	   ISNULL(B.PROC_STATE, ' ') AS PROC_STATE, &#xD;&#xA;	   ISNULL(B.EQP_RCP_ID, ' ') AS EQP_RCP_ID,&#xD;&#xA;	   CASE A.RECIPE_TYPE WHEN 'None' THEN C.RECIPE_TYPE ELSE A.RECIPE_TYPE END AS RECIPE_TYPE,&#xD;&#xA;	   CASE A.RECIPE_RULE WHEN 'None' THEN C.RECIPE_RULE ELSE A.RECIPE_RULE END AS RECIPE_RULE,&#xD;&#xA;	   CASE A.RECIPE_DOWNLOAD WHEN 'None' THEN C.RECIPE_DOWNLOAD ELSE A.RECIPE_DOWNLOAD END AS RECIPE_DOWNLOAD,&#xD;&#xA;	   CASE A.RECIPE_VALIDATION WHEN 'None' THEN C.RECIPE_VALIDATION ELSE A.RECIPE_VALIDATION END AS RECIPE_VALIDATION&#xD;&#xA;  FROM QTMSEQPDEF A&#xD;&#xA;  LEFT JOIN QTMSEQPSTS B&#xD;&#xA;    ON A.FACTORY     = B.FACTORY&#xD;&#xA;   AND A.EQP_NAME    = B.EQP_NAME&#xD;&#xA;  LEFT JOIN QTMSEQPTYP C&#xD;&#xA;    ON A.FACTORY     = C.FACTORY&#xD;&#xA;   AND A.TYPE        = C.TYPE&#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.EQP_NAME    = @eqp_name&#xD;&#xA;   AND A.DELETE_FLAG = 'N'">
