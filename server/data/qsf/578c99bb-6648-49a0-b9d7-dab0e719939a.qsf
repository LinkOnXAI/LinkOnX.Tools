        <SG _S="4319" N="ListEquipmentParameter">
          <QY P="MsSql" Q="SELECT A.PARA_ID, B.PARA_DESC, &#xD;&#xA;       A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5,&#xD;&#xA;	   B.PARA_FORMAT,&#xD;&#xA;	   A.PARA_VALIDATION_RULE,&#xD;&#xA;       A.PARA_TARGET_VALUE, A.PARA_USL, A.PARA_UCL, A.PARA_LCL, A.PARA_LSL&#xD;&#xA;  FROM &#xD;&#xA;     (&#xD;&#xA;SELECT FACTORY, TYPE, &#xD;&#xA;       PARA_ID, PARA_LEVEL,&#xD;&#xA;	   PARA_VALUE,&#xD;&#xA;	   PARA_VALIDATION, PARA_VALIDATION_RULE,&#xD;&#xA;	   PARA_GROUP, PARA_CAT_1, PARA_CAT_2, PARA_CAT_3, PARA_CAT_4, PARA_CAT_5,&#xD;&#xA;	   PARA_TARGET_VALUE, PARA_USL, PARA_UCL, PARA_LCL, PARA_LSL&#xD;&#xA;  FROM QTMSEQPSVP&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND TYPE      = @type&#xD;&#xA;   AND EQP_NAME  = @eqp_name&#xD;&#xA;   AND RCP_ID    = @rcp_id&#xD;&#xA;   AND SPEC_VER  = @spec_ver&#xD;&#xA;     ) AS A&#xD;&#xA; LEFT JOIN QTMSPARDEF B&#xD;&#xA;    ON A.FACTORY    = B.FACTORY&#xD;&#xA;   AND A.TYPE       = B.TYPE&#xD;&#xA;   AND A.PARA_ID    = B.PARA_ID&#xD;&#xA;   AND A.PARA_GROUP = B.PARA_GROUP&#xD;&#xA;   AND A.PARA_CAT_1 = B.PARA_CAT_1&#xD;&#xA;   AND A.PARA_CAT_2 = B.PARA_CAT_2&#xD;&#xA;   AND A.PARA_CAT_3 = B.PARA_CAT_3&#xD;&#xA;   AND A.PARA_CAT_4 = B.PARA_CAT_4&#xD;&#xA;   AND A.PARA_CAT_5 = B.PARA_CAT_5&#xD;&#xA; ORDER BY A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5, A.PARA_ID">
            <QP N="factory" />
