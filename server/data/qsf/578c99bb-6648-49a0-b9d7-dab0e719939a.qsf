      <F _S="3858" N="UploadWizard">
        <SG _S="3860" N="ListEquipmentType">
          <QY P="MsSql" Q="SELECT TYPE, TYPE_DESC&#xD;&#xA;  FROM QTMSEQPTYP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY TYPE">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3861" N="ListEquipment">
          <QY P="MsSql" Q="SELECT A.TYPE, A.EQP_NAME, A.EQP_DESC, &#xD;&#xA;       ISNULL(B.COMM_STATE, ' ') AS COMM_STATE, &#xD;&#xA;	   ISNULL(B.CTRL_MODE, ' ') AS CTRL_MODE&#xD;&#xA;  FROM QTMSEQPDEF A&#xD;&#xA;  LEFT JOIN QTMSEQPSTS B&#xD;&#xA;    ON A.FACTORY     = B.FACTORY&#xD;&#xA;   AND A.EQP_NAME    = B.EQP_NAME&#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.TYPE        = ISNULL(@type, A.TYPE)&#xD;&#xA;   AND A.DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY A.EQP_NAME">
            <QP N="factory" />
            <QP N="type" />
          </QY>
        </SG>
        <SG _S="3862" N="ListMasterRecipe">
          <QY P="MsSql" Q="SELECT RCP_ID, RCP_DESC, RCP_ACTIVE, RCP_HOLD&#xD;&#xA;  FROM QTMSMASRCP&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND TYPE         = @type&#xD;&#xA;   AND DELETE_FLAG &lt;&gt; 'Y'&#xD;&#xA; ORDER BY RCP_ID">
            <QP N="factory" />
            <QP N="type" />
          </QY>
        </SG>
      </F>
      <F _S="4524" N="RecipeGenerate">
        <SG _S="4526" N="ListStructParameter">
          <QY P="MsSql" Q="SELECT PSTR.PARA_SEQ, PSTR.PARA_ID, PDEF.PARA_DESC, &#xD;&#xA;       PSTR.PARA_GROUP, PSTR.PARA_CAT_1, PSTR.PARA_CAT_2, PSTR.PARA_CAT_3, PSTR.PARA_CAT_4, PSTR.PARA_CAT_5, &#xD;&#xA;	   PDEF.PARA_FORMAT&#xD;&#xA;  FROM QTMSPARSTV PSTV&#xD;&#xA;  LEFT JOIN QTMSPARSTR PSTR&#xD;&#xA;    ON PSTV.FACTORY    = PSTR.FACTORY&#xD;&#xA;   AND PSTV.TYPE       = PSTR.TYPE&#xD;&#xA;   AND PSTV.STR_VER    = PSTR.STR_VER&#xD;&#xA;  LEFT JOIN QTMSPARDEF PDEF&#xD;&#xA;    ON PSTR.FACTORY    = PDEF.FACTORY&#xD;&#xA;   AND PSTR.TYPE       = PDEF.TYPE&#xD;&#xA;   AND PSTR.PARA_ID    = PDEF.PARA_ID&#xD;&#xA;   AND PSTR.PARA_GROUP = PDEF.PARA_GROUP&#xD;&#xA;   AND PSTR.PARA_CAT_1 = PDEF.PARA_CAT_1&#xD;&#xA;   AND PSTR.PARA_CAT_2 = PDEF.PARA_CAT_2&#xD;&#xA;   AND PSTR.PARA_CAT_3 = PDEF.PARA_CAT_3&#xD;&#xA;   AND PSTR.PARA_CAT_4 = PDEF.PARA_CAT_4&#xD;&#xA;   AND PSTR.PARA_CAT_5 = PDEF.PARA_CAT_5&#xD;&#xA; WHERE PSTV.FACTORY        = @factory&#xD;&#xA;   AND PSTV.TYPE           = @type&#xD;&#xA;   AND PSTV.STR_VER_ACTIVE = @str_ver_active&#xD;&#xA;   AND PSTV.DELETE_FLAG    = 'N'&#xD;&#xA; ORDER BY PSTR.PARA_SEQ">
            <QP N="factory" />
            <QP N="type" />
            <QP N="str_ver_active" />
          </QY>
        </SG>
        <SG _S="4528" N="ListTemporaryRecipeParameter">
          <QY P="MsSql" Q="SELECT PARA_ID, PARA_GROUP, PARA_CAT_1, PARA_CAT_2, PARA_CAT_3, PARA_CAT_4, PARA_CAT_5, EQ_PARA_VALUE AS PARA_VALUE&#xD;&#xA;  FROM QTMSTMPRPR&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TYPE     = @type&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND RCP_ID   = @rcp_id">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
          </QY>
        </SG>
        <SG _S="4541" N="ListEquipmentType">
          <QY P="MsSql" Q="SELECT TYPE, RECIPE_TYPE&#xD;&#xA;  FROM QTMSEQPTYP&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="4537" N="InsertTempRecipe">
          <QY P="MsSql" Q="INSERT INTO QTMSTMPRCP (&#xD;&#xA;  FACTORY,&#xD;&#xA;  TYPE,&#xD;&#xA;  EQP_NAME,&#xD;&#xA;  RCP_ID,&#xD;&#xA;  RCP_CLASS,&#xD;&#xA;  CREATE_USER_ID,&#xD;&#xA;  CREATE_TIME,&#xD;&#xA;  UPDATE_USER_ID,&#xD;&#xA;  UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;  @factory,&#xD;&#xA;  @type,&#xD;&#xA;  @eqp_name,&#xD;&#xA;  @rcp_id,&#xD;&#xA;  @rcp_class,&#xD;&#xA;  @create_user_id,&#xD;&#xA;  @create_time,&#xD;&#xA;  @update_user_id,&#xD;&#xA;  @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="rcp_class" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="4538" N="InsertTempRecipeFile">
          <QY P="MsSql" Q="INSERT INTO QTMSTMPRFL (&#xD;&#xA;  FACTORY,&#xD;&#xA;  TYPE,&#xD;&#xA;  EQP_NAME,&#xD;&#xA;  RCP_ID,&#xD;&#xA;  EQP_PATH,&#xD;&#xA;  SERVER_BODY_PATH,&#xD;&#xA;  SERVER_MSG_PATH,&#xD;&#xA;  SERVER_MSG_LENGTH,&#xD;&#xA;  CREATE_USER_ID,&#xD;&#xA;  CREATE_TIME,&#xD;&#xA;  UPDATE_USER_ID,&#xD;&#xA;  UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;  @factory,&#xD;&#xA;  @type,&#xD;&#xA;  @eqp_name,&#xD;&#xA;  @rcp_id,&#xD;&#xA;  @eqp_path,&#xD;&#xA;  @server_body_path,&#xD;&#xA;  @server_msg_path,&#xD;&#xA;  @server_msg_length,&#xD;&#xA;  @create_user_id,&#xD;&#xA;  @create_time,&#xD;&#xA;  @update_user_id,&#xD;&#xA;  @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="eqp_path" />
            <QP N="server_body_path" />
            <QP N="server_msg_path" />
            <QP N="server_msg_length" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="4534" N="DeleteTempRecipe">
          <QY P="MsSql" Q="DELETE  &#xD;&#xA;  FROM QTMSTMPRCP&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TYPE     = @type&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND RCP_ID   = @rcp_id">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
          </QY>
        </SG>
        <SG _S="4529" N="HasEquipment">
          <QY P="MsSql" Q="SELECT A.TYPE, A.EQP_NAME, A.RECIPE_CONTROL, A.EAP_CHANNEL, C.TRAN_TIMEOUT,&#xD;&#xA;       ISNULL(B.CTRL_MODE, ' ') AS CTRL_MODE, &#xD;&#xA;       ISNULL(B.COMM_STATE, ' ') AS COMM_STATE,&#xD;&#xA;	   ISNULL(B.PROC_STATE, ' ') AS PROC_STATE, &#xD;&#xA;	   ISNULL(B.EQP_RCP_ID, ' ') AS EQP_RCP_ID,&#xD;&#xA;	   CASE A.RECIPE_TYPE WHEN 'None' THEN C.RECIPE_TYPE ELSE A.RECIPE_TYPE END AS RECIPE_TYPE,&#xD;&#xA;	   CASE A.RECIPE_RULE WHEN 'None' THEN C.RECIPE_RULE ELSE A.RECIPE_RULE END AS RECIPE_RULE,&#xD;&#xA;	   CASE A.RECIPE_DOWNLOAD WHEN 'None' THEN C.RECIPE_DOWNLOAD ELSE A.RECIPE_DOWNLOAD END AS RECIPE_DOWNLOAD,&#xD;&#xA;	   CASE A.RECIPE_VALIDATION WHEN 'None' THEN C.RECIPE_VALIDATION ELSE A.RECIPE_VALIDATION END AS RECIPE_VALIDATION&#xD;&#xA;  FROM QTMSEQPDEF A&#xD;&#xA;  LEFT JOIN QTMSEQPSTS B&#xD;&#xA;    ON A.FACTORY     = B.FACTORY&#xD;&#xA;   AND A.EQP_NAME    = B.EQP_NAME&#xD;&#xA;  LEFT JOIN QTMSEQPTYP C&#xD;&#xA;    ON A.FACTORY     = C.FACTORY&#xD;&#xA;   AND A.TYPE        = C.TYPE&#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.EQP_NAME    = @eqp_name&#xD;&#xA;   AND A.DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="4532" N="HasTempRecipe">
          <QY P="MsSql" Q="SELECT RCP_ID&#xD;&#xA;  FROM QTMSTMPRCP&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TYPE     = @type&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND RCP_ID   = @rcp_id">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
          </QY>
        </SG>
        <SG _S="4533" N="HasTypeParameters">
          <QY P="MsSql" Q="SELECT PARA_ID, PARA_GROUP, PARA_CAT_1, PARA_CAT_2, PARA_CAT_3, PARA_CAT_4, PARA_CAT_5, DELETE_FLAG&#xD;&#xA;  FROM QTMSPARDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE    = @type">
            <QP N="factory" />
            <QP N="type" />
          </QY>
        </SG>
        <SG _S="4531" N="HasRecipeParser">
          <QY P="MsSql" Q="SELECT C.PSR_NAME, C.PSR_VER, C.PSR_VER_FILE&#xD;&#xA;  FROM QTMSTYPPSR A&#xD;&#xA;  LEFT JOIN QTMSPSRDEF B &#xD;&#xA;    ON A.FACTORY  = B.FACTORY &#xD;&#xA;   AND A.PSR_NAME = B.PSR_NAME&#xD;&#xA;  LEFT JOIN QTMSPSRVER C &#xD;&#xA;    ON C.FACTORY  = B.FACTORY &#xD;&#xA;   AND C.PSR_NAME = B.PSR_NAME&#xD;&#xA;   AND C.PSR_VER  = B.ACTIVE_VER&#xD;&#xA; WHERE A.FACTORY  = @factory&#xD;&#xA;   AND A.EQP_TYPE = @eq_type">
            <QP N="factory" />
            <QP N="eq_type" />
          </QY>
        </SG>
        <SG _S="4535" N="DeleteTempRecipeParameter">
          <QY P="MsSql" Q="DELETE  &#xD;&#xA;  FROM QTMSTMPRPR&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TYPE     = @type&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND RCP_ID   = @rcp_id">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
          </QY>
        </SG>
        <SG _S="4539" N="DeleteTypeParameter">
          <QY P="MsSql" Q="DELETE&#xD;&#xA;  FROM QTMSPARDEF&#xD;&#xA; WHERE FACTORY    = @factory &#xD;&#xA;   AND TYPE       = @type&#xD;&#xA;   AND PARA_ID    = @para_id&#xD;&#xA;   AND PARA_GROUP = @para_group&#xD;&#xA;   AND PARA_CAT_1 = @para_cat_1&#xD;&#xA;   AND PARA_CAT_2 = @para_cat_2&#xD;&#xA;   AND PARA_CAT_3 = @para_cat_3&#xD;&#xA;   AND PARA_CAT_4 = @para_cat_4&#xD;&#xA;   AND PARA_CAT_5 = @para_cat_5">
            <QP N="factory" />
            <QP N="type" />
            <QP N="para_id" />
            <QP N="para_group" />
            <QP N="para_cat_1" />
            <QP N="para_cat_2" />
            <QP N="para_cat_3" />
            <QP N="para_cat_4" />
            <QP N="para_cat_5" />
          </QY>
        </SG>
        <SG _S="4536" N="DeleteTempRecipeFile">
          <QY P="MsSql" Q="DELETE &#xD;&#xA;  FROM QTMSTMPRFL  &#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TYPE     = @type&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND RCP_ID   = @rcp_id">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
          </QY>
        </SG>
        <SG _S="4527" N="ListMasterRecipeParameter">
          <QY P="MsSql" Q="SELECT PARA_ID, PARA_GROUP, PARA_CAT_1, PARA_CAT_2, PARA_CAT_3, PARA_CAT_4, PARA_CAT_5, PARA_VALUE&#xD;&#xA;  FROM QTMSMASRPR&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TYPE     = @type&#xD;&#xA;   AND RCP_ID   = @rcp_id&#xD;&#xA;   AND RCP_VER  = @rcp_ver">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="rcp_ver" />
          </QY>
        </SG>
      </F>
      <F _S="2681" N="DownloadWizard">
        <SG _S="2683" N="ListEquipmentType">
          <QY P="MsSql" Q="SELECT TYPE, TYPE_DESC, RECIPE_TYPE&#xD;&#xA;  FROM QTMSEQPTYP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY TYPE">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="2684" N="ListEquipment">
          <QY P="MsSql" Q="SELECT A.TYPE, A.EQP_NAME, A.EQP_DESC, &#xD;&#xA;       ISNULL(B.COMM_STATE, ' ') AS COMM_STATE, &#xD;&#xA;	   ISNULL(B.CTRL_MODE, ' ') AS CTRL_MODE&#xD;&#xA;  FROM QTMSEQPDEF A&#xD;&#xA;  LEFT JOIN QTMSEQPSTS B&#xD;&#xA;    ON A.FACTORY     = B.FACTORY&#xD;&#xA;   AND A.EQP_NAME    = B.EQP_NAME&#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.TYPE        = ISNULL(@type, A.TYPE)&#xD;&#xA;   AND A.DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY A.EQP_NAME">
            <QP N="factory" />
            <QP N="type" />
          </QY>
        </SG>
        <SG _S="4360" N="CountEquipmentRecipeVersion">
          <QY P="MsSql" Q="SELECT COUNT(*) AS CNT&#xD;&#xA;  FROM QTMSEQPRVR&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND EQP_NAME    = @eqp_name&#xD;&#xA;   AND RCP_ID      = @rcp_id&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
          </QY>
        </SG>
        <SG _S="4361" N="CountMasterRecipeVersion">
          <QY P="MsSql" Q="SELECT COUNT(*) AS CNT&#xD;&#xA;  FROM QTMSMASRVR&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND RCP_ID      = @rcp_id&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
          </QY>
        </SG>
        <SG _S="2685" N="ListMasterRecipe">
          <QY P="MsSql" Q="SELECT RCP_ID, RCP_DESC, RCP_ACTIVE, RCP_HOLD&#xD;&#xA;  FROM QTMSMASRCP&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND TYPE         = @type&#xD;&#xA;   AND DELETE_FLAG &lt;&gt; 'Y'&#xD;&#xA; ORDER BY RCP_ID">
            <QP N="factory" />
            <QP N="type" />
          </QY>
        </SG>
        <SG _S="3870" N="ListMasterRecipeVersion">
          <QY P="MsSql" Q="SELECT RCP_ID, RCP_VER, RCP_VER_DESC, RCP_VER_ACTIVE, RCP_VER_STATUS&#xD;&#xA;  FROM QTMSMASRVR&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND RCP_ID      = @rcp_id&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY RCP_VER DESC&#xD;&#xA;OFFSET (CONVERT(int, @PAGE_NO)-1) * CONVERT(int, @PAGE_SIZE) ROW FETCH NEXT CONVERT(int, @PAGE_SIZE) ROW ONLY">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="PAGE_NO" />
            <QP N="PAGE_SIZE" />
          </QY>
        </SG>
        <SG _S="2686" N="ListEquipmentRecipe">
          <QY P="MsSql" Q="SELECT RCP_ID, RCP_DESC, RCP_HOLD&#xD;&#xA;  FROM QTMSEQPRCP&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND TYPE         = @type&#xD;&#xA;   AND EQP_NAME     = @eqp_name&#xD;&#xA;   AND DELETE_FLAG &lt;&gt; 'Y'&#xD;&#xA; ORDER BY RCP_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="3872" N="ListEquipmentRecipeVersion">
          <QY P="MsSql" Q="SELECT RCP_ID, RCP_VER, RCP_VER_DESC&#xD;&#xA;  FROM QTMSEQPRVR&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND EQP_NAME    = @eqp_name&#xD;&#xA;   AND RCP_ID      = @rcp_id&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY RCP_VER DESC&#xD;&#xA;OFFSET (CONVERT(int, @PAGE_NO)-1) * CONVERT(int, @PAGE_SIZE) ROW FETCH NEXT CONVERT(int, @PAGE_SIZE) ROW ONLY">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="PAGE_NO" />
            <QP N="PAGE_SIZE" />
          </QY>
        </SG>
      </F>
      <F _S="2596" N="ApprovalRejectWizard">
        <SG _S="2597" N="ListApprovalRejectRequest">
          <QY P="MsSql" Q="SELECT&#xD;&#xA;	TYPE,&#xD;&#xA;	RCP_MEMBER,&#xD;&#xA;	EQP_NAME,&#xD;&#xA;	RCP_ID,&#xD;&#xA;	RCP_VER,&#xD;&#xA;	APQ_COMMENT&#xD;&#xA;FROM QTMSRCPAPQ&#xD;&#xA;WHERE FACTORY = @factory&#xD;&#xA;  AND RCP_MEMBER = @rcp_member&#xD;&#xA;ORDER BY TYPE, RCP_ID, RCP_VER">
            <QP N="factory" />
            <QP N="rcp_member" />
          </QY>
        </SG>
      </F>
      <F _S="2620" N="RecipeHold">
        <SG _S="2622" N="HasEquipmentType">
          <QY P="MsSql" Q="SELECT TYPE&#xD;&#xA;  FROM QTMSEQPTYP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE     = @type">
            <QP N="factory" />
            <QP N="type" />
          </QY>
        </SG>
        <SG _S="2623" N="HasEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME&#xD;&#xA;  FROM QTMSEQPDEF&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND TYPE         = @type&#xD;&#xA;   AND EQP_NAME     = @eqp_name&#xD;&#xA;   AND DELETE_FLAG  = 'N'">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="2624" N="HasMasterRecipe">
          <QY P="MsSql" Q="SELECT RCP_ID, RCP_HOLD&#xD;&#xA;  FROM QTMSMASRCP&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND RCP_ID      = @rcp_id&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
          </QY>
        </SG>
        <SG _S="2625" N="HasEquipmentRecipe">
          <QY P="MsSql" Q="SELECT RCP_ID, RCP_HOLD&#xD;&#xA;  FROM QTMSEQPRCP&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND EQP_NAME    = @eqp_name&#xD;&#xA;   AND RCP_ID      = @rcp_id&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
