        <SG _S="4471" N="HasRecipeUploadWaitingItem">
          <QY P="MsSql" Q="SELECT RCP_ID, TRAN_STATUS, TRAN_TIME, RESULT, REASON&#xD;&#xA;  FROM QTMSRCPUPT&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND EQP_NAME    = @eqp_name&#xD;&#xA;   AND RCP_ID      = @rcp_id">
