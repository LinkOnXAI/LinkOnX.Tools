          <QY P="MsSql" Q="SELECT RCP_ID, RCP_DESC, RCP_ACTIVE, RCP_HOLD&#xD;&#xA;  FROM QTMSEQPRCP&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND TYPE         = @type&#xD;&#xA;   AND EQP_NAME     = @eqp_name&#xD;&#xA;   AND DELETE_FLAG &lt;&gt; 'Y'&#xD;&#xA; ORDER BY RCP_ID">
