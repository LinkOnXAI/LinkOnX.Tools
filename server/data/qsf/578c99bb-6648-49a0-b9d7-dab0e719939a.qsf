      <F _S="4336" N="RecipeControlDisable">
        <SG _S="4339" N="HasEquipment">
          <QY P="MsSql" Q="SELECT A.EAP_CHANNEL, &#xD;&#xA;        ISNULL(B.COMM_STATE, ' ') AS COMM_STATE, &#xD;&#xA;        ISNULL(B.CTRL_MODE, ' ') AS CTRL_MODE,&#xD;&#xA;        ISNULL(B.PROC_STATE, ' ') AS PROC_STATE,&#xD;&#xA;        ISNULL(B.EQP_RCP_ID, ' ') AS EQP_RCP_ID&#xD;&#xA;  FROM QTMSEQPDEF A&#xD;&#xA;  LEFT JOIN QTMSEQPSTS B&#xD;&#xA;    ON A.FACTORY      = B.FACTORY&#xD;&#xA;   AND A.EQP_NAME     = B.EQP_NAME&#xD;&#xA;  WHERE A.FACTORY     = @factory &#xD;&#xA;    AND A.TYPE        = @type&#xD;&#xA;    AND A.EQP_NAME    = @eqp_name&#xD;&#xA;    AND A.DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="4340" N="HasEquipmentType">
          <QY P="MsSql" Q="SELECT TYPE&#xD;&#xA;  FROM QTMSEQPTYP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE    = @type">
            <QP N="factory" />
            <QP N="type" />
          </QY>
        </SG>
        <SG _S="4341" N="UpdateEquipment">
          <QY P="MsSql" Q="UPDATE QTMSEQPDEF SET&#xD;&#xA;   RECIPE_CONTROL    = @recipe_control,&#xD;&#xA;   UPDATE_USER_ID    = @update_user_id,&#xD;&#xA;   UPDATE_TIME       = @update_time&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EQP_NAME      = @eqp_name">
            <QP N="recipe_control" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
      </F>
      <F _S="4342" N="RecipeControlEnable">
        <SG _S="4343" N="HasEquipment">
          <QY P="MsSql" Q="SELECT A.EAP_CHANNEL, &#xD;&#xA;        ISNULL(B.COMM_STATE, ' ') AS COMM_STATE, &#xD;&#xA;        ISNULL(B.CTRL_MODE, ' ') AS CTRL_MODE,&#xD;&#xA;        ISNULL(B.PROC_STATE, ' ') AS PROC_STATE,&#xD;&#xA;        ISNULL(B.EQP_RCP_ID, ' ') AS EQP_RCP_ID&#xD;&#xA;  FROM QTMSEQPDEF A&#xD;&#xA;  LEFT JOIN QTMSEQPSTS B&#xD;&#xA;    ON A.FACTORY      = B.FACTORY&#xD;&#xA;   AND A.EQP_NAME     = B.EQP_NAME&#xD;&#xA;  WHERE A.FACTORY     = @factory &#xD;&#xA;    AND A.TYPE        = @type&#xD;&#xA;    AND A.EQP_NAME    = @eqp_name&#xD;&#xA;    AND A.DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="4344" N="HasEquipmentType">
          <QY P="MsSql" Q="SELECT TYPE&#xD;&#xA;  FROM QTMSEQPTYP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE    = @type">
            <QP N="factory" />
            <QP N="type" />
          </QY>
        </SG>
        <SG _S="4345" N="UpdateEquipment">
          <QY P="MsSql" Q="UPDATE QTMSEQPDEF SET&#xD;&#xA;   RECIPE_CONTROL    = @recipe_control,&#xD;&#xA;   UPDATE_USER_ID    = @update_user_id,&#xD;&#xA;   UPDATE_TIME       = @update_time&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EQP_NAME      = @eqp_name">
            <QP N="recipe_control" />
            <QP N="update_user_id" />
