      <F _S="15" N="EventSearch">
        <SG _S="18" N="SearchEapEvent">
          <QY P="MsSql" Q="SELECT EVENT_DESC,&#xD;&#xA;       DATA_1_PRT, DATA_2_PRT, DATA_3_PRT, DATA_4_PRT, DATA_5_PRT,&#xD;&#xA;       DATA_6_PRT, DATA_7_PRT, DATA_8_PRT, DATA_9_PRT, DATA_10_PRT,    &#xD;&#xA;       DATA_11_PRT, DATA_12_PRT, DATA_13_PRT, DATA_14_PRT, DATA_15_PRT,&#xD;&#xA;       DATA_16_PRT, DATA_17_PRT, DATA_18_PRT, DATA_19_PRT, DATA_20_PRT,&#xD;&#xA;       ALT_COMMENT&#xD;&#xA;  FROM QRASEAPEVT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EVENT_ID = @event_id">
            <QP N="factory" />
            <QP N="event_id" />
          </QY>
        </SG>
        <SG _S="16" N="SearchUserEvent">
          <QY P="MsSql" Q="SELECT EVENT_DESC,&#xD;&#xA;       DATA_1_PRT, DATA_2_PRT, DATA_3_PRT, DATA_4_PRT, DATA_5_PRT,&#xD;&#xA;       DATA_6_PRT, DATA_7_PRT, DATA_8_PRT, DATA_9_PRT, DATA_10_PRT,&#xD;&#xA;       DATA_11_PRT, DATA_12_PRT, DATA_13_PRT, DATA_14_PRT, DATA_15_PRT,&#xD;&#xA;       DATA_16_PRT, DATA_17_PRT, DATA_18_PRT, DATA_19_PRT, DATA_20_PRT&#xD;&#xA;  FROM QSECUSREVT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND SYSTEM   = @system&#xD;&#xA;   AND EVENT_ID = @event_id&#xD;&#xA;   AND ACTION   = @action">
            <QP N="factory" />
            <QP N="system" />
            <QP N="event_id" />
            <QP N="action" />
          </QY>
        </SG>
        <SG _S="471" N="SearchEquipmentEvent">
          <QY P="MsSql" Q="SELECT EVENT_DESC,&#xD;&#xA;       DATA_1_PRT, DATA_2_PRT, DATA_3_PRT, DATA_4_PRT, DATA_5_PRT,&#xD;&#xA;       DATA_6_PRT, DATA_7_PRT, DATA_8_PRT, DATA_9_PRT, DATA_10_PRT,    &#xD;&#xA;       DATA_11_PRT, DATA_12_PRT, DATA_13_PRT, DATA_14_PRT, DATA_15_PRT,&#xD;&#xA;       DATA_16_PRT, DATA_17_PRT, DATA_18_PRT, DATA_19_PRT, DATA_20_PRT,&#xD;&#xA;       ALT_COMMENT&#xD;&#xA;  FROM QTMSEQPEVT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EVENT_ID = @event_id">
            <QP N="factory" />
            <QP N="event_id" />
          </QY>
        </SG>
        <SG _S="294" N="SearchRecipeEvent">
          <QY P="MsSql" Q="SELECT EVENT_DESC,&#xD;&#xA;       DATA_1_PRT, DATA_2_PRT, DATA_3_PRT, DATA_4_PRT, DATA_5_PRT,&#xD;&#xA;       DATA_6_PRT, DATA_7_PRT, DATA_8_PRT, DATA_9_PRT, DATA_10_PRT,    &#xD;&#xA;       DATA_11_PRT, DATA_12_PRT, DATA_13_PRT, DATA_14_PRT, DATA_15_PRT,&#xD;&#xA;       DATA_16_PRT, DATA_17_PRT, DATA_18_PRT, DATA_19_PRT, DATA_20_PRT,&#xD;&#xA;       ALT_COMMENT&#xD;&#xA;  FROM QTMSRCPEVT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EVENT_ID = @event_id">
            <QP N="factory" />
            <QP N="event_id" />
          </QY>
        </SG>
        <SG _S="2095" N="SearchRecipeEventAll">
          <QY P="MsSql" Q="SELECT EVENT_ID, EVENT_DESC&#xD;&#xA;  FROM QTMSRCPEVT&#xD;&#xA; WHERE FACTORY  = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="1246" N="SearchLotEvent">
          <QY P="MsSql" Q="SELECT EVENT_DESC,&#xD;&#xA;       DATA_1_PRT, DATA_2_PRT, DATA_3_PRT, DATA_4_PRT, DATA_5_PRT,&#xD;&#xA;       DATA_6_PRT, DATA_7_PRT, DATA_8_PRT, DATA_9_PRT, DATA_10_PRT,    &#xD;&#xA;       DATA_11_PRT, DATA_12_PRT, DATA_13_PRT, DATA_14_PRT, DATA_15_PRT,&#xD;&#xA;       DATA_16_PRT, DATA_17_PRT, DATA_18_PRT, DATA_19_PRT, DATA_20_PRT,&#xD;&#xA;       ALT_COMMENT&#xD;&#xA;  FROM QWIPLOTEVT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND SYSTEM = @system&#xD;&#xA;   AND EVENT_ID = @event_id">
            <QP N="factory" />
            <QP N="system" />
            <QP N="event_id" />
          </QY>
        </SG>
        <SG _S="20" N="SearchEventAlert">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;   EVENT_ID&#xD;&#xA;  FROM QSECURGALT&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND EVENT_TYPE = @event_type&#xD;&#xA;   AND EVENT_ID   = @event_id">
            <QP N="factory" />
            <QP N="event_type" />
            <QP N="event_id" />
          </QY>
        </SG>
        <SG _S="3648" N="SearchApprovalEvent">
          <QY P="MsSql" Q="SELECT EVENT_DESC,&#xD;&#xA;       DATA_1_PRT, DATA_2_PRT, DATA_3_PRT, DATA_4_PRT, DATA_5_PRT,&#xD;&#xA;       DATA_6_PRT, DATA_7_PRT, DATA_8_PRT, DATA_9_PRT, DATA_10_PRT,    &#xD;&#xA;       DATA_11_PRT, DATA_12_PRT, DATA_13_PRT, DATA_14_PRT, DATA_15_PRT,&#xD;&#xA;       DATA_16_PRT, DATA_17_PRT, DATA_18_PRT, DATA_19_PRT, DATA_20_PRT,&#xD;&#xA;       ALT_COMMENT&#xD;&#xA;  FROM QTMSAPREVT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EVENT_ID = @event_id">
            <QP N="factory" />
            <QP N="event_id" />
          </QY>
        </SG>
      </F>
      <F _S="3256" N="ApprovalHistory">
        <SG _S="3635" N="SelectApprovalRequestSeq">
          <QY P="MsSql" Q="SELECT NEXT VALUE FOR SEQ_TMSAPR_SEQ" />
        </SG>
        <SG _S="3257" N="SelectApprovalHistorySeq">
          <QY P="MsSql" Q="SELECT NEXT VALUE FOR SEQ_TMSAPR_HIS" />
        </SG>
        <SG _S="3540" N="InsertApprovalHistory">
          <QY P="MsSql" Q="INSERT INTO QTMSAPRHIS (&#xD;&#xA;   FACTORY,&#xD;&#xA;   APR_SEQ,&#xD;&#xA;   APR_TYPE,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   EVENT_ID,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   STEP,&#xD;&#xA;   ACTION,&#xD;&#xA;   EVT_H_1,&#xD;&#xA;   EVT_D_1,   &#xD;&#xA;   EVT_H_2,&#xD;&#xA;   EVT_D_2,&#xD;&#xA;   EVT_H_3,&#xD;&#xA;   EVT_D_3,&#xD;&#xA;   EVT_H_4,&#xD;&#xA;   EVT_D_4,&#xD;&#xA;   EVT_H_5,&#xD;&#xA;   EVT_D_5,&#xD;&#xA;   EVT_H_6,&#xD;&#xA;   EVT_D_6,&#xD;&#xA;   EVT_H_7,&#xD;&#xA;   EVT_D_7,&#xD;&#xA;   EVT_H_8,&#xD;&#xA;   EVT_D_8,&#xD;&#xA;   EVT_H_9,&#xD;&#xA;   EVT_D_9,&#xD;&#xA;   EVT_H_10,&#xD;&#xA;   EVT_D_10,&#xD;&#xA;   EVT_H_11,&#xD;&#xA;   EVT_D_11,   &#xD;&#xA;   EVT_H_12,&#xD;&#xA;   EVT_D_12,&#xD;&#xA;   EVT_H_13,&#xD;&#xA;   EVT_D_13,&#xD;&#xA;   EVT_H_14,&#xD;&#xA;   EVT_D_14,&#xD;&#xA;   EVT_H_15,&#xD;&#xA;   EVT_D_15,&#xD;&#xA;   EVT_H_16,&#xD;&#xA;   EVT_D_16,&#xD;&#xA;   EVT_H_17,&#xD;&#xA;   EVT_D_17,&#xD;&#xA;   EVT_H_18,&#xD;&#xA;   EVT_D_18,&#xD;&#xA;   EVT_H_19,&#xD;&#xA;   EVT_D_19,&#xD;&#xA;   EVT_H_20,&#xD;&#xA;   EVT_D_20,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT      &#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @apr_seq,&#xD;&#xA;   @apr_type,&#xD;&#xA;   @hist_seq,&#xD;&#xA;   @event_id,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @step,&#xD;&#xA;   @action,&#xD;&#xA;   @evt_h_1,&#xD;&#xA;   @evt_d_1,   &#xD;&#xA;   @evt_h_2,&#xD;&#xA;   @evt_d_2,&#xD;&#xA;   @evt_h_3,&#xD;&#xA;   @evt_d_3,&#xD;&#xA;   @evt_h_4,&#xD;&#xA;   @evt_d_4,&#xD;&#xA;   @evt_h_5,&#xD;&#xA;   @evt_d_5,&#xD;&#xA;   @evt_h_6,&#xD;&#xA;   @evt_d_6,&#xD;&#xA;   @evt_h_7,&#xD;&#xA;   @evt_d_7,&#xD;&#xA;   @evt_h_8,&#xD;&#xA;   @evt_d_8,&#xD;&#xA;   @evt_h_9,&#xD;&#xA;   @evt_d_9,&#xD;&#xA;   @evt_h_10,&#xD;&#xA;   @evt_d_10,&#xD;&#xA;   @evt_h_11,&#xD;&#xA;   @evt_d_11,   &#xD;&#xA;   @evt_h_12,&#xD;&#xA;   @evt_d_12,&#xD;&#xA;   @evt_h_13,&#xD;&#xA;   @evt_d_13,&#xD;&#xA;   @evt_h_14,&#xD;&#xA;   @evt_d_14,&#xD;&#xA;   @evt_h_15,&#xD;&#xA;   @evt_d_15,&#xD;&#xA;   @evt_h_16,&#xD;&#xA;   @evt_d_16,&#xD;&#xA;   @evt_h_17,&#xD;&#xA;   @evt_d_17,&#xD;&#xA;   @evt_h_18,&#xD;&#xA;   @evt_d_18,&#xD;&#xA;   @evt_h_19,&#xD;&#xA;   @evt_d_19,&#xD;&#xA;   @evt_h_20,&#xD;&#xA;   @evt_d_20,&#xD;&#xA;   @tran_user_id,&#xD;&#xA;   @tran_comment&#xD;&#xA; )">
            <QP N="factory" />
