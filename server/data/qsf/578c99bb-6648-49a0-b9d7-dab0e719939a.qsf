        <SG _S="4563" N="InsertTestProgramVersion">
          <QY P="MsSql" Q="INSERT INTO QTMSPGMVER(&#xD;&#xA;   FACTORY,&#xD;&#xA;   TYPE,&#xD;&#xA;   PGM_ID,&#xD;&#xA;   PGM_VER,&#xD;&#xA;   PGM_VER_DESC,&#xD;&#xA;   PGM_VER_COMMENT,&#xD;&#xA;   PGM_VER_FILE,&#xD;&#xA;   ACTIVE,&#xD;&#xA;   STATUS,&#xD;&#xA;   APR_SEQ,&#xD;&#xA;   DELETE_FLAG,   &#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @type,&#xD;&#xA;   @pgm_id,&#xD;&#xA;   @pgm_ver,&#xD;&#xA;   @pgm_ver_desc,&#xD;&#xA;   @pgm_ver_comment,&#xD;&#xA;   @pgm_ver_file,&#xD;&#xA;   @active,&#xD;&#xA;   @status,&#xD;&#xA;   @apr_seq,&#xD;&#xA;   @delete_flag,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
