      <F _S="2921" N="LineEquipmentSelector">
        <SG _S="2922" N="ListEquipment">
          <QY P="MsSql" Q="SELECT Q.EQP_NAME AS EQP_NAME, M.RES_DESC AS EQP_DESC&#xD;&#xA;FROM QTMSEQPDEF Q&#xD;&#xA;JOIN MES.LSISDB.dbo.MRASRESDEF M&#xD;&#xA;  ON Q.FACTORY = M.FACTORY&#xD;&#xA; AND Q.EQP_NAME = M.RES_ID&#xD;&#xA; AND M.AREA_ID = @line&#xD;&#xA; AND M.RES_TYPE = 'EQUIPMENT'&#xD;&#xA; AND M.DELETE_FLAG &lt;&gt; 'Y'&#xD;&#xA;WHERE Q.FACTORY = @factory&#xD;&#xA;ORDER BY Q.EQP_NAME ASC&#xD;&#xA;">
