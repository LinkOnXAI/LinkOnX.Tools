      <F _S="3330" N="ValidationParameterSelector">
        <SG _S="3336" N="ListParameter">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;	DISTINCT A.PARA_ID, &#xD;&#xA;	A.PARA_GROUP, &#xD;&#xA;	A.PARA_CAT_1,&#xD;&#xA;	A.PARA_CAT_2,&#xD;&#xA;	A.PARA_CAT_3,&#xD;&#xA;	A.PARA_CAT_4,&#xD;&#xA;	A.PARA_CAT_5&#xD;&#xA; FROM QTMSRCPPVH  A &#xD;&#xA;  LEFT JOIN QTMSRCPVAH B &#xD;&#xA; ON A.HIST_SEQ = B.HIST_SEQ&#xD;&#xA;WHERE A.FACTORY = B.FACTORY&#xD;&#xA; AND B.FACTORY = @factory&#xD;&#xA; AND B.TYPE    = @type &#xD;&#xA; AND B.RCP_ID  = @rcp_id&#xD;&#xA; AND A.PARA_FORMAT &lt;&gt; 'Ascii'&#xD;&#xA; AND (B.TRAN_TIME &gt;= @tran_from_time AND B.TRAN_TIME &lt;= @tran_to_time)&#xD;&#xA; ORDER BY A.PARA_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
      </F>
