        <SG _S="2737" N="InsertEquipmentType">
          <QY P="MsSql" Q="INSERT INTO QTMSEQPTYP (&#xD;&#xA;	FACTORY,&#xD;&#xA;	TYPE,&#xD;&#xA;	TYPE_DESC,&#xD;&#xA;	CREATE_USER_ID,&#xD;&#xA;	CREATE_TIME,&#xD;&#xA;	UPDATE_USER_ID,&#xD;&#xA;	UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;	@factory,&#xD;&#xA;	@type,&#xD;&#xA;	@type_desc,&#xD;&#xA;	@create_user_id,&#xD;&#xA;	@create_time,&#xD;&#xA;	@update_user_id,&#xD;&#xA;	@update_time&#xD;&#xA;)">
