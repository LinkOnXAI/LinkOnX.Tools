        <SG _S="4297" N="ListMasterSpecVersion">
          <QY P="MsSql" Q="SELECT RCP_ID, SPEC_VER, SPEC_VER_DESC, ACTIVE, STATUS, CREATE_TIME, CREATE_USER_ID, UPDATE_TIME, UPDATE_USER_ID&#xD;&#xA;  FROM QTMSMASSVR&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE    = @type   &#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY RCP_ID, SPEC_VER DESC">
            <QP N="factory" />
            <QP N="type" />
