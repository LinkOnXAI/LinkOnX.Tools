          </QY>
        </SG>
        <SG _S="4398" N="ListTempRecipeParameterManaged">
          <QY P="MsSql" Q="SELECT A.PARA_ID, B.PARA_DESC,		&#xD;&#xA;	   A.PARA_GROUP,&#xD;&#xA;	   A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5,&#xD;&#xA;	   B.PARA_FORMAT, A.EQ_PARA_VALUE, B.MANAGE_FLAG&#xD;&#xA;  FROM QTMSTMPRPR A&#xD;&#xA;  LEFT JOIN QTMSPARDEF B&#xD;&#xA;    ON A.FACTORY     = B.FACTORY&#xD;&#xA;   AND A.TYPE        = B.TYPE&#xD;&#xA;   AND A.PARA_ID     = B.PARA_ID&#xD;&#xA;   AND A.PARA_GROUP  = B.PARA_GROUP&#xD;&#xA;   AND A.PARA_CAT_1  = B.PARA_CAT_1&#xD;&#xA;   AND A.PARA_CAT_2  = B.PARA_CAT_2&#xD;&#xA;   AND A.PARA_CAT_3  = B.PARA_CAT_3&#xD;&#xA;   AND A.PARA_CAT_4  = B.PARA_CAT_4&#xD;&#xA;   AND A.PARA_CAT_5  = B.PARA_CAT_5&#xD;&#xA; WHERE A.FACTORY     = @factory &#xD;&#xA;   AND A.TYPE 	     = @type&#xD;&#xA;   AND A.EQP_NAME    = @eqp_name&#xD;&#xA;   AND A.RCP_ID	     = @rcp_id&#xD;&#xA;   AND B.MANAGE_FLAG = 'Yes'&#xD;&#xA; ORDER BY A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5, A.PARA_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
          </QY>
        </SG>
        <SG _S="4122" N="ListTempRecipeParameterPaging">
          <QY P="MsSql" Q="SELECT A.PARA_ID, B.PARA_DESC,		&#xD;&#xA;	   A.PARA_GROUP,&#xD;&#xA;	   A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5,&#xD;&#xA;	   B.PARA_FORMAT, A.EQ_PARA_VALUE, B.MANAGE_FLAG&#xD;&#xA;  FROM QTMSTMPRPR A&#xD;&#xA;  LEFT JOIN QTMSPARDEF B&#xD;&#xA;    ON A.FACTORY    = B.FACTORY&#xD;&#xA;   AND A.TYPE       = B.TYPE&#xD;&#xA;   AND A.PARA_ID    = B.PARA_ID&#xD;&#xA;   AND A.PARA_GROUP = B.PARA_GROUP&#xD;&#xA;   AND A.PARA_CAT_1 = B.PARA_CAT_1&#xD;&#xA;   AND A.PARA_CAT_2 = B.PARA_CAT_2&#xD;&#xA;   AND A.PARA_CAT_3 = B.PARA_CAT_3&#xD;&#xA;   AND A.PARA_CAT_4 = B.PARA_CAT_4&#xD;&#xA;   AND A.PARA_CAT_5 = B.PARA_CAT_5&#xD;&#xA; WHERE A.FACTORY    = @factory &#xD;&#xA;   AND A.TYPE 	    = @type&#xD;&#xA;   AND A.EQP_NAME   = @eqp_name&#xD;&#xA;   AND A.RCP_ID	    = @rcp_id&#xD;&#xA; ORDER BY A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5, A.PARA_ID&#xD;&#xA; OFFSET (CONVERT(int, @PAGE_NO)-1) * CONVERT(int, @PAGE_SIZE) ROW FETCH NEXT CONVERT(int, @PAGE_SIZE) ROW ONLY">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="PAGE_NO" />
            <QP N="PAGE_SIZE" />
          </QY>
        </SG>
        <SG _S="3308" N="CountTempRecipeParameter">
          <QY P="MsSql" Q="SELECT  COUNT(*) AS CNT&#xD;&#xA;FROM QTMSTMPRPR&#xD;&#xA;WHERE FACTORY 	 = @factory &#xD;&#xA;  AND TYPE 		 = @type&#xD;&#xA;  AND EQP_NAME   = @eqp_name&#xD;&#xA;  AND RCP_ID	 = @rcp_id">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
          </QY>
        </SG>
      </F>
      <F _S="4259" N="MesRecipeViewer">
        <SG _S="4260" N="ListRecipeInfo">
          <QY P="MsSql" Q="SELECT OPR.OPER AS OPER&#xD;&#xA;     , OPR.OPER_DESC AS OPER_DESC &#xD;&#xA;     , RES.RES_ID AS RES_ID&#xD;&#xA;     , MAT.MAT_ID AS MAT_ID &#xD;&#xA;     , MAT.MAT_DESC AS MAT_DESC &#xD;&#xA;     , DATA_2 AS RECIPE_NAME &#xD;&#xA;FROM MGCMTBLDAT GCM, MWIPMATDEF MAT, MWIPOPRDEF OPR, MRASRESMFO RES&#xD;&#xA;WHERE 1 = 1 &#xD;&#xA;AND GCM.FACTORY = '??factory??'&#xD;&#xA;AND GCM.TABLE_NAME = 'HM_DSC_RECIPE_NAME'&#xD;&#xA;AND GCM.FACTORY = OPR.FACTORY(+)&#xD;&#xA;AND GCM.KEY_1 = OPR.OPER(+)&#xD;&#xA;AND GCM.FACTORY = MAT.FACTORY(+)&#xD;&#xA;AND GCM.KEY_2 = MAT.MAT_ID(+)&#xD;&#xA;AND GCM.FACTORY = RES.FACTORY(+)&#xD;&#xA;AND GCM.KEY_1 = RES.OPER(+)&#xD;&#xA;ORDER BY DATA_2, OPR.OPER, RES.RES_ID" />
        </SG>
        <SG _S="4277" N="ListRecipeInfoByEquipment">
          <QY P="MsSql" Q="SELECT OPR.OPER AS OPER&#xD;&#xA;     , OPR.OPER_DESC AS OPER_DESC &#xD;&#xA;     , RES.RES_ID AS RES_ID&#xD;&#xA;     , MAT.MAT_ID AS MAT_ID &#xD;&#xA;     , MAT.MAT_DESC AS MAT_DESC &#xD;&#xA;     , DATA_2 AS RCP_ID &#xD;&#xA;FROM MGCMTBLDAT GCM, MWIPMATDEF MAT, MWIPOPRDEF OPR, MRASRESMFO RES&#xD;&#xA;WHERE 1 = 1 &#xD;&#xA;AND GCM.FACTORY = '??factory??'&#xD;&#xA;AND GCM.KEY_1 = '??oper??'&#xD;&#xA;AND RES.RES_ID = '??eqp_name??'&#xD;&#xA;AND GCM.TABLE_NAME = 'HM_DSC_RECIPE_NAME'&#xD;&#xA;AND GCM.FACTORY = OPR.FACTORY(+)&#xD;&#xA;AND GCM.KEY_1 = OPR.OPER(+)&#xD;&#xA;AND GCM.FACTORY = MAT.FACTORY(+)&#xD;&#xA;AND GCM.KEY_2 = MAT.MAT_ID(+)&#xD;&#xA;AND GCM.FACTORY = RES.FACTORY(+)&#xD;&#xA;AND GCM.KEY_1 = RES.OPER(+)&#xD;&#xA;ORDER BY DATA_2, OPR.OPER, RES.RES_ID;" />
        </SG>
        <SG _S="4276" N="ListResInfo">
          <QY P="MsSql" Q="SELECT DEF.RES_ID AS RES_ID&#xD;&#xA;     , DEF.RES_DESC AS RES_DESC&#xD;&#xA;FROM MGCMTBLDAT GCM, MRASRESMFO RES, MRASRESDEF DEF&#xD;&#xA;WHERE 1 = 1 &#xD;&#xA;AND GCM.FACTORY = '??factory??'&#xD;&#xA;AND GCM.KEY_1 = '??oper??'&#xD;&#xA;AND GCM.TABLE_NAME = 'HM_DSC_RECIPE_NAME'&#xD;&#xA;AND GCM.FACTORY = RES.FACTORY(+)&#xD;&#xA;AND GCM.KEY_1 = RES.OPER(+)&#xD;&#xA;AND RES.RES_ID = DEF.RES_ID(+)&#xD;&#xA;AND DEF.RES_ID NOT IN ' '&#xD;&#xA;AND DEF.RES_DESC NOT IN ' '&#xD;&#xA;GROUP BY DEF.RES_ID, DEF.RES_DESC&#xD;&#xA;ORDER BY DEF.RES_ID, DEF.RES_DESC;" />
        </SG>
        <SG _S="4275" N="ListOperInfo">
          <QY P="MsSql" Q="SELECT OPR.OPER AS OPER&#xD;&#xA;     , OPR.OPER_DESC AS OPER_DESC&#xD;&#xA;FROM MGCMTBLDAT GCM, MWIPOPRDEF OPR&#xD;&#xA;WHERE 1 = 1 &#xD;&#xA;AND GCM.FACTORY = '??factory??'&#xD;&#xA;AND GCM.TABLE_NAME = 'HM_DSC_RECIPE_NAME'&#xD;&#xA;AND GCM.FACTORY = OPR.FACTORY(+)&#xD;&#xA;AND GCM.KEY_1 = OPR.OPER(+)&#xD;&#xA;GROUP BY OPR.OPER, OPR.OPER_DESC&#xD;&#xA;ORDER BY OPR.OPER, OPR.OPER_DESC;" />
        </SG>
        <SG _S="4273" N="ListMasterRecipe">
          <QY P="MsSql" Q="SELECT RCP_ID, RCP_DESC, RCP_ACTIVE, ACTIVE_RCP_VER, LAST_RCP_VER, RCP_HOLD&#xD;&#xA;  FROM QTMSMASRCP &#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE 	   = @type   &#xD;&#xA;   AND RCP_ID  = @rcp_id&#xD;&#xA; ORDER BY RCP_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
          </QY>
        </SG>
        <SG _S="4274" N="SearchEquipmentType">
          <QY P="MsSql" Q="SELECT TYPE&#xD;&#xA;  FROM QTMSEQPDEF &#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EQP_NAME    = @eqp_name">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
      </F>
      <F _S="3178" N="EquipmentStatus">
        <SG _S="3179" N="ListEquipmentStatus">
          <QY P="MsSql" Q="SELECT A.EQP_NAME, A.EQP_DESC, A.TYPE, A.LINE, A.RECIPE_CONTROL,&#xD;&#xA;       ISNULL(B.COMM_STATE, ' ') AS COMM_STATE, &#xD;&#xA;	   ISNULL(B.CTRL_MODE, ' ') AS CTRL_MODE,&#xD;&#xA;	   ISNULL(B.PROC_STATE, ' ') AS PROC_STATE,&#xD;&#xA;	   ISNULL(B.EQP_RCP_ID, ' ') AS EQP_RCP_ID,&#xD;&#xA;	   ISNULL(B.LAST_EVENT_ID, ' ') AS LAST_EVENT_ID,&#xD;&#xA;	   ISNULL(B.LAST_EVENT_TIME, ' ') AS LAST_EVENT_TIME&#xD;&#xA;  FROM QTMSEQPDEF A&#xD;&#xA;  LEFT JOIN QTMSEQPSTS B&#xD;&#xA;    ON A.FACTORY     = B.FACTORY&#xD;&#xA;   AND A.EQP_NAME    = B.EQP_NAME&#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY A.EQP_NAME">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="2280" N="Report">
      <F _S="2328" N="RecipeHistory">
        <SG _S="2651" N="SearchRecipeHistory">
          <QY P="MsSql" Q="SELECT H.TRAN_TIME, H.HIST_SEQ, H.RCP_ID, M.RCP_DESC, M.RCP_CLASS, &#xD;&#xA;       H.EVENT_ID, H.TYPE, H.RCP_MEMBER, &#xD;&#xA;       H.EQP_NAME, H.TGT_EQP_NAME, H.RCP_ACTIVE, H.RCP_ACTIVE_VER, H.RCP_HOLD, H.TRAN_USER_ID,&#xD;&#xA;       H.EVT_H_1, H.EVT_D_1, H.EVT_H_2, H.EVT_D_2, H.EVT_H_3, H.EVT_D_3, H.EVT_H_4, H.EVT_D_4, H.EVT_H_5, H.EVT_D_5, &#xD;&#xA;       H.EVT_H_6, H.EVT_D_6, H.EVT_H_7, H.EVT_D_7, H.EVT_H_8, H.EVT_D_8, H.EVT_H_9, H.EVT_D_9, H.EVT_H_10, H.EVT_D_10, &#xD;&#xA;       H.EVT_H_11, H.EVT_D_11, H.EVT_H_12, H.EVT_D_12, H.EVT_H_13, H.EVT_D_13, H.EVT_H_14, H.EVT_D_14, H.EVT_H_15, H.EVT_D_15, &#xD;&#xA;       H.EVT_H_16, H.EVT_D_16, H.EVT_H_17, H.EVT_D_17, H.EVT_H_18, H.EVT_D_18, H.EVT_H_19, H.EVT_D_19, H.EVT_H_20, H.EVT_D_20,&#xD;&#xA;       H. TRAN_COMMENT&#xD;&#xA;  FROM QTMSRCPHIS H&#xD;&#xA;  LEFT JOIN QTMSMASRCP M&#xD;&#xA;    ON H.FACTORY    = M.FACTORY&#xD;&#xA;   AND H.TYPE       = M.TYPE&#xD;&#xA;   AND H.RCP_ID     = M.RCP_ID&#xD;&#xA; WHERE H.FACTORY    = @factory&#xD;&#xA;   AND H.TYPE       = ISNULL(@type, H.TYPE)&#xD;&#xA;   AND H.RCP_ID     = ISNULL(@rcp_id, H.RCP_ID)&#xD;&#xA;   AND H.TRAN_TIME &gt;= @tran_from_time&#xD;&#xA;   AND H.TRAN_TIME &lt;= ISNULL(@tran_to_time, H.TRAN_TIME)&#xD;&#xA; ORDER BY H.HIST_SEQ DESC">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
        <SG _S="4136" N="SearchRecipeHistoryPaging">
          <QY P="MsSql" Q="SELECT H.TRAN_TIME, H.HIST_SEQ, H.RCP_ID, M.RCP_DESC, M.RCP_CLASS, &#xD;&#xA;       H.EVENT_ID, H.TYPE, H.RCP_MEMBER, &#xD;&#xA;       H.EQP_NAME, H.TGT_EQP_NAME, H.RCP_ACTIVE, H.RCP_ACTIVE_VER, H.RCP_HOLD, H.TRAN_USER_ID,&#xD;&#xA;       H.EVT_H_1, H.EVT_D_1, H.EVT_H_2, H.EVT_D_2, H.EVT_H_3, H.EVT_D_3, H.EVT_H_4, H.EVT_D_4, H.EVT_H_5, H.EVT_D_5, &#xD;&#xA;       H.EVT_H_6, H.EVT_D_6, H.EVT_H_7, H.EVT_D_7, H.EVT_H_8, H.EVT_D_8, H.EVT_H_9, H.EVT_D_9, H.EVT_H_10, H.EVT_D_10, &#xD;&#xA;       H.EVT_H_11, H.EVT_D_11, H.EVT_H_12, H.EVT_D_12, H.EVT_H_13, H.EVT_D_13, H.EVT_H_14, H.EVT_D_14, H.EVT_H_15, H.EVT_D_15, &#xD;&#xA;       H.EVT_H_16, H.EVT_D_16, H.EVT_H_17, H.EVT_D_17, H.EVT_H_18, H.EVT_D_18, H.EVT_H_19, H.EVT_D_19, H.EVT_H_20, H.EVT_D_20,&#xD;&#xA;       H. TRAN_COMMENT&#xD;&#xA;  FROM QTMSRCPHIS H&#xD;&#xA;  LEFT JOIN QTMSMASRCP M&#xD;&#xA;    ON H.FACTORY    = M.FACTORY&#xD;&#xA;   AND H.TYPE       = M.TYPE&#xD;&#xA;   AND H.RCP_ID     = M.RCP_ID&#xD;&#xA; WHERE H.FACTORY    = @factory&#xD;&#xA;   AND H.TYPE       = ISNULL(@type, H.TYPE)&#xD;&#xA;   AND H.RCP_ID     = ISNULL(@rcp_id, H.RCP_ID)&#xD;&#xA;   AND H.TRAN_TIME &gt;= @tran_from_time&#xD;&#xA;   AND H.TRAN_TIME &lt;= ISNULL(@tran_to_time, H.TRAN_TIME)&#xD;&#xA; ORDER BY H.HIST_SEQ DESC&#xD;&#xA; OFFSET (CONVERT(int, @PAGE_NO)-1) * CONVERT(int, @PAGE_SIZE) ROW FETCH NEXT CONVERT(int, @PAGE_SIZE) ROW ONLY">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
            <QP N="PAGE_NO" />
            <QP N="PAGE_SIZE" />
          </QY>
        </SG>
        <SG _S="3309" N="CountRecipeHistory">
          <QY P="MsSql" Q="SELECT  COUNT(*) AS CNT&#xD;&#xA;   FROM QTMSRCPHIS&#xD;&#xA;  WHERE FACTORY     = @factory&#xD;&#xA;  	AND TYPE        = ISNULL(@type, TYPE)&#xD;&#xA;	AND RCP_ID      = ISNULL(@rcp_id, RCP_ID)&#xD;&#xA;	AND TRAN_TIME  &gt;= @tran_from_time&#xD;&#xA;	AND TRAN_TIME  &lt;= ISNULL(@tran_to_time, TRAN_TIME)">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
      </F>
      <F _S="2387" N="UserHistory">
        <SG _S="2388" N="SearchUserHistory">
          <QY P="MsSql" Q="SELECT TRAN_TIME, USER_ID,&#xD;&#xA;       SYSTEM, EVENT_ID, ACTION, HOST_IP, HOST_NAME,&#xD;&#xA;       EVT_H_1, EVT_D_1, EVT_H_2, EVT_D_2, EVT_H_3, EVT_D_3, EVT_H_4, EVT_D_4, EVT_H_5, EVT_D_5, &#xD;&#xA;       EVT_H_6, EVT_D_6, EVT_H_7, EVT_D_7, EVT_H_8, EVT_D_8, EVT_H_9, EVT_D_9, EVT_H_10, EVT_D_10,       &#xD;&#xA;       EVT_H_11, EVT_D_11, EVT_H_12, EVT_D_12, EVT_H_13, EVT_D_13, EVT_H_14, EVT_D_14, EVT_H_15, EVT_D_15, &#xD;&#xA;       EVT_H_16, EVT_D_16, EVT_H_17, EVT_D_17, EVT_H_18, EVT_D_18, EVT_H_19, EVT_D_19, EVT_H_20, EVT_D_20,&#xD;&#xA;       TRAN_COMMENT&#xD;&#xA;  FROM QSECUSRHIS&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND SYSTEM       = @system&#xD;&#xA;   AND USER_ID      = ISNULL(@user_id, USER_ID)&#xD;&#xA;   AND C_TRAN_TIME &gt;= CONVERT (DATETIME, (STUFF(STUFF(STUFF(STUFF(@tran_from_time, 9, 0, ' '), 12, 0, ':'), 15, 0, ':'), 18, 0, '.'))) &#xD;&#xA;   AND C_TRAN_TIME &lt;= CONVERT (DATETIME, (STUFF(STUFF(STUFF(STUFF(@tran_to_time, 9, 0, ' '), 12, 0, ':'), 15, 0, ':'), 18, 0, '.')))&#xD;&#xA; ORDER BY C_TRAN_TIME DESC">
            <QP N="factory" />
            <QP N="system" />
            <QP N="user_id" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
        <SG _S="4139" N="SearchUserHistoryPaging">
          <QY P="MsSql" Q="SELECT TRAN_TIME, USER_ID,&#xD;&#xA;       SYSTEM, EVENT_ID, ACTION, HOST_IP, HOST_NAME,&#xD;&#xA;       EVT_H_1, EVT_D_1, EVT_H_2, EVT_D_2, EVT_H_3, EVT_D_3, EVT_H_4, EVT_D_4, EVT_H_5, EVT_D_5, &#xD;&#xA;       EVT_H_6, EVT_D_6, EVT_H_7, EVT_D_7, EVT_H_8, EVT_D_8, EVT_H_9, EVT_D_9, EVT_H_10, EVT_D_10,       &#xD;&#xA;       EVT_H_11, EVT_D_11, EVT_H_12, EVT_D_12, EVT_H_13, EVT_D_13, EVT_H_14, EVT_D_14, EVT_H_15, EVT_D_15, &#xD;&#xA;       EVT_H_16, EVT_D_16, EVT_H_17, EVT_D_17, EVT_H_18, EVT_D_18, EVT_H_19, EVT_D_19, EVT_H_20, EVT_D_20,&#xD;&#xA;       TRAN_COMMENT&#xD;&#xA;  FROM QSECUSRHIS&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND SYSTEM       = @system&#xD;&#xA;   AND USER_ID      = ISNULL(@user_id, USER_ID)&#xD;&#xA;   AND C_TRAN_TIME &gt;= CONVERT (DATETIME, (STUFF(STUFF(STUFF(STUFF(@tran_from_time, 9, 0, ' '), 12, 0, ':'), 15, 0, ':'), 18, 0, '.'))) &#xD;&#xA;   AND C_TRAN_TIME &lt;= CONVERT (DATETIME, (STUFF(STUFF(STUFF(STUFF(@tran_to_time, 9, 0, ' '), 12, 0, ':'), 15, 0, ':'), 18, 0, '.')))&#xD;&#xA; ORDER BY C_TRAN_TIME DESC&#xD;&#xA;OFFSET (CONVERT(int, @PAGE_NO)-1) * CONVERT(int, @PAGE_SIZE) ROW FETCH NEXT CONVERT(int, @PAGE_SIZE) ROW ONLY">
            <QP N="factory" />
            <QP N="system" />
            <QP N="user_id" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
            <QP N="PAGE_NO" />
            <QP N="PAGE_SIZE" />
          </QY>
        </SG>
        <SG _S="3779" N="SearchUserHistoryCount">
          <QY P="MsSql" Q="SELECT COUNT(*) AS CNT&#xD;&#xA;  FROM QSECUSRHIS&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND SYSTEM       = @system&#xD;&#xA;   AND USER_ID      = ISNULL(@user_id, USER_ID)&#xD;&#xA;   AND C_TRAN_TIME &gt;= CONVERT (DATETIME, (STUFF(STUFF(STUFF(STUFF(@tran_from_time, 9, 0, ' '), 12, 0, ':'), 15, 0, ':'), 18, 0, '.'))) &#xD;&#xA;   AND C_TRAN_TIME &lt;= CONVERT (DATETIME, (STUFF(STUFF(STUFF(STUFF(@tran_to_time, 9, 0, ' '), 12, 0, ':'), 15, 0, ':'), 18, 0, '.')))">
            <QP N="factory" />
            <QP N="system" />
            <QP N="user_id" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
      </F>
      <F _S="2891" N="UnappliedItemList">
        <SG _S="2906" N="ItemList">
          <QY P="MsSql" Q="SELECT&#xD;&#xA;	MAT_ID,&#xD;&#xA;	MAT_DESC&#xD;&#xA;FROM MES.LSISDB.dbo.MWIPMATDEF&#xD;&#xA;WHERE FACTORY = @factory&#xD;&#xA;AND MAT_TYPE = 'FG by Make'&#xD;&#xA;AND DELETE_FLAG &lt;&gt; 'Y'&#xD;&#xA;AND MFG_DEVISION = ISNULL(@spg_code, MFG_DEVISION)&#xD;&#xA;AND BASE_MAT_ID = ISNULL(@status, BASE_MAT_ID)&#xD;&#xA;AND MAT_CMF_5 = ISNULL(@exp_dom, MAT_CMF_5)&#xD;&#xA;AND VOLUME_UNIT = ISNULL(@planner, VOLUME_UNIT)&#xD;&#xA;AND CREATE_TIME &gt;= ISNULL(@tran_from_time, CREATE_TIME)&#xD;&#xA;AND CREATE_TIME &lt;= ISNULL(@tran_to_time, CREATE_TIME)&#xD;&#xA;AND MAT_ID NOT IN (SELECT ITEM_CODE&#xD;&#xA;					 FROM QTMSITMDEF&#xD;&#xA;				      WHERE FACTORY = @factory&#xD;&#xA;				          AND SPG_CODE = ISNULL(@spg_code, SPG_CODE)&#xD;&#xA;				          AND DELETE_FLAG = 'N')">
            <QP N="factory" />
            <QP N="spg_code" />
            <QP N="status" />
            <QP N="exp_dom" />
            <QP N="planner" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
        <SG _S="2892" N="SearchItemList">
          <QY P="MsSql" Q="SELECT&#xD;&#xA;	MAT_ID,&#xD;&#xA;	MAT_DESC&#xD;&#xA;FROM MES.LSISDB.dbo.MWIPMATDEF&#xD;&#xA;WHERE FACTORY = @factory&#xD;&#xA;AND MAT_TYPE = 'FG by Make'&#xD;&#xA;AND DELETE_FLAG &lt;&gt; 'Y'&#xD;&#xA;AND MFG_DEVISION = ISNULL(@spg_code, MFG_DEVISION)&#xD;&#xA;AND BASE_MAT_ID = ISNULL(@status, BASE_MAT_ID)&#xD;&#xA;AND MAT_CMF_5 = ISNULL(@exp_dom, MAT_CMF_5)&#xD;&#xA;AND VOLUME_UNIT = ISNULL(@planner, VOLUME_UNIT)&#xD;&#xA;AND CREATE_TIME &gt;= ISNULL(@tran_from_time, CREATE_TIME)&#xD;&#xA;AND CREATE_TIME &lt;= ISNULL(@tran_to_time, CREATE_TIME)&#xD;&#xA;AND MAT_ID NOT IN (SELECT ITEM_CODE&#xD;&#xA;					 FROM QTMSITMDEF&#xD;&#xA;				      WHERE FACTORY = @factory&#xD;&#xA;				          AND SPG_CODE = ISNULL(@spg_code, SPG_CODE)&#xD;&#xA;				          AND DELETE_FLAG = 'N')&#xD;&#xA;AND MAT_ID LIKE @item_code">
            <QP N="factory" />
            <QP N="spg_code" />
            <QP N="status" />
            <QP N="exp_dom" />
            <QP N="planner" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
            <QP N="item_code" />
          </QY>
        </SG>
        <SG _S="2946" N="ItemRecipeList">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;	A.ITEM_CODE,&#xD;&#xA;	B.MAT_DESC&#xD;&#xA;FROM (SELECT FACTORY, ITEM_CODE&#xD;&#xA;	    FROM QTMSITMDEF&#xD;&#xA;	   WHERE FACTORY = @factory&#xD;&#xA;		 AND SPG_CODE = @spg_code&#xD;&#xA;		 AND DELETE_FLAG &lt;&gt; 'Y'&#xD;&#xA;		 AND CREATE_TIME &gt;= ISNULL(@tran_from_time, CREATE_TIME)&#xD;&#xA;		 AND CREATE_TIME &lt;= ISNULL(@tran_to_time, CREATE_TIME)&#xD;&#xA;		 AND ITEM_CODE NOT IN (SELECT RCP_ID&#xD;&#xA;								 FROM QTMSMASRCP&#xD;&#xA;								WHERE FACTORY = @factory&#xD;&#xA;								  AND DELETE_FLAG &lt;&gt; 'Y')) A&#xD;&#xA;LEFT JOIN MES.LSISDB.dbo.MWIPMATDEF B WITH (NOLOCK)&#xD;&#xA;  ON A.FACTORY = B.FACTORY&#xD;&#xA; AND A.ITEM_CODE = B.MAT_ID">
            <QP N="factory" />
            <QP N="spg_code" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
        <SG _S="2947" N="SearchItemRecipeList">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;	A.ITEM_CODE,&#xD;&#xA;	B.MAT_DESC&#xD;&#xA;FROM (SELECT FACTORY, ITEM_CODE&#xD;&#xA;	    FROM QTMSITMDEF&#xD;&#xA;	   WHERE FACTORY = @factory&#xD;&#xA;		 AND SPG_CODE = @spg_code&#xD;&#xA;		 AND DELETE_FLAG &lt;&gt; 'Y'&#xD;&#xA;		 AND CREATE_TIME &gt;= ISNULL(@tran_from_time, CREATE_TIME)&#xD;&#xA;		 AND CREATE_TIME &lt;= ISNULL(@tran_to_time, CREATE_TIME)&#xD;&#xA;		 AND ITEM_CODE NOT IN (SELECT RCP_ID&#xD;&#xA;								 FROM QTMSMASRCP&#xD;&#xA;								WHERE FACTORY = @factory&#xD;&#xA;								  AND DELETE_FLAG &lt;&gt; 'Y')&#xD;&#xA;		 AND ITEM_CODE LIKE @item_code) A&#xD;&#xA;LEFT JOIN MES.LSISDB.dbo.MWIPMATDEF B WITH (NOLOCK)&#xD;&#xA;  ON A.FACTORY = B.FACTORY&#xD;&#xA; AND A.ITEM_CODE = B.MAT_ID">
            <QP N="factory" />
            <QP N="spg_code" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
            <QP N="item_code" />
          </QY>
        </SG>
      </F>
      <F _S="2659" N="ApprovalStatus">
        <SG _S="2660" N="SearchApprovalStatus">
          <QY P="MsSql" Q="SELECT  &#xD;&#xA;	RCP_ID,&#xD;&#xA;	RCP_DESC,&#xD;&#xA;	RCP_VER,&#xD;&#xA;	RCP_VER_DESC,&#xD;&#xA;	TYPE, &#xD;&#xA;	RCP_MEMBER,&#xD;&#xA;	EQP_NAME,&#xD;&#xA;	APQ_TIME,&#xD;&#xA;	APQ_USER_ID,&#xD;&#xA;	APQ_COMMENT&#xD;&#xA;   FROM QTMSRCPAPQ&#xD;&#xA;  WHERE FACTORY        = @factory&#xD;&#xA;  	AND TYPE              = ISNULL(@type, TYPE)&#xD;&#xA;  	AND RCP_MEMBER = ISNULL(@rcp_member, RCP_MEMBER)&#xD;&#xA;	AND EQP_NAME     = ISNULL(@eqp_name, EQP_NAME)&#xD;&#xA;	AND RCP_ID          = ISNULL(@rcp_id, RCP_ID)&#xD;&#xA;	AND APQ_TIME  &gt;= @tran_from_time&#xD;&#xA;	AND APQ_TIME  &lt;= ISNULL(@tran_to_time, APQ_TIME)&#xD;&#xA; ORDER BY APQ_TIME">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_member" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
      </F>
      <F _S="2661" N="ApprovalHistory">
        <SG _S="3781" N="ListApprovalItem">
          <QY P="MsSql" Q="SELECT APR_SEQ, APR_TYPE, RESULT,&#xD;&#xA;       STEPS, APQ_TIME, APQ_USER_ID,&#xD;&#xA;	   TRAN_TIME,TRAN_USER_ID&#xD;&#xA;  FROM QTMSAPRRST&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND APR_TYPE     = ISNULL(@apr_type, APR_TYPE)&#xD;&#xA;   AND APQ_USER_ID  = ISNULL(@apq_user_id, APQ_USER_ID)&#xD;&#xA;   AND TRAN_USER_ID = ISNULL(@tran_user_id, TRAN_USER_ID)&#xD;&#xA;   AND APQ_TIME    &gt;= @apq_time_from&#xD;&#xA;   AND TRAN_TIME   &lt;= ISNULL(@apq_time_to, TRAN_TIME)&#xD;&#xA; ORDER BY APR_SEQ DESC">
            <QP N="factory" />
            <QP N="apr_type" />
            <QP N="apq_user_id" />
            <QP N="tran_user_id" />
            <QP N="apq_time_from" />
            <QP N="apq_time_to" />
          </QY>
        </SG>
        <SG _S="4137" N="ListApprovalItemPaging">
          <QY P="MsSql" Q="SELECT APR_SEQ, APR_TYPE, RESULT,&#xD;&#xA;       STEPS, APQ_TIME, APQ_USER_ID,&#xD;&#xA;	   TRAN_TIME,TRAN_USER_ID&#xD;&#xA;  FROM QTMSAPRRST&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND APR_TYPE     = ISNULL(@apr_type, APR_TYPE)&#xD;&#xA;   AND APQ_USER_ID  = ISNULL(@apq_user_id, APQ_USER_ID)&#xD;&#xA;   AND TRAN_USER_ID = ISNULL(@tran_user_id, TRAN_USER_ID)&#xD;&#xA;   AND APQ_TIME    &gt;= @apq_time_from&#xD;&#xA;   AND TRAN_TIME   &lt;= ISNULL(@apq_time_to, TRAN_TIME)&#xD;&#xA; ORDER BY APR_SEQ DESC&#xD;&#xA;OFFSET (CONVERT(int, @PAGE_NO)-1) * CONVERT(int, @PAGE_SIZE) ROW FETCH NEXT CONVERT(int, @PAGE_SIZE) ROW ONLY">
            <QP N="factory" />
            <QP N="apr_type" />
            <QP N="apq_user_id" />
            <QP N="tran_user_id" />
            <QP N="apq_time_from" />
            <QP N="apq_time_to" />
            <QP N="PAGE_NO" />
            <QP N="PAGE_SIZE" />
          </QY>
        </SG>
        <SG _S="4321" N="ListMasterParameter">
          <QY P="MsSql" Q="SELECT A.PARA_ID, B.PARA_DESC, &#xD;&#xA;       A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5,&#xD;&#xA;	   B.PARA_FORMAT,&#xD;&#xA;	   A.PARA_VALIDATION_RULE,&#xD;&#xA;       A.PARA_TARGET_VALUE, A.PARA_USL, A.PARA_UCL, A.PARA_LCL, A.PARA_LSL&#xD;&#xA;  FROM &#xD;&#xA;     (&#xD;&#xA;SELECT FACTORY, TYPE, &#xD;&#xA;       PARA_ID, PARA_LEVEL,&#xD;&#xA;	   PARA_VALUE,&#xD;&#xA;	   PARA_VALIDATION, PARA_VALIDATION_RULE,&#xD;&#xA;	   PARA_GROUP, PARA_CAT_1, PARA_CAT_2, PARA_CAT_3, PARA_CAT_4, PARA_CAT_5,&#xD;&#xA;	   PARA_TARGET_VALUE, PARA_USL, PARA_UCL, PARA_LCL, PARA_LSL&#xD;&#xA;  FROM QTMSMASSVP&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND TYPE      = @type&#xD;&#xA;   AND RCP_ID    = @rcp_id&#xD;&#xA;   AND SPEC_VER  = @spec_ver&#xD;&#xA;     ) AS A&#xD;&#xA; LEFT JOIN QTMSPARDEF B&#xD;&#xA;    ON A.FACTORY    = B.FACTORY&#xD;&#xA;   AND A.TYPE       = B.TYPE&#xD;&#xA;   AND A.PARA_ID    = B.PARA_ID&#xD;&#xA;   AND A.PARA_GROUP = B.PARA_GROUP&#xD;&#xA;   AND A.PARA_CAT_1 = B.PARA_CAT_1&#xD;&#xA;   AND A.PARA_CAT_2 = B.PARA_CAT_2&#xD;&#xA;   AND A.PARA_CAT_3 = B.PARA_CAT_3&#xD;&#xA;   AND A.PARA_CAT_4 = B.PARA_CAT_4&#xD;&#xA;   AND A.PARA_CAT_5 = B.PARA_CAT_5&#xD;&#xA; ORDER BY A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5, A.PARA_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="spec_ver" />
          </QY>
        </SG>
        <SG _S="4324" N="ListRecipeParameterPaging">
          <QY P="MsSql" Q="SELECT A.PARA_ID, B.PARA_DESC,&#xD;&#xA;       A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5,&#xD;&#xA;	   A.PARA_VALUE&#xD;&#xA;  FROM QTMSMASRPR A&#xD;&#xA;  LEFT JOIN QTMSPARDEF B&#xD;&#xA;    ON A.FACTORY    = B.FACTORY&#xD;&#xA;   AND A.TYPE       = B.TYPE&#xD;&#xA;   AND A.PARA_ID    = B.PARA_ID&#xD;&#xA;   AND A.PARA_GROUP = B.PARA_GROUP&#xD;&#xA;   AND A.PARA_CAT_1 = B.PARA_CAT_1&#xD;&#xA;   AND A.PARA_CAT_2 = B.PARA_CAT_2&#xD;&#xA;   AND A.PARA_CAT_3 = B.PARA_CAT_3&#xD;&#xA;   AND A.PARA_CAT_4 = B.PARA_CAT_4&#xD;&#xA;   AND A.PARA_CAT_5 = B.PARA_CAT_5&#xD;&#xA; WHERE A.FACTORY      = @factory&#xD;&#xA;   AND A.TYPE         = @type&#xD;&#xA;   AND A.RCP_ID       = @rcp_id&#xD;&#xA;   AND A.RCP_VER      = @rcp_ver&#xD;&#xA; ORDER BY A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5, A.PARA_ID&#xD;&#xA; OFFSET (CONVERT(int, @PAGE_NO)-1) * CONVERT(int, @PAGE_SIZE) ROW FETCH NEXT CONVERT(int, @PAGE_SIZE) ROW ONLY">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="rcp_ver" />
            <QP N="PAGE_NO" />
            <QP N="PAGE_SIZE" />
          </QY>
        </SG>
