        </SG>
        <SG _S="2629" N="InsertEquipmentRecipeAlarm">
          <QY P="MsSql" Q="INSERT INTO QTMSRCPALM (&#xD;&#xA;   FACTORY,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   TYPE,&#xD;&#xA;   RCP_MEMBER,&#xD;&#xA;   RCP_ID,&#xD;&#xA;   RCP_VER,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   EVENT_ID,&#xD;&#xA;   RCP_RESULT,&#xD;&#xA;   RCP_REASON,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT&#xD;&#xA;)&#xD;&#xA;SELECT&#xD;&#xA;   FACTORY,&#xD;&#xA;   @tran_time,&#xD;&#xA;   TYPE,&#xD;&#xA;   @rcp_member,&#xD;&#xA;   RCP_ID,&#xD;&#xA;   ACTIVE_RCP_VER,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   @last_hist_seq,&#xD;&#xA;   @event_id,&#xD;&#xA;   @rcp_result,&#xD;&#xA;   @rcp_reason,&#xD;&#xA;   @tran_user_id,&#xD;&#xA;   @tran_comment&#xD;&#xA;  FROM QTMSEQPRCP&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TYPE     = @type&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND RCP_ID   = @rcp_id">
            <QP N="tran_time" />
            <QP N="rcp_member" />
            <QP N="last_hist_seq" />
            <QP N="event_id" />
            <QP N="rcp_result" />
            <QP N="rcp_reason" />
