      <F _S="3555" N="Approval">
        <SG _S="3556" N="SearchApprovalItem">
          <QY P="MsSql" Q="SELECT APR_SEQ, APR_TYPE, APQ_TIME, APQ_USER_ID,&#xD;&#xA;	   APR_LINE_NAME, APR_CURR_STEP, APR_LAST_STEP,&#xD;&#xA;	   STATUS,&#xD;&#xA;	   UPDATE_TIME&#xD;&#xA;  FROM QTMSAPRITM&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND APR_SEQ  = @apr_seq&#xD;&#xA;   AND APR_TYPE = @apr_type">
            <QP N="factory" />
            <QP N="apr_seq" />
            <QP N="apr_type" />
          </QY>
        </SG>
        <SG _S="3745" N="SearchApprovalHistory">
          <QY P="MsSql" Q="SELECT APR_SEQ, APR_TYPE, HIST_SEQ, STEP, ACTION, TRAN_TIME, TRAN_USER_ID, TRAN_COMMENT,&#xD;&#xA;       EVT_H_1, EVT_D_1, EVT_H_2, EVT_D_2, EVT_H_3, EVT_D_3, EVT_H_4, EVT_D_4, EVT_H_5, EVT_D_5, &#xD;&#xA;       EVT_H_6, EVT_D_6, EVT_H_7, EVT_D_7, EVT_H_8, EVT_D_8, EVT_H_9, EVT_D_9, EVT_H_10, EVT_D_10, &#xD;&#xA;       EVT_H_11, EVT_D_11, EVT_H_12, EVT_D_12, EVT_H_13, EVT_D_13, EVT_H_14, EVT_D_14, EVT_H_15, EVT_D_15, &#xD;&#xA;       EVT_H_16, EVT_D_16, EVT_H_17, EVT_D_17, EVT_H_18, EVT_D_18, EVT_H_19, EVT_D_19, EVT_H_20, EVT_D_20&#xD;&#xA;  FROM QTMSAPRHIS&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND APR_SEQ    = @apr_seq&#xD;&#xA;   AND APR_TYPE   = @apr_type&#xD;&#xA;   AND TRAN_TIME &gt;= @tran_f_time&#xD;&#xA;   AND TRAN_TIME &lt;= @tran_t_time&#xD;&#xA; ORDER BY HIST_SEQ">
            <QP N="factory" />
            <QP N="apr_seq" />
            <QP N="apr_type" />
            <QP N="tran_f_time" />
            <QP N="tran_t_time" />
          </QY>
        </SG>
        <SG _S="3746" N="SearchApprovalFile">
          <QY P="MsSql" Q="SELECT FILE_NAME&#xD;&#xA;  FROM QTMSAPRFIL&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND APR_SEQ = @apr_seq">
            <QP N="factory" />
            <QP N="apr_seq" />
          </QY>
        </SG>
        <SG _S="3747" N="SearchMasterRecipeVersion">
          <QY P="MsSql" Q="SELECT B.TYPE, B.RCP_ID, B.RCP_CLASS, A.RCP_VER&#xD;&#xA;  FROM QTMSMASRVR A&#xD;&#xA;  LEFT JOIN QTMSMASRCP B&#xD;&#xA;    ON A.FACTORY     = B.FACTORY&#xD;&#xA;   AND A.TYPE        = B.TYPE&#xD;&#xA;   AND A.RCP_ID      = B.RCP_ID&#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.APR_SEQ     = @apr_seq&#xD;&#xA;   AND A.DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="apr_seq" />
          </QY>
        </SG>
        <SG _S="4299" N="SearchMasterRecipeActiveVersion">
          <QY P="MsSql" Q="SELECT RCP_VER&#xD;&#xA;  FROM QTMSMASRVR&#xD;&#xA; WHERE FACTORY        = @factory&#xD;&#xA;   AND TYPE           = @type&#xD;&#xA;   AND RCP_ID         = @rcp_id&#xD;&#xA;   AND RCP_VER_ACTIVE = @rcp_ver_active &#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="rcp_ver_active" />
          </QY>
        </SG>
        <SG _S="3748" N="SearchMasterParameterVersion">
          <QY P="MsSql" Q="SELECT B.TYPE, B.RCP_ID, B.RCP_CLASS, A.SPEC_VER&#xD;&#xA;  FROM QTMSMASSVR A&#xD;&#xA;  LEFT JOIN QTMSMASRCP B&#xD;&#xA;    ON A.FACTORY     = B.FACTORY&#xD;&#xA;   AND A.TYPE        = B.TYPE&#xD;&#xA;   AND A.RCP_ID      = B.RCP_ID&#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.APR_SEQ     = @apr_seq&#xD;&#xA;   AND A.DELETE_FLAG = 'N'&#xD;&#xA;">
            <QP N="factory" />
            <QP N="apr_seq" />
          </QY>
        </SG>
        <SG _S="4301" N="SearchMasterParameterActiveVersion">
          <QY P="MsSql" Q="SELECT SPEC_VER&#xD;&#xA;  FROM QTMSMASSVR&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE    = @type&#xD;&#xA;   AND RCP_ID  = @rcp_id&#xD;&#xA;   AND ACTIVE  = @active &#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="active" />
          </QY>
        </SG>
        <SG _S="3749" N="SearchEquipmentParameterVersion">
          <QY P="MsSql" Q="SELECT B.TYPE, A.EQP_NAME, B.RCP_ID, B.RCP_CLASS, A.SPEC_VER&#xD;&#xA;  FROM QTMSEQPSVR A&#xD;&#xA;  LEFT JOIN QTMSMASRCP B&#xD;&#xA;    ON A.FACTORY     = B.FACTORY&#xD;&#xA;   AND A.TYPE        = B.TYPE&#xD;&#xA;   AND A.RCP_ID      = B.RCP_ID&#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.APR_SEQ     = @apr_seq&#xD;&#xA;   AND A.DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="apr_seq" />
          </QY>
        </SG>
        <SG _S="4300" N="SearchEquipmentParameterActiveVersion">
          <QY P="MsSql" Q="SELECT SPEC_VER&#xD;&#xA;  FROM QTMSEQPSVR&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TYPE     = @type &#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND RCP_ID   = @rcp_id &#xD;&#xA;   AND ACTIVE   = @active &#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="active" />
          </QY>
        </SG>
        <SG _S="3750" N="SearchMatchDataVersion">
          <QY P="MsSql" Q="SELECT B.TYPE, B.RCP_ID, B.RCP_CLASS, A.MDT_VER&#xD;&#xA;  FROM QTMSMDTVER A&#xD;&#xA;  LEFT JOIN QTMSMASRCP B&#xD;&#xA;    ON A.FACTORY     = B.FACTORY&#xD;&#xA;   AND A.TYPE        = B.TYPE&#xD;&#xA;   AND A.RCP_ID      = B.RCP_ID&#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.APR_SEQ     = @apr_seq&#xD;&#xA;   AND A.DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="apr_seq" />
          </QY>
        </SG>
        <SG _S="3558" N="ListApprovalItemForOwner">
          <QY P="MsSql" Q="SELECT APQ_TIME, APR_SEQ, APR_TYPE, APQ_USER_ID, APR_LINE_NAME, APR_CURR_STEP, APR_LAST_STEP, STATUS, APR_EXTEND, UPDATE_TIME&#xD;&#xA;  FROM QTMSAPRITM&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND APQ_USER_ID = @apq_user_id&#xD;&#xA; ORDER BY APR_SEQ DESC, APR_TYPE ASC">
            <QP N="factory" />
            <QP N="apq_user_id" />
          </QY>
        </SG>
        <SG _S="3714" N="ListApprovalItemForApprover">
          <QY P="MsSql" Q="SELECT *&#xD;&#xA;  FROM (&#xD;&#xA;		SELECT B.APQ_TIME, B.APR_SEQ, B.APR_TYPE, B.APQ_USER_ID, A.APR_LINE_NAME, B.APR_CURR_STEP, B.APR_LAST_STEP, B.STATUS, B.APR_EXTEND, B.UPDATE_TIME&#xD;&#xA;		  FROM (&#xD;&#xA;				SELECT FACTORY, APR_LINE_NAME, STEP&#xD;&#xA;				  FROM QTMSAPLUSR &#xD;&#xA;				 WHERE FACTORY = @factory&#xD;&#xA;				   AND USER_ID = @user_id&#xD;&#xA;			   ) A&#xD;&#xA;		 INNER JOIN QTMSAPRITM B&#xD;&#xA;			ON A.FACTORY       = B.FACTORY&#xD;&#xA;		   AND A.APR_LINE_NAME = B.APR_LINE_NAME&#xD;&#xA;		   AND A.STEP          = B.APR_CURR_STEP&#xD;&#xA;		 UNION&#xD;&#xA;		SELECT APQ_TIME, APR_SEQ, APR_TYPE, APQ_USER_ID, APR_LINE_NAME, APR_CURR_STEP, APR_LAST_STEP, STATUS, APR_EXTEND, UPDATE_TIME&#xD;&#xA;		  FROM QTMSAPRITM&#xD;&#xA;		 WHERE FACTORY = @factory&#xD;&#xA;		   AND APR_EXTEND = 'Yes'&#xD;&#xA;		   AND APR_EXTEND_USER_ID = @user_id&#xD;&#xA;     ) UNIONRESULT&#xD;&#xA; ORDER BY UNIONRESULT.APR_SEQ DESC, UNIONRESULT.APR_TYPE ASC">
            <QP N="factory" />
            <QP N="user_id" />
          </QY>
        </SG>
        <SG _S="4165" N="ListRecipeParameter">
          <QY P="MsSql" Q="SELECT A.PARA_ID, B.PARA_DESC,&#xD;&#xA;       A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5,&#xD;&#xA;	   A.PARA_VALUE&#xD;&#xA;  FROM QTMSMASRPR A&#xD;&#xA;  LEFT JOIN QTMSPARDEF B&#xD;&#xA;    ON A.FACTORY    = B.FACTORY&#xD;&#xA;   AND A.TYPE       = B.TYPE&#xD;&#xA;   AND A.PARA_ID    = B.PARA_ID&#xD;&#xA;   AND A.PARA_GROUP = B.PARA_GROUP&#xD;&#xA;   AND A.PARA_CAT_1 = B.PARA_CAT_1&#xD;&#xA;   AND A.PARA_CAT_2 = B.PARA_CAT_2&#xD;&#xA;   AND A.PARA_CAT_3 = B.PARA_CAT_3&#xD;&#xA;   AND A.PARA_CAT_4 = B.PARA_CAT_4&#xD;&#xA;   AND A.PARA_CAT_5 = B.PARA_CAT_5&#xD;&#xA; WHERE A.FACTORY      = @factory&#xD;&#xA;   AND A.TYPE         = @type&#xD;&#xA;   AND A.RCP_ID       = @rcp_id&#xD;&#xA;   AND A.RCP_VER      = @rcp_ver&#xD;&#xA; ORDER BY A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5, A.PARA_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="rcp_ver" />
          </QY>
        </SG>
        <SG _S="4053" N="ListRecipeParameterPaging">
          <QY P="MsSql" Q="SELECT A.PARA_ID, B.PARA_DESC,&#xD;&#xA;       A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5,&#xD;&#xA;	   A.PARA_VALUE&#xD;&#xA;  FROM QTMSMASRPR A&#xD;&#xA;  LEFT JOIN QTMSPARDEF B&#xD;&#xA;    ON A.FACTORY    = B.FACTORY&#xD;&#xA;   AND A.TYPE       = B.TYPE&#xD;&#xA;   AND A.PARA_ID    = B.PARA_ID&#xD;&#xA;   AND A.PARA_GROUP = B.PARA_GROUP&#xD;&#xA;   AND A.PARA_CAT_1 = B.PARA_CAT_1&#xD;&#xA;   AND A.PARA_CAT_2 = B.PARA_CAT_2&#xD;&#xA;   AND A.PARA_CAT_3 = B.PARA_CAT_3&#xD;&#xA;   AND A.PARA_CAT_4 = B.PARA_CAT_4&#xD;&#xA;   AND A.PARA_CAT_5 = B.PARA_CAT_5&#xD;&#xA; WHERE A.FACTORY      = @factory&#xD;&#xA;   AND A.TYPE         = @type&#xD;&#xA;   AND A.RCP_ID       = @rcp_id&#xD;&#xA;   AND A.RCP_VER      = @rcp_ver&#xD;&#xA; ORDER BY A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5, A.PARA_ID&#xD;&#xA; OFFSET (CONVERT(int, @PAGE_NO)-1) * CONVERT(int, @PAGE_SIZE) ROW FETCH NEXT CONVERT(int, @PAGE_SIZE) ROW ONLY">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="rcp_ver" />
            <QP N="PAGE_NO" />
            <QP N="PAGE_SIZE" />
          </QY>
        </SG>
        <SG _S="4166" N="ListMasterParameter">
          <QY P="MsSql" Q="SELECT A.PARA_ID, B.PARA_DESC, &#xD;&#xA;       A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5,&#xD;&#xA;	   B.PARA_FORMAT,&#xD;&#xA;	   A.PARA_VALIDATION_RULE,&#xD;&#xA;       A.PARA_TARGET_VALUE, A.PARA_USL, A.PARA_UCL, A.PARA_LCL, A.PARA_LSL&#xD;&#xA;  FROM &#xD;&#xA;     (&#xD;&#xA;SELECT FACTORY, TYPE, &#xD;&#xA;       PARA_ID, PARA_LEVEL,&#xD;&#xA;	   PARA_VALUE,&#xD;&#xA;	   PARA_VALIDATION, PARA_VALIDATION_RULE,&#xD;&#xA;	   PARA_GROUP, PARA_CAT_1, PARA_CAT_2, PARA_CAT_3, PARA_CAT_4, PARA_CAT_5,&#xD;&#xA;	   PARA_TARGET_VALUE, PARA_USL, PARA_UCL, PARA_LCL, PARA_LSL&#xD;&#xA;  FROM QTMSMASSVP&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND TYPE      = @type&#xD;&#xA;   AND RCP_ID    = @rcp_id&#xD;&#xA;   AND SPEC_VER  = @spec_ver&#xD;&#xA;     ) AS A&#xD;&#xA; LEFT JOIN QTMSPARDEF B&#xD;&#xA;    ON A.FACTORY    = B.FACTORY&#xD;&#xA;   AND A.TYPE       = B.TYPE&#xD;&#xA;   AND A.PARA_ID    = B.PARA_ID&#xD;&#xA;   AND A.PARA_GROUP = B.PARA_GROUP&#xD;&#xA;   AND A.PARA_CAT_1 = B.PARA_CAT_1&#xD;&#xA;   AND A.PARA_CAT_2 = B.PARA_CAT_2&#xD;&#xA;   AND A.PARA_CAT_3 = B.PARA_CAT_3&#xD;&#xA;   AND A.PARA_CAT_4 = B.PARA_CAT_4&#xD;&#xA;   AND A.PARA_CAT_5 = B.PARA_CAT_5&#xD;&#xA; ORDER BY A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5, A.PARA_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="spec_ver" />
          </QY>
        </SG>
        <SG _S="4054" N="ListMasterParameterPaging">
