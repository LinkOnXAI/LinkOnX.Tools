        <SG _S="4470" N="InsertRecipeUploadTemporary">
          <QY P="MsSql" Q="INSERT INTO QTMSRCPUPT (&#xD;&#xA;   FACTORY,&#xD;&#xA;   TYPE,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   RCP_ID,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   TRAN_STATUS,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT&#xD;&#xA;   )&#xD;&#xA;VALUES( &#xD;&#xA;   @factory,&#xD;&#xA;   @type,&#xD;&#xA;   @eqp_name,&#xD;&#xA;   @rcp_id,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @tran_status,&#xD;&#xA;   @tran_user_id,&#xD;&#xA;   @tran_comment)">
            <QP N="factory" />
