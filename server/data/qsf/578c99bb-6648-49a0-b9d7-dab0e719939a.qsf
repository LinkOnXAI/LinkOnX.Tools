      <F _S="1504" N="RecipeHistory">
        <SG _S="1519" N="UpdateMasterRecipe">
          <QY P="MsSql" Q="UPDATE QTMSMASRCP SET&#xD;&#xA;   LAST_HIST_SEQ   = @last_hist_seq,&#xD;&#xA;   LAST_EVENT_ID   = @last_event_id,&#xD;&#xA;   LAST_EVENT_TIME = @last_event_time,&#xD;&#xA;   UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;   UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND RCP_ID      = @rcp_id">
            <QP N="last_hist_seq" />
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
          </QY>
        </SG>
