        </SG>
        <SG _S="4183" N="HasRecipeParser">
          <QY P="MsSql" Q="SELECT C.PSR_NAME, C.PSR_VER, C.PSR_VER_FILE&#xD;&#xA;  FROM QTMSTYPPSR A&#xD;&#xA;  LEFT JOIN QTMSPSRDEF B &#xD;&#xA;    ON A.FACTORY  = B.FACTORY &#xD;&#xA;   AND A.PSR_NAME = B.PSR_NAME&#xD;&#xA;  LEFT JOIN QTMSPSRVER C &#xD;&#xA;    ON C.FACTORY  = B.FACTORY &#xD;&#xA;   AND C.PSR_NAME = B.PSR_NAME&#xD;&#xA;   AND C.PSR_VER  = B.ACTIVE_VER&#xD;&#xA; WHERE A.FACTORY  = @factory&#xD;&#xA;   AND A.EQP_TYPE = @eq_type">
            <QP N="factory" />
            <QP N="eq_type" />
          </QY>
        </SG>
        <SG _S="4184" N="HasTypeParameters">
          <QY P="MsSql" Q="SELECT PARA_ID, PARA_DESC, PARA_GROUP, PARA_CAT_1, PARA_CAT_2, PARA_CAT_3, PARA_CAT_4, PARA_FORMAT, PARA_CAT_5, PARA_DECIMAL_POINT, PARA_UNIT, PARA_LEVEL, MANAGE_FLAG, DELETE_FLAG&#xD;&#xA;  FROM QTMSPARDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE    = @type">
            <QP N="factory" />
            <QP N="type" />
          </QY>
        </SG>
      </F>
      <F _S="4373" N="RecipeParser">
        <SG _S="4374" N="ListActivateParser">
          <QY P="MsSql" Q="SELECT FACTORY, PSR_NAME, PSR_VER, PSR_VER_FILE&#xD;&#xA;  FROM QTMSPSRVER&#xD;&#xA; WHERE PSR_VER_ACTIVE = 'Yes'" />
        </SG>
      </F>
      <F _S="4395" N="ParameterCustomCaption">
        <SG _S="4396" N="SearchCustomCaption">
          <QY P="MsSql" Q="SELECT PARA_CAT1_CAPTION, PARA_CAT2_CAPTION, PARA_CAT3_CAPTION, PARA_CAT4_CAPTION, PARA_CAT5_CAPTION&#xD;&#xA;  FROM QTMSPARCUS&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND PARA_CUSTOM = @para_custom">
            <QP N="factory" />
            <QP N="type" />
            <QP N="para_custom" />
          </QY>
        </SG>
      </F>
      <F _S="4448" N="ProcessRecipe">
        <SG _S="4484" N="ListProcessRecipeInMasterRecipe">
          <QY P="MsSql" Q="SELECT PROC_RCP_ID&#xD;&#xA;  FROM QTMSMASRSQ&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE    = @type&#xD;&#xA;   AND RCP_ID  = @rcp_id&#xD;&#xA;   AND RCP_VER =&#xD;&#xA;       (&#xD;&#xA;SELECT ACTIVE_RCP_VER&#xD;&#xA;  FROM QTMSMASRCP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE    = @type&#xD;&#xA;   AND RCP_ID  = @rcp_id&#xD;&#xA;       ) ">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
          </QY>
        </SG>
        <SG _S="4486" N="ListProcessRecipeInMasterRecipeVersion">
          <QY P="MsSql" Q="SELECT PROC_RCP_ID&#xD;&#xA;  FROM QTMSMASRSQ&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE    = @type&#xD;&#xA;   AND RCP_ID  = @rcp_id&#xD;&#xA;   AND RCP_VER = @rcp_ver">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="rcp_ver" />
          </QY>
        </SG>
        <SG _S="4491" N="ListProcessRecipeInTemporary">
          <QY P="MsSql" Q="SELECT PROC_RCP_ID&#xD;&#xA;  FROM QTMSTMPRSQ&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TYPE     = @type&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND RCP_ID   = @rcp_id">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
          </QY>
        </SG>
        <SG _S="4485" N="ListProcessRecipeInEquipmentRecipe">
          <QY P="MsSql" Q="SELECT PROC_RCP_ID&#xD;&#xA;  FROM QTMSEQPRSQ&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TYPE     = @type&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND RCP_ID   = @rcp_id&#xD;&#xA;   AND RCP_VER  =&#xD;&#xA;       (&#xD;&#xA;SELECT LAST_RCP_VER&#xD;&#xA;  FROM QTMSEQPRCP&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TYPE     = @type&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND RCP_ID   = @rcp_id&#xD;&#xA;       ) ">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
          </QY>
        </SG>
        <SG _S="4487" N="ListProcessRecipeInEquipmentRecipeVersion">
          <QY P="MsSql" Q="SELECT PROC_RCP_ID&#xD;&#xA;  FROM QTMSEQPRSQ&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TYPE     = @type&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND RCP_ID   = @rcp_id&#xD;&#xA;   AND RCP_VER  = @rcp_ver">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="rcp_ver" />
          </QY>
        </SG>
        <SG _S="4450" N="ListMasterProcessRecipe">
          <QY P="MsSql" Q="SELECT RCP_ID, RCP_DESC, RCP_ACTIVE, RCP_HOLD&#xD;&#xA;  FROM QTMSMASRCP&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND RCP_CLASS   = @rcp_class&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_class" />
          </QY>
        </SG>
        <SG _S="4488" N="SearchMasterRecipe">
          <QY P="MsSql" Q="SELECT RCP_DESC, RCP_CLASS, RCP_ACTIVE, ACTIVE_RCP_VER, RCP_HOLD&#xD;&#xA;  FROM QTMSMASRCP&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND RCP_ID      = @rcp_id&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
          </QY>
        </SG>
        <SG _S="4490" N="SearchEquipmentRecipeLastVersion">
          <QY P="MsSql" Q="SELECT TOP 1 RCP_VER&#xD;&#xA;  FROM QTMSEQPRVR&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND EQP_NAME    = @eqp_name&#xD;&#xA;   AND RCP_ID      = @rcp_id&#xD;&#xA;   AND MAS_RCP_VER = @mas_rcp_ver&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY RCP_VER DESC">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="mas_rcp_ver" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="6" N="Dialog">
      <F _S="57" N="UserSelector">
        <SG _S="58" N="ListUserGroup_Backup">
          <QY P="MsSql" Q="SELECT USER_GRP, USER_GRP_DESC&#xD;&#xA;  FROM QSECUSRGRP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY USER_GRP">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="59" N="ListUser_Backup" D="@">
          <QY P="MsSql" Q="SELECT A.USER_ID, ISNULL(B.USER_NAME, A.USER_NAME) AS USER_NAME, A.USER_DESC&#xD;&#xA;  FROM QSECUSRDEF A&#xD;&#xA;  LEFT JOIN MES.MSECUSRDEF@MES B&#xD;&#xA;    ON A.FACTORY = @factory &#xD;&#xA;    AND A.USER_ID = B.USER_ID&#xD;&#xA; WHERE A.FACTORY = @factory&#xD;&#xA;   AND A.USER_GRP = @user_grp">
            <QP N="MES" />
            <QP N="factory" />
            <QP N="user_grp" />
          </QY>
        </SG>
        <SG _S="2262" N="ListUser">
          <QY P="MsSql" Q="SELECT A.USER_ID, A.USER_NAME, A.USER_GRP, ISNULL(B.ROLE, ' ') AS ROLE&#xD;&#xA;  FROM QSECUSRDEF A&#xD;&#xA;  LEFT JOIN QTMSUSRROL B&#xD;&#xA;    ON A.FACTORY = B.FACTORY&#xD;&#xA;   AND A.USER_ID = B.USER_ID&#xD;&#xA; WHERE A.FACTORY = @factory&#xD;&#xA; ORDER BY A.USER_ID">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="2875" N="SearchUserList">
          <QY P="MsSql" Q="SELECT USER_ID, USER_NAME, USER_DESC&#xD;&#xA;  FROM QSECUSRDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY USER_ID">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="3260" N="UserGroupSelector">
        <SG _S="3261" N="ListUserGroup">
          <QY P="MsSql" Q="SELECT USER_GRP, USER_GRP_DESC&#xD;&#xA;FROM QTMSURGDEF&#xD;&#xA;WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="3196" N="UserGroupFunctionSelector">
        <SG _S="3197" N="ListFunction">
          <QY P="MsSql" Q="SELECT FUN, FUN_DESC, TRAN_USED&#xD;&#xA;  FROM QTMSURGFUN&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY FUN">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="3198" N="UserGroupAuthoritySelector">
        <SG _S="3199" N="ListUserGroup">
          <QY P="MsSql" Q="SELECT USER_GRP, USER_GRP_DESC, ALL_AUTHORITY&#xD;&#xA;  FROM QTMSURGDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY USER_GRP">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3200" N="ListAuthority">
          <QY P="MsSql" Q="SELECT A.FUN, B.FUN_DESC, A.TRAN_ENABLED, B.TRAN_USED&#xD;&#xA;  FROM QTMSURGAUT A&#xD;&#xA;  LEFT JOIN QTMSURGFUN B&#xD;&#xA;    ON A.FACTORY  = B.FACTORY&#xD;&#xA;   AND A.FUN      = B.FUN&#xD;&#xA; WHERE A.FACTORY  = @factory&#xD;&#xA;   AND A.USER_GRP = @user_grp&#xD;&#xA;   AND A.TYPE      = @type&#xD;&#xA; ORDER BY A.FUN">
            <QP N="factory" />
            <QP N="user_grp" />
            <QP N="type" />
          </QY>
        </SG>
      </F>
      <F _S="2506" N="TypeParameterSelector">
        <SG _S="2507" N="ListParameter">
          <QY P="MsSql" Q="SELECT PARA_ID, PARA_DESC, PARA_GROUP, &#xD;&#xA;       PARA_CAT_1, PARA_CAT_2, PARA_CAT_3, PARA_CAT_4, PARA_CAT_5,&#xD;&#xA;       PARA_FORMAT, PARA_DECIMAL_POINT, PARA_UNIT, PARA_LEVEL, MANAGE_FLAG&#xD;&#xA;  FROM QTMSPARDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND MANAGE_FLAG = ISNULL(@manage_flag, MANAGE_FLAG)&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY PARA_GROUP, PARA_CAT_1, PARA_CAT_2, PARA_CAT_3, PARA_CAT_4, PARA_CAT_5, PARA_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="manage_flag" />
          </QY>
        </SG>
        <SG _S="4168" N="ListParameterPaging">
          <QY P="MsSql" Q="SELECT PARA_ID, PARA_DESC, PARA_GROUP, &#xD;&#xA;       PARA_CAT_1, PARA_CAT_2, PARA_CAT_3, PARA_CAT_4, PARA_CAT_5,&#xD;&#xA;       PARA_FORMAT, PARA_DECIMAL_POINT, PARA_UNIT, PARA_LEVEL, MANAGE_FLAG&#xD;&#xA;  FROM QTMSPARDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND MANAGE_FLAG = ISNULL(@manage_flag, MANAGE_FLAG)&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY PARA_GROUP, PARA_CAT_1, PARA_CAT_2, PARA_CAT_3, PARA_CAT_4, PARA_CAT_5, PARA_ID&#xD;&#xA;OFFSET (CONVERT(int, @PAGE_NO)-1) * CONVERT(int, @PAGE_SIZE) ROW FETCH NEXT CONVERT(int, @PAGE_SIZE) ROW ONLY">
            <QP N="factory" />
            <QP N="type" />
            <QP N="manage_flag" />
            <QP N="PAGE_NO" />
            <QP N="PAGE_SIZE" />
          </QY>
        </SG>
        <SG _S="4113" N="CountParameter">
          <QY P="MsSql" Q="SELECT COUNT(*) AS CNT&#xD;&#xA;  FROM QTMSPARDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND MANAGE_FLAG = ISNULL(@manage_flag, MANAGE_FLAG)&#xD;&#xA;   AND DELETE_FLAG &lt;&gt; 'Y'">
            <QP N="factory" />
            <QP N="type" />
            <QP N="manage_flag" />
          </QY>
        </SG>
      </F>
      <F _S="4156" N="MasterDataSelector">
        <SG _S="4157" N="SearchMasterData">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;   DATA_NAME, &#xD;&#xA;   DATA_DESC, &#xD;&#xA;   TARGET_DB,&#xD;&#xA;   SQL_MOD,&#xD;&#xA;   SQL_FUN,&#xD;&#xA;   SQL_COD,&#xD;&#xA;   REF_DATA&#xD;&#xA;  FROM QTMSMDTDEF&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA; AND DATA_NAME &lt;&gt; @data_name">
            <QP N="factory" />
            <QP N="data_name" />
          </QY>
        </SG>
      </F>
      <F _S="4158" N="MatchDataSelector">
        <SG _S="4159" N="ListMasterData">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;   DATA_SEQ,&#xD;&#xA;   DATA_NAME, &#xD;&#xA;   DATA_DESC, &#xD;&#xA;   DATA_KEY,&#xD;&#xA;   SELE_MODE,&#xD;&#xA;   TARGET_DB,&#xD;&#xA;   SQL_MOD,&#xD;&#xA;   SQL_FUN,&#xD;&#xA;   SQL_COD,&#xD;&#xA;   REF_DATA&#xD;&#xA;  FROM QTMSMDTDEF&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA; ORDER BY DATA_SEQ">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="4160" N="ListMatchData">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;   DATA_KEY_1, &#xD;&#xA;   DATA_KEY_2, &#xD;&#xA;   DATA_KEY_3,&#xD;&#xA;   DATA_KEY_4, &#xD;&#xA;   DATA_KEY_5,&#xD;&#xA;   STATUS&#xD;&#xA;  FROM QTMSMDTREL&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE    = @type&#xD;&#xA;   AND RCP_ID  = @rcp_id&#xD;&#xA; ORDER BY DATA_KEY_1, DATA_KEY_2, DATA_KEY_3, DATA_KEY_4, DATA_KEY_5">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
          </QY>
        </SG>
      </F>
      <F _S="4161" N="MatchDataVersionSelector">
        <SG _S="4162" N="ListMatchDataVersion">
          <QY P="MsSql" Q="SELECT MDT_VER, MDT_VER_DESC, ACTIVE, STATUS&#xD;&#xA;  FROM QTMSMDTVER&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE    = @type&#xD;&#xA;   AND RCP_ID  = @rcp_id&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY MDT_VER DESC">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
          </QY>
        </SG>
      </F>
      <F _S="4303" N="RecipeCompare">
        <SG _S="4315" N="ListMasterRecipeParameter">
          <QY P="MsSql" Q="SELECT A.PARA_ID, B.PARA_DESC,&#xD;&#xA;       A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5,&#xD;&#xA;	 B.PARA_FORMAT, A.PARA_VALUE&#xD;&#xA;  FROM QTMSMASRPR A&#xD;&#xA;  LEFT JOIN QTMSPARDEF B&#xD;&#xA;    ON A.FACTORY    = B.FACTORY&#xD;&#xA;   AND A.TYPE       = B.TYPE&#xD;&#xA;   AND A.PARA_ID    = B.PARA_ID&#xD;&#xA;   AND A.PARA_GROUP = B.PARA_GROUP&#xD;&#xA;   AND A.PARA_CAT_1 = B.PARA_CAT_1&#xD;&#xA;   AND A.PARA_CAT_2 = B.PARA_CAT_2&#xD;&#xA;   AND A.PARA_CAT_3 = B.PARA_CAT_3&#xD;&#xA;   AND A.PARA_CAT_4 = B.PARA_CAT_4&#xD;&#xA;   AND A.PARA_CAT_5 = B.PARA_CAT_5&#xD;&#xA; WHERE A.FACTORY      = @factory&#xD;&#xA;   AND A.TYPE         = @type&#xD;&#xA;   AND A.RCP_ID       = @rcp_id&#xD;&#xA;   AND A.RCP_VER      = @rcp_ver&#xD;&#xA; ORDER BY A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="rcp_ver" />
          </QY>
        </SG>
        <SG _S="4312" N="CountEquipmentRecipeParameter">
          <QY P="MsSql" Q="SELECT COUNT(*) AS CNT&#xD;&#xA;  FROM QTMSRCPPVH&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE    = @type&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND RCP_ID  = @rcp_id&#xD;&#xA;   AND HIST_SEQ = @hist_seq">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="hist_seq" />
          </QY>
        </SG>
        <SG _S="4313" N="CountMasterRecipeParameter">
          <QY P="MsSql" Q="SELECT COUNT(*) AS CNT&#xD;&#xA;  FROM QTMSMASRPR&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE    = @type&#xD;&#xA;   AND RCP_ID  = @rcp_id&#xD;&#xA;   AND RCP_VER = @rcp_ver">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="rcp_ver" />
          </QY>
        </SG>
        <SG _S="4314" N="ListEquipmentRecipeParameter">
          <QY P="MsSql" Q="SELECT A.PARA_ID, B.PARA_DESC,&#xD;&#xA;       A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5,&#xD;&#xA;       B.PARA_FORMAT, A.PARA_VALUE, B.MANAGE_FLAG   &#xD;&#xA;  FROM QTMSRCPPVH A&#xD;&#xA;  LEFT JOIN QTMSPARDEF B&#xD;&#xA;    ON A.FACTORY    = B.FACTORY&#xD;&#xA;   AND A.TYPE       = B.TYPE&#xD;&#xA;   AND A.PARA_ID    = B.PARA_ID&#xD;&#xA;   AND A.PARA_GROUP = B.PARA_GROUP&#xD;&#xA;   AND A.PARA_CAT_1 = B.PARA_CAT_1&#xD;&#xA;   AND A.PARA_CAT_2 = B.PARA_CAT_2&#xD;&#xA;   AND A.PARA_CAT_3 = B.PARA_CAT_3&#xD;&#xA;   AND A.PARA_CAT_4 = B.PARA_CAT_4&#xD;&#xA;   AND A.PARA_CAT_5 = B.PARA_CAT_5&#xD;&#xA; WHERE A.FACTORY      = @factory&#xD;&#xA;   AND A.TYPE         = @type&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND A.RCP_ID       = @rcp_id&#xD;&#xA;   AND HIST_SEQ = @hist_seq&#xD;&#xA; ORDER BY A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5, A.PARA_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="hist_seq" />
          </QY>
        </SG>
      </F>
      <F _S="4304" N="ParameterSpecCompare">
        <SG _S="4308" N="CountMasterParameter">
          <QY P="MsSql" Q="SELECT COUNT(*) AS CNT&#xD;&#xA;  FROM QTMSMASSVP&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND TYPE      = @type&#xD;&#xA;   AND RCP_ID    = @rcp_id&#xD;&#xA;   AND SPEC_VER  = @spec_ver">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="spec_ver" />
          </QY>
        </SG>
        <SG _S="4309" N="ListEquipmentParameter">
          <QY P="MsSql" Q="SELECT A.PARA_ID, B.PARA_DESC, &#xD;&#xA;       A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5,&#xD;&#xA;	   B.PARA_FORMAT, A.PARA_VALUE, &#xD;&#xA;	   A.PARA_VALIDATION_RULE,&#xD;&#xA;       A.PARA_TARGET_VALUE, A.PARA_USL, A.PARA_UCL, A.PARA_LCL, A.PARA_LSL&#xD;&#xA;  FROM &#xD;&#xA;     (&#xD;&#xA;SELECT FACTORY, TYPE, &#xD;&#xA;       PARA_ID, PARA_LEVEL,&#xD;&#xA;	   PARA_VALUE,&#xD;&#xA;	   PARA_VALIDATION, PARA_VALIDATION_RULE,&#xD;&#xA;	   PARA_GROUP, PARA_CAT_1, PARA_CAT_2, PARA_CAT_3, PARA_CAT_4, PARA_CAT_5,&#xD;&#xA;	   PARA_TARGET_VALUE, PARA_USL, PARA_UCL, PARA_LCL, PARA_LSL&#xD;&#xA;  FROM QTMSEQPSVP&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND TYPE      = @type&#xD;&#xA;   AND EQP_NAME  = @eqp_name&#xD;&#xA;   AND RCP_ID    = @rcp_id&#xD;&#xA;   AND SPEC_VER  = @spec_ver&#xD;&#xA;     ) AS A&#xD;&#xA; LEFT JOIN QTMSPARDEF B&#xD;&#xA;    ON A.FACTORY    = B.FACTORY&#xD;&#xA;   AND A.TYPE       = B.TYPE&#xD;&#xA;   AND A.PARA_ID    = B.PARA_ID&#xD;&#xA;   AND A.PARA_GROUP = B.PARA_GROUP&#xD;&#xA;   AND A.PARA_CAT_1 = B.PARA_CAT_1&#xD;&#xA;   AND A.PARA_CAT_2 = B.PARA_CAT_2&#xD;&#xA;   AND A.PARA_CAT_3 = B.PARA_CAT_3&#xD;&#xA;   AND A.PARA_CAT_4 = B.PARA_CAT_4&#xD;&#xA;   AND A.PARA_CAT_5 = B.PARA_CAT_5&#xD;&#xA; ORDER BY A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5, A.PARA_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="spec_ver" />
          </QY>
        </SG>
        <SG _S="4310" N="ListMasterParameter">
          <QY P="MsSql" Q="SELECT A.PARA_ID, B.PARA_DESC, &#xD;&#xA;       A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5,&#xD;&#xA;	   B.PARA_FORMAT, A.PARA_VALUE,&#xD;&#xA;	   A.PARA_VALIDATION_RULE,&#xD;&#xA;       A.PARA_TARGET_VALUE, A.PARA_USL, A.PARA_UCL, A.PARA_LCL, A.PARA_LSL&#xD;&#xA;  FROM &#xD;&#xA;     (&#xD;&#xA;SELECT FACTORY, TYPE, &#xD;&#xA;       PARA_ID, PARA_LEVEL,&#xD;&#xA;	   PARA_VALUE,&#xD;&#xA;	   PARA_VALIDATION, PARA_VALIDATION_RULE,&#xD;&#xA;	   PARA_GROUP, PARA_CAT_1, PARA_CAT_2, PARA_CAT_3, PARA_CAT_4, PARA_CAT_5,&#xD;&#xA;	   PARA_TARGET_VALUE, PARA_USL, PARA_UCL, PARA_LCL, PARA_LSL&#xD;&#xA;  FROM QTMSMASSVP&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND TYPE      = @type&#xD;&#xA;   AND RCP_ID    = @rcp_id&#xD;&#xA;   AND SPEC_VER  = @spec_ver&#xD;&#xA;     ) AS A&#xD;&#xA; LEFT JOIN QTMSPARDEF B&#xD;&#xA;    ON A.FACTORY    = B.FACTORY&#xD;&#xA;   AND A.TYPE       = B.TYPE&#xD;&#xA;   AND A.PARA_ID    = B.PARA_ID&#xD;&#xA;   AND A.PARA_GROUP = B.PARA_GROUP&#xD;&#xA;   AND A.PARA_CAT_1 = B.PARA_CAT_1&#xD;&#xA;   AND A.PARA_CAT_2 = B.PARA_CAT_2&#xD;&#xA;   AND A.PARA_CAT_3 = B.PARA_CAT_3&#xD;&#xA;   AND A.PARA_CAT_4 = B.PARA_CAT_4&#xD;&#xA;   AND A.PARA_CAT_5 = B.PARA_CAT_5&#xD;&#xA; ORDER BY A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5, A.PARA_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="spec_ver" />
          </QY>
        </SG>
        <SG _S="4307" N="CountEquipmentParameter">
          <QY P="MsSql" Q="SELECT COUNT(*) AS CNT&#xD;&#xA;  FROM QTMSEQPSVP&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND TYPE      = @type&#xD;&#xA;   AND EQP_NAME  = @eqp_name&#xD;&#xA;   AND RCP_ID    = @rcp_id&#xD;&#xA;   AND SPEC_VER  = @spec_ver">
