            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="3498" N="InsertEquipmentRecipeFile">
          <QY P="MsSql" Q="INSERT INTO QTMSEQPRFL (&#xD;&#xA;   FACTORY,&#xD;&#xA;   TYPE,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   RCP_ID,&#xD;&#xA;   RCP_VER,&#xD;&#xA;   EQP_PATH,&#xD;&#xA;   SERVER_BODY_PATH,&#xD;&#xA;   SERVER_MSG_PATH,&#xD;&#xA;   SERVER_MSG_LENGTH,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @type,&#xD;&#xA;   @eqp_name,&#xD;&#xA;   @rcp_id,&#xD;&#xA;   @rcp_ver,&#xD;&#xA;   @eqp_path,&#xD;&#xA;   @server_body_path,&#xD;&#xA;   @server_msg_path,&#xD;&#xA;   @server_msg_length,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
