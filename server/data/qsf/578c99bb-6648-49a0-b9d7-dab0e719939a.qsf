        <SG _S="3609" N="HasApprovalLine">
          <QY P="MsSql" Q="SELECT A.APR_LINE_NAME, MIN(ISNULL(B.STEP, 0)) AS STEP_MIN, MAX(ISNULL(B.STEP, 0)) AS STEP_MAX&#xD;&#xA;  FROM QTMSAPLDEF A&#xD;&#xA;  LEFT JOIN QTMSAPLUSR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.APR_LINE_NAME = B.APR_LINE_NAME&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.APR_LINE_NAME = @apr_line_name&#xD;&#xA; GROUP BY A.APR_LINE_NAME">
