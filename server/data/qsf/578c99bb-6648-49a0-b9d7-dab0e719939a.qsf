      <F _S="48" N="User">
        <SG _S="51" N="HasEquipmentType">
          <QY P="MsSql" Q="SELECT TYPE&#xD;&#xA;  FROM QTMSEQPTYP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE     = @type">
