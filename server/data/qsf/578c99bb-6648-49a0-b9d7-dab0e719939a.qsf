            <QP N="active" />
            <QP N="status" />
            <QP N="apr_seq" />
            <QP N="delete_flag" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="4564" N="InsertTestProgramVersionFile">
          <QY P="MsSql" Q="INSERT INTO QTMSPGMFIL(&#xD;&#xA;   FACTORY,&#xD;&#xA;   TYPE,&#xD;&#xA;   PGM_ID,&#xD;&#xA;   PGM_VER,&#xD;&#xA;   FILE_NAME,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @type,&#xD;&#xA;   @pgm_id,&#xD;&#xA;   @pgm_ver,&#xD;&#xA;   @file_name,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="type" />
            <QP N="pgm_id" />
            <QP N="pgm_ver" />
            <QP N="file_name" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="2510" N="Command">
      <F _S="2511" N="ApprovalReqWizard">
        <SG _S="2512" N="ListEquipmentType">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;	TYPE, &#xD;&#xA;	TYPE_DESC&#xD;&#xA;  FROM QTMSEQPTYP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY TYPE">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="2513" N="ListEquipment">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;	EQP_NAME, &#xD;&#xA;	EQP_DESC&#xD;&#xA;  FROM QTMSEQPDEF&#xD;&#xA; WHERE FACTORY     = @factory &#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY EQP_NAME">
            <QP N="factory" />
            <QP N="type" />
          </QY>
        </SG>
        <SG _S="2514" N="ListMasterRecipe">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;	RCP_ID, &#xD;&#xA;	RCP_DESC&#xD;&#xA;  FROM QTMSMASRCP&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY RCP_ID">
            <QP N="factory" />
            <QP N="type" />
          </QY>
        </SG>
        <SG _S="2913" N="SearchListMasterRecipe">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;	RCP_ID, &#xD;&#xA;	RCP_DESC&#xD;&#xA;  FROM QTMSMASRCP&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA;   AND RCP_ID LIKE @rcp_id&#xD;&#xA; ORDER BY RCP_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
          </QY>
        </SG>
        <SG _S="2515" N="ListEquipmentRecipe">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;	RCP_ID, &#xD;&#xA;	RCP_DESC&#xD;&#xA;  FROM QTMSEQPRCP&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND EQP_NAME    = @eqp_name&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY RCP_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="2914" N="SearchListEquipmentRecipe">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;	RCP_ID, &#xD;&#xA;	RCP_DESC&#xD;&#xA;  FROM QTMSEQPRCP&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND EQP_NAME    = @eqp_name&#xD;&#xA;   AND RCP_ID LIKE @rcp_id&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY RCP_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
          </QY>
        </SG>
        <SG _S="2516" N="ListMasterRecipeVer">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;	RCP_VER, &#xD;&#xA;	RCP_VER_DESC&#xD;&#xA;  FROM QTMSMASRVR&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE    = @type&#xD;&#xA;   AND RCP_ID  = @rcp_id&#xD;&#xA;   AND RCP_VER_STATUS = @rcp_ver_status&#xD;&#xA; ORDER BY RCP_VER DESC">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="rcp_ver_status" />
          </QY>
        </SG>
        <SG _S="2517" N="ListEquipmentRecipeVer">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;	RCP_VER, &#xD;&#xA;	RCP_VER_DESC&#xD;&#xA;  FROM QTMSEQPRVR&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TYPE     = @type&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND RCP_ID   = @rcp_id&#xD;&#xA;   AND RCP_VER_STATUS = @rcp_ver_status   &#xD;&#xA; ORDER BY RCP_VER DESC">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="rcp_ver_status" />
          </QY>
        </SG>
      </F>
      <F _S="2547" N="ApprovalWizard">
        <SG _S="2550" N="ListApprovalRequest">
          <QY P="MsSql" Q="SELECT&#xD;&#xA;	TYPE,&#xD;&#xA;	RCP_MEMBER,&#xD;&#xA;	EQP_NAME,&#xD;&#xA;	RCP_ID,&#xD;&#xA;	RCP_VER,&#xD;&#xA;	APQ_COMMENT&#xD;&#xA;FROM QTMSRCPAPQ&#xD;&#xA;WHERE FACTORY = @factory&#xD;&#xA;  AND RCP_MEMBER = @rcp_member&#xD;&#xA;ORDER BY TYPE, RCP_ID, RCP_VER">
            <QP N="factory" />
            <QP N="rcp_member" />
          </QY>
        </SG>
      </F>
      <F _S="2616" N="HoldWizard">
        <SG _S="2904" N="ListEquipmentType">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;	TYPE, &#xD;&#xA;	TYPE_DESC&#xD;&#xA;  FROM QTMSEQPTYP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY TYPE">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3856" N="ListEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME, EQP_DESC&#xD;&#xA;  FROM QTMSEQPDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE    = @type&#xD;&#xA; ORDER BY EQP_NAME">
            <QP N="factory" />
            <QP N="type" />
          </QY>
        </SG>
        <SG _S="2618" N="ListMasterRecipe">
          <QY P="MsSql" Q="SELECT RCP_ID, RCP_DESC, RCP_ACTIVE&#xD;&#xA;  FROM QTMSMASRCP&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND TYPE         = @type&#xD;&#xA;   AND RCP_HOLD     = @rcp_hold&#xD;&#xA;   AND DELETE_FLAG &lt;&gt; 'Y'&#xD;&#xA; ORDER BY RCP_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_hold" />
          </QY>
        </SG>
        <SG _S="2619" N="ListEquipmentRecipe">
          <QY P="MsSql" Q="SELECT RCP_ID, RCP_DESC, RCP_ACTIVE&#xD;&#xA;  FROM QTMSEQPRCP&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND TYPE         = @type&#xD;&#xA;   AND EQP_NAME     = @eqp_name&#xD;&#xA;   AND RCP_HOLD     = @rcp_hold&#xD;&#xA;   AND DELETE_FLAG &lt;&gt; 'Y'&#xD;&#xA; ORDER BY RCP_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_hold" />
          </QY>
        </SG>
      </F>
      <F _S="2632" N="ReleaseWizard">
        <SG _S="2905" N="ListEquipmentType">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;	TYPE, &#xD;&#xA;	TYPE_DESC&#xD;&#xA;  FROM QTMSEQPTYP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY TYPE">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3857" N="ListEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME, EQP_DESC&#xD;&#xA;  FROM QTMSEQPDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE    = @type&#xD;&#xA; ORDER BY EQP_NAME">
            <QP N="factory" />
            <QP N="type" />
          </QY>
        </SG>
        <SG _S="2634" N="ListMasterRecipe">
          <QY P="MsSql" Q="SELECT RCP_ID, RCP_DESC, RCP_ACTIVE&#xD;&#xA;  FROM QTMSMASRCP&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND TYPE         = @type&#xD;&#xA;   AND RCP_HOLD     = @rcp_hold&#xD;&#xA;   AND DELETE_FLAG &lt;&gt; 'Y'&#xD;&#xA; ORDER BY RCP_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_hold" />
          </QY>
        </SG>
        <SG _S="2635" N="ListEquipmentRecipe">
          <QY P="MsSql" Q="SELECT RCP_ID, RCP_DESC, RCP_ACTIVE&#xD;&#xA;  FROM QTMSEQPRCP&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND TYPE         = @type&#xD;&#xA;   AND EQP_NAME     = @eqp_name&#xD;&#xA;   AND RCP_HOLD     = @rcp_hold&#xD;&#xA;   AND DELETE_FLAG &lt;&gt; 'Y'&#xD;&#xA; ORDER BY RCP_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_hold" />
          </QY>
        </SG>
