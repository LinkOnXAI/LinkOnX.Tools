            <QP N="eqp_name" />
            <QP N="last_hist_seq" />
            <QP N="event_id" />
            <QP N="rcp_result" />
            <QP N="rcp_reason" />
            <QP N="tran_user_id" />
            <QP N="tran_comment" />
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
