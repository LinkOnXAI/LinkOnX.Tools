            <QP N="type" />
          </QY>
        </SG>
        <SG _S="55" N="InsertUser">
          <QY P="MsSql" Q="INSERT INTO QTMSUSRDEF (&#xD;&#xA;   FACTORY,&#xD;&#xA;   TYPE,&#xD;&#xA;   USER_ID,&#xD;&#xA;   AUT_ADMIN,&#xD;&#xA;   AUT_RELATION,&#xD;&#xA;   AUT_REVISION,&#xD;&#xA;   AUT_APPROVAL_REQ,&#xD;&#xA;   AUT_APPROVAL,&#xD;&#xA;   AUT_HOLD,&#xD;&#xA;   AUT_RELEASE,&#xD;&#xA;   AUT_UPLOAD,&#xD;&#xA;   AUT_DOWNLOAD,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @type,&#xD;&#xA;   @user_id,&#xD;&#xA;   @aut_admin,&#xD;&#xA;   @aut_relation,&#xD;&#xA;   @aut_revision,&#xD;&#xA;   @aut_approval_req,&#xD;&#xA;   @aut_approval,&#xD;&#xA;   @aut_hold,&#xD;&#xA;   @aut_release,&#xD;&#xA;   @aut_upload,&#xD;&#xA;   @aut_download,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="type" />
