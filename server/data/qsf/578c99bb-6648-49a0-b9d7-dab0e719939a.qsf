      <F _S="2689" N="RecipeDownload">
        <SG _S="3882" N="HasEquipmentType">
          <QY P="MsSql" Q="SELECT TYPE, RECIPE_TYPE, TRAN_TIMEOUT&#xD;&#xA;  FROM QTMSEQPTYP&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type">
