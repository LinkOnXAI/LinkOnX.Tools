            <QP N="type" />
          </QY>
        </SG>
        <SG _S="52" N="ListEquipmentType">
          <QY P="MsSql" Q="SELECT A.TYPE, B.TYPE_DESC&#xD;&#xA;  FROM QTMSEQPTYP A&#xD;&#xA;  LEFT JOIN QRASEQPTYP B&#xD;&#xA;    ON A.FACTORY = B.FACTORY&#xD;&#xA;   AND A.TYPE = B.TYPE&#xD;&#xA; WHERE A.FACTORY = @factory&#xD;&#xA; ORDER BY A.TYPE">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="2194" N="ListUser">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;	A.USER_ID, &#xD;&#xA;	B.USER_NAME,&#xD;&#xA;       A.AUT_ADMIN,&#xD;&#xA;       A.AUT_RELATION, &#xD;&#xA;       A.AUT_REVISION, &#xD;&#xA;       A.AUT_APPROVAL_REQ, &#xD;&#xA;       A.AUT_APPROVAL,&#xD;&#xA;	A.AUT_HOLD, &#xD;&#xA;	A.AUT_RELEASE, &#xD;&#xA;	A.AUT_UPLOAD, &#xD;&#xA;	A.AUT_DOWNLOAD&#xD;&#xA;  FROM QTMSUSRDEF A&#xD;&#xA;  LEFT JOIN QSECUSRDEF B&#xD;&#xA;    ON A.FACTORY  = B.FACTORY&#xD;&#xA;   AND A.USER_ID  = B.USER_ID&#xD;&#xA; WHERE A.FACTORY  = @factory&#xD;&#xA;   AND A.TYPE     = @type&#xD;&#xA; ORDER BY A.USER_ID">
            <QP N="factory" />
            <QP N="type" />
          </QY>
        </SG>
        <SG _S="54" N="DeleteUser">
          <QY P="MsSql" Q="DELETE &#xD;&#xA;  FROM QTMSUSRDEF&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TYPE     = @type">
