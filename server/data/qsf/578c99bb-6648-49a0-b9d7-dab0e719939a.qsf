      <F _S="3763" N="ApprovalPendingClose">
        <SG _S="3764" N="HasApprovalItem">
          <QY P="MsSql" Q="SELECT APR_SEQ, APR_TYPE, APQ_TIME, APQ_USER_ID,&#xD;&#xA;	   APR_LINE_NAME, APR_CURR_STEP, APR_LAST_STEP, STATUS,&#xD;&#xA;	   APR_TIME, APR_USER_ID&#xD;&#xA;  FROM QTMSAPRITM&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND APR_SEQ  = @apr_seq&#xD;&#xA;   AND APR_TYPE = @apr_type">
            <QP N="factory" />
            <QP N="apr_seq" />
            <QP N="apr_type" />
          </QY>
        </SG>
        <SG _S="3765" N="HasMasterRecipeVersion">
          <QY P="MsSql" Q="SELECT TYPE, RCP_ID, RCP_VER, RCP_VER_STATUS&#xD;&#xA;  FROM QTMSMASRVR&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND APR_SEQ = @apr_seq&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="apr_seq" />
          </QY>
        </SG>
        <SG _S="3766" N="HasMasterParameterVersion">
          <QY P="MsSql" Q="SELECT TYPE, RCP_ID, SPEC_VER, STATUS&#xD;&#xA;  FROM QTMSMASSVR&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND APR_SEQ = @apr_seq&#xD;&#xA;   AND DELETE_FLAG = 'N'">
