          <QY P="MsSql" Q="SELECT SERVER_MSG_PATH  &#xD;&#xA;  FROM QTMSEQPRFL&#xD;&#xA; WHERE FACTORY 	= @factory&#xD;&#xA; AND TYPE 		= @type&#xD;&#xA; AND EQP_NAME	= @eqpName&#xD;&#xA; AND RCP_ID     = @recipeId&#xD;&#xA; AND RCP_VER    = @rcp_ver">
