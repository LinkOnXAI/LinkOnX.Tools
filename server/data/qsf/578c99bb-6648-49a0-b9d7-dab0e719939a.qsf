      <F _S="2594" N="MasterParameterSelector">
        <SG _S="2595" N="ListParameter">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;	A.RCP_ID,&#xD;&#xA;	A.RCP_VER, &#xD;&#xA;	A.PARA_ID, &#xD;&#xA;	B.PARA_DESC,&#xD;&#xA;	B.PARA_CHAR_ID,&#xD;&#xA;	B.PARA_GROUP,&#xD;&#xA;	B.PARA_CAT_1,&#xD;&#xA;	B.PARA_CAT_2,&#xD;&#xA;	B.PARA_CAT_3,&#xD;&#xA;	B.PARA_CAT_4,&#xD;&#xA;	B.PARA_CAT_5,&#xD;&#xA;	B.PARA_FORMAT,&#xD;&#xA;	B.PARA_DECIMAL_POINT,&#xD;&#xA;	B.PARA_UNIT,&#xD;&#xA;	A.PARA_VALUE, &#xD;&#xA;	A.PARA_VALIDATION,&#xD;&#xA;	A.PARA_VALIDATION_RULE,&#xD;&#xA;	A.PARA_TARGET_VALUE,&#xD;&#xA;	A.PARA_USL, &#xD;&#xA;	A.PARA_UCL, &#xD;&#xA;	A.PARA_LCL, &#xD;&#xA;	A.PARA_LSL&#xD;&#xA;  FROM QTMSMASRVP A&#xD;&#xA;  LEFT JOIN QTMSPARDEF B&#xD;&#xA;    ON A.FACTORY = B.FACTORY&#xD;&#xA;   AND A.TYPE = B.TYPE&#xD;&#xA;   AND A.PARA_ID = B.PARA_ID&#xD;&#xA; WHERE A.FACTORY = @factory&#xD;&#xA;   AND A.TYPE    = @type&#xD;&#xA;   AND A.RCP_ID  = @rcp_id&#xD;&#xA;   AND A.RCP_VER = @rcp_ver">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="rcp_ver" />
          </QY>
        </SG>
      </F>
      <F _S="4154" N="MasterParameterVersionSelector">
