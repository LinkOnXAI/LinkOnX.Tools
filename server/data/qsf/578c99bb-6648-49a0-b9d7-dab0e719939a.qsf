            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="2738" N="UpdateEquipmentType">
          <QY P="MsSql" Q="UPDATE QTMSEQPTYP SET&#xD;&#xA;	TYPE_DESC          = @type_desc,&#xD;&#xA;    UPDATE_USER_ID     = @update_user_id,&#xD;&#xA;    UPDATE_TIME        = @update_time&#xD;&#xA; WHERE FACTORY         = @factory&#xD;&#xA;   AND TYPE            = @type">
