      <F _S="2852" N="ItemCodeSelector">
        <SG _S="2853" N="ListSpg">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;	KEY_1 AS SPG_CODE, &#xD;&#xA;	DATA_1 AS SPG_NAME&#xD;&#xA;  FROM MES.LSISDB.dbo.MGCMTBLDAT &#xD;&#xA; WHERE FACTORY    = @factory &#xD;&#xA;   AND TABLE_NAME = 'LS_ITEM_SPG'">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="2854" N="ListItemCode">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;	A.ITEM_CODE, &#xD;&#xA;	B.MAT_DESC AS ITEM_NAME, &#xD;&#xA;	A.DELETE_FLAG&#xD;&#xA;  FROM QTMSITMDEF A&#xD;&#xA;  LEFT JOIN MES.LSISDB.dbo.MWIPMATDEF B&#xD;&#xA;    ON A.FACTORY      = B.FACTORY&#xD;&#xA;   AND A.SPG_CODE     = B.MFG_DEVISION&#xD;&#xA;   AND A.ITEM_CODE    = B.MAT_ID&#xD;&#xA;   AND B.MAT_TYPE     = 'FG by Make'&#xD;&#xA;   AND B.DELETE_FLAG &lt;&gt; 'Y'&#xD;&#xA; WHERE A.FACTORY      = @factory&#xD;&#xA;   AND A.SPG_CODE     = @spg_code">
            <QP N="factory" />
            <QP N="spg_code" />
          </QY>
        </SG>
        <SG _S="2944" N="SearchListItemCode">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;	A.ITEM_CODE, &#xD;&#xA;	B.MAT_DESC AS ITEM_NAME, &#xD;&#xA;	A.DELETE_FLAG&#xD;&#xA;  FROM QTMSITMDEF A&#xD;&#xA;  LEFT JOIN MES.LSISDB.dbo.MWIPMATDEF B&#xD;&#xA;    ON A.FACTORY      = B.FACTORY&#xD;&#xA;   AND A.SPG_CODE     = B.MFG_DEVISION&#xD;&#xA;   AND A.ITEM_CODE    = B.MAT_ID&#xD;&#xA;   AND B.MAT_TYPE     = 'FG by Make'&#xD;&#xA;   AND B.DELETE_FLAG &lt;&gt; 'Y'&#xD;&#xA; WHERE A.FACTORY      = @factory&#xD;&#xA;   AND A.SPG_CODE     = @spg_code&#xD;&#xA;   AND A.ITEM_CODE LIKE @item_code">
            <QP N="factory" />
            <QP N="spg_code" />
            <QP N="item_code" />
          </QY>
        </SG>
      </F>
      <F _S="2889" N="SpgCodeSelector">
        <SG _S="2890" N="ListSpg">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;	KEY_1 AS SPG_CODE, &#xD;&#xA;	DATA_1 AS SPG_NAME&#xD;&#xA;  FROM MES.LSISDB.dbo.MGCMTBLDAT &#xD;&#xA; WHERE FACTORY    = @factory &#xD;&#xA;   AND TABLE_NAME = 'LS_ITEM_SPG'">
            <QP N="factory" />
