    </M>
    <M _S="21" N="EapChannelDistributer">
      <F _S="22" N="ChannelDistributer">
        <SG _S="23" N="ListEap">
          <QY P="MsSql" Q="SELECT FACTORY, EAP, STATUS&#xD;&#xA;  FROM QRASEAPDEF&#xD;&#xA; WHERE UP_DOWN = 'Up'&#xD;&#xA;   AND DELETE_FLAG = 'N'" />
        </SG>
        <SG _S="24" N="UpdateEap">
          <QY P="MsSql" Q="UPDATE QRASEAPDEF SET&#xD;&#xA;  LAST_HIST_SEQ    = LAST_HIST_SEQ + 1,&#xD;&#xA;  LAST_EVENT_ID    = @last_event_id,&#xD;&#xA;  LAST_EVENT_TIME  = @last_event_time,&#xD;&#xA;  UPDATE_USER_ID   = @update_user_id,&#xD;&#xA;  UPDATE_TIME      = @update_time&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EAP     = @eap">
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="25" N="InsertEapHistory">
          <QY P="MsSql" Q="INSERT INTO QRASEAPHIS (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EAP,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   EVENT_ID,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   SERVER,&#xD;&#xA;   STEP,&#xD;&#xA;   UP_DOWN,&#xD;&#xA;   STATUS,&#xD;&#xA;   NEED_ACTION,&#xD;&#xA;   NEXT_NEED_ACTION,&#xD;&#xA;   SET_PACKAGE,&#xD;&#xA;   SET_PKG_VER,&#xD;&#xA;   REL_PACKAGE,&#xD;&#xA;   REL_PKG_VER,&#xD;&#xA;   APL_PACKAGE,&#xD;&#xA;   APL_PKG_VER,   &#xD;&#xA;   SET_MODEL,&#xD;&#xA;   SET_MDL_VER,&#xD;&#xA;   REL_MODEL,&#xD;&#xA;   REL_MDL_VER,&#xD;&#xA;   APL_MODEL,&#xD;&#xA;   APL_MDL_VER,   &#xD;&#xA;   SET_USED_COM,&#xD;&#xA;   SET_COMPONENT,&#xD;&#xA;   SET_COM_VER,   &#xD;&#xA;   REL_USED_COM,&#xD;&#xA;   REL_COMPONENT,&#xD;&#xA;   REL_COM_VER,   &#xD;&#xA;   APL_USED_COM,&#xD;&#xA;   APL_COMPONENT,&#xD;&#xA;   APL_COM_VER,   &#xD;&#xA;   EVT_H_1,&#xD;&#xA;   EVT_D_1,   &#xD;&#xA;   EVT_H_2,&#xD;&#xA;   EVT_D_2,&#xD;&#xA;   EVT_H_3,&#xD;&#xA;   EVT_D_3,&#xD;&#xA;   EVT_H_4,&#xD;&#xA;   EVT_D_4,&#xD;&#xA;   EVT_H_5,&#xD;&#xA;   EVT_D_5,&#xD;&#xA;   EVT_H_6,&#xD;&#xA;   EVT_D_6,&#xD;&#xA;   EVT_H_7,&#xD;&#xA;   EVT_D_7,&#xD;&#xA;   EVT_H_8,&#xD;&#xA;   EVT_D_8,&#xD;&#xA;   EVT_H_9,&#xD;&#xA;   EVT_D_9,&#xD;&#xA;   EVT_H_10,&#xD;&#xA;   EVT_D_10,&#xD;&#xA;   EVT_H_11,&#xD;&#xA;   EVT_D_11,   &#xD;&#xA;   EVT_H_12,&#xD;&#xA;   EVT_D_12,&#xD;&#xA;   EVT_H_13,&#xD;&#xA;   EVT_D_13,&#xD;&#xA;   EVT_H_14,&#xD;&#xA;   EVT_D_14,&#xD;&#xA;   EVT_H_15,&#xD;&#xA;   EVT_D_15,&#xD;&#xA;   EVT_H_16,&#xD;&#xA;   EVT_D_16,&#xD;&#xA;   EVT_H_17,&#xD;&#xA;   EVT_D_17,&#xD;&#xA;   EVT_H_18,&#xD;&#xA;   EVT_D_18,&#xD;&#xA;   EVT_H_19,&#xD;&#xA;   EVT_D_19,&#xD;&#xA;   EVT_H_20,&#xD;&#xA;   EVT_D_20,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT      &#xD;&#xA;) &#xD;&#xA;SELECT &#xD;&#xA;   A.FACTORY,&#xD;&#xA;   A.EAP,&#xD;&#xA;   A.LAST_HIST_SEQ,&#xD;&#xA;   @event_id,&#xD;&#xA;   @tran_time,&#xD;&#xA;   A.SERVER,&#xD;&#xA;   A.STEP,&#xD;&#xA;   A.UP_DOWN,&#xD;&#xA;   A.STATUS,&#xD;&#xA;   A.NEED_ACTION,&#xD;&#xA;   A.NEXT_NEED_ACTION,   &#xD;&#xA;   ISNULL(B.PACKAGE, ' '),&#xD;&#xA;   ISNULL(B.PKG_VER, 0),&#xD;&#xA;   ISNULL(C.PACKAGE, ' '),&#xD;&#xA;   ISNULL(C.PKG_VER, 0),&#xD;&#xA;   ISNULL(D.PACKAGE, ' '),&#xD;&#xA;   ISNULL(D.PKG_VER, 0),   &#xD;&#xA;   ISNULL(B.MODEL, ' '),&#xD;&#xA;   ISNULL(B.MDL_VER, 0),&#xD;&#xA;   ISNULL(C.MODEL, ' '),&#xD;&#xA;   ISNULL(C.MDL_VER, 0),&#xD;&#xA;   ISNULL(D.MODEL, ' '),&#xD;&#xA;   ISNULL(D.MDL_VER, 0),   &#xD;&#xA;   ISNULL(B.USED_COM, 'No'),&#xD;&#xA;   ISNULL(B.COMPONENT, ' '),&#xD;&#xA;   ISNULL(B.COM_VER, 0),&#xD;&#xA;   ISNULL(C.USED_COM, 'No'),&#xD;&#xA;   ISNULL(C.COMPONENT, ' '),&#xD;&#xA;   ISNULL(C.COM_VER, 0),&#xD;&#xA;   ISNULL(D.USED_COM, 'No'),&#xD;&#xA;   ISNULL(D.COMPONENT, ' '),&#xD;&#xA;   ISNULL(D.COM_VER, 0),&#xD;&#xA;   @evt_h_1,&#xD;&#xA;   @evt_d_1,   &#xD;&#xA;   @evt_h_2,&#xD;&#xA;   @evt_d_2,&#xD;&#xA;   @evt_h_3,&#xD;&#xA;   @evt_d_3,&#xD;&#xA;   @evt_h_4,&#xD;&#xA;   @evt_d_4,&#xD;&#xA;   @evt_h_5,&#xD;&#xA;   @evt_d_5,&#xD;&#xA;   @evt_h_6,&#xD;&#xA;   @evt_d_6,&#xD;&#xA;   @evt_h_7,&#xD;&#xA;   @evt_d_7,&#xD;&#xA;   @evt_h_8,&#xD;&#xA;   @evt_d_8,&#xD;&#xA;   @evt_h_9,&#xD;&#xA;   @evt_d_9,&#xD;&#xA;   @evt_h_10,&#xD;&#xA;   @evt_d_10,&#xD;&#xA;   @evt_h_11,&#xD;&#xA;   @evt_d_11,   &#xD;&#xA;   @evt_h_12,&#xD;&#xA;   @evt_d_12,&#xD;&#xA;   @evt_h_13,&#xD;&#xA;   @evt_d_13,&#xD;&#xA;   @evt_h_14,&#xD;&#xA;   @evt_d_14,&#xD;&#xA;   @evt_h_15,&#xD;&#xA;   @evt_d_15,&#xD;&#xA;   @evt_h_16,&#xD;&#xA;   @evt_d_16,&#xD;&#xA;   @evt_h_17,&#xD;&#xA;   @evt_d_17,&#xD;&#xA;   @evt_h_18,&#xD;&#xA;   @evt_d_18,&#xD;&#xA;   @evt_h_19,&#xD;&#xA;   @evt_d_19,&#xD;&#xA;   @evt_h_20,&#xD;&#xA;   @evt_d_20,&#xD;&#xA;   @tran_user_id,&#xD;&#xA;   @tran_comment&#xD;&#xA;  FROM QRASEAPDEF A  &#xD;&#xA;  LEFT JOIN QRASEAPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EAP           = B.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QRASEAPATR C&#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP           = C.EAP&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QRASEAPATR D&#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.EAP           = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.EAP         = @eap">
            <QP N="event_id" />
            <QP N="tran_time" />
            <QP N="evt_h_1" />
            <QP N="evt_d_1" />
            <QP N="evt_h_2" />
            <QP N="evt_d_2" />
            <QP N="evt_h_3" />
            <QP N="evt_d_3" />
            <QP N="evt_h_4" />
            <QP N="evt_d_4" />
            <QP N="evt_h_5" />
            <QP N="evt_d_5" />
            <QP N="evt_h_6" />
            <QP N="evt_d_6" />
            <QP N="evt_h_7" />
            <QP N="evt_d_7" />
            <QP N="evt_h_8" />
            <QP N="evt_d_8" />
            <QP N="evt_h_9" />
            <QP N="evt_d_9" />
            <QP N="evt_h_10" />
            <QP N="evt_d_10" />
            <QP N="evt_h_11" />
            <QP N="evt_d_11" />
            <QP N="evt_h_12" />
            <QP N="evt_d_12" />
            <QP N="evt_h_13" />
            <QP N="evt_d_13" />
            <QP N="evt_h_14" />
            <QP N="evt_d_14" />
            <QP N="evt_h_15" />
            <QP N="evt_d_15" />
            <QP N="evt_h_16" />
            <QP N="evt_d_16" />
            <QP N="evt_h_17" />
            <QP N="evt_d_17" />
            <QP N="evt_h_18" />
            <QP N="evt_d_18" />
            <QP N="evt_h_19" />
            <QP N="evt_d_19" />
            <QP N="evt_h_20" />
            <QP N="evt_d_20" />
            <QP N="tran_user_id" />
            <QP N="tran_comment" />
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="26" N="DataPurge">
      <F _S="27" N="DataPurge">
        <SG _S="28" N="SearcFactory">
          <QY P="MsSql" Q="SELECT FACTORY&#xD;&#xA; FROM QSYSFACDEF" />
        </SG>
        <SG _S="3445" N="DeleteRecipeHistory" UMG="No">
          <QY P="MsSql" Q="WITH TMP_DELETE AS &#xD;&#xA;(&#xD;&#xA;SELECT TRAN_TIME, ROW_NUMBER() OVER(ORDER BY TRAN_TIME) AS ROWNUM &#xD;&#xA;  FROM QTMSRCPHIS&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND TRAN_TIME &lt; @tran_time&#xD;&#xA;)&#xD;&#xA;DELETE FROM TMP_DELETE WHERE ROWNUM &lt;= @delete_count">
            <QP N="factory" />
            <QP N="tran_time" />
            <QP N="delete_count" />
          </QY>
        </SG>
        <SG _S="4356" N="DeleteRecipeDownloadHistory">
          <QY P="MsSql" Q="WITH TMP_DELETE AS &#xD;&#xA;(&#xD;&#xA;SELECT TRAN_TIME, ROW_NUMBER() OVER(ORDER BY TRAN_TIME) AS ROWNUM &#xD;&#xA;  FROM QTMSRCPDWH&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND TRAN_TIME &lt; @tran_time&#xD;&#xA;)&#xD;&#xA;DELETE FROM TMP_DELETE WHERE ROWNUM &lt;= @delete_count">
            <QP N="factory" />
            <QP N="tran_time" />
            <QP N="delete_count" />
          </QY>
        </SG>
        <SG _S="35" N="DeleteRecipeAlarmHistory" UMG="No">
          <QY P="MsSql" Q="WITH TMP_DELETE AS (&#xD;&#xA;	SELECT TRAN_TIME, ROW_NUMBER() OVER(ORDER BY TRAN_TIME) AS ROWNUM &#xD;&#xA;		FROM QTMSRCPALM&#xD;&#xA;		WHERE FACTORY = @factory&#xD;&#xA;		AND TRAN_TIME &lt; @tran_time&#xD;&#xA;)&#xD;&#xA;DELETE FROM TMP_DELETE WHERE ROWNUM &lt;= @delete_count">
            <QP N="factory" />
            <QP N="tran_time" />
            <QP N="delete_count" />
          </QY>
        </SG>
        <SG _S="4352" N="DeleteApprovalResult">
          <QY P="MsSql" Q="DELETE&#xD;&#xA;  FROM QTMSAPRRST&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND APR_SEQ = @apr_seq">
            <QP N="factory" />
            <QP N="apr_seq" />
          </QY>
        </SG>
        <SG _S="4355" N="DeleteApprovalFile">
          <QY P="MsSql" Q="DELETE&#xD;&#xA;  FROM QTMSAPRFIL&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND APR_SEQ = @apr_seq">
            <QP N="factory" />
            <QP N="apr_seq" />
          </QY>
        </SG>
        <SG _S="4353" N="DeleteApprovalHistory">
          <QY P="MsSql" Q="DELETE&#xD;&#xA;  FROM QTMSAPRHIS&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND APR_SEQ = @apr_seq">
            <QP N="factory" />
            <QP N="apr_seq" />
          </QY>
        </SG>
        <SG _S="927" N="DeleteRecipeValidationHistory" UMG="No">
          <QY P="MsSql" Q="DELETE&#xD;&#xA;  FROM QTMSRCPVAH&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TYPE     = @type&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND HIST_SEQ = @hist_seq">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="hist_seq" />
          </QY>
        </SG>
        <SG _S="4359" N="DeleteRecipeValidationHistoryFile">
          <QY P="MsSql" Q="DELETE&#xD;&#xA;  FROM QTMSRCPVFL&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TYPE     = @type&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND HIST_SEQ = @hist_seq">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="hist_seq" />
          </QY>
        </SG>
        <SG _S="4358" N="DeleteRecipeValidationHistoryParameter">
          <QY P="MsSql" Q="DELETE&#xD;&#xA;  FROM QTMSRCPPVH&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TYPE     = @type&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND HIST_SEQ = @hist_seq">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="hist_seq" />
          </QY>
        </SG>
        <SG _S="3444" N="DeleteEquipmentHistory" UMG="No">
          <QY P="MsSql" Q="WITH TMP_DELETE AS (&#xD;&#xA;	SELECT TRAN_TIME, ROW_NUMBER() OVER(ORDER BY TRAN_TIME) AS ROWNUM &#xD;&#xA;		FROM QTMSEQPHIS&#xD;&#xA;		WHERE FACTORY = @factory&#xD;&#xA;		AND TRAN_TIME &lt; @tran_time&#xD;&#xA;)&#xD;&#xA;DELETE FROM TMP_DELETE WHERE ROWNUM &lt;= @delete_count">
            <QP N="factory" />
            <QP N="tran_time" />
            <QP N="delete_count" />
          </QY>
        </SG>
        <SG _S="4351" N="ListApprovalResult">
          <QY P="MsSql" Q="WITH T1 AS&#xD;&#xA;(&#xD;&#xA;SELECT DISTINCT(APR_SEQ) APR_SEQ&#xD;&#xA;  FROM QTMSAPRRST&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND TRAN_TIME &lt; @tran_time&#xD;&#xA;)&#xD;&#xA;SELECT APR_SEQ&#xD;&#xA;  FROM&#xD;&#xA;  (&#xD;&#xA;  SELECT APR_SEQ, ROW_NUMBER() OVER(ORDER BY APR_SEQ) AS ROWNUM &#xD;&#xA;    FROM T1&#xD;&#xA;  ) T2&#xD;&#xA; WHERE ROWNUM &lt;= @delete_count">
            <QP N="factory" />
            <QP N="tran_time" />
            <QP N="delete_count" />
          </QY>
        </SG>
        <SG _S="4357" N="ListRecipeValidationHistory">
          <QY P="MsSql" Q="WITH T1 AS&#xD;&#xA;(&#xD;&#xA;SELECT TYPE, EQP_NAME, RCP_ID, HIST_SEQ, ROW_NUMBER() OVER(ORDER BY TRAN_TIME) AS ROWNUM &#xD;&#xA;  FROM QTMSRCPVAH&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND TRAN_TIME &lt; @tran_time&#xD;&#xA;)&#xD;&#xA;SELECT TYPE, EQP_NAME, RCP_ID, HIST_SEQ&#xD;&#xA;  FROM T1&#xD;&#xA; WHERE ROWNUM &lt;= @delete_count">
            <QP N="factory" />
            <QP N="tran_time" />
            <QP N="delete_count" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="4185" N="DataPusher">
      <F _S="4186" N="ApprovalDataPush">
        <SG _S="4187" N="ListApprovalLineStepUser">
          <QY P="MsSql" Q="SELECT USER_ID&#xD;&#xA;  FROM QTMSAPLUSR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND APR_LINE_NAME = @apr_line_name&#xD;&#xA;   AND STEP          = @step">
            <QP N="factory" />
            <QP N="apr_line_name" />
            <QP N="step" />
          </QY>
        </SG>
      </F>
      <F _S="4229" N="RecipeValidationResultPush">
        <SG _S="4230" N="ListTypeOwner">
          <QY P="MsSql" Q="SELECT USER_ID&#xD;&#xA;  FROM QTMSTYPUSR&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE    = @type">
            <QP N="factory" />
            <QP N="type" />
          </QY>
        </SG>
        <SG _S="4248" N="ListSytemRoleUser">
          <QY P="MsSql" Q="SELECT USER_ID&#xD;&#xA;  FROM QTMSUSRROL&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND ROLE IN&#xD;&#xA;       (&#xD;&#xA;SELECT ROLE&#xD;&#xA;  FROM QTMSROLDEF&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND ALL_AUTHORITY = @all_authority&#xD;&#xA;       )">
            <QP N="factory" />
            <QP N="all_authority" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="2915" N="MailSender">
      <F _S="4328" N="ApprovalMail">
        <SG _S="4330" N="ListApprover">
          <QY P="MsSql" Q="SELECT A.USER_ID, B.USER_NAME, B.EMAIL_ID&#xD;&#xA;  FROM QTMSAPLUSR A&#xD;&#xA;  LEFT JOIN QSECUSRDEF B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.USER_ID       = B.USER_ID&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.APR_LINE_NAME = @apr_line_name&#xD;&#xA;   AND A.STEP          = @step">
            <QP N="factory" />
            <QP N="apr_line_name" />
            <QP N="step" />
          </QY>
        </SG>
        <SG _S="4331" N="ListTypeOwner">
          <QY P="MsSql" Q="SELECT A.USER_ID, B.USER_NAME, B.EMAIL_ID&#xD;&#xA;  FROM (&#xD;&#xA;SELECT FACTORY, USER_ID&#xD;&#xA;  FROM QTMSTYPUSR&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE    = @type&#xD;&#xA;       ) A&#xD;&#xA;  LEFT JOIN QSECUSRDEF B&#xD;&#xA;    ON A.FACTORY = B.FACTORY&#xD;&#xA;   AND A.USER_ID = B.USER_ID&#xD;&#xA;  LEFT JOIN QTMSUSRROL C&#xD;&#xA;    ON A.FACTORY = C.FACTORY&#xD;&#xA;   AND A.USER_ID = C.USER_ID&#xD;&#xA; ORDER BY A.USER_ID">
            <QP N="factory" />
            <QP N="type" />
          </QY>
        </SG>
        <SG _S="4333" N="ListUser">
          <QY P="MsSql" Q="SELECT USER_ID, USER_NAME, EMAIL_ID&#xD;&#xA;  FROM QSECUSRDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="4378" N="RecipeValidationFailMail">
        <SG _S="4380" N="ListTypeOwner">
          <QY P="MsSql" Q="SELECT A.USER_ID, B.USER_NAME, B.EMAIL_ID&#xD;&#xA;  FROM (&#xD;&#xA;SELECT FACTORY, USER_ID&#xD;&#xA;  FROM QTMSTYPUSR&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE    = @type&#xD;&#xA;       ) A&#xD;&#xA;  LEFT JOIN QSECUSRDEF B&#xD;&#xA;    ON A.FACTORY = B.FACTORY&#xD;&#xA;   AND A.USER_ID = B.USER_ID&#xD;&#xA;  LEFT JOIN QTMSUSRROL C&#xD;&#xA;    ON A.FACTORY = C.FACTORY&#xD;&#xA;   AND A.USER_ID = C.USER_ID&#xD;&#xA; ORDER BY A.USER_ID">
            <QP N="factory" />
            <QP N="type" />
          </QY>
        </SG>
        <SG _S="4382" N="ListValidationParameter">
          <QY P="MsSql" Q="SELECT PARA_ID, PARA_DESC, PARA_GROUP, PARA_CAT_1, PARA_CAT_2, PARA_CAT_3, PARA_CAT_4, PARA_CAT_5, PARA_VALUE,&#xD;&#xA;       PARA_RESULT, PARA_REASON,&#xD;&#xA;       SPEC_MEMBER, SPEC_VER, PARA_VALIDATION_RULE, PARA_TARGET_VALUE, PARA_USL, PARA_UCL, PARA_LCL, PARA_LSL&#xD;&#xA;  FROM QTMSRCPPVH&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type &#xD;&#xA;   AND EQP_NAME    = @eqp_name&#xD;&#xA;   AND RCP_ID      = @rcp_id&#xD;&#xA;   AND HIST_SEQ    = @hist_seq&#xD;&#xA;   AND PARA_RESULT = @para_result&#xD;&#xA; ORDER BY PARA_GROUP, PARA_CAT_1, PARA_CAT_2, PARA_CAT_3, PARA_CAT_4, PARA_CAT_5, PARA_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="hist_seq" />
            <QP N="para_result" />
          </QY>
        </SG>
      </F>
      <F _S="4386" N="RecipeParameterChangeMail">
        <SG _S="4387" N="ListTypeOwner">
          <QY P="MsSql" Q="SELECT A.USER_ID, B.USER_NAME, B.EMAIL_ID&#xD;&#xA;  FROM (&#xD;&#xA;SELECT FACTORY, USER_ID&#xD;&#xA;  FROM QTMSTYPUSR&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE    = @type&#xD;&#xA;       ) A&#xD;&#xA;  LEFT JOIN QSECUSRDEF B&#xD;&#xA;    ON A.FACTORY = B.FACTORY&#xD;&#xA;   AND A.USER_ID = B.USER_ID&#xD;&#xA;  LEFT JOIN QTMSUSRROL C&#xD;&#xA;    ON A.FACTORY = C.FACTORY&#xD;&#xA;   AND A.USER_ID = C.USER_ID&#xD;&#xA; ORDER BY A.USER_ID">
            <QP N="factory" />
            <QP N="type" />
          </QY>
        </SG>
        <SG _S="4388" N="ListValidationParameter">
          <QY P="MsSql" Q="SELECT PARA_ID, PARA_DESC, PARA_GROUP, PARA_CAT_1, PARA_CAT_2, PARA_CAT_3, PARA_CAT_4, PARA_CAT_5, PARA_VALUE&#xD;&#xA;  FROM QTMSRCPPVH&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type &#xD;&#xA;   AND EQP_NAME    = @eqp_name&#xD;&#xA;   AND RCP_ID      = @rcp_id&#xD;&#xA;   AND HIST_SEQ    = @hist_seq&#xD;&#xA; ORDER BY PARA_GROUP, PARA_CAT_1, PARA_CAT_2, PARA_CAT_3, PARA_CAT_4, PARA_CAT_5, PARA_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="hist_seq" />
          </QY>
        </SG>
        <SG _S="4390" N="SearchCurrentEquipmentRecipeVersion">
          <QY P="MsSql" Q="SELECT RCP_VER, VALIDATION_HIST_SEQ, CREATE_TIME, CREATE_USER_ID&#xD;&#xA;  FROM QTMSEQPRVR&#xD;&#xA; WHERE FACTORY             = @factory&#xD;&#xA;   AND TYPE                = @type&#xD;&#xA;   AND EQP_NAME            = @eqp_name&#xD;&#xA;   AND RCP_ID              = @rcp_id&#xD;&#xA;   AND VALIDATION_HIST_SEQ = @validation_hist_seq">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="validation_hist_seq" />
          </QY>
        </SG>
        <SG _S="4391" N="SearchPreviousEquipmentRecipeVersion">
          <QY P="MsSql" Q="SELECT TOP 1 RCP_VER, VALIDATION_HIST_SEQ, CREATE_TIME, CREATE_USER_ID&#xD;&#xA;  FROM QTMSEQPRVR&#xD;&#xA; WHERE FACTORY             = @factory&#xD;&#xA;   AND TYPE                = @type&#xD;&#xA;   AND EQP_NAME            = @eqp_name&#xD;&#xA;   AND RCP_ID              = @rcp_id&#xD;&#xA;   AND VALIDATION_HIST_SEQ &lt; @validation_hist_seq&#xD;&#xA; ORDER BY RCP_VER DESC">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="validation_hist_seq" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="1621" N="SmsPusher">
      <F _S="1622" N="ApprovalSms">
        <SG _S="4368" N="ListApprover">
          <QY P="MsSql" Q="SELECT A.USER_ID, B.USER_NAME, B.PHONE_MOBILE&#xD;&#xA;  FROM QTMSAPLUSR A&#xD;&#xA;  LEFT JOIN QSECUSRDEF B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.USER_ID       = B.USER_ID&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.APR_LINE_NAME = @apr_line_name&#xD;&#xA;   AND A.STEP          = @step">
            <QP N="factory" />
            <QP N="apr_line_name" />
            <QP N="step" />
          </QY>
        </SG>
        <SG _S="4369" N="ListTypeOwner">
          <QY P="MsSql" Q="SELECT A.USER_ID, B.USER_NAME, B.PHONE_MOBILE&#xD;&#xA;  FROM (&#xD;&#xA;SELECT FACTORY, USER_ID&#xD;&#xA;  FROM QTMSTYPUSR&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE    = @type&#xD;&#xA;       ) A&#xD;&#xA;  LEFT JOIN QSECUSRDEF B&#xD;&#xA;    ON A.FACTORY = B.FACTORY&#xD;&#xA;   AND A.USER_ID = B.USER_ID&#xD;&#xA;  LEFT JOIN QTMSUSRROL C&#xD;&#xA;    ON A.FACTORY = C.FACTORY&#xD;&#xA;   AND A.USER_ID = C.USER_ID&#xD;&#xA; ORDER BY A.USER_ID">
            <QP N="factory" />
            <QP N="type" />
          </QY>
        </SG>
        <SG _S="4370" N="ListUser">
          <QY P="MsSql" Q="SELECT USER_ID, USER_NAME, PHONE_MOBILE&#xD;&#xA;  FROM QSECUSRDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="4372" N="SearchRmsSmsInfo">
          <QY P="MsSql" Q="SELECT DATA_1, DATA_2, DATA_3, DATA_4, DATA_5, DATA_6&#xD;&#xA;  FROM QGCMTBLDAT &#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND TABLE_NAME = @table_name&#xD;&#xA;   AND DATA_KEY   = @data_key">
            <QP N="factory" />
            <QP N="table_name" />
            <QP N="data_key" />
          </QY>
        </SG>
        <SG _S="4371" N="InsertSendSmsInfo">
          <QY P="MsSql" Q="INSERT INTO Send_Sms_Info (&#xD;&#xA; szSystemType, &#xD;&#xA; szDate, &#xD;&#xA; szTime, &#xD;&#xA; szCallPhone, &#xD;&#xA; szCallPhone1, &#xD;&#xA; szCallPhone2,&#xD;&#xA; szCallPhone3, &#xD;&#xA; szUserCode, &#xD;&#xA; szUserName, &#xD;&#xA; szReqPhone1, &#xD;&#xA; szReqPhone2, &#xD;&#xA; szReqPhone3,&#xD;&#xA; szCallMessage, &#xD;&#xA; szResult&#xD;&#xA;) VALUES (&#xD;&#xA; @systemType,&#xD;&#xA; @date,&#xD;&#xA; @time,&#xD;&#xA; @callPhone,&#xD;&#xA; @callPhone1,&#xD;&#xA; @callPhone2,&#xD;&#xA; @callPhone3,&#xD;&#xA; @userCode,&#xD;&#xA; @userName,&#xD;&#xA; @reqPhone1,&#xD;&#xA; @reqPhone2,&#xD;&#xA; @reqPhone3,&#xD;&#xA; @callMessage,&#xD;&#xA; @result&#xD;&#xA; )">
            <QP N="systemType" />
            <QP N="date" />
            <QP N="time" />
            <QP N="callPhone" />
            <QP N="callPhone1" />
            <QP N="callPhone2" />
            <QP N="callPhone3" />
            <QP N="userCode" />
            <QP N="userName" />
            <QP N="reqPhone1" />
            <QP N="reqPhone2" />
            <QP N="reqPhone3" />
            <QP N="callMessage" />
            <QP N="result" />
          </QY>
        </SG>
      </F>
    </M>
  </S>
</Q>