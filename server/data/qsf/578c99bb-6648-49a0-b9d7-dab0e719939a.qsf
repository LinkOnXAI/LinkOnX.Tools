            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="last_hist_seq" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
          </QY>
        </SG>
        <SG _S="4467" N="HasRecipeUploadWorkingItem">
          <QY P="MsSql" Q="SELECT RCP_ID, TRAN_TIME&#xD;&#xA;  FROM QTMSRCPUPT&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND EQP_NAME    = @eqp_name">
            <QP N="factory" />
