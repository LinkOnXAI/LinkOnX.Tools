      <F _S="2744" N="RecipeList" D=".">
        <SG _S="2745" N="SearchRecipeList">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;		FACTORY,&#xD;&#xA;		TYPE, &#xD;&#xA;		RCP_ID,		&#xD;&#xA;		'Equipment' AS MEMBER,&#xD;&#xA;		EQP_NAME ,&#xD;&#xA;		RCP_DESC, &#xD;&#xA;		RCP_ACTIVE,&#xD;&#xA;		ACTIVE_RCP_VER,&#xD;&#xA;		LAST_RCP_VER,&#xD;&#xA;		RCP_HOLD&#xD;&#xA;FROM 	&#xD;&#xA;		QTMSEQPRCP&#xD;&#xA;WHERE &#xD;&#xA;		FACTORY        = @factory&#xD;&#xA;     AND	TYPE 		= @type&#xD;&#xA;     AND 	RCP_ID		= ISNULL(@recipe, RCP_ID)    &#xD;&#xA;     AND   RCP_ACTIVE   = ISNULL(@active, RCP_ACTIVE)&#xD;&#xA;     AND 	RCP_HOLD	= @hold&#xD;&#xA;     AND   DELETE_FLAG = 'N'&#xD;&#xA;UNION ALL&#xD;&#xA;SELECT&#xD;&#xA;		FACTORY,&#xD;&#xA;		TYPE,  &#xD;&#xA;		RCP_ID,		 &#xD;&#xA;		 'Master' AS MEMBER,&#xD;&#xA;		 '' AS EQP_NAME ,&#xD;&#xA;		RCP_DESC, &#xD;&#xA;		RCP_ACTIVE,&#xD;&#xA;		ACTIVE_RCP_VER,&#xD;&#xA;		LAST_RCP_VER,&#xD;&#xA;		RCP_HOLD&#xD;&#xA;FROM&#xD;&#xA;		QTMSMASRCP &#xD;&#xA;WHERE&#xD;&#xA;		FACTORY		= @factory &#xD;&#xA;     AND 	TYPE 		= @type&#xD;&#xA;     AND 	RCP_ID		=ISNULL(@recipe, RCP_ID)&#xD;&#xA;     AND   RCP_ACTIVE   = ISNULL(@active, RCP_ACTIVE)&#xD;&#xA;     AND 	RCP_HOLD	= @hold&#xD;&#xA;     AND   DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="type" />
            <QP N="recipe" />
            <QP N="active" />
            <QP N="hold" />
          </QY>
        </SG>
        <SG _S="2749" N="SearchRecipeListByEquipment">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;		FACTORY,&#xD;&#xA;		TYPE, &#xD;&#xA;		RCP_ID,&#xD;&#xA;		'Equipment' AS MEMBER,&#xD;&#xA;		EQP_NAME ,&#xD;&#xA;		RCP_DESC, &#xD;&#xA;		RCP_ACTIVE,&#xD;&#xA;		ACTIVE_RCP_VER,&#xD;&#xA;		LAST_RCP_VER,&#xD;&#xA;		RCP_HOLD&#xD;&#xA;FROM 	&#xD;&#xA;		QTMSEQPRCP&#xD;&#xA;WHERE &#xD;&#xA;		FACTORY        = @factory &#xD;&#xA;     AND 	TYPE 		= @type &#xD;&#xA;     AND 	EQP_NAME 	= ISNULL(@eqp_name, EQP_NAME) &#xD;&#xA;     AND 	RCP_ID		= ISNULL(@recipe, RCP_ID)&#xD;&#xA;     AND   RCP_ACTIVE   = ISNULL(@active, RCP_ACTIVE)&#xD;&#xA;     AND 	RCP_HOLD	= @hold&#xD;&#xA;     AND   DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="recipe" />
            <QP N="active" />
            <QP N="hold" />
          </QY>
        </SG>
        <SG _S="2748" N="SearchRecipeListByMaster">
          <QY P="MsSql" Q="SELECT&#xD;&#xA;		FACTORY,&#xD;&#xA;		 TYPE,  &#xD;&#xA;		 RCP_ID,&#xD;&#xA;		 'Master' AS MEMBER,&#xD;&#xA;		 '' AS EQP_NAME ,&#xD;&#xA;		RCP_DESC, &#xD;&#xA;		RCP_ACTIVE,&#xD;&#xA;		ACTIVE_RCP_VER,&#xD;&#xA;		LAST_RCP_VER,&#xD;&#xA;		RCP_HOLD&#xD;&#xA;FROM &#xD;&#xA;		QTMSMASRCP &#xD;&#xA;WHERE &#xD;&#xA;		FACTORY        = @factory&#xD;&#xA;     AND   TYPE 		=@type &#xD;&#xA;     AND 	RCP_ID		=ISNULL(@recipe, RCP_ID)&#xD;&#xA;     AND   RCP_ACTIVE   = ISNULL(@active, RCP_ACTIVE)&#xD;&#xA;     AND 	RCP_HOLD	= @hold&#xD;&#xA;     AND   DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="type" />
            <QP N="recipe" />
            <QP N="active" />
            <QP N="hold" />
          </QY>
        </SG>
        <SG _S="2750" N="SearchRecipeVerListByMaster">
          <QY P="MsSql" Q="SELECT&#xD;&#xA;		FACTORY,&#xD;&#xA;		 TYPE,  &#xD;&#xA;		 RCP_ID,&#xD;&#xA;		 'Master' AS MEMBER,&#xD;&#xA;		 '' AS EQP_NAME ,&#xD;&#xA;		RCP_VER,&#xD;&#xA;		RCP_VER_DESC, &#xD;&#xA;		RCP_VER_ACTIVE,&#xD;&#xA;		RCP_VER_STATUS&#xD;&#xA;FROM &#xD;&#xA;		QTMSMASRVR &#xD;&#xA;WHERE &#xD;&#xA;		FACTORY        = @factory&#xD;&#xA;     AND   TYPE 		= @type &#xD;&#xA;     AND 	RCP_ID		= @recipe">
            <QP N="factory" />
            <QP N="type" />
            <QP N="recipe" />
          </QY>
        </SG>
        <SG _S="2751" N="SearchRecipeVerListByEquipment">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;		FACTORY,&#xD;&#xA;		TYPE,  &#xD;&#xA;		RCP_ID,&#xD;&#xA;		 'Equipment' AS MEMBER,&#xD;&#xA;		EQP_NAME ,&#xD;&#xA;		RCP_VER,&#xD;&#xA;		RCP_VER_DESC, &#xD;&#xA;		RCP_VER_ACTIVE,&#xD;&#xA;		RCP_VER_STATUS&#xD;&#xA;FROM 	&#xD;&#xA;		QTMSEQPRVR&#xD;&#xA;WHERE &#xD;&#xA;		FACTORY        = @factory &#xD;&#xA;     AND 	TYPE 		= @type &#xD;&#xA;     AND 	EQP_NAME 	= ISNULL(@eqp_name, EQP_NAME) &#xD;&#xA;     AND 	RCP_ID		= @recipe">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="recipe" />
          </QY>
        </SG>
      </F>
      <F _S="4059" N="MasterRecipeList">
        <SG _S="4062" N="ListMasterRecipe">
          <QY P="MsSql" Q="SELECT RCP_ID, RCP_DESC, RCP_CLASS, RCP_ACTIVE, ACTIVE_RCP_VER, LAST_RCP_VER, RCP_HOLD&#xD;&#xA;  FROM QTMSMASRCP &#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE 	   = @type &#xD;&#xA;   AND RCP_ID	   = ISNULL(@rcp_id, RCP_ID)&#xD;&#xA;   AND RCP_ACTIVE  = ISNULL(@rcp_active, RCP_ACTIVE)&#xD;&#xA;   AND RCP_HOLD	   = ISNULL(@rcp_hold, RCP_HOLD)&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY RCP_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="rcp_active" />
            <QP N="rcp_hold" />
          </QY>
        </SG>
        <SG _S="4451" N="ListMasterRecipeSequence">
          <QY P="MsSql" Q="SELECT PROC_STEP, PROC_ID&#xD;&#xA;  FROM QTMSMASRSQ&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TYPE     = @type&#xD;&#xA;   AND RCP_ID   = @rcp_id&#xD;&#xA;   AND RCP_VER  = @rcp_ver&#xD;&#xA; ORDER BY PROC_STEP">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="rcp_ver" />
          </QY>
        </SG>
        <SG _S="4063" N="ListMasterRecipeVersion">
          <QY P="MsSql" Q="SELECT RCP_VER, RCP_VER_DESC, RCP_VER_ACTIVE, RCP_VER_STATUS, &#xD;&#xA;       CREATE_TIME, CREATE_USER_ID, UPDATE_TIME, UPDATE_USER_ID&#xD;&#xA;  FROM QTMSMASRVR &#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type &#xD;&#xA;   AND RCP_ID      = @rcp_id&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY RCP_VER DESC">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
          </QY>
        </SG>
        <SG _S="4065" N="ListMasterRecipeParameter">
          <QY P="MsSql" Q="SELECT A.PARA_ID, B.PARA_DESC,&#xD;&#xA;       A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5,&#xD;&#xA;	   B.PARA_FORMAT, A.PARA_VALUE, B.MANAGE_FLAG&#xD;&#xA;  FROM QTMSMASRPR A&#xD;&#xA;  LEFT JOIN QTMSPARDEF B&#xD;&#xA;    ON A.FACTORY    = B.FACTORY&#xD;&#xA;   AND A.TYPE       = B.TYPE&#xD;&#xA;   AND A.PARA_ID    = B.PARA_ID&#xD;&#xA;   AND A.PARA_GROUP = B.PARA_GROUP&#xD;&#xA;   AND A.PARA_CAT_1 = B.PARA_CAT_1&#xD;&#xA;   AND A.PARA_CAT_2 = B.PARA_CAT_2&#xD;&#xA;   AND A.PARA_CAT_3 = B.PARA_CAT_3&#xD;&#xA;   AND A.PARA_CAT_4 = B.PARA_CAT_4&#xD;&#xA;   AND A.PARA_CAT_5 = B.PARA_CAT_5&#xD;&#xA; WHERE A.FACTORY      = @factory&#xD;&#xA;   AND A.TYPE         = @type&#xD;&#xA;   AND A.RCP_ID       = @rcp_id&#xD;&#xA;   AND A.RCP_VER      = @rcp_ver&#xD;&#xA;   AND B.MANAGE_FLAG = ISNULL(@manage_flag, B.MANAGE_FLAG)&#xD;&#xA; ORDER BY A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5, A.PARA_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="rcp_ver" />
            <QP N="manage_flag" />
          </QY>
        </SG>
        <SG _S="4131" N="ListMasterRecipeParameterPaging">
          <QY P="MsSql" Q="SELECT A.PARA_ID, B.PARA_DESC,&#xD;&#xA;       A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5,&#xD;&#xA;	   B.PARA_FORMAT, A.PARA_VALUE, B.MANAGE_FLAG&#xD;&#xA;  FROM QTMSMASRPR A&#xD;&#xA;  LEFT JOIN QTMSPARDEF B&#xD;&#xA;    ON A.FACTORY    = B.FACTORY&#xD;&#xA;   AND A.TYPE       = B.TYPE&#xD;&#xA;   AND A.PARA_ID    = B.PARA_ID&#xD;&#xA;   AND A.PARA_GROUP = B.PARA_GROUP&#xD;&#xA;   AND A.PARA_CAT_1 = B.PARA_CAT_1&#xD;&#xA;   AND A.PARA_CAT_2 = B.PARA_CAT_2&#xD;&#xA;   AND A.PARA_CAT_3 = B.PARA_CAT_3&#xD;&#xA;   AND A.PARA_CAT_4 = B.PARA_CAT_4&#xD;&#xA;   AND A.PARA_CAT_5 = B.PARA_CAT_5&#xD;&#xA; WHERE A.FACTORY      = @factory&#xD;&#xA;   AND A.TYPE         = @type&#xD;&#xA;   AND A.RCP_ID       = @rcp_id&#xD;&#xA;   AND A.RCP_VER      = @rcp_ver&#xD;&#xA; ORDER BY A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5, A.PARA_ID&#xD;&#xA; OFFSET (CONVERT(int, @PAGE_NO)-1) * CONVERT(int, @PAGE_SIZE) ROW FETCH NEXT CONVERT(int, @PAGE_SIZE) ROW ONLY">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="rcp_ver" />
            <QP N="PAGE_NO" />
            <QP N="PAGE_SIZE" />
          </QY>
        </SG>
        <SG _S="4066" N="CountMasterRecipeParameter">
          <QY P="MsSql" Q="SELECT COUNT(*) AS CNT&#xD;&#xA;  FROM QTMSMASRPR&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE    = @type&#xD;&#xA;   AND RCP_ID  = @rcp_id&#xD;&#xA;   AND RCP_VER = @rcp_ver">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="rcp_ver" />
          </QY>
        </SG>
      </F>
      <F _S="4096" N="MasterParameter">
        <SG _S="4097" N="ListVersion">
          <QY P="MsSql" Q="SELECT SPEC_VER, SPEC_VER_DESC, ACTIVE, STATUS,&#xD;&#xA;       CREATE_TIME, CREATE_USER_ID, UPDATE_TIME, UPDATE_USER_ID&#xD;&#xA;  FROM QTMSMASSVR&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE    = @type&#xD;&#xA;   AND RCP_ID  = @rcp_id&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY SPEC_VER DESC">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
          </QY>
        </SG>
        <SG _S="4099" N="ListParameter">
          <QY P="MsSql" Q="SELECT A.PARA_ID, B.PARA_DESC, &#xD;&#xA;       A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5,&#xD;&#xA;	   B.PARA_FORMAT,&#xD;&#xA;	   A.PARA_VALIDATION_RULE,&#xD;&#xA;       A.PARA_TARGET_VALUE, A.PARA_USL, A.PARA_UCL, A.PARA_LCL, A.PARA_LSL&#xD;&#xA;  FROM &#xD;&#xA;     (&#xD;&#xA;SELECT FACTORY, TYPE, &#xD;&#xA;       PARA_ID, PARA_LEVEL,&#xD;&#xA;	   PARA_VALUE,&#xD;&#xA;	   PARA_VALIDATION, PARA_VALIDATION_RULE,&#xD;&#xA;	   PARA_GROUP, PARA_CAT_1, PARA_CAT_2, PARA_CAT_3, PARA_CAT_4, PARA_CAT_5,&#xD;&#xA;	   PARA_TARGET_VALUE, PARA_USL, PARA_UCL, PARA_LCL, PARA_LSL&#xD;&#xA;  FROM QTMSMASSVP&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND TYPE      = @type&#xD;&#xA;   AND RCP_ID    = @rcp_id&#xD;&#xA;   AND SPEC_VER  = @spec_ver&#xD;&#xA;     ) AS A&#xD;&#xA; LEFT JOIN QTMSPARDEF B&#xD;&#xA;    ON A.FACTORY    = B.FACTORY&#xD;&#xA;   AND A.TYPE       = B.TYPE&#xD;&#xA;   AND A.PARA_ID    = B.PARA_ID&#xD;&#xA;   AND A.PARA_GROUP = B.PARA_GROUP&#xD;&#xA;   AND A.PARA_CAT_1 = B.PARA_CAT_1&#xD;&#xA;   AND A.PARA_CAT_2 = B.PARA_CAT_2&#xD;&#xA;   AND A.PARA_CAT_3 = B.PARA_CAT_3&#xD;&#xA;   AND A.PARA_CAT_4 = B.PARA_CAT_4&#xD;&#xA;   AND A.PARA_CAT_5 = B.PARA_CAT_5&#xD;&#xA; ORDER BY A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5, A.PARA_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="spec_ver" />
          </QY>
        </SG>
        <SG _S="4134" N="ListParameterPaging">
          <QY P="MsSql" Q="SELECT A.PARA_ID, B.PARA_DESC, &#xD;&#xA;       A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5,&#xD;&#xA;	   B.PARA_FORMAT,&#xD;&#xA;	   A.PARA_VALIDATION_RULE,&#xD;&#xA;       A.PARA_TARGET_VALUE, A.PARA_USL, A.PARA_UCL, A.PARA_LCL, A.PARA_LSL&#xD;&#xA;  FROM &#xD;&#xA;     (&#xD;&#xA;SELECT FACTORY, TYPE, &#xD;&#xA;       PARA_ID, PARA_LEVEL,&#xD;&#xA;	   PARA_VALUE,&#xD;&#xA;	   PARA_VALIDATION, PARA_VALIDATION_RULE,&#xD;&#xA;	   PARA_GROUP, PARA_CAT_1, PARA_CAT_2, PARA_CAT_3, PARA_CAT_4, PARA_CAT_5,&#xD;&#xA;	   PARA_TARGET_VALUE, PARA_USL, PARA_UCL, PARA_LCL, PARA_LSL&#xD;&#xA;  FROM QTMSMASSVP&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND TYPE      = @type&#xD;&#xA;   AND RCP_ID    = @rcp_id&#xD;&#xA;   AND SPEC_VER  = @spec_ver&#xD;&#xA;     ) AS A&#xD;&#xA; LEFT JOIN QTMSPARDEF B&#xD;&#xA;    ON A.FACTORY    = B.FACTORY&#xD;&#xA;   AND A.TYPE       = B.TYPE&#xD;&#xA;   AND A.PARA_ID    = B.PARA_ID&#xD;&#xA;   AND A.PARA_GROUP = B.PARA_GROUP&#xD;&#xA;   AND A.PARA_CAT_1 = B.PARA_CAT_1&#xD;&#xA;   AND A.PARA_CAT_2 = B.PARA_CAT_2&#xD;&#xA;   AND A.PARA_CAT_3 = B.PARA_CAT_3&#xD;&#xA;   AND A.PARA_CAT_4 = B.PARA_CAT_4&#xD;&#xA;   AND A.PARA_CAT_5 = B.PARA_CAT_5&#xD;&#xA; ORDER BY A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5, A.PARA_ID&#xD;&#xA; OFFSET (CONVERT(int, @PAGE_NO)-1) * CONVERT(int, @PAGE_SIZE) ROW FETCH NEXT CONVERT(int, @PAGE_SIZE) ROW ONLY">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="spec_ver" />
            <QP N="PAGE_NO" />
            <QP N="PAGE_SIZE" />
          </QY>
        </SG>
        <SG _S="4098" N="CountParameter">
          <QY P="MsSql" Q="SELECT COUNT(*) AS CNT&#xD;&#xA;  FROM QTMSMASSVP&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND TYPE      = @type&#xD;&#xA;   AND RCP_ID    = @rcp_id&#xD;&#xA;   AND SPEC_VER  = @spec_ver">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="spec_ver" />
          </QY>
        </SG>
      </F>
      <F _S="4100" N="EquipmentParameter">
        <SG _S="4101" N="ListVersion">
          <QY P="MsSql" Q="SELECT SPEC_VER, SPEC_VER_DESC, ACTIVE, STATUS,&#xD;&#xA;       CREATE_TIME, CREATE_USER_ID, UPDATE_TIME, UPDATE_USER_ID&#xD;&#xA;  FROM QTMSEQPSVR&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TYPE     = @type&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND RCP_ID   = @rcp_id&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY SPEC_VER DESC">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
          </QY>
        </SG>
        <SG _S="4102" N="ListParameter">
          <QY P="MsSql" Q="SELECT A.PARA_ID, B.PARA_DESC, &#xD;&#xA;       A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5,&#xD;&#xA;	   B.PARA_FORMAT,&#xD;&#xA;	   A.PARA_VALIDATION_RULE,&#xD;&#xA;       A.PARA_TARGET_VALUE, A.PARA_USL, A.PARA_UCL, A.PARA_LCL, A.PARA_LSL&#xD;&#xA;  FROM &#xD;&#xA;     (&#xD;&#xA;SELECT FACTORY, TYPE, &#xD;&#xA;       PARA_ID, PARA_LEVEL,&#xD;&#xA;	   PARA_VALUE,&#xD;&#xA;	   PARA_VALIDATION, PARA_VALIDATION_RULE,&#xD;&#xA;	   PARA_GROUP, PARA_CAT_1, PARA_CAT_2, PARA_CAT_3, PARA_CAT_4, PARA_CAT_5,&#xD;&#xA;	   PARA_TARGET_VALUE, PARA_USL, PARA_UCL, PARA_LCL, PARA_LSL&#xD;&#xA;  FROM QTMSEQPSVP&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND TYPE      = @type&#xD;&#xA;   AND EQP_NAME  = @eqp_name&#xD;&#xA;   AND RCP_ID    = @rcp_id&#xD;&#xA;   AND SPEC_VER  = @spec_ver&#xD;&#xA;     ) AS A&#xD;&#xA; LEFT JOIN QTMSPARDEF B&#xD;&#xA;    ON A.FACTORY    = B.FACTORY&#xD;&#xA;   AND A.TYPE       = B.TYPE&#xD;&#xA;   AND A.PARA_ID    = B.PARA_ID&#xD;&#xA;   AND A.PARA_GROUP = B.PARA_GROUP&#xD;&#xA;   AND A.PARA_CAT_1 = B.PARA_CAT_1&#xD;&#xA;   AND A.PARA_CAT_2 = B.PARA_CAT_2&#xD;&#xA;   AND A.PARA_CAT_3 = B.PARA_CAT_3&#xD;&#xA;   AND A.PARA_CAT_4 = B.PARA_CAT_4&#xD;&#xA;   AND A.PARA_CAT_5 = B.PARA_CAT_5&#xD;&#xA; ORDER BY A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5, A.PARA_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="spec_ver" />
          </QY>
        </SG>
        <SG _S="4135" N="ListParameterPaging">
          <QY P="MsSql" Q="SELECT A.PARA_ID, B.PARA_DESC, &#xD;&#xA;       A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5,&#xD;&#xA;	   B.PARA_FORMAT,&#xD;&#xA;	   A.PARA_VALIDATION_RULE,&#xD;&#xA;       A.PARA_TARGET_VALUE, A.PARA_USL, A.PARA_UCL, A.PARA_LCL, A.PARA_LSL&#xD;&#xA;  FROM &#xD;&#xA;     (&#xD;&#xA;SELECT FACTORY, TYPE, &#xD;&#xA;       PARA_ID, PARA_LEVEL,&#xD;&#xA;	   PARA_VALUE,&#xD;&#xA;	   PARA_VALIDATION, PARA_VALIDATION_RULE,&#xD;&#xA;	   PARA_GROUP, PARA_CAT_1, PARA_CAT_2, PARA_CAT_3, PARA_CAT_4, PARA_CAT_5,&#xD;&#xA;	   PARA_TARGET_VALUE, PARA_USL, PARA_UCL, PARA_LCL, PARA_LSL&#xD;&#xA;  FROM QTMSEQPSVP&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND TYPE      = @type&#xD;&#xA;   AND EQP_NAME  = @eqp_name&#xD;&#xA;   AND RCP_ID    = @rcp_id&#xD;&#xA;   AND SPEC_VER  = @spec_ver&#xD;&#xA;     ) AS A&#xD;&#xA; LEFT JOIN QTMSPARDEF B&#xD;&#xA;    ON A.FACTORY    = B.FACTORY&#xD;&#xA;   AND A.TYPE       = B.TYPE&#xD;&#xA;   AND A.PARA_ID    = B.PARA_ID&#xD;&#xA;   AND A.PARA_GROUP = B.PARA_GROUP&#xD;&#xA;   AND A.PARA_CAT_1 = B.PARA_CAT_1&#xD;&#xA;   AND A.PARA_CAT_2 = B.PARA_CAT_2&#xD;&#xA;   AND A.PARA_CAT_3 = B.PARA_CAT_3&#xD;&#xA;   AND A.PARA_CAT_4 = B.PARA_CAT_4&#xD;&#xA;   AND A.PARA_CAT_5 = B.PARA_CAT_5&#xD;&#xA; ORDER BY A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5, A.PARA_ID&#xD;&#xA; OFFSET (CONVERT(int, @PAGE_NO)-1) * CONVERT(int, @PAGE_SIZE) ROW FETCH NEXT CONVERT(int, @PAGE_SIZE) ROW ONLY">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="spec_ver" />
            <QP N="PAGE_NO" />
            <QP N="PAGE_SIZE" />
          </QY>
        </SG>
        <SG _S="4103" N="CountParameter">
          <QY P="MsSql" Q="SELECT COUNT(*) AS CNT&#xD;&#xA;  FROM QTMSEQPSVP&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND TYPE      = @type&#xD;&#xA;   AND EQP_NAME  = @eqp_name&#xD;&#xA;   AND RCP_ID    = @rcp_id&#xD;&#xA;   AND SPEC_VER  = @spec_ver">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="spec_ver" />
          </QY>
        </SG>
      </F>
      <F _S="2752" N="RecipeParameter">
        <SG _S="2753" N="SearchRecipeParameterByEquipment">
          <QY P="MsSql" Q="SELECT	A.FACTORY, &#xD;&#xA;		'Equipment' as MEMBER, &#xD;&#xA;		A.TYPE, &#xD;&#xA;		A.EQP_NAME, &#xD;&#xA;		A.RCP_ID, &#xD;&#xA;		A.SPEC_VER, &#xD;&#xA;		A.PARA_ID, &#xD;&#xA;		B.PARA_DESC,&#xD;&#xA;		A.PARA_VALUE, &#xD;&#xA;		A.PARA_VALIDATION, &#xD;&#xA;		A.PARA_VALIDATION_RULE, &#xD;&#xA;		A.PARA_TARGET_VALUE, &#xD;&#xA;		A.PARA_USL, &#xD;&#xA;		A.PARA_UCL, &#xD;&#xA;		A.PARA_LSL, &#xD;&#xA;		A.PARA_LCL&#xD;&#xA;FROM QTMSEQPSVP A&#xD;&#xA;LEFT JOIN QTMSPARDEF B&#xD;&#xA;  ON A.FACTORY = B.FACTORY&#xD;&#xA; AND A.TYPE = B.TYPE&#xD;&#xA; AND A.PARA_ID = B.PARA_ID&#xD;&#xA;WHERE A.FACTORY       = @factory &#xD;&#xA;     AND 	 A.TYPE 		= @type &#xD;&#xA;     AND	 A.EQP_NAME	= @eqpname&#xD;&#xA;     AND 	 A.RCP_ID		= @recipe&#xD;&#xA;     AND 	 A.SPEC_VER	= @spec_ver">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqpname" />
            <QP N="recipe" />
            <QP N="spec_ver" />
          </QY>
        </SG>
        <SG _S="2754" N="SearchRecipeParameterByMaster">
          <QY P="MsSql" Q="SELECT  A.FACTORY,&#xD;&#xA;		'Master' as MEMBER, &#xD;&#xA;	 	A.TYPE,  '' AS EQUIPMENT, &#xD;&#xA;		A.RCP_ID, &#xD;&#xA;		A.SPEC_VER, &#xD;&#xA;		A.PARA_ID, &#xD;&#xA;		B.PARA_DESC,&#xD;&#xA;		A.PARA_VALUE, &#xD;&#xA;		A.PARA_VALIDATION, &#xD;&#xA;		A.PARA_VALIDATION_RULE, &#xD;&#xA;		A.PARA_TARGET_VALUE, &#xD;&#xA;		A.PARA_USL, &#xD;&#xA;		A.PARA_UCL, &#xD;&#xA;		A.PARA_LSL, &#xD;&#xA;		A.PARA_LCL&#xD;&#xA;FROM QTMSMASSVP A&#xD;&#xA;LEFT JOIN QTMSPARDEF B&#xD;&#xA;  ON A.FACTORY = B.FACTORY&#xD;&#xA; AND A.TYPE = B.TYPE&#xD;&#xA; AND A.PARA_ID = B.PARA_ID&#xD;&#xA;WHERE A.FACTORY 	= @factory &#xD;&#xA;  AND A.TYPE 		= @type&#xD;&#xA;  AND A.RCP_ID		= @recipe&#xD;&#xA;  AND A.SPEC_VER	= @spec_ver">
            <QP N="factory" />
            <QP N="type" />
            <QP N="recipe" />
            <QP N="spec_ver" />
          </QY>
        </SG>
      </F>
      <F _S="4252" N="RecipeDownloadHistory">
        <SG _S="4253" N="ListRecipeHistory">
          <QY P="MsSql" Q="SELECT HIS.HIST_SEQ, HIS.TRAN_TIME, &#xD;&#xA;       HIS.TYPE, HIS.EQP_NAME, HIS.RCP_ID, &#xD;&#xA;	   ISNULL(RCP.RCP_DESC, ' ') AS RCP_DESC, ISNULL(RCP.RCP_CLASS, ' ') AS RCP_CLASS,&#xD;&#xA;	   HIS.RCP_MEMBER, HIS.RCP_VER, HIS.EQP_RESULT, HIS.EQP_REASON&#xD;&#xA;  FROM QTMSRCPDWH HIS&#xD;&#xA;  LEFT JOIN QTMSMASRCP RCP&#xD;&#xA;    ON HIS.FACTORY    = RCP.FACTORY&#xD;&#xA;   AND HIS.TYPE       = RCP.TYPE&#xD;&#xA;   AND HIS.RCP_ID     = RCP.RCP_ID&#xD;&#xA; WHERE HIS.FACTORY    = @factory&#xD;&#xA;   AND HIS.TYPE       = ISNULL(@type, HIS.TYPE)&#xD;&#xA;   AND HIS.EQP_NAME   = ISNULL(@eqp_name, HIS.EQP_NAME)&#xD;&#xA;   AND HIS.RCP_ID     = ISNULL(@rcp_id, HIS.RCP_ID)&#xD;&#xA;   AND HIS.TRAN_TIME &gt;= @tran_from_time&#xD;&#xA;   AND HIS.TRAN_TIME &lt;= @tran_to_time&#xD;&#xA; ORDER BY HIS.HIST_SEQ DESC">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
        <SG _S="4255" N="CountMasterRecipeParameter">
          <QY P="MsSql" Q="SELECT COUNT(*) AS CNT&#xD;&#xA;  FROM QTMSMASRPR&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE    = @type&#xD;&#xA;   AND RCP_ID  = @rcp_id&#xD;&#xA;   AND RCP_VER = @rcp_ver">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="rcp_ver" />
          </QY>
        </SG>
        <SG _S="4257" N="ListMasterRecipeParameter">
          <QY P="MsSql" Q="SELECT A.PARA_ID, B.PARA_DESC,&#xD;&#xA;       A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5,&#xD;&#xA;	 B.PARA_FORMAT, A.PARA_VALUE, B.MANAGE_FLAG&#xD;&#xA;  FROM QTMSMASRPR A&#xD;&#xA;  LEFT JOIN QTMSPARDEF B&#xD;&#xA;    ON A.FACTORY    = B.FACTORY&#xD;&#xA;   AND A.TYPE       = B.TYPE&#xD;&#xA;   AND A.PARA_ID    = B.PARA_ID&#xD;&#xA;   AND A.PARA_GROUP = B.PARA_GROUP&#xD;&#xA;   AND A.PARA_CAT_1 = B.PARA_CAT_1&#xD;&#xA;   AND A.PARA_CAT_2 = B.PARA_CAT_2&#xD;&#xA;   AND A.PARA_CAT_3 = B.PARA_CAT_3&#xD;&#xA;   AND A.PARA_CAT_4 = B.PARA_CAT_4&#xD;&#xA;   AND A.PARA_CAT_5 = B.PARA_CAT_5&#xD;&#xA; WHERE A.FACTORY      = @factory&#xD;&#xA;   AND A.TYPE         = @type&#xD;&#xA;   AND A.RCP_ID       = @rcp_id&#xD;&#xA;   AND A.RCP_VER      = @rcp_ver&#xD;&#xA;   AND B.MANAGE_FLAG  = ISNULL(@managed_flag, B.MANAGE_FLAG)&#xD;&#xA; ORDER BY A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="rcp_ver" />
            <QP N="managed_flag" />
          </QY>
        </SG>
        <SG _S="4258" N="ListMasterRecipeParameterPaging">
          <QY P="MsSql" Q="SELECT A.PARA_ID, B.PARA_DESC,&#xD;&#xA;       A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5,&#xD;&#xA;	 B.PARA_FORMAT, A.PARA_VALUE, B.MANAGE_FLAG&#xD;&#xA;  FROM QTMSMASRPR A&#xD;&#xA;  LEFT JOIN QTMSPARDEF B&#xD;&#xA;    ON A.FACTORY    = B.FACTORY&#xD;&#xA;   AND A.TYPE       = B.TYPE&#xD;&#xA;   AND A.PARA_ID    = B.PARA_ID&#xD;&#xA;   AND A.PARA_GROUP = B.PARA_GROUP&#xD;&#xA;   AND A.PARA_CAT_1 = B.PARA_CAT_1&#xD;&#xA;   AND A.PARA_CAT_2 = B.PARA_CAT_2&#xD;&#xA;   AND A.PARA_CAT_3 = B.PARA_CAT_3&#xD;&#xA;   AND A.PARA_CAT_4 = B.PARA_CAT_4&#xD;&#xA;   AND A.PARA_CAT_5 = B.PARA_CAT_5&#xD;&#xA; WHERE A.FACTORY      = @factory&#xD;&#xA;   AND A.TYPE         = @type&#xD;&#xA;   AND A.RCP_ID       = @rcp_id&#xD;&#xA;   AND A.RCP_VER      = @rcp_ver&#xD;&#xA; ORDER BY A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_ID&#xD;&#xA; OFFSET (CONVERT(int, @PAGE_NO)-1) * CONVERT(int, @PAGE_SIZE) ROW FETCH NEXT CONVERT(int, @PAGE_SIZE) ROW ONLY">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="rcp_ver" />
            <QP N="PAGE_NO" />
            <QP N="PAGE_SIZE" />
          </QY>
        </SG>
      </F>
      <F _S="3057" N="TypeParameter">
        <SG _S="3059" N="ListParameter">
          <QY P="MsSql" Q="SELECT PARA_ID, PARA_DESC, 	&#xD;&#xA;       PARA_GROUP, PARA_CAT_1, PARA_CAT_2, PARA_CAT_3, PARA_CAT_4, PARA_CAT_5,&#xD;&#xA;	   PARA_FORMAT, PARA_DECIMAL_POINT, PARA_UNIT, PARA_LEVEL, MANAGE_FLAG,&#xD;&#xA;	   PARA_VALIDATION_RULE, PARA_UPPER_RANGE_TYPE, PARA_LOWER_RANGE_TYPE,&#xD;&#xA;       PARA_USL, PARA_UCL, PARA_LCL, PARA_LSL&#xD;&#xA;  FROM QTMSPARDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND MANAGE_FLAG = ISNULL(@manage_flag, MANAGE_FLAG)&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY PARA_GROUP, PARA_CAT_1, PARA_CAT_2, PARA_CAT_3, PARA_CAT_4, PARA_CAT_5, PARA_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="manage_flag" />
