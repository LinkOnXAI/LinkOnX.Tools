        <SG _S="3314" N="SearchEquipmentLine">
          <QY P="MsSql" Q="SELECT LINE, LINE_DESC&#xD;&#xA;  FROM QTMSEQPLIN&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND LINE    = @line">
            <QP N="factory" />
            <QP N="line" />
          </QY>
        </SG>
        <SG _S="3315" N="InsertEquipmentLine">
          <QY P="MsSql" Q="INSERT INTO QTMSEQPLIN (&#xD;&#xA;   FACTORY,&#xD;&#xA;   LINE,&#xD;&#xA;   LINE_DESC,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @line,&#xD;&#xA;   @line_desc,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="line" />
            <QP N="line_desc" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="3316" N="UpdateEquipmentLine">
          <QY P="MsSql" Q="UPDATE QTMSEQPLIN SET&#xD;&#xA;  LINE_DESC      = @line_desc,&#xD;&#xA;  UPDATE_USER_ID = @update_user_id,&#xD;&#xA;  UPDATE_TIME    = @update_time&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND LINE      = @line">
            <QP N="line_desc" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="line" />
          </QY>
        </SG>
        <SG _S="3317" N="DeleteEquipmentLine">
          <QY P="MsSql" Q="DELETE &#xD;&#xA;  FROM QTMSEQPLIN&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND LINE    = @line">
            <QP N="factory" />
            <QP N="line" />
          </QY>
        </SG>
        <SG _S="3318" N="CountEquipmentLine">
          <QY P="MsSql" Q="SELECT EQP_NAME&#xD;&#xA;  FROM QTMSEQPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND LINE        = @line&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="line" />
          </QY>
        </SG>
      </F>
