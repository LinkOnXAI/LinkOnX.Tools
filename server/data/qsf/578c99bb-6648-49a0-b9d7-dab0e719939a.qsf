          <QY P="MsSql" Q="SELECT RCP_VER, RCP_VER_DESC, CREATE_TIME&#xD;&#xA;  FROM QTMSEQPRVR&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TYPE     = @type&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND RCP_ID   = @rcp_id&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY RCP_VER DESC">
