            <QP N="recipe" />
          </QY>
        </SG>
        <SG _S="3474" N="ListEquipmentRecipeSpecVersion">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;		FACTORY,&#xD;&#xA;		 TYPE,  &#xD;&#xA;		 EQP_NAME ,&#xD;&#xA;		RCP_ID,&#xD;&#xA;		SPEC_VER,&#xD;&#xA;		SPEC_VER_DESC, &#xD;&#xA;		ACTIVE,&#xD;&#xA;		STATUS&#xD;&#xA;FROM 	&#xD;&#xA;		QTMSEQPSVR&#xD;&#xA;WHERE &#xD;&#xA;		FACTORY        = @factory &#xD;&#xA;     AND 	TYPE 		= @type &#xD;&#xA;     AND 	EQP_NAME 	= ISNULL(@eqp_name, EQP_NAME) &#xD;&#xA;     AND 	RCP_ID		= @recipe&#xD;&#xA;     AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="recipe" />
          </QY>
        </SG>
      </F>
      <F _S="4287" N="RecipeSpecVersionSelectorEx">
