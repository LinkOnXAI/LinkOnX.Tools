    <M _S="60" N="System">
      <F _S="61" N="UserLogIn">
        <SG _S="981" N="SearchUserGrp">
          <QY P="MsSql" Q="SELECT USER_GRP, ALL_AUTHORITY&#xD;&#xA;  FROM QSECUSRGRP&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND USER_GRP = @user_grp">
            <QP N="factory" />
            <QP N="user_grp" />
          </QY>
        </SG>
        <SG _S="1304" N="SearchUserNotice">
          <QY P="MsSql" Q="SELECT USER_ID, LAST_NTC_TIME&#xD;&#xA;  FROM QSECUSRNTC&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SYSTEM_CODE = @system_code &#xD;&#xA;   AND USER_ID     = @user_id">
            <QP N="factory" />
            <QP N="system_code" />
            <QP N="user_id" />
          </QY>
        </SG>
        <SG _S="906" N="SearchNotice">
          <QY P="MsSql" Q="SELECT   &#xD;&#xA;  NTC_CONTENTS_01, &#xD;&#xA;  NTC_CONTENTS_02, &#xD;&#xA;  NTC_CONTENTS_03, &#xD;&#xA;  NTC_CONTENTS_04, &#xD;&#xA;  NTC_CONTENTS_05, &#xD;&#xA;  NTC_CONTENTS_06, &#xD;&#xA;  NTC_CONTENTS_07, &#xD;&#xA;  NTC_CONTENTS_08, &#xD;&#xA;  NTC_CONTENTS_09,&#xD;&#xA;  NTC_CONTENTS_10,&#xD;&#xA;  NTC_CONTENTS_11,&#xD;&#xA;  NTC_CONTENTS_12,&#xD;&#xA;  NTC_CONTENTS_13,&#xD;&#xA;  NTC_CONTENTS_14,&#xD;&#xA;  NTC_CONTENTS_15,&#xD;&#xA;  NTC_CONTENTS_16,&#xD;&#xA;  NTC_CONTENTS_17,&#xD;&#xA;  NTC_CONTENTS_18,&#xD;&#xA;  NTC_CONTENTS_19,&#xD;&#xA;  NTC_CONTENTS_20,&#xD;&#xA;  UPDATE_TIME&#xD;&#xA;  FROM QSYSNTCDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SYSTEM_CODE = @system_code">
            <QP N="factory" />
            <QP N="system_code" />
          </QY>
        </SG>
        <SG _S="63" N="ListAuthority">
          <QY P="MsSql" Q="SELECT FUN, TRAN_ENABLED&#xD;&#xA;  FROM QSECURGAUT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND USER_GRP = @user_grp&#xD;&#xA;   AND APP      = @app&#xD;&#xA; ORDER BY FUN">
            <QP N="factory" />
            <QP N="user_grp" />
            <QP N="app" />
          </QY>
        </SG>
      </F>
      <F _S="1307" N="UserNotice">
        <SG _S="1308" N="HasUserNotice">
          <QY P="MsSql" Q="SELECT USER_ID&#xD;&#xA;  FROM QSECUSRNTC&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SYSTEM_CODE = @system_code &#xD;&#xA;   AND USER_ID     = @user_id">
            <QP N="factory" />
            <QP N="system_code" />
            <QP N="user_id" />
          </QY>
        </SG>
        <SG _S="1309" N="InsertUserNotice">
          <QY P="MsSql" Q="INSERT INTO QSECUSRNTC (&#xD;&#xA;   FACTORY,&#xD;&#xA;   SYSTEM_CODE,&#xD;&#xA;   USER_ID,&#xD;&#xA;   LAST_NTC_TIME&#xD;&#xA;)&#xD;&#xA;VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @system_code,&#xD;&#xA;   @user_id,&#xD;&#xA;   @last_ntc_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="system_code" />
            <QP N="user_id" />
            <QP N="last_ntc_time" />
          </QY>
        </SG>
        <SG _S="1310" N="UpdateUserNotice">
          <QY P="MsSql" Q="UPDATE QSECUSRNTC SET&#xD;&#xA;   LAST_NTC_TIME   = @last_ntc_time&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND SYSTEM_CODE = @system_code &#xD;&#xA;   AND USER_ID     = @user_id">
            <QP N="last_ntc_time" />
            <QP N="factory" />
            <QP N="system_code" />
            <QP N="user_id" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="4415" N="TransactionHandler">
      <F _S="4416" N="TemporaryClean">
        <SG _S="4418" N="DeleteRecipeDownloadTemporary">
          <QY P="MsSql" Q="DELETE&#xD;&#xA;  FROM QTMSRCPDWT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TYPE     = @type&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND RCP_ID   = @rcp_id&#xD;&#xA;   AND HIST_SEQ = @hist_seq">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="hist_seq" />
          </QY>
        </SG>
        <SG _S="4419" N="InsertRecipeDownloadHistory">
          <QY P="MsSql" Q="INSERT INTO QTMSRCPDWH (&#xD;&#xA;   FACTORY,&#xD;&#xA;   TYPE,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   RCP_ID,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   RCP_MEMBER,&#xD;&#xA;   RCP_VER,&#xD;&#xA;   EQP_RESULT,&#xD;&#xA;   EQP_REASON,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT&#xD;&#xA;   )&#xD;&#xA;VALUES( &#xD;&#xA;   @factory,&#xD;&#xA;   @type,&#xD;&#xA;   @eqp_name,&#xD;&#xA;   @rcp_id,&#xD;&#xA;   @hist_seq,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @rcp_member,&#xD;&#xA;   @rcp_ver,&#xD;&#xA;   @eqp_result,&#xD;&#xA;   @eqp_reason,&#xD;&#xA;   @tran_user_id,&#xD;&#xA;   @tran_comment)">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="hist_seq" />
            <QP N="tran_time" />
            <QP N="rcp_member" />
            <QP N="rcp_ver" />
            <QP N="eqp_result" />
            <QP N="eqp_reason" />
            <QP N="tran_user_id" />
            <QP N="tran_comment" />
          </QY>
        </SG>
        <SG _S="4420" N="SearcFactory">
          <QY P="MsSql" Q="SELECT FACTORY&#xD;&#xA; FROM QSYSFACDEF" />
