      <F _S="2923" N="LineEquipment">
        <SG _S="2992" N="CountLineEquipment">
          <QY P="MsSql" Q="SELECT COUNT(*) AS CNT&#xD;&#xA;FROM QTMSLINEQP&#xD;&#xA;WHERE FACTORY = @factory&#xD;&#xA;AND LINE = @line_code">
            <QP N="factory" />
            <QP N="line_code" />
          </QY>
        </SG>
        <SG _S="2998" N="ListEquipment">
          <QY P="MsSql" Q="SELECT R.LINE AS LINE_CODE, R.SEQ, R.EQP_NAME, M.EQP_DESC&#xD;&#xA;FROM QTMSLINEQP R&#xD;&#xA;LEFT JOIN QRASEQPDEF M&#xD;&#xA;   ON R.FACTORY = M.FACTORY&#xD;&#xA; AND R.EQP_NAME = M.EQP_NAME&#xD;&#xA;WHERE R.FACTORY = @factory&#xD;&#xA;AND R.LINE = @line_code&#xD;&#xA;ORDER BY R.SEQ ASC">
            <QP N="factory" />
            <QP N="line_code" />
          </QY>
        </SG>
        <SG _S="2993" N="InsertLineEquipment">
          <QY P="MsSql" Q="INSERT INTO QTMSLINEQP (&#xD;&#xA;   FACTORY,&#xD;&#xA;   LINE,&#xD;&#xA;   SEQ,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) &#xD;&#xA;VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @line_code,&#xD;&#xA;   @seq,&#xD;&#xA;   @eqp_name,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="line_code" />
            <QP N="seq" />
            <QP N="eqp_name" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="2994" N="HasLineEquipment">
          <QY P="MsSql" Q="SELECT LINE, SEQ, EQP_NAME&#xD;&#xA;FROM QTMSLINEQP&#xD;&#xA;WHERE FACTORY = @factory&#xD;&#xA;AND LINE = @line_code&#xD;&#xA;AND EQP_NAME = @eqp_name">
            <QP N="factory" />
            <QP N="line_code" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="2995" N="DeleteLineEquipment">
          <QY P="MsSql" Q="DELETE &#xD;&#xA;  FROM QTMSLINEQP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND LINE = @line_code&#xD;&#xA;   AND EQP_NAME  = @eqp_name">
            <QP N="factory" />
            <QP N="line_code" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="2996" N="UpdateLineEquipmentSeq">
          <QY P="MsSql" Q="UPDATE QTMSLINEQP&#xD;&#xA;SET QTMSLINEQP.SEQ = QTMSLINEQP.NUM&#xD;&#xA;FROM (&#xD;&#xA;		SELECT SEQ, ROW_NUMBER() OVER (ORDER BY SEQ) AS NUM&#xD;&#xA;		FROM QTMSLINEQP&#xD;&#xA;		WHERE FACTORY = @factory&#xD;&#xA;		AND LINE = @line_code&#xD;&#xA;	) QTMSLINEQP">
            <QP N="factory" />
            <QP N="line_code" />
          </QY>
        </SG>
        <SG _S="2997" N="DeleteAllLineEquipment">
          <QY P="MsSql" Q="DELETE &#xD;&#xA;  FROM QTMSLINEQP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; AND LINE = @line_code">
            <QP N="factory" />
            <QP N="line_code" />
          </QY>
        </SG>
      </F>
      <F _S="4543" N="TestProgram">
        <SG _S="4544" N="ListTestProgram">
          <QY P="MsSql" Q="SELECT TYPE, PGM_ID, PGM_DESC, ACTIVE, ACTIVE_VER, LAST_VER&#xD;&#xA;  FROM QTMSPGMDEF &#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = ISNULL(@type, TYPE)&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY TYPE, PGM_ID">
            <QP N="factory" />
            <QP N="type" />
          </QY>
        </SG>
        <SG _S="4546" N="ListTestProgramVersion">
          <QY P="MsSql" Q="SELECT PGM.PGM_VER, PGM.PGM_VER_DESC, PGM.PGM_VER_COMMENT, PGM.PGM_VER_FILE, PGM.ACTIVE, PGM.STATUS,&#xD;&#xA;       PGM.CREATE_TIME, CASE WHEN USER_C.USER_NAME IS NULL THEN PGM.CREATE_USER_ID ELSE CONCAT(PGM.CREATE_USER_ID, ' [', USER_C.USER_NAME, ']') END AS CREATE_USER , &#xD;&#xA;	   PGM.UPDATE_TIME, CASE WHEN USER_U.USER_NAME IS NULL THEN PGM.UPDATE_USER_ID ELSE CONCAT(PGM.UPDATE_USER_ID, ' [', USER_U.USER_NAME, ']') END AS UPDATE_USER&#xD;&#xA;  FROM (&#xD;&#xA;SELECT FACTORY, PGM_VER, PGM_VER_DESC, PGM_VER_COMMENT, PGM_VER_FILE, ACTIVE, STATUS, CREATE_TIME, CREATE_USER_ID, UPDATE_TIME, UPDATE_USER_ID&#xD;&#xA;  FROM QTMSPGMVER&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND PGM_ID      = @pgm_id&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA;       ) PGM&#xD;&#xA;  LEFT JOIN QSECUSRDEF USER_C&#xD;&#xA;    ON PGM.FACTORY        = USER_C.FACTORY&#xD;&#xA;   AND PGM.CREATE_USER_ID = USER_C.USER_ID&#xD;&#xA;  LEFT JOIN QSECUSRDEF USER_U&#xD;&#xA;    ON PGM.FACTORY        = USER_U.FACTORY&#xD;&#xA;   AND PGM.UPDATE_USER_ID = USER_U.USER_ID&#xD;&#xA; ORDER BY PGM.PGM_VER DESC">
            <QP N="factory" />
            <QP N="type" />
            <QP N="pgm_id" />
          </QY>
        </SG>
        <SG _S="4555" N="ListTestProgramVersionFile">
          <QY P="MsSql" Q="SELECT FILE_NAME&#xD;&#xA;  FROM QTMSPGMFIL&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TYPE     = @type&#xD;&#xA;   AND PGM_ID   = @pgm_id&#xD;&#xA;   AND PGM_VER  = @pgm_ver&#xD;&#xA; ORDER BY FILE_NAME">
            <QP N="factory" />
            <QP N="type" />
            <QP N="pgm_id" />
            <QP N="pgm_ver" />
          </QY>
        </SG>
        <SG _S="4553" N="DeleteTestProgramVersion">
          <QY P="MsSql" Q="UPDATE QTMSPGMVER SET&#xD;&#xA;   ACTIVE         = @active,&#xD;&#xA;   STATUS         = @status,&#xD;&#xA;   APR_SEQ        = @apr_seq,&#xD;&#xA;   DELETE_FLAG    = @delete_flag,&#xD;&#xA;   UPDATE_USER_ID = @update_user_id,&#xD;&#xA;   UPDATE_TIME    = @update_time&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND TYPE       = @type&#xD;&#xA;   AND PGM_ID     = @pgm_id">
            <QP N="active" />
            <QP N="status" />
            <QP N="apr_seq" />
            <QP N="delete_flag" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="type" />
            <QP N="pgm_id" />
          </QY>
        </SG>
        <SG _S="4554" N="DeleteTestProgram">
