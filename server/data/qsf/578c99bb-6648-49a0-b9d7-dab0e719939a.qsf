          <QY P="MsSql" Q="SELECT TYPE, EQP_NAME, RECIPE_CONTROL&#xD;&#xA;  FROM QTMSEQPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EQP_NAME    = @eqp_name&#xD;&#xA;   AND DELETE_FLAG = 'N'">
