            <QP N="rcp_ver" />
            <QP N="tran_user_id" />
            <QP N="tran_comment" />
          </QY>
        </SG>
        <SG _S="3874" N="HasMasterParameterVersion">
          <QY P="MsSql" Q="SELECT RCP_ID, SPEC_VER, ACTIVE, STATUS&#xD;&#xA;  FROM QTMSMASSVR&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE    = @type&#xD;&#xA;   AND RCP_ID  = @rcp_id&#xD;&#xA;   AND RCP_VER = @rcp_ver&#xD;&#xA;   AND DELETE_FLAG = 'N'">
