            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="rcp_ver" />
          </QY>
        </SG>
        <SG _S="4403" N="InsertRecipeDownloadTemporary">
          <QY P="MsSql" Q="INSERT INTO QTMSRCPDWT (&#xD;&#xA;   FACTORY,&#xD;&#xA;   TYPE,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   RCP_ID,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   RCP_MEMBER,&#xD;&#xA;   RCP_VER,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT&#xD;&#xA;   )&#xD;&#xA;VALUES( &#xD;&#xA;   @factory,&#xD;&#xA;   @type,&#xD;&#xA;   @eqp_name,&#xD;&#xA;   @rcp_id,&#xD;&#xA;   @hist_seq,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @rcp_member,&#xD;&#xA;   @rcp_ver,&#xD;&#xA;   @tran_user_id,&#xD;&#xA;   @tran_comment)">
            <QP N="factory" />
