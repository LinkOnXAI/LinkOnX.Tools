        <SG _S="4481" N="DeleteRecipeUploadTemporary">
          <QY P="MsSql" Q="DELETE&#xD;&#xA;  FROM QTMSRCPUPT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TYPE     = @type&#xD;&#xA;   AND EQP_NAME = @eqp_name">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="3031" N="DeleteTempRecipeParameter">
          <QY P="MsSql" Q="DELETE  &#xD;&#xA;  FROM QTMSTMPRPR&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TYPE     = @type&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND RCP_ID   = @rcp_id">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
          </QY>
        </SG>
        <SG _S="4478" N="DeleteTempRecipeSequence">
          <QY P="MsSql" Q="DELETE  &#xD;&#xA;  FROM QTMSTMPRSQ&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TYPE     = @type&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND RCP_ID   = @rcp_id">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
          </QY>
        </SG>
        <SG _S="4483" N="HasRecipeUploadWaitingItem">
          <QY P="MsSql" Q="SELECT RCP_ID, TRAN_STATUS, TRAN_TIME, RESULT, REASON&#xD;&#xA;  FROM QTMSRCPUPT&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND EQP_NAME    = @eqp_name&#xD;&#xA;   AND RCP_ID      = @rcp_id">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
          </QY>
        </SG>
        <SG _S="3032" N="DeleteTempRecipeFile">
          <QY P="MsSql" Q="DELETE &#xD;&#xA;  FROM QTMSTMPRFL  &#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TYPE     = @type&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND RCP_ID   = @rcp_id">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
          </QY>
        </SG>
        <SG _S="4112" N="DeleteTypeParameter">
          <QY P="MsSql" Q="DELETE&#xD;&#xA;  FROM QTMSPARDEF&#xD;&#xA; WHERE FACTORY    = @factory &#xD;&#xA;   AND TYPE       = @type&#xD;&#xA;   AND PARA_ID    = @para_id&#xD;&#xA;   AND PARA_GROUP = @para_group&#xD;&#xA;   AND PARA_CAT_1 = @para_cat_1&#xD;&#xA;   AND PARA_CAT_2 = @para_cat_2&#xD;&#xA;   AND PARA_CAT_3 = @para_cat_3&#xD;&#xA;   AND PARA_CAT_4 = @para_cat_4&#xD;&#xA;   AND PARA_CAT_5 = @para_cat_5">
            <QP N="factory" />
            <QP N="type" />
            <QP N="para_id" />
            <QP N="para_group" />
            <QP N="para_cat_1" />
            <QP N="para_cat_2" />
            <QP N="para_cat_3" />
            <QP N="para_cat_4" />
            <QP N="para_cat_5" />
          </QY>
        </SG>
      </F>
      <F _S="3477" N="RecipeValidation">
        <SG _S="3478" N="HasEquipment" UMG="No">
          <QY P="MsSql" Q="SELECT A.TYPE, A.EQP_NAME, A.RECIPE_CONTROL, A.EAP_CHANNEL, C.TRAN_TIMEOUT,&#xD;&#xA;       ISNULL(B.CTRL_MODE, ' ') AS CTRL_MODE, &#xD;&#xA;       ISNULL(B.COMM_STATE, ' ') AS COMM_STATE,&#xD;&#xA;	   ISNULL(B.PROC_STATE, ' ') AS PROC_STATE, &#xD;&#xA;	   ISNULL(B.EQP_RCP_ID, ' ') AS EQP_RCP_ID,&#xD;&#xA;	   CASE A.RECIPE_TYPE WHEN 'None' THEN C.RECIPE_TYPE ELSE A.RECIPE_TYPE END AS RECIPE_TYPE,&#xD;&#xA;	   CASE A.RECIPE_RULE WHEN 'None' THEN C.RECIPE_RULE ELSE A.RECIPE_RULE END AS RECIPE_RULE,&#xD;&#xA;	   CASE A.RECIPE_DOWNLOAD WHEN 'None' THEN C.RECIPE_DOWNLOAD ELSE A.RECIPE_DOWNLOAD END AS RECIPE_DOWNLOAD,&#xD;&#xA;	   CASE A.RECIPE_VALIDATION WHEN 'None' THEN C.RECIPE_VALIDATION ELSE A.RECIPE_VALIDATION END AS RECIPE_VALIDATION&#xD;&#xA;  FROM QTMSEQPDEF A&#xD;&#xA;  LEFT JOIN QTMSEQPSTS B&#xD;&#xA;    ON A.FACTORY     = B.FACTORY&#xD;&#xA;   AND A.EQP_NAME    = B.EQP_NAME&#xD;&#xA;  LEFT JOIN QTMSEQPTYP C&#xD;&#xA;    ON A.FACTORY     = C.FACTORY&#xD;&#xA;   AND A.TYPE        = C.TYPE&#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.EQP_NAME    = @eqp_name&#xD;&#xA;   AND A.DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="3927" N="HasMasterRecipe">
          <QY P="MsSql" Q="SELECT RCP_DESC, RCP_CLASS, RCP_ACTIVE, ACTIVE_RCP_VER, RCP_HOLD, DELETE_FLAG&#xD;&#xA;  FROM QTMSMASRCP&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND RCP_ID      = @rcp_id">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
          </QY>
        </SG>
        <SG _S="3928" N="HasMasterParameterVer">
          <QY P="MsSql" Q="SELECT SPEC_VER&#xD;&#xA;  FROM QTMSMASSVR&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TYPE     = @type&#xD;&#xA;   AND RCP_ID   = @rcp_id&#xD;&#xA;   AND ACTIVE   = @active&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="active" />
          </QY>
        </SG>
        <SG _S="3930" N="HasEquipmentRecipe">
          <QY P="MsSql" Q="SELECT RCP_ACTIVE, RCP_HOLD, ACTIVE_RCP_VER,  LAST_RCP_VER, DELETE_FLAG&#xD;&#xA;  FROM QTMSEQPRCP&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND EQP_NAME    = @eqp_name&#xD;&#xA;   AND RCP_ID      = @rcp_id">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
          </QY>
        </SG>
        <SG _S="3931" N="HasEquipmentParameterVer">
          <QY P="MsSql" Q="SELECT SPEC_VER&#xD;&#xA;  FROM QTMSEQPSVR&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TYPE     = @type&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND RCP_ID   = @rcp_id&#xD;&#xA;   AND ACTIVE   = @active&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="active" />
          </QY>
        </SG>
        <SG _S="3493" N="HasRecipeParser">
          <QY P="MsSql" Q="SELECT C.PSR_NAME, C.PSR_VER, C.PSR_VER_FILE&#xD;&#xA;  FROM QTMSTYPPSR A&#xD;&#xA;  LEFT JOIN QTMSPSRDEF B &#xD;&#xA;    ON A.FACTORY = B.FACTORY &#xD;&#xA;   AND A.PSR_NAME = B.PSR_NAME&#xD;&#xA;  LEFT JOIN QTMSPSRVER C &#xD;&#xA;    ON C.FACTORY = B.FACTORY &#xD;&#xA;   AND C.PSR_NAME = B.PSR_NAME&#xD;&#xA;   AND C.PSR_VER = B.ACTIVE_VER&#xD;&#xA; WHERE A.FACTORY = @factory&#xD;&#xA;   AND A.EQP_TYPE = @eq_type">
            <QP N="factory" />
            <QP N="eq_type" />
          </QY>
        </SG>
        <SG _S="3932" N="ListParameter">
          <QY P="MsSql" Q="SELECT A.PARA_ID, B.PARA_DESC,&#xD;&#xA;       A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5,&#xD;&#xA;	   B.PARA_FORMAT, B.PARA_DECIMAL_POINT, B.PARA_UNIT, B.MANAGE_FLAG&#xD;&#xA;  FROM QTMSMASRPR A&#xD;&#xA;  LEFT JOIN QTMSPARDEF B&#xD;&#xA;    ON A.FACTORY    = B.FACTORY&#xD;&#xA;   AND A.TYPE       = B.TYPE&#xD;&#xA;   AND A.PARA_ID    = B.PARA_ID&#xD;&#xA;   AND A.PARA_GROUP = B.PARA_GROUP&#xD;&#xA;   AND A.PARA_CAT_1 = B.PARA_CAT_1&#xD;&#xA;   AND A.PARA_CAT_2 = B.PARA_CAT_2&#xD;&#xA;   AND A.PARA_CAT_3 = B.PARA_CAT_3&#xD;&#xA;   AND A.PARA_CAT_4 = B.PARA_CAT_4&#xD;&#xA;   AND A.PARA_CAT_5 = B.PARA_CAT_5&#xD;&#xA; WHERE A.FACTORY      = @factory&#xD;&#xA;   AND A.TYPE         = @type&#xD;&#xA;   AND A.RCP_ID       = @rcp_id&#xD;&#xA;   AND A.RCP_VER      = @rcp_ver">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="rcp_ver" />
          </QY>
        </SG>
        <SG _S="3482" N="ListMasterSpecParameter">
          <QY P="MsSql" Q="SELECT SPEC_VER, PARA_ID, PARA_GROUP, PARA_CAT_1, PARA_CAT_2, PARA_CAT_3, PARA_CAT_4, PARA_CAT_5, &#xD;&#xA;       PARA_VALIDATION_RULE, PARA_TARGET_VALUE,PARA_USL, PARA_UCL, PARA_LCL, PARA_LSL&#xD;&#xA;  FROM QTMSMASSVP&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TYPE     = @type&#xD;&#xA;   AND RCP_ID   = @rcp_id&#xD;&#xA;   AND SPEC_VER = @spec_ver">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="spec_ver" />
          </QY>
        </SG>
        <SG _S="3483" N="ListEquipmentSpecParameter">
          <QY P="MsSql" Q="SELECT SPEC_VER, PARA_ID, PARA_GROUP, PARA_CAT_1, PARA_CAT_2, PARA_CAT_3, PARA_CAT_4, PARA_CAT_5, &#xD;&#xA;       PARA_VALIDATION_RULE, PARA_TARGET_VALUE,PARA_USL, PARA_UCL, PARA_LCL, PARA_LSL&#xD;&#xA;  FROM QTMSEQPSVP&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TYPE     = @type&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND RCP_ID   = @rcp_id&#xD;&#xA;   AND SPEC_VER = @spec_ver">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="spec_ver" />
          </QY>
        </SG>
        <SG _S="3487" N="InsertRecipeValidationHistory">
          <QY P="MsSql" Q="INSERT INTO QTMSRCPVAH (&#xD;&#xA;   FACTORY,&#xD;&#xA;   TYPE,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   RCP_ID,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   RCP_RESULT,&#xD;&#xA;   RCP_REASON,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT&#xD;&#xA;   )&#xD;&#xA;VALUES( &#xD;&#xA;   @factory,&#xD;&#xA;   @type,&#xD;&#xA;   @eqp_name,&#xD;&#xA;   @rcp_id,&#xD;&#xA;   @last_hist_seq,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @rcp_result,&#xD;&#xA;   @rcp_reason,&#xD;&#xA;   @tran_user_id,&#xD;&#xA;   @tran_comment)">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="last_hist_seq" />
            <QP N="tran_time" />
            <QP N="rcp_result" />
            <QP N="rcp_reason" />
            <QP N="tran_user_id" />
            <QP N="tran_comment" />
          </QY>
        </SG>
        <SG _S="3933" N="InsertRecipeValidationHistoryFile">
          <QY P="MsSql" Q="INSERT INTO QTMSRCPVFL (&#xD;&#xA;  FACTORY,&#xD;&#xA;  TYPE,&#xD;&#xA;  EQP_NAME,&#xD;&#xA;  RCP_ID,&#xD;&#xA;  HIST_SEQ,&#xD;&#xA;  EQP_PATH,&#xD;&#xA;  SERVER_BODY_PATH,&#xD;&#xA;  SERVER_MSG_PATH,&#xD;&#xA;  TRAN_USER_ID,&#xD;&#xA;  TRAN_COMMENT&#xD;&#xA;) VALUES (&#xD;&#xA;  @factory,&#xD;&#xA;  @type,&#xD;&#xA;  @eqp_name,&#xD;&#xA;  @rcp_id,&#xD;&#xA;  @last_hist_seq,&#xD;&#xA;  @eqp_path,&#xD;&#xA;  @server_body_path,&#xD;&#xA;  @server_msg_path,&#xD;&#xA;  @tran_user_id,&#xD;&#xA;   @tran_comment&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="last_hist_seq" />
            <QP N="eqp_path" />
            <QP N="server_body_path" />
            <QP N="server_msg_path" />
            <QP N="tran_user_id" />
            <QP N="tran_comment" />
          </QY>
        </SG>
        <SG _S="3488" N="InsertRecipeValidationHistoryParameter">
          <QY P="MsSql" Q="INSERT INTO QTMSRCPPVH(&#xD;&#xA;   FACTORY,&#xD;&#xA;   TYPE,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   RCP_ID,   &#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   PARA_ID,&#xD;&#xA;   PARA_DESC,&#xD;&#xA;   PARA_GROUP,&#xD;&#xA;   PARA_CAT_1,&#xD;&#xA;   PARA_CAT_2,&#xD;&#xA;   PARA_CAT_3, &#xD;&#xA;   PARA_CAT_4, &#xD;&#xA;   PARA_CAT_5,&#xD;&#xA;   PARA_FORMAT,&#xD;&#xA;   PARA_DECIMAL_POINT,&#xD;&#xA;   PARA_UNIT,&#xD;&#xA;   PARA_VALUE,&#xD;&#xA;   PARA_VALIDATION,&#xD;&#xA;   SPEC_MEMBER,&#xD;&#xA;   SPEC_VER,&#xD;&#xA;   PARA_VALIDATION_RULE,&#xD;&#xA;   PARA_TARGET_VALUE, &#xD;&#xA;   PARA_USL,&#xD;&#xA;   PARA_UCL,&#xD;&#xA;   PARA_LCL,&#xD;&#xA;   PARA_LSL,&#xD;&#xA;   PARA_RESULT,&#xD;&#xA;   PARA_REASON&#xD;&#xA;   )&#xD;&#xA;VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @type,&#xD;&#xA;   @eqp_name,&#xD;&#xA;   @rcp_id,   &#xD;&#xA;   @last_hist_seq,&#xD;&#xA;   @para_id,&#xD;&#xA;   @para_desc,&#xD;&#xA;   @para_group,&#xD;&#xA;   @para_cat1,&#xD;&#xA;   @para_cat2,&#xD;&#xA;   @para_cat3,&#xD;&#xA;   @para_cat4,&#xD;&#xA;   @para_cat5,&#xD;&#xA;   @para_format,&#xD;&#xA;   @para_decimal_point,&#xD;&#xA;   @para_unit,&#xD;&#xA;   @para_value,&#xD;&#xA;   @para_validation,&#xD;&#xA;   @spec_member,&#xD;&#xA;   @spec_ver,&#xD;&#xA;   @para_validation_rule,&#xD;&#xA;   @para_target_value,&#xD;&#xA;   @para_usl,&#xD;&#xA;   @para_ucl,&#xD;&#xA;   @para_lcl,&#xD;&#xA;   @para_lsl,&#xD;&#xA;   @para_result,&#xD;&#xA;   @para_reason&#xD;&#xA;   )">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="last_hist_seq" />
            <QP N="para_id" />
            <QP N="para_desc" />
            <QP N="para_group" />
            <QP N="para_cat1" />
            <QP N="para_cat2" />
            <QP N="para_cat3" />
            <QP N="para_cat4" />
            <QP N="para_cat5" />
            <QP N="para_format" />
            <QP N="para_decimal_point" />
            <QP N="para_unit" />
            <QP N="para_value" />
            <QP N="para_validation" />
            <QP N="spec_member" />
            <QP N="spec_ver" />
            <QP N="para_validation_rule" />
            <QP N="para_target_value" />
            <QP N="para_usl" />
            <QP N="para_ucl" />
            <QP N="para_lcl" />
            <QP N="para_lsl" />
            <QP N="para_result" />
            <QP N="para_reason" />
          </QY>
        </SG>
        <SG _S="3489" N="InsertRecipeAlarm">
          <QY P="MsSql" Q="INSERT INTO QTMSRCPALM (&#xD;&#xA;   FACTORY,&#xD;&#xA;   TYPE,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   RCP_ID,&#xD;&#xA;   EVENT_ID,&#xD;&#xA;   RCP_RESULT,&#xD;&#xA;   RCP_REASON,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT&#xD;&#xA;)&#xD;&#xA;VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @type,&#xD;&#xA;   @eqp_name,&#xD;&#xA;   @last_hist_seq,&#xD;&#xA;   @tran_time,   &#xD;&#xA;   @rcp_id,&#xD;&#xA;   @event_id,&#xD;&#xA;   @rcp_result,&#xD;&#xA;   @rcp_reason,&#xD;&#xA;   @tran_user_id,&#xD;&#xA;   @tran_comment)">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="last_hist_seq" />
            <QP N="tran_time" />
            <QP N="rcp_id" />
            <QP N="event_id" />
            <QP N="rcp_result" />
            <QP N="rcp_reason" />
            <QP N="tran_user_id" />
            <QP N="tran_comment" />
          </QY>
        </SG>
        <SG _S="3496" N="InsertEquipmentRecipe">
          <QY P="MsSql" Q="INSERT INTO QTMSEQPRCP (&#xD;&#xA;  FACTORY,&#xD;&#xA;  TYPE,&#xD;&#xA;  EQP_NAME,&#xD;&#xA;  RCP_ID,&#xD;&#xA;  RCP_CLASS,&#xD;&#xA;  RCP_HOLD,&#xD;&#xA;  LAST_RCP_VER,&#xD;&#xA;  LAST_EVENT_ID,&#xD;&#xA;  LAST_EVENT_TIME,&#xD;&#xA;  LAST_HIST_SEQ,&#xD;&#xA;  DELETE_FLAG,   &#xD;&#xA;  CREATE_USER_ID,&#xD;&#xA;  CREATE_TIME,&#xD;&#xA;  UPDATE_USER_ID,&#xD;&#xA;  UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;  @factory,&#xD;&#xA;  @type,&#xD;&#xA;  @eqp_name,&#xD;&#xA;  @rcp_id,&#xD;&#xA;  @rcp_class,&#xD;&#xA;  @rcp_hold,&#xD;&#xA;  @last_rcp_ver,&#xD;&#xA;  @last_event_id,&#xD;&#xA;  @last_event_time,&#xD;&#xA;  @last_hist_seq,&#xD;&#xA;  @delete_flag,   &#xD;&#xA;  @create_user_id,&#xD;&#xA;  @create_time,&#xD;&#xA;  @update_user_id,&#xD;&#xA;  @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="rcp_class" />
            <QP N="rcp_hold" />
            <QP N="last_rcp_ver" />
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="last_hist_seq" />
            <QP N="delete_flag" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="3497" N="InsertEquipmentRecipeVersion">
          <QY P="MsSql" Q="INSERT INTO QTMSEQPRVR (&#xD;&#xA;   FACTORY,&#xD;&#xA;   TYPE,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   RCP_ID,&#xD;&#xA;   RCP_VER,&#xD;&#xA;   MAS_RCP_VER,&#xD;&#xA;   VALIDATION_HIST_SEQ,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @type,&#xD;&#xA;   @eqp_name,&#xD;&#xA;   @rcp_id,&#xD;&#xA;   @rcp_ver,&#xD;&#xA;   @mas_rcp_ver,&#xD;&#xA;   @validation_hist_seq,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="rcp_ver" />
            <QP N="mas_rcp_ver" />
            <QP N="validation_hist_seq" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="4473" N="InsertEquipmentRecipeSequenceStep">
          <QY P="MsSql" Q="INSERT INTO QTMSEQPRSQ (&#xD;&#xA;   FACTORY,&#xD;&#xA;   TYPE,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   RCP_ID,&#xD;&#xA;   RCP_VER,&#xD;&#xA;   PROC_STEP,&#xD;&#xA;   PROC_RCP_ID,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @type,&#xD;&#xA;   @eqp_name,&#xD;&#xA;   @rcp_id,&#xD;&#xA;   @rcp_ver,&#xD;&#xA;   @proc_step,&#xD;&#xA;   @proc_rcp_id,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="rcp_ver" />
            <QP N="proc_step" />
            <QP N="proc_rcp_id" />
            <QP N="create_user_id" />
