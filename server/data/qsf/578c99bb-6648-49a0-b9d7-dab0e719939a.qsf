        <SG _S="3643" N="InsertApprovalItem">
          <QY P="MsSql" Q="INSERT INTO QTMSAPRITM(&#xD;&#xA;   FACTORY,&#xD;&#xA;   APR_SEQ,&#xD;&#xA;   APR_TYPE,&#xD;&#xA;   APQ_TIME,&#xD;&#xA;   APQ_USER_ID,&#xD;&#xA;   APR_LINE_NAME,&#xD;&#xA;   APR_CURR_STEP,&#xD;&#xA;   APR_LAST_STEP,&#xD;&#xA;   STATUS,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @apr_seq,&#xD;&#xA;   @apr_type,&#xD;&#xA;   @apq_time,&#xD;&#xA;   @apq_user_id,&#xD;&#xA;   @apr_line_name,&#xD;&#xA;   @apr_curr_step,&#xD;&#xA;   @apr_last_step,&#xD;&#xA;   @status,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="apr_seq" />
            <QP N="apr_type" />
            <QP N="apq_time" />
            <QP N="apq_user_id" />
            <QP N="apr_line_name" />
            <QP N="apr_curr_step" />
            <QP N="apr_last_step" />
            <QP N="status" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="3743" N="InsertApprovalFile">
