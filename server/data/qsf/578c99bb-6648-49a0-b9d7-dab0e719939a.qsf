        </SG>
        <SG _S="4293" N="ListMasterRecipe">
          <QY P="MsSql" Q="SELECT RCP_ID, RCP_DESC, RCP_ACTIVE, RCP_HOLD&#xD;&#xA;  FROM QTMSMASRCP&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND TYPE         = @type&#xD;&#xA;   AND DELETE_FLAG &lt;&gt; 'Y'&#xD;&#xA; ORDER BY RCP_ID">
            <QP N="factory" />
            <QP N="type" />
