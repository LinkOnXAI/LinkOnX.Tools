            <QP N="server_body_path" />
            <QP N="server_msg_path" />
            <QP N="server_msg_length" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="3499" N="UpdateEquipmentRecipeByRevision">
          <QY P="MsSql" Q="UPDATE QTMSEQPRCP SET&#xD;&#xA;  RCP_CLASS       = @rcp_class,&#xD;&#xA;  LAST_RCP_VER    = @last_rcp_ver,&#xD;&#xA;  LAST_EVENT_ID   = @last_event_id,&#xD;&#xA;  LAST_EVENT_TIME = @last_event_time,&#xD;&#xA;  LAST_HIST_SEQ   = @last_hist_seq,&#xD;&#xA;  DELETE_FLAG     = 'N',&#xD;&#xA;  UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;  UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND TYPE       = @type&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;   AND RCP_ID     = @rcp_id">
