      <F _S="2827" N="EquipmentHistory">
        <SG _S="2828" N="SearchEquipmentHistory">
          <QY P="MsSql" Q="SELECT  TRAN_TIME, EQP_NAME, EVENT_ID, COMM_STATE, CTRL_MODE, PROC_STATE, EQP_RCP_ID, TRAN_USER_ID,&#xD;&#xA;        EVT_H_1, EVT_D_1, EVT_H_2, EVT_D_2, EVT_H_3, EVT_D_3, EVT_H_4, EVT_D_4, EVT_H_5, EVT_D_5, &#xD;&#xA;        EVT_H_6, EVT_D_6, EVT_H_7, EVT_D_7, EVT_H_8, EVT_D_8, EVT_H_9, EVT_D_9, EVT_H_10, EVT_D_10, &#xD;&#xA;        EVT_H_11, EVT_D_11, EVT_H_12, EVT_D_12, EVT_H_13, EVT_D_13, EVT_H_14, EVT_D_14, EVT_H_15, EVT_D_15, &#xD;&#xA;        EVT_H_16, EVT_D_16, EVT_H_17, EVT_D_17, EVT_H_18, EVT_D_18, EVT_H_19, EVT_D_19, EVT_H_20, EVT_D_20,&#xD;&#xA;        TRAN_COMMENT&#xD;&#xA;   FROM QTMSEQPHIS&#xD;&#xA;  WHERE FACTORY      = @factory&#xD;&#xA;    AND EQP_NAME     = ISNULL(@eqp_name, EQP_NAME)&#xD;&#xA;    AND TRAN_TIME   &gt;= @tran_from_time&#xD;&#xA;    AND TRAN_TIME   &lt;= ISNULL(@tran_to_time, TRAN_TIME)&#xD;&#xA; ORDER BY TRAN_TIME DESC ">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
        <SG _S="4138" N="SearchEquipmentHistoryPaging">
          <QY P="MsSql" Q="SELECT  TRAN_TIME, EQP_NAME, EVENT_ID, COMM_STATE, CTRL_MODE, PROC_STATE, EQP_RCP_ID, TRAN_USER_ID,&#xD;&#xA;        EVT_H_1, EVT_D_1, EVT_H_2, EVT_D_2, EVT_H_3, EVT_D_3, EVT_H_4, EVT_D_4, EVT_H_5, EVT_D_5, &#xD;&#xA;        EVT_H_6, EVT_D_6, EVT_H_7, EVT_D_7, EVT_H_8, EVT_D_8, EVT_H_9, EVT_D_9, EVT_H_10, EVT_D_10, &#xD;&#xA;        EVT_H_11, EVT_D_11, EVT_H_12, EVT_D_12, EVT_H_13, EVT_D_13, EVT_H_14, EVT_D_14, EVT_H_15, EVT_D_15, &#xD;&#xA;        EVT_H_16, EVT_D_16, EVT_H_17, EVT_D_17, EVT_H_18, EVT_D_18, EVT_H_19, EVT_D_19, EVT_H_20, EVT_D_20,&#xD;&#xA;        TRAN_COMMENT&#xD;&#xA;   FROM QTMSEQPHIS&#xD;&#xA;  WHERE FACTORY      = @factory&#xD;&#xA;    AND EQP_NAME     = ISNULL(@eqp_name, EQP_NAME)&#xD;&#xA;    AND TRAN_TIME   &gt;= @tran_from_time&#xD;&#xA;    AND TRAN_TIME   &lt;= ISNULL(@tran_to_time, TRAN_TIME)&#xD;&#xA; ORDER BY TRAN_TIME DESC&#xD;&#xA; OFFSET (CONVERT(int, @PAGE_NO)-1) * CONVERT(int, @PAGE_SIZE) ROW FETCH NEXT CONVERT(int, @PAGE_SIZE) ROW ONLY">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
            <QP N="PAGE_NO" />
            <QP N="PAGE_SIZE" />
          </QY>
        </SG>
        <SG _S="3310" N="CountEquipmentHistory">
          <QY P="MsSql" Q="SELECT COUNT(*) AS CNT&#xD;&#xA;   FROM QTMSEQPHIS&#xD;&#xA;  WHERE FACTORY      = @factory&#xD;&#xA;    AND EQP_NAME     = ISNULL(@eqp_name, EQP_NAME)&#xD;&#xA;    AND TRAN_TIME   &gt;= @tran_from_time&#xD;&#xA;    AND TRAN_TIME   &lt;= ISNULL(@tran_to_time, TRAN_TIME)">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
      </F>
      <F _S="2842" N="RecipeValidationHistory">
        <SG _S="4178" N="ListRecipeHistory">
          <QY P="MsSql" Q="SELECT HIS.HIST_SEQ, HIS.TRAN_TIME, &#xD;&#xA;       HIS.TYPE, HIS.EQP_NAME, HIS.RCP_ID, HIS.RCP_DESC, ISNULL(RCP.RCP_CLASS, ' ') AS RCP_CLASS,&#xD;&#xA;	   HIS.RCP_RESULT, HIS.RCP_REASON&#xD;&#xA;  FROM QTMSRCPVAH HIS&#xD;&#xA;  LEFT JOIN QTMSMASRCP RCP&#xD;&#xA;    ON HIS.FACTORY    = RCP.FACTORY&#xD;&#xA;   AND HIS.TYPE       = RCP.TYPE&#xD;&#xA;   AND HIS.RCP_ID     = RCP.RCP_ID&#xD;&#xA; WHERE HIS.FACTORY    = @factory&#xD;&#xA;   AND HIS.TYPE       = ISNULL(@type, HIS.TYPE)&#xD;&#xA;   AND HIS.EQP_NAME   = ISNULL(@eqp_name, HIS.EQP_NAME)&#xD;&#xA;   AND HIS.RCP_ID     = ISNULL(@rcp_id, HIS.RCP_ID)&#xD;&#xA;   AND HIS.TRAN_TIME &gt;= @tran_from_time&#xD;&#xA;   AND HIS.TRAN_TIME &lt;= @tran_to_time&#xD;&#xA; ORDER BY HIS.HIST_SEQ DESC">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
        <SG _S="2844" N="ListParameterHistory">
          <QY P="MsSql" Q="SELECT PARA_ID, PARA_DESC, PARA_GROUP, PARA_CAT_1, PARA_CAT_2, PARA_CAT_3, PARA_CAT_4, PARA_CAT_5,&#xD;&#xA;       PARA_FORMAT,PARA_VALUE, &#xD;&#xA;	   PARA_RESULT, PARA_REASON, PARA_VALIDATION, &#xD;&#xA;	   SPEC_MEMBER, SPEC_VER, PARA_VALIDATION_RULE,   &#xD;&#xA;	   PARA_TARGET_VALUE, PARA_USL, PARA_UCL, PARA_LCL, PARA_LSL&#xD;&#xA;  FROM QTMSRCPPVH&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND EQP_NAME    = @eqp_name&#xD;&#xA;   AND RCP_ID      = @rcp_id&#xD;&#xA;   AND HIST_SEQ    = @hist_seq&#xD;&#xA;   AND PARA_RESULT = ISNULL(@para_result, PARA_RESULT)&#xD;&#xA; ORDER BY PARA_GROUP, PARA_CAT_1, PARA_CAT_2, PARA_CAT_3, PARA_CAT_4, PARA_CAT_5, PARA_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="hist_seq" />
            <QP N="para_result" />
          </QY>
        </SG>
        <SG _S="4179" N="ListParameterHistoryPaging">
          <QY P="MsSql" Q="SELECT PARA_ID, PARA_DESC, PARA_GROUP, PARA_CAT_1, PARA_CAT_2, PARA_CAT_3, PARA_CAT_4, PARA_CAT_5,&#xD;&#xA;       PARA_FORMAT,PARA_VALUE, &#xD;&#xA;	   PARA_RESULT, PARA_REASON, PARA_VALIDATION, &#xD;&#xA;	   SPEC_MEMBER, SPEC_VER, PARA_VALIDATION_RULE,   &#xD;&#xA;	   PARA_TARGET_VALUE, PARA_USL, PARA_UCL, PARA_LCL, PARA_LSL&#xD;&#xA;  FROM QTMSRCPPVH&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND TYPE       = @type&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;   AND RCP_ID     = @rcp_id&#xD;&#xA;   AND HIST_SEQ   = @hist_seq&#xD;&#xA; ORDER BY PARA_GROUP, PARA_CAT_1, PARA_CAT_2, PARA_CAT_3, PARA_CAT_4, PARA_CAT_5, PARA_ID&#xD;&#xA; OFFSET (CONVERT(int, @PAGE_NO)-1) * CONVERT(int, @PAGE_SIZE) ROW FETCH NEXT CONVERT(int, @PAGE_SIZE) ROW ONLY">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="hist_seq" />
            <QP N="PAGE_NO" />
            <QP N="PAGE_SIZE" />
          </QY>
        </SG>
        <SG _S="4182" N="CountParameterHistory">
          <QY P="MsSql" Q="SELECT COUNT(*) AS CNT&#xD;&#xA;  FROM QTMSRCPPVH&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND TYPE       = @type&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;   AND RCP_ID     = @rcp_id&#xD;&#xA;   AND HIST_SEQ   = @hist_seq">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="hist_seq" />
          </QY>
        </SG>
      </F>
      <F _S="3353" N="RecipeValidationParaTrend">
        <SG _S="3355" N="SearchParameterHistory">
          <QY P="MsSql" Q="SELECT B.TRAN_TIME, A.PARA_VALUE, A.PARA_RESULT, A.PARA_REASON, &#xD;&#xA;       A.SPEC_MEMBER, A.SPEC_VER,&#xD;&#xA;	   A.PARA_VALIDATION_RULE, A.PARA_TARGET_VALUE, A.PARA_USL, A.PARA_UCL, A.PARA_LCL, A.PARA_LSL&#xD;&#xA;  FROM QTMSRCPPVH  A &#xD;&#xA;  LEFT JOIN QTMSRCPVAH B &#xD;&#xA;    ON A.HIST_SEQ = B.HIST_SEQ&#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND B.TYPE        = @type&#xD;&#xA;   AND B.EQP_NAME    = @eqp_name   &#xD;&#xA;   AND B.RCP_ID      = @rcp_id&#xD;&#xA;   AND A.PARA_ID     = @para_id&#xD;&#xA;   AND A.PARA_GROUP  = @para_group&#xD;&#xA;   AND A.PARA_CAT_1  = @para_cat1&#xD;&#xA;   AND A.PARA_CAT_2  = @para_cat2&#xD;&#xA;   AND A.PARA_CAT_3  = @para_cat3&#xD;&#xA;   AND A.PARA_CAT_4  = @para_cat4&#xD;&#xA;   AND A.PARA_CAT_5  = @para_cat5   &#xD;&#xA;   AND B.TRAN_TIME  &gt;= @tran_from_time&#xD;&#xA;   AND B.TRAN_TIME  &lt;= @tran_to_time&#xD;&#xA; ORDER BY B.TRAN_TIME">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="para_id" />
            <QP N="para_group" />
            <QP N="para_cat1" />
            <QP N="para_cat2" />
            <QP N="para_cat3" />
            <QP N="para_cat4" />
            <QP N="para_cat5" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
        <SG _S="4232" N="ListParameter">
          <QY P="MsSql" Q="SELECT PARA_ID, PARA_DESC, 	&#xD;&#xA;       PARA_GROUP, PARA_CAT_1, PARA_CAT_2, PARA_CAT_3, PARA_CAT_4, PARA_CAT_5,&#xD;&#xA;	   PARA_FORMAT, MANAGE_FLAG&#xD;&#xA;  FROM QTMSPARDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY PARA_GROUP, PARA_CAT_1, PARA_CAT_2, PARA_CAT_3, PARA_CAT_4, PARA_CAT_5, PARA_ID">
            <QP N="factory" />
            <QP N="type" />
          </QY>
        </SG>
      </F>
      <F _S="2948" N="RecipeCompare">
        <SG _S="2949" N="X-SearchRecipeMasterParameter">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;	PARA_ID, &#xD;&#xA;	PARA_VALUE, &#xD;&#xA;	PARA_VALIDATION, &#xD;&#xA;	PARA_VALIDATION_RULE,&#xD;&#xA;       PARA_TARGET_VALUE, &#xD;&#xA;       PARA_USL, &#xD;&#xA;       PARA_UCL, &#xD;&#xA;       PARA_LCL, &#xD;&#xA;       PARA_LSL&#xD;&#xA;  FROM QTMSMASRVP&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND TYPE       	   = @type&#xD;&#xA;   AND RCP_ID	   = @rcp_id&#xD;&#xA;   AND RCP_VER       = @rcp_ver">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="rcp_ver" />
          </QY>
        </SG>
        <SG _S="4211" N="ListMasterRecipeParameter">
          <QY P="MsSql" Q="SELECT A.PARA_ID, B.PARA_DESC,&#xD;&#xA;       A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5,&#xD;&#xA;	 B.PARA_FORMAT, A.PARA_VALUE&#xD;&#xA;  FROM QTMSMASRPR A&#xD;&#xA;  LEFT JOIN QTMSPARDEF B&#xD;&#xA;    ON A.FACTORY    = B.FACTORY&#xD;&#xA;   AND A.TYPE       = B.TYPE&#xD;&#xA;   AND A.PARA_ID    = B.PARA_ID&#xD;&#xA;   AND A.PARA_GROUP = B.PARA_GROUP&#xD;&#xA;   AND A.PARA_CAT_1 = B.PARA_CAT_1&#xD;&#xA;   AND A.PARA_CAT_2 = B.PARA_CAT_2&#xD;&#xA;   AND A.PARA_CAT_3 = B.PARA_CAT_3&#xD;&#xA;   AND A.PARA_CAT_4 = B.PARA_CAT_4&#xD;&#xA;   AND A.PARA_CAT_5 = B.PARA_CAT_5&#xD;&#xA; WHERE A.FACTORY      = @factory&#xD;&#xA;   AND A.TYPE         = @type&#xD;&#xA;   AND A.RCP_ID       = @rcp_id&#xD;&#xA;   AND A.RCP_VER      = @rcp_ver&#xD;&#xA; ORDER BY A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5, A.PARA_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="rcp_ver" />
          </QY>
        </SG>
        <SG _S="4350" N="ListTemporaryRecipeParameter">
          <QY P="MsSql" Q="SELECT A.PARA_ID, B.PARA_DESC,&#xD;&#xA;       A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5,&#xD;&#xA;	 B.PARA_FORMAT, A.EQ_PARA_VALUE AS PARA_VALUE&#xD;&#xA;  FROM QTMSTMPRPR A&#xD;&#xA;  LEFT JOIN QTMSPARDEF B&#xD;&#xA;    ON A.FACTORY    = B.FACTORY&#xD;&#xA;   AND A.TYPE       = B.TYPE&#xD;&#xA;   AND A.PARA_ID    = B.PARA_ID&#xD;&#xA;   AND A.PARA_GROUP = B.PARA_GROUP&#xD;&#xA;   AND A.PARA_CAT_1 = B.PARA_CAT_1&#xD;&#xA;   AND A.PARA_CAT_2 = B.PARA_CAT_2&#xD;&#xA;   AND A.PARA_CAT_3 = B.PARA_CAT_3&#xD;&#xA;   AND A.PARA_CAT_4 = B.PARA_CAT_4&#xD;&#xA;   AND A.PARA_CAT_5 = B.PARA_CAT_5&#xD;&#xA; WHERE A.FACTORY      = @factory&#xD;&#xA;   AND A.TYPE         = @type&#xD;&#xA;   AND A.EQP_NAME     = @eqp_name&#xD;&#xA;   AND A.RCP_ID       = @rcp_id&#xD;&#xA; ORDER BY A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5, A.PARA_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
          </QY>
        </SG>
        <SG _S="4226" N="X-CountEquipmentRecipeParameter">
          <QY P="MsSql" Q="SELECT COUNT(*) AS CNT&#xD;&#xA;  FROM QTMSRCPPVH&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE    = @type&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND RCP_ID  = @rcp_id&#xD;&#xA;   AND HIST_SEQ = @hist_seq">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="hist_seq" />
          </QY>
        </SG>
        <SG _S="4349" N="CountTemporaryRecipeParameter">
          <QY P="MsSql" Q="SELECT COUNT(*) AS CNT&#xD;&#xA;  FROM QTMSTMPRPR&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TYPE     = @type&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND RCP_ID   = @rcp_id">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
          </QY>
        </SG>
        <SG _S="4227" N="CountMasterRecipeParameter">
          <QY P="MsSql" Q="SELECT COUNT(*) AS CNT&#xD;&#xA;  FROM QTMSMASRPR&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE    = @type&#xD;&#xA;   AND RCP_ID  = @rcp_id&#xD;&#xA;   AND RCP_VER = @rcp_ver">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="rcp_ver" />
          </QY>
        </SG>
        <SG _S="4212" N="X-ListEquipmentRecipeParameter">
          <QY P="MsSql" Q="SELECT A.PARA_ID, B.PARA_DESC,&#xD;&#xA;       A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5,&#xD;&#xA;       B.PARA_FORMAT, A.PARA_VALUE, B.MANAGE_FLAG   &#xD;&#xA;  FROM QTMSRCPPVH A&#xD;&#xA;  LEFT JOIN QTMSPARDEF B&#xD;&#xA;    ON A.FACTORY    = B.FACTORY&#xD;&#xA;   AND A.TYPE       = B.TYPE&#xD;&#xA;   AND A.PARA_ID    = B.PARA_ID&#xD;&#xA;   AND A.PARA_GROUP = B.PARA_GROUP&#xD;&#xA;   AND A.PARA_CAT_1 = B.PARA_CAT_1&#xD;&#xA;   AND A.PARA_CAT_2 = B.PARA_CAT_2&#xD;&#xA;   AND A.PARA_CAT_3 = B.PARA_CAT_3&#xD;&#xA;   AND A.PARA_CAT_4 = B.PARA_CAT_4&#xD;&#xA;   AND A.PARA_CAT_5 = B.PARA_CAT_5&#xD;&#xA; WHERE A.FACTORY    = @factory&#xD;&#xA;   AND A.TYPE       = @type&#xD;&#xA;   AND EQP_NAME     = @eqp_name&#xD;&#xA;   AND A.RCP_ID     = @rcp_id&#xD;&#xA;   AND HIST_SEQ     = @hist_seq&#xD;&#xA; ORDER BY A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5, A.PARA_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="hist_seq" />
          </QY>
        </SG>
        <SG _S="4225" N="X-SearchRecipeHistorySeq">
          <QY P="MsSql" Q="SELECT VALIDATION_HIST_SEQ&#xD;&#xA;  FROM QTMSEQPRVR&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND TYPE         = @type&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND RCP_ID       = @rcp_id&#xD;&#xA;   AND RCP_VER = @rcp_ver">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="rcp_ver" />
          </QY>
        </SG>
        <SG _S="2950" N="X-SearchRecipeEquipmentParameter">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;	PARA_ID, &#xD;&#xA;	PARA_VALUE, &#xD;&#xA;	PARA_VALIDATION, &#xD;&#xA;	PARA_VALIDATION_RULE,&#xD;&#xA;       PARA_TARGET_VALUE, &#xD;&#xA;       PARA_USL, &#xD;&#xA;       PARA_UCL, &#xD;&#xA;       PARA_LCL, &#xD;&#xA;       PARA_LSL&#xD;&#xA;  FROM QTMSEQPRVP&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND TYPE       	   = @type&#xD;&#xA;   AND EQP_NAME     = @eqp_name&#xD;&#xA;   AND RCP_ID	   = @rcp_id&#xD;&#xA;   AND RCP_VER       = @rcp_ver">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="rcp_ver" />
          </QY>
        </SG>
      </F>
      <F _S="4279" N="SpecificationCompare">
        <SG _S="4280" N="ListMasterParameter">
          <QY P="MsSql" Q="SELECT A.PARA_ID, B.PARA_DESC, &#xD;&#xA;       A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5,&#xD;&#xA;	   B.PARA_FORMAT, A.PARA_VALUE,&#xD;&#xA;	   A.PARA_VALIDATION_RULE,&#xD;&#xA;       A.PARA_TARGET_VALUE, A.PARA_USL, A.PARA_UCL, A.PARA_LCL, A.PARA_LSL&#xD;&#xA;  FROM &#xD;&#xA;     (&#xD;&#xA;SELECT FACTORY, TYPE, &#xD;&#xA;       PARA_ID, PARA_LEVEL,&#xD;&#xA;	   PARA_VALUE,&#xD;&#xA;	   PARA_VALIDATION, PARA_VALIDATION_RULE,&#xD;&#xA;	   PARA_GROUP, PARA_CAT_1, PARA_CAT_2, PARA_CAT_3, PARA_CAT_4, PARA_CAT_5,&#xD;&#xA;	   PARA_TARGET_VALUE, PARA_USL, PARA_UCL, PARA_LCL, PARA_LSL&#xD;&#xA;  FROM QTMSMASSVP&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND TYPE      = @type&#xD;&#xA;   AND RCP_ID    = @rcp_id&#xD;&#xA;   AND SPEC_VER  = @spec_ver&#xD;&#xA;     ) AS A&#xD;&#xA; LEFT JOIN QTMSPARDEF B&#xD;&#xA;    ON A.FACTORY    = B.FACTORY&#xD;&#xA;   AND A.TYPE       = B.TYPE&#xD;&#xA;   AND A.PARA_ID    = B.PARA_ID&#xD;&#xA;   AND A.PARA_GROUP = B.PARA_GROUP&#xD;&#xA;   AND A.PARA_CAT_1 = B.PARA_CAT_1&#xD;&#xA;   AND A.PARA_CAT_2 = B.PARA_CAT_2&#xD;&#xA;   AND A.PARA_CAT_3 = B.PARA_CAT_3&#xD;&#xA;   AND A.PARA_CAT_4 = B.PARA_CAT_4&#xD;&#xA;   AND A.PARA_CAT_5 = B.PARA_CAT_5&#xD;&#xA; ORDER BY A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5, A.PARA_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="spec_ver" />
          </QY>
        </SG>
        <SG _S="4286" N="CountMasterParameter">
          <QY P="MsSql" Q="SELECT COUNT(*) AS CNT&#xD;&#xA;  FROM QTMSMASSVP&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND TYPE      = @type&#xD;&#xA;   AND RCP_ID    = @rcp_id&#xD;&#xA;   AND SPEC_VER  = @spec_ver">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="spec_ver" />
          </QY>
        </SG>
        <SG _S="4285" N="CountEquipmentParameter">
          <QY P="MsSql" Q="SELECT COUNT(*) AS CNT&#xD;&#xA;  FROM QTMSEQPSVP&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND TYPE      = @type&#xD;&#xA;   AND EQP_NAME  = @eqp_name&#xD;&#xA;   AND RCP_ID    = @rcp_id&#xD;&#xA;   AND SPEC_VER  = @spec_ver">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="spec_ver" />
          </QY>
        </SG>
        <SG _S="4283" N="ListEquipmentParameter">
          <QY P="MsSql" Q="SELECT A.PARA_ID, B.PARA_DESC, &#xD;&#xA;       A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5,&#xD;&#xA;	   B.PARA_FORMAT, A.PARA_VALUE, &#xD;&#xA;	   A.PARA_VALIDATION_RULE,&#xD;&#xA;       A.PARA_TARGET_VALUE, A.PARA_USL, A.PARA_UCL, A.PARA_LCL, A.PARA_LSL&#xD;&#xA;  FROM &#xD;&#xA;     (&#xD;&#xA;SELECT FACTORY, TYPE, &#xD;&#xA;       PARA_ID, PARA_LEVEL,&#xD;&#xA;	   PARA_VALUE,&#xD;&#xA;	   PARA_VALIDATION, PARA_VALIDATION_RULE,&#xD;&#xA;	   PARA_GROUP, PARA_CAT_1, PARA_CAT_2, PARA_CAT_3, PARA_CAT_4, PARA_CAT_5,&#xD;&#xA;	   PARA_TARGET_VALUE, PARA_USL, PARA_UCL, PARA_LCL, PARA_LSL&#xD;&#xA;  FROM QTMSEQPSVP&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND TYPE      = @type&#xD;&#xA;   AND EQP_NAME  = @eqp_name&#xD;&#xA;   AND RCP_ID    = @rcp_id&#xD;&#xA;   AND SPEC_VER  = @spec_ver&#xD;&#xA;     ) AS A&#xD;&#xA; LEFT JOIN QTMSPARDEF B&#xD;&#xA;    ON A.FACTORY    = B.FACTORY&#xD;&#xA;   AND A.TYPE       = B.TYPE&#xD;&#xA;   AND A.PARA_ID    = B.PARA_ID&#xD;&#xA;   AND A.PARA_GROUP = B.PARA_GROUP&#xD;&#xA;   AND A.PARA_CAT_1 = B.PARA_CAT_1&#xD;&#xA;   AND A.PARA_CAT_2 = B.PARA_CAT_2&#xD;&#xA;   AND A.PARA_CAT_3 = B.PARA_CAT_3&#xD;&#xA;   AND A.PARA_CAT_4 = B.PARA_CAT_4&#xD;&#xA;   AND A.PARA_CAT_5 = B.PARA_CAT_5&#xD;&#xA; ORDER BY A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5, A.PARA_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="spec_ver" />
          </QY>
        </SG>
      </F>
      <F _S="3397" N="RecipeFileView">
        <SG _S="3413" N="SelectRecipeTempFile">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;FACTORY, &#xD;&#xA;TYPE, &#xD;&#xA;EQP_NAME, &#xD;&#xA;RCP_ID, &#xD;&#xA;SERVER_BODY_PATH&#xD;&#xA;FROM QTMSTMPRFL&#xD;&#xA; WHERE FACTORY 	= @factory&#xD;&#xA; AND TYPE 		= @type&#xD;&#xA; AND EQP_NAME 		= @eqpName&#xD;&#xA; AND RCP_ID 		= @recipeId">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqpName" />
            <QP N="recipeId" />
          </QY>
        </SG>
        <SG _S="3415" N="SelectRecipeMasterFile">
          <QY P="MsSql" Q="SELECT FACTORY, TYPE, RCP_ID, SERVER_BODY_PATH&#xD;&#xA;  FROM QTMSMASRFL&#xD;&#xA; WHERE FACTORY 	= @factory&#xD;&#xA; AND TYPE 		= @type&#xD;&#xA; AND RCP_ID 		= @recipeId">
            <QP N="factory" />
            <QP N="type" />
            <QP N="recipeId" />
          </QY>
        </SG>
        <SG _S="3414" N="SelectRecipeEquipmentFile">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;	FACTORY, &#xD;&#xA;	TYPE, &#xD;&#xA;	EQP_NAME, &#xD;&#xA;	RCP_ID, &#xD;&#xA;	RCP_VER, &#xD;&#xA;	SERVER_BODY_PATH&#xD;&#xA;  FROM QTMSEQPRFL&#xD;&#xA; WHERE FACTORY 	= @factory&#xD;&#xA; AND TYPE 		= @type&#xD;&#xA; AND EQP_NAME	= @eqpName&#xD;&#xA; AND RCP_ID 		= @recipeId&#xD;&#xA; AND RCP_VER = @rcp_ver">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqpName" />
            <QP N="recipeId" />
            <QP N="rcp_ver" />
          </QY>
        </SG>
      </F>
      <F _S="3236" N="RecipeFileParser">
        <SG _S="3239" N="ListType">
          <QY P="MsSql" Q="SELECT A.TYPE, B.TYPE_DESC , A.RCP_ID  AS RECIPE_ID , B.RECIPE_TYPE &#xD;&#xA; FROM QTMSTMPRFL A&#xD;&#xA; LEFT JOIN QTMSEQPTYP B&#xD;&#xA; ON A.FACTORY = B.FACTORY&#xD;&#xA; AND A.TYPE = B.TYPE&#xD;&#xA; WHERE A.FACTORY = @factory&#xD;&#xA; GROUP BY A.TYPE,  B.TYPE_DESC , A.RCP_ID , B.RECIPE_TYPE">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3241" N="ListEqp">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;	A.EQP_NAME, &#xD;&#xA;	A.EQP_DESC ,&#xD;&#xA;	B.RCP_ID AS RECIPE_ID,&#xD;&#xA;	C.RECIPE_TYPE&#xD;&#xA;FROM QTMSEQPDEF A&#xD;&#xA;LEFT JOIN QTMSEQPRCP B&#xD;&#xA;ON A.FACTORY = B.FACTORY&#xD;&#xA;AND A.EQP_NAME = B.EQP_NAME&#xD;&#xA; LEFT JOIN QTMSEQPTYP C&#xD;&#xA; ON A.FACTORY = C.FACTORY&#xD;&#xA; AND A.TYPE = C.TYPE&#xD;&#xA;WHERE A.FACTORY = @factory&#xD;&#xA; AND A.TYPE = ISNULL(@type, A.TYPE)  &#xD;&#xA; AND A.DELETE_FLAG &lt;&gt; 'Y'">
            <QP N="factory" />
            <QP N="type" />
          </QY>
        </SG>
        <SG _S="3243" N="HasFactory">
          <QY P="MsSql" Q="SELECT FACTORY&#xD;&#xA;  FROM QSYSFACDEF&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3252" N="HasEquipment">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;	A.EQP_NAME,&#xD;&#xA;	A.TYPE,&#xD;&#xA;	CASE A.RECIPE_TYPE WHEN 'None' THEN C.RECIPE_TYPE ELSE A.RECIPE_TYPE END AS RECIPE_TYPE,&#xD;&#xA;	CASE A.RECIPE_RULE WHEN 'None' THEN C.RECIPE_RULE ELSE A.RECIPE_RULE END AS RECIPE_RULE,&#xD;&#xA;	CASE A.RECIPE_DOWNLOAD WHEN 'None' THEN C.RECIPE_DOWNLOAD ELSE A.RECIPE_DOWNLOAD END AS RECIPE_DOWNLOAD,&#xD;&#xA;	CASE A.CMF_1 WHEN 'None' THEN C.CMF_1 ELSE A.CMF_1 END AS RCP_ID,&#xD;&#xA;	CASE A.CMF_2 WHEN 'None' THEN C.CMF_2 ELSE A.CMF_2 END AS AUTO_START,&#xD;&#xA;	CASE A.CMF_5 WHEN 'None' THEN C.CMF_5 ELSE A.CMF_5 END AS MDL_CHG_SKIP,&#xD;&#xA;	CASE A.CMF_6 WHEN 'None' THEN C.CMF_6 ELSE A.CMF_6 END AS ORDER_QTY&#xD;&#xA;FROM QTMSEQPDEF A&#xD;&#xA;LEFT JOIN QRASEQPDEF B&#xD;&#xA;  ON A.FACTORY = B.FACTORY&#xD;&#xA; AND A.EQP_NAME = B.EQP_NAME&#xD;&#xA;LEFT JOIN QTMSEQPTYP C&#xD;&#xA;  ON A.FACTORY = C.FACTORY&#xD;&#xA; AND A.TYPE = C.TYPE&#xD;&#xA;WHERE A.FACTORY = @factory&#xD;&#xA;  AND A.EQP_NAME = @eqp_name&#xD;&#xA;  AND A.DELETE_FLAG = 'N'&#xD;&#xA;  AND B.DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="3253" N="HasRecipeParser">
          <QY P="MsSql" Q="SELECT C.PSR_NAME,C.PSR_VER_FILE&#xD;&#xA;FROM QTMSTYPPSR A&#xD;&#xA;LEFT JOIN QTMSPSRDEF B ON&#xD;&#xA;A.FACTORY = B.FACTORY &#xD;&#xA;AND A.PSR_NAME = B.PSR_NAME&#xD;&#xA;LEFT JOIN QTMSPSRVER C ON&#xD;&#xA;C.FACTORY = B.FACTORY &#xD;&#xA;AND C.PSR_NAME = B.PSR_NAME&#xD;&#xA;AND C.PSR_VER = B.ACTIVE_VER&#xD;&#xA;WHERE A.FACTORY = @factory&#xD;&#xA;AND A.EQP_TYPE = @eq_type">
            <QP N="factory" />
            <QP N="eq_type" />
          </QY>
        </SG>
        <SG _S="3244" N="HasTypeAuthority">
          <QY P="MsSql" Q="SELECT        &#xD;&#xA;	A.TYPE,&#xD;&#xA;	A.FUN,&#xD;&#xA;	A.TRAN_ENABLED,&#xD;&#xA;	B.ALL_AUTHORITY&#xD;&#xA;  FROM QTMSURGAUT A &#xD;&#xA;  LEFT JOIN QTMSURGDEF B ON&#xD;&#xA;  A.FACTORY = B.FACTORY&#xD;&#xA;  AND A.USER_GRP = B.USER_GRP&#xD;&#xA; WHERE A.FACTORY = @factory&#xD;&#xA;   AND A.USER_GRP IN (SELECT USER_GRP FROM QTMSURGUSR WHERE FACTORY = @factory AND USER_ID = @user_id)">
            <QP N="factory" />
            <QP N="user_id" />
          </QY>
        </SG>
      </F>
      <F _S="4073" N="EquipmentRecipeList">
        <SG _S="4074" N="ListEquipmentRecipe">
          <QY P="MsSql" Q="SELECT EQP_NAME, RCP_ID, RCP_DESC, RCP_CLASS, LAST_RCP_VER, RCP_HOLD&#xD;&#xA;  FROM QTMSEQPRCP &#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE 	   = @type &#xD;&#xA;   AND EQP_NAME    = ISNULL(@eqp_name, EQP_NAME)&#xD;&#xA;   AND RCP_ID	   = ISNULL(@rcp_id, RCP_ID)&#xD;&#xA;   AND RCP_HOLD	   = ISNULL(@rcp_hold, RCP_HOLD)&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY EQP_NAME, RCP_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="rcp_hold" />
          </QY>
        </SG>
        <SG _S="4075" N="ListEquipmentRecipeVersion">
          <QY P="MsSql" Q="SELECT RCP_VER, RCP_VER_DESC, MAS_RCP_VER, VALIDATION_HIST_SEQ,&#xD;&#xA;       CREATE_TIME, CREATE_USER_ID, UPDATE_TIME, UPDATE_USER_ID&#xD;&#xA;  FROM QTMSEQPRVR&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type &#xD;&#xA;   AND EQP_NAME    = @eqp_name&#xD;&#xA;   AND RCP_ID      = @rcp_id&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY RCP_VER DESC&#xD;&#xA; OFFSET (CONVERT(int, @PAGE_NO)-1) * CONVERT(int, @PAGE_SIZE) ROW FETCH NEXT CONVERT(int, @PAGE_SIZE) ROW ONLY">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="PAGE_NO" />
            <QP N="PAGE_SIZE" />
          </QY>
        </SG>
        <SG _S="4076" N="ListEquipmentRecipeParameter">
          <QY P="MsSql" Q="SELECT A.PARA_ID, B.PARA_DESC,&#xD;&#xA;       A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5,&#xD;&#xA;       B.PARA_FORMAT, A.PARA_VALUE, B.MANAGE_FLAG   &#xD;&#xA;  FROM QTMSRCPPVH A&#xD;&#xA;  LEFT JOIN QTMSPARDEF B&#xD;&#xA;    ON A.FACTORY    = B.FACTORY&#xD;&#xA;   AND A.TYPE       = B.TYPE&#xD;&#xA;   AND A.PARA_ID    = B.PARA_ID&#xD;&#xA;   AND A.PARA_GROUP = B.PARA_GROUP&#xD;&#xA;   AND A.PARA_CAT_1 = B.PARA_CAT_1&#xD;&#xA;   AND A.PARA_CAT_2 = B.PARA_CAT_2&#xD;&#xA;   AND A.PARA_CAT_3 = B.PARA_CAT_3&#xD;&#xA;   AND A.PARA_CAT_4 = B.PARA_CAT_4&#xD;&#xA;   AND A.PARA_CAT_5 = B.PARA_CAT_5&#xD;&#xA; WHERE A.FACTORY      = @factory&#xD;&#xA;   AND A.TYPE         = @type&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND A.RCP_ID       = @rcp_id&#xD;&#xA;   AND HIST_SEQ = @hist_seq&#xD;&#xA; ORDER BY A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5, A.PARA_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="hist_seq" />
          </QY>
        </SG>
        <SG _S="4132" N="ListEquipmentRecipeParameterPaging">
          <QY P="MsSql" Q="SELECT A.PARA_ID, B.PARA_DESC,&#xD;&#xA;       A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5,&#xD;&#xA;       B.PARA_FORMAT, A.PARA_VALUE, B.MANAGE_FLAG   &#xD;&#xA;  FROM QTMSRCPPVH A&#xD;&#xA;  LEFT JOIN QTMSPARDEF B&#xD;&#xA;    ON A.FACTORY    = B.FACTORY&#xD;&#xA;   AND A.TYPE       = B.TYPE&#xD;&#xA;   AND A.PARA_ID    = B.PARA_ID&#xD;&#xA;   AND A.PARA_GROUP = B.PARA_GROUP&#xD;&#xA;   AND A.PARA_CAT_1 = B.PARA_CAT_1&#xD;&#xA;   AND A.PARA_CAT_2 = B.PARA_CAT_2&#xD;&#xA;   AND A.PARA_CAT_3 = B.PARA_CAT_3&#xD;&#xA;   AND A.PARA_CAT_4 = B.PARA_CAT_4&#xD;&#xA;   AND A.PARA_CAT_5 = B.PARA_CAT_5&#xD;&#xA; WHERE A.FACTORY      = @factory&#xD;&#xA;   AND A.TYPE         = @type&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND A.RCP_ID       = @rcp_id&#xD;&#xA;   AND HIST_SEQ = @hist_seq&#xD;&#xA; ORDER BY A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5, A.PARA_ID&#xD;&#xA; OFFSET (CONVERT(int, @PAGE_NO)-1) * CONVERT(int, @PAGE_SIZE) ROW FETCH NEXT CONVERT(int, @PAGE_SIZE) ROW ONLY">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="hist_seq" />
            <QP N="PAGE_NO" />
            <QP N="PAGE_SIZE" />
          </QY>
        </SG>
        <SG _S="4104" N="CountEquipmentRecipeVersion">
          <QY P="MsSql" Q="SELECT COUNT(*) AS CNT&#xD;&#xA;  FROM QTMSEQPRVR&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE    = @type &#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND RCP_ID  = @rcp_id&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
          </QY>
        </SG>
        <SG _S="4077" N="CountEquipmentRecipeParameter">
          <QY P="MsSql" Q="SELECT COUNT(*) AS CNT&#xD;&#xA;  FROM QTMSRCPPVH&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE    = @type&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND RCP_ID  = @rcp_id&#xD;&#xA;   AND HIST_SEQ = @hist_seq">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="hist_seq" />
          </QY>
        </SG>
      </F>
      <F _S="4400" N="RecipeControlSummary">
        <SG _S="4401" N="ListEquipmentSummary">
          <QY P="MsSql" Q="SELECT EQP.TYPE, EQP.EQP_NAME, EQP.EQP_DESC,&#xD;&#xA;       SUM(ISNULL(HIS.VAH_SUCC, 0))AS VAH_SUCC, SUM(ISNULL(HIS.VAH_FAIL, 0))AS VAH_FAIL,&#xD;&#xA;	   SUM(ISNULL(HIS.DWH_SUCC, 0))AS DWH_SUCC, SUM(ISNULL(HIS.DWH_FAIL, 0))AS DWH_FAIL&#xD;&#xA;  FROM QTMSEQPDEF AS EQP&#xD;&#xA;  LEFT JOIN &#xD;&#xA;       (&#xD;&#xA;SELECT FACTORY, TYPE, EQP_NAME, COUNT(*) AS VAH_SUCC, 0 AS VAH_FAIL, 0 AS DWH_SUCC, 0 AS DWH_FAIL&#xD;&#xA;  FROM QTMSRCPVAH&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND TYPE       = ISNULL(@type, TYPE)&#xD;&#xA;   AND TRAN_TIME &gt;= @tran_from_time&#xD;&#xA;   AND TRAN_TIME &lt;= @tran_to_time&#xD;&#xA;   AND RCP_RESULT = 'Success'&#xD;&#xA; GROUP BY FACTORY, TYPE, EQP_NAME&#xD;&#xA; UNION&#xD;&#xA;SELECT FACTORY, TYPE, EQP_NAME, 0 AS VAH_SUCC, COUNT(*) AS VAH_FAIL, 0 AS DWH_SUCC, 0 AS DWH_FAIL&#xD;&#xA;  FROM QTMSRCPVAH&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND TYPE       = ISNULL(@type, TYPE)&#xD;&#xA;   AND TRAN_TIME &gt;= @tran_from_time&#xD;&#xA;   AND TRAN_TIME &lt;= @tran_to_time&#xD;&#xA;   AND RCP_RESULT = 'fail'&#xD;&#xA; GROUP BY FACTORY, TYPE, EQP_NAME&#xD;&#xA; UNION&#xD;&#xA;SELECT FACTORY, TYPE, EQP_NAME, 0 AS VAH_SUCC, 0 AS VAH_FAIL, COUNT(*) AS DWH_SUCC, 0 AS DWH_FAIL&#xD;&#xA;  FROM QTMSRCPDWH&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND TYPE       = ISNULL(@type, TYPE)&#xD;&#xA;   AND TRAN_TIME &gt;= @tran_from_time&#xD;&#xA;   AND TRAN_TIME &lt;= @tran_to_time&#xD;&#xA;   AND EQP_RESULT = 'Success'&#xD;&#xA; GROUP BY FACTORY, TYPE, EQP_NAME&#xD;&#xA; UNION&#xD;&#xA;SELECT FACTORY, TYPE, EQP_NAME, 0 AS VAH_SUCC, 0 AS VAH_FAIL, 0 AS DWH_SUCC, COUNT(*) AS DWH_FAIL&#xD;&#xA;  FROM QTMSRCPDWH&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND TYPE       = ISNULL(@type, TYPE)&#xD;&#xA;   AND TRAN_TIME &gt;= @tran_from_time&#xD;&#xA;   AND TRAN_TIME &lt;= @tran_to_time&#xD;&#xA;   AND EQP_RESULT = 'fail'&#xD;&#xA; GROUP BY FACTORY, TYPE, EQP_NAME&#xD;&#xA;	   ) AS HIS&#xD;&#xA;    ON EQP.FACTORY     = HIS.FACTORY&#xD;&#xA;   AND EQP.TYPE        = EQP.TYPE&#xD;&#xA;   AND EQP.EQP_NAME    = HIS.EQP_NAME&#xD;&#xA; WHERE EQP.FACTORY     = @factory&#xD;&#xA;   AND EQP.TYPE        = ISNULL(@type, EQP.TYPE)&#xD;&#xA;   AND EQP.DELETE_FLAG = 'N'&#xD;&#xA; GROUP BY EQP.TYPE, EQP.EQP_NAME, EQP.EQP_DESC&#xD;&#xA; ORDER BY EQP.EQP_NAME">
            <QP N="factory" />
            <QP N="type" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
        <SG _S="4413" N="ListRecipeValidationSummary">
          <QY P="MsSql" Q="SELECT HIS.RCP_ID, &#xD;&#xA;       ISNULL(MAS.RCP_DESC, ' ') AS RCP_DESC, ISNULL(MAS.RCP_CLASS, 'Unknown') AS RCP_CLASS, &#xD;&#xA;       SUM(HIS.VAH_SUCC) AS VAH_SUCC, SUM(HIS.VAH_FAIL) AS VAH_FAIL&#xD;&#xA;  FROM &#xD;&#xA;     (&#xD;&#xA;SELECT FACTORY, TYPE, RCP_ID, COUNT(*) AS VAH_SUCC, 0 AS VAH_FAIL&#xD;&#xA;  FROM QTMSRCPVAH&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND TYPE       = @type&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;   AND TRAN_TIME &gt;= @tran_from_time&#xD;&#xA;   AND TRAN_TIME &lt;= @tran_to_time&#xD;&#xA;   AND RCP_RESULT = 'Success'&#xD;&#xA; GROUP BY FACTORY, TYPE, RCP_ID&#xD;&#xA; UNION&#xD;&#xA;SELECT FACTORY, TYPE, RCP_ID, 0 AS VAH_SUCC, COUNT(*) AS VAH_FAIL&#xD;&#xA;  FROM QTMSRCPVAH&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND TYPE       = @type&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;   AND TRAN_TIME &gt;= @tran_from_time&#xD;&#xA;   AND TRAN_TIME &lt;= @tran_to_time&#xD;&#xA;   AND RCP_RESULT = 'fail'&#xD;&#xA;  GROUP BY FACTORY, TYPE, RCP_ID&#xD;&#xA;     ) AS HIS&#xD;&#xA;  LEFT JOIN QTMSMASRCP AS MAS&#xD;&#xA;    ON HIS.FACTORY = MAS.FACTORY&#xD;&#xA;   AND HIS.TYPE    = MAS.TYPE&#xD;&#xA;   AND HIS.RCP_ID  = MAS.RCP_ID&#xD;&#xA; GROUP BY HIS.RCP_ID, RCP_DESC, RCP_CLASS&#xD;&#xA; ORDER BY HIS.RCP_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
        <SG _S="4414" N="ListRecipeDownloadSummary">
          <QY P="MsSql" Q="SELECT HIS.RCP_ID, &#xD;&#xA;       ISNULL(MAS.RCP_DESC, ' ') AS RCP_DESC, ISNULL(MAS.RCP_CLASS, 'Unknown') AS RCP_CLASS, &#xD;&#xA;       SUM(HIS.DWH_SUCC) AS DWH_SUCC, SUM(HIS.DWH_FAIL) AS DWH_FAIL&#xD;&#xA;  FROM &#xD;&#xA;     (&#xD;&#xA;SELECT FACTORY, TYPE, RCP_ID, COUNT(*) AS DWH_SUCC, 0 AS DWH_FAIL&#xD;&#xA;  FROM QTMSRCPDWH&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND TYPE       = @type&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;   AND TRAN_TIME &gt;= @tran_from_time&#xD;&#xA;   AND TRAN_TIME &lt;= @tran_to_time&#xD;&#xA;   AND EQP_RESULT = 'Success'&#xD;&#xA; GROUP BY FACTORY, TYPE, RCP_ID&#xD;&#xA; UNION&#xD;&#xA;SELECT FACTORY, TYPE, RCP_ID, 0 AS DWH_SUCC, COUNT(*) AS DWH_FAIL&#xD;&#xA;  FROM QTMSRCPDWH&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND TYPE       = @type&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;   AND TRAN_TIME &gt;= @tran_from_time&#xD;&#xA;   AND TRAN_TIME &lt;= @tran_to_time&#xD;&#xA;   AND EQP_RESULT = 'fail'&#xD;&#xA;  GROUP BY FACTORY, TYPE, RCP_ID&#xD;&#xA;     ) AS HIS&#xD;&#xA;  LEFT JOIN QTMSMASRCP AS MAS&#xD;&#xA;    ON HIS.FACTORY = MAS.FACTORY&#xD;&#xA;   AND HIS.TYPE    = MAS.TYPE&#xD;&#xA;   AND HIS.RCP_ID  = MAS.RCP_ID&#xD;&#xA; GROUP BY HIS.RCP_ID, RCP_DESC, RCP_CLASS&#xD;&#xA; ORDER BY HIS.RCP_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="42" N="EapTransaction">
      <F _S="3036" N="EquipmentConnect">
        <SG _S="3038" N="HasEquipment">
          <QY P="MsSql" Q="SELECT A.EQP_NAME, B.COMM_STATE, B.CTRL_MODE&#xD;&#xA;  FROM QTMSEQPDEF A&#xD;&#xA;  	LEFT JOIN QTMSEQPSTS B&#xD;&#xA;  	ON A.EQP_NAME = B.EQP_NAME&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="4215" N="SearchEquipment">
          <QY P="MsSql" Q="SELECT A.EQP_NAME, B.COMM_STATE, B.CTRL_MODE&#xD;&#xA;  FROM QTMSEQPDEF A&#xD;&#xA;  	LEFT JOIN QTMSEQPSTS B&#xD;&#xA;  	ON A.EQP_NAME = B.EQP_NAME&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3040" N="InsertEquipmentHis">
          <QY P="MsSql" Q="INSERT INTO QTMSEQPHIS (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   EVENT_ID,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   COMM_STATE,&#xD;&#xA;   CTRL_MODE,&#xD;&#xA;   EVT_H_1,&#xD;&#xA;   EVT_D_1,   &#xD;&#xA;   EVT_H_2,&#xD;&#xA;   EVT_D_2,&#xD;&#xA;   EVT_H_3,&#xD;&#xA;   EVT_D_3,&#xD;&#xA;   EVT_H_4,&#xD;&#xA;   EVT_D_4,&#xD;&#xA;   EVT_H_5,&#xD;&#xA;   EVT_D_5,&#xD;&#xA;   EVT_H_6,&#xD;&#xA;   EVT_D_6,&#xD;&#xA;   EVT_H_7,&#xD;&#xA;   EVT_D_7,&#xD;&#xA;   EVT_H_8,&#xD;&#xA;   EVT_D_8,&#xD;&#xA;   EVT_H_9,&#xD;&#xA;   EVT_D_9,&#xD;&#xA;   EVT_H_10,&#xD;&#xA;   EVT_D_10,&#xD;&#xA;   EVT_H_11,&#xD;&#xA;   EVT_D_11,   &#xD;&#xA;   EVT_H_12,&#xD;&#xA;   EVT_D_12,&#xD;&#xA;   EVT_H_13,&#xD;&#xA;   EVT_D_13,&#xD;&#xA;   EVT_H_14,&#xD;&#xA;   EVT_D_14,&#xD;&#xA;   EVT_H_15,&#xD;&#xA;   EVT_D_15,&#xD;&#xA;   EVT_H_16,&#xD;&#xA;   EVT_D_16,&#xD;&#xA;   EVT_H_17,&#xD;&#xA;   EVT_D_17,&#xD;&#xA;   EVT_H_18,&#xD;&#xA;   EVT_D_18,&#xD;&#xA;   EVT_H_19,&#xD;&#xA;   EVT_D_19,&#xD;&#xA;   EVT_H_20,&#xD;&#xA;   EVT_D_20,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT      &#xD;&#xA;) &#xD;&#xA;VALUES( &#xD;&#xA;   @factory,&#xD;&#xA;   @eqp_name,&#xD;&#xA;   @last_his_seq,&#xD;&#xA;   @event_id,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @comm_state,&#xD;&#xA;   @ctrl_mode,&#xD;&#xA;   @evt_h_1,&#xD;&#xA;   @evt_d_1,   &#xD;&#xA;   @evt_h_2,&#xD;&#xA;   @evt_d_2,&#xD;&#xA;   @evt_h_3,&#xD;&#xA;   @evt_d_3,&#xD;&#xA;   @evt_h_4,&#xD;&#xA;   @evt_d_4,&#xD;&#xA;   @evt_h_5,&#xD;&#xA;   @evt_d_5,&#xD;&#xA;   @evt_h_6,&#xD;&#xA;   @evt_d_6,&#xD;&#xA;   @evt_h_7,&#xD;&#xA;   @evt_d_7,&#xD;&#xA;   @evt_h_8,&#xD;&#xA;   @evt_d_8,&#xD;&#xA;   @evt_h_9,&#xD;&#xA;   @evt_d_9,&#xD;&#xA;   @evt_h_10,&#xD;&#xA;   @evt_d_10,&#xD;&#xA;   @evt_h_11,&#xD;&#xA;   @evt_d_11,   &#xD;&#xA;   @evt_h_12,&#xD;&#xA;   @evt_d_12,&#xD;&#xA;   @evt_h_13,&#xD;&#xA;   @evt_d_13,&#xD;&#xA;   @evt_h_14,&#xD;&#xA;   @evt_d_14,&#xD;&#xA;   @evt_h_15,&#xD;&#xA;   @evt_d_15,&#xD;&#xA;   @evt_h_16,&#xD;&#xA;   @evt_d_16,&#xD;&#xA;   @evt_h_17,&#xD;&#xA;   @evt_d_17,&#xD;&#xA;   @evt_h_18,&#xD;&#xA;   @evt_d_18,&#xD;&#xA;   @evt_h_19,&#xD;&#xA;   @evt_d_19,&#xD;&#xA;   @evt_h_20,&#xD;&#xA;   @evt_d_20,&#xD;&#xA;   @tran_user_id,&#xD;&#xA;   @tran_comment)">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="last_his_seq" />
            <QP N="event_id" />
            <QP N="tran_time" />
            <QP N="comm_state" />
            <QP N="ctrl_mode" />
            <QP N="evt_h_1" />
            <QP N="evt_d_1" />
            <QP N="evt_h_2" />
            <QP N="evt_d_2" />
            <QP N="evt_h_3" />
            <QP N="evt_d_3" />
            <QP N="evt_h_4" />
            <QP N="evt_d_4" />
            <QP N="evt_h_5" />
            <QP N="evt_d_5" />
            <QP N="evt_h_6" />
            <QP N="evt_d_6" />
            <QP N="evt_h_7" />
            <QP N="evt_d_7" />
            <QP N="evt_h_8" />
            <QP N="evt_d_8" />
            <QP N="evt_h_9" />
            <QP N="evt_d_9" />
            <QP N="evt_h_10" />
            <QP N="evt_d_10" />
            <QP N="evt_h_11" />
            <QP N="evt_d_11" />
            <QP N="evt_h_12" />
            <QP N="evt_d_12" />
            <QP N="evt_h_13" />
            <QP N="evt_d_13" />
            <QP N="evt_h_14" />
            <QP N="evt_d_14" />
            <QP N="evt_h_15" />
