            <QP N="tran_time" />
            <QP N="tran_status" />
            <QP N="tran_user_id" />
            <QP N="tran_comment" />
          </QY>
        </SG>
        <SG _S="4209" N="UpdateEquipmentRecipeValidationFlag">
          <QY P="MsSql" Q="UPDATE QTMSEQPRCP SET&#xD;&#xA;  CMF_1           = @validation_flag,&#xD;&#xA;  UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;  UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND TYPE       = @type&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;   AND RCP_ID     = @rcp_id">
            <QP N="validation_flag" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
          </QY>
        </SG>
        <SG _S="4469" N="DeleteRecipeUploadTemporary">
          <QY P="MsSql" Q="DELETE&#xD;&#xA;  FROM QTMSRCPUPT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TYPE     = @type&#xD;&#xA;   AND EQP_NAME = @eqp_name">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="4468" N="UpdateRecipeUploadTemporary">
          <QY P="MsSql" Q="UPDATE QTMSRCPUPT SET&#xD;&#xA;  TRAN_STATUS   = @tran_status,&#xD;&#xA;  RESULT        = @result,&#xD;&#xA;  REASON        = @reason&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TYPE     = @type&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND RCP_ID   = @rcp_id">
            <QP N="tran_status" />
            <QP N="result" />
            <QP N="reason" />
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
          </QY>
        </SG>
      </F>
      <F _S="4195" N="ValidationRecipeRegist">
        <SG _S="4204" N="HasEquipment">
          <QY P="MsSql" Q="SELECT A.TYPE, A.EQP_NAME, &#xD;&#xA;       ISNULL(B.CTRL_MODE, ' ') AS CTRL_MODE, &#xD;&#xA;       ISNULL(B.COMM_STATE, ' ') AS COMM_STATE,&#xD;&#xA;	   ISNULL(B.PROC_STATE, ' ') AS PROC_STATE, &#xD;&#xA;	   ISNULL(B.EQP_RCP_ID, ' ') AS EQP_RCP_ID,&#xD;&#xA;	   CASE A.RECIPE_TYPE WHEN 'None' THEN C.RECIPE_TYPE ELSE A.RECIPE_TYPE END AS RECIPE_TYPE,&#xD;&#xA;	   CASE A.RECIPE_RULE WHEN 'None' THEN C.RECIPE_RULE ELSE A.RECIPE_RULE END AS RECIPE_RULE,&#xD;&#xA;	   CASE A.RECIPE_DOWNLOAD WHEN 'None' THEN C.RECIPE_DOWNLOAD ELSE A.RECIPE_DOWNLOAD END AS RECIPE_DOWNLOAD,&#xD;&#xA;	   CASE A.RECIPE_VALIDATION WHEN 'None' THEN C.RECIPE_VALIDATION ELSE A.RECIPE_VALIDATION END AS RECIPE_VALIDATION&#xD;&#xA;  FROM QTMSEQPDEF A&#xD;&#xA;  LEFT JOIN QTMSEQPSTS B&#xD;&#xA;    ON A.FACTORY     = B.FACTORY&#xD;&#xA;   AND A.EQP_NAME    = B.EQP_NAME&#xD;&#xA;  LEFT JOIN QTMSEQPTYP C&#xD;&#xA;    ON A.FACTORY     = C.FACTORY&#xD;&#xA;   AND A.TYPE        = C.TYPE&#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.EQP_NAME    = @eqp_name&#xD;&#xA;   AND A.DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="4205" N="HasEquipmentRecipe">
          <QY P="MsSql" Q="SELECT RCP_ACTIVE, RCP_HOLD, ACTIVE_RCP_VER,  LAST_RCP_VER, DELETE_FLAG&#xD;&#xA;  FROM QTMSEQPRCP&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND EQP_NAME    = @eqp_name&#xD;&#xA;   AND RCP_ID      = @rcp_id">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
          </QY>
        </SG>
        <SG _S="4206" N="InsertEquipmentRecipe">
          <QY P="MsSql" Q="INSERT INTO QTMSEQPRCP (&#xD;&#xA;  FACTORY,&#xD;&#xA;  TYPE,&#xD;&#xA;  EQP_NAME,&#xD;&#xA;  RCP_ID,&#xD;&#xA;  RCP_HOLD,&#xD;&#xA;  LAST_RCP_VER,&#xD;&#xA;  LAST_EVENT_ID,&#xD;&#xA;  LAST_EVENT_TIME,&#xD;&#xA;  LAST_HIST_SEQ,&#xD;&#xA;  DELETE_FLAG,   &#xD;&#xA;  CMF_1,&#xD;&#xA;  CREATE_USER_ID,&#xD;&#xA;  CREATE_TIME,&#xD;&#xA;  UPDATE_USER_ID,&#xD;&#xA;  UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;  @factory,&#xD;&#xA;  @type,&#xD;&#xA;  @eqp_name,&#xD;&#xA;  @rcp_id,&#xD;&#xA;  @rcp_hold,&#xD;&#xA;  @last_rcp_ver,&#xD;&#xA;  @last_event_id,&#xD;&#xA;  @last_event_time,&#xD;&#xA;  @last_hist_seq,&#xD;&#xA;  @delete_flag,   &#xD;&#xA;  @validation_flag,&#xD;&#xA;  @create_user_id,&#xD;&#xA;  @create_time,&#xD;&#xA;  @update_user_id,&#xD;&#xA;  @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="rcp_hold" />
            <QP N="last_rcp_ver" />
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="last_hist_seq" />
            <QP N="delete_flag" />
            <QP N="validation_flag" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="4207" N="UpdateEquipmentRecipe">
          <QY P="MsSql" Q="UPDATE QTMSEQPRCP SET&#xD;&#xA;  CMF_1           = @validation_flag,&#xD;&#xA;  LAST_EVENT_ID   = @last_event_id,&#xD;&#xA;  LAST_EVENT_TIME = @last_event_time,&#xD;&#xA;  LAST_HIST_SEQ   = @last_hist_seq,&#xD;&#xA;  DELETE_FLAG     = 'N',&#xD;&#xA;  UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;  UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND TYPE       = @type&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;   AND RCP_ID     = @rcp_id">
            <QP N="validation_flag" />
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="last_hist_seq" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
          </QY>
        </SG>
        <SG _S="4210" N="HasMasterRecipe">
          <QY P="MsSql" Q="SELECT RCP_DESC, RCP_ACTIVE, ACTIVE_RCP_VER, RCP_HOLD, DELETE_FLAG&#xD;&#xA;  FROM QTMSMASRCP&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND RCP_ID      = @rcp_id">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
          </QY>
        </SG>
      </F>
      <F _S="4362" N="RecipeVersionInformation">
        <SG _S="4364" N="HasEquipment" UMG="No">
          <QY P="MsSql" Q="SELECT A.TYPE, A.EQP_NAME,&#xD;&#xA;	   CASE A.RECIPE_RULE WHEN 'None' THEN B.RECIPE_RULE ELSE A.RECIPE_RULE END AS RECIPE_RULE&#xD;&#xA;  FROM QTMSEQPDEF A&#xD;&#xA;  LEFT JOIN QTMSEQPTYP B&#xD;&#xA;    ON A.FACTORY     = B.FACTORY&#xD;&#xA;   AND A.TYPE        = B.TYPE&#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.EQP_NAME    = @eqp_name&#xD;&#xA;   AND A.DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="4365" N="HasMasterRecipe">
          <QY P="MsSql" Q="SELECT RCP_ACTIVE, ACTIVE_RCP_VER, RCP_HOLD&#xD;&#xA;  FROM QTMSMASRCP&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND RCP_ID      = @rcp_id&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
          </QY>
        </SG>
        <SG _S="4367" N="HasEquipmentRecipeVersion">
          <QY P="MsSql" Q="SELECT TOP 1 RCP_VER&#xD;&#xA;  FROM QTMSEQPRVR&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND EQP_NAME    = @eqp_name&#xD;&#xA;   AND RCP_ID      = @rcp_id&#xD;&#xA;   AND MAS_RCP_VER = @mas_rcp_ver&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY RCP_VER DESC">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
            <QP N="mas_rcp_ver" />
          </QY>
        </SG>
        <SG _S="4366" N="HasEquipmentRecipe">
          <QY P="MsSql" Q="SELECT RCP_HOLD&#xD;&#xA;  FROM QTMSEQPRCP&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND EQP_NAME    = @eqp_name&#xD;&#xA;   AND RCP_ID      = @rcp_id&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="type" />
            <QP N="eqp_name" />
            <QP N="rcp_id" />
          </QY>
        </SG>
      </F>
      <F _S="3228" N="RecipeList">
        <SG _S="3232" N="HasEquipment">
          <QY P="MsSql" Q="SELECT A.TYPE, A.EQP_NAME, &#xD;&#xA;       ISNULL(B.COMM_STATE, ' ') AS COMM_STATE, &#xD;&#xA;	   ISNULL(B.CTRL_MODE, ' ') AS CTRL_MODE,&#xD;&#xA;	   ISNULL(B.PROC_STATE, ' ') AS PROC_STATE,&#xD;&#xA;	   ISNULL(B.EQP_RCP_ID, ' ') AS EQP_RCP_ID&#xD;&#xA;  FROM QTMSEQPDEF A&#xD;&#xA;  LEFT JOIN QTMSEQPSTS B&#xD;&#xA;    ON A.FACTORY     = B.FACTORY&#xD;&#xA;   AND A.EQP_NAME    = B.EQP_NAME&#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.EQP_NAME    = @eqp_name&#xD;&#xA;   AND A.DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
      </F>
      <F _S="4198" N="ValidationRecipeConfirm">
        <SG _S="4200" N="HasEquipment" UMG="No">
          <QY P="MsSql" Q="SELECT A.TYPE, A.EQP_NAME, &#xD;&#xA;       ISNULL(B.CTRL_MODE, ' ') AS CTRL_MODE, &#xD;&#xA;       ISNULL(B.COMM_STATE, ' ') AS COMM_STATE,&#xD;&#xA;	   ISNULL(B.PROC_STATE, ' ') AS PROC_STATE, &#xD;&#xA;	   ISNULL(B.EQP_RCP_ID, ' ') AS EQP_RCP_ID,&#xD;&#xA;	   CASE A.RECIPE_TYPE WHEN 'None' THEN C.RECIPE_TYPE ELSE A.RECIPE_TYPE END AS RECIPE_TYPE,&#xD;&#xA;	   CASE A.RECIPE_RULE WHEN 'None' THEN C.RECIPE_RULE ELSE A.RECIPE_RULE END AS RECIPE_RULE,&#xD;&#xA;	   CASE A.RECIPE_DOWNLOAD WHEN 'None' THEN C.RECIPE_DOWNLOAD ELSE A.RECIPE_DOWNLOAD END AS RECIPE_DOWNLOAD,&#xD;&#xA;	   CASE A.RECIPE_VALIDATION WHEN 'None' THEN C.RECIPE_VALIDATION ELSE A.RECIPE_VALIDATION END AS RECIPE_VALIDATION&#xD;&#xA;  FROM QTMSEQPDEF A&#xD;&#xA;  LEFT JOIN QTMSEQPSTS B&#xD;&#xA;    ON A.FACTORY     = B.FACTORY&#xD;&#xA;   AND A.EQP_NAME    = B.EQP_NAME&#xD;&#xA;  LEFT JOIN QTMSEQPTYP C&#xD;&#xA;    ON A.FACTORY     = C.FACTORY&#xD;&#xA;   AND A.TYPE        = C.TYPE&#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.EQP_NAME    = @eqp_name&#xD;&#xA;   AND A.DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="4208" N="HasMasterRecipe">
          <QY P="MsSql" Q="SELECT RCP_DESC, RCP_ACTIVE, ACTIVE_RCP_VER, RCP_HOLD, DELETE_FLAG&#xD;&#xA;  FROM QTMSMASRCP&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND RCP_ID      = @rcp_id">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
          </QY>
        </SG>
        <SG _S="4201" N="HasEquipmentRecipe">
          <QY P="MsSql" Q="SELECT RCP_HOLD, DELETE_FLAG, CMF_1 AS VALIDATION_FLAG&#xD;&#xA;  FROM QTMSEQPRCP&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND EQP_NAME    = @eqp_name&#xD;&#xA;   AND RCP_ID      = @rcp_id">
