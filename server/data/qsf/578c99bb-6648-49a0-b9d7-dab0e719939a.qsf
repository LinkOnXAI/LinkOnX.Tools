    </M>
    <M _S="2879" N="View">
      <F _S="2880" N="RecipeViewer">
        <SG _S="3500" N="ListEquipmentType">
          <QY P="MsSql" Q="SELECT TYPE, TYPE_DESC, RECIPE_TYPE, RECIPE_COMPOSITION, RECIPE_RULE, RECIPE_DOWNLOAD, RECIPE_VALIDATION&#xD;&#xA;  FROM QTMSEQPTYP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY TYPE">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="4446" N="ListMasterRecipeForClassProcess">
          <QY P="MsSql" Q="SELECT RCP_ID, RCP_DESC, RCP_ACTIVE, RCP_HOLD&#xD;&#xA;  FROM QTMSMASRCP&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND RCP_CLASS   = @rcp_class&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_class" />
          </QY>
        </SG>
        <SG _S="3501" N="ListMasterRecipe">
          <QY P="MsSql" Q="SELECT RCP_ID, RCP_DESC, RCP_CLASS, RCP_ACTIVE, ACTIVE_RCP_VER, LAST_RCP_VER, RCP_HOLD&#xD;&#xA;  FROM QTMSMASRCP&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY RCP_ID">
            <QP N="factory" />
            <QP N="type" />
          </QY>
        </SG>
        <SG _S="3502" N="ListMasterRecipeVersion">
          <QY P="MsSql" Q="SELECT RCP_VER, RCP_VER_DESC, RCP_VER_ACTIVE, RCP_VER_STATUS,&#xD;&#xA;       CREATE_TIME, CREATE_USER_ID, UPDATE_TIME, UPDATE_USER_ID&#xD;&#xA;  FROM QTMSMASRVR&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE    = @type&#xD;&#xA;   AND RCP_ID  = @rcp_id&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY RCP_VER DESC">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
          </QY>
        </SG>
        <SG _S="4123" N="ListMasterRecipeVersionPaging">
          <QY P="MsSql" Q="SELECT RCP_VER, RCP_VER_DESC, RCP_VER_ACTIVE, RCP_VER_STATUS,&#xD;&#xA;       CREATE_TIME, CREATE_USER_ID, UPDATE_TIME, UPDATE_USER_ID&#xD;&#xA;  FROM QTMSMASRVR&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE    = @type&#xD;&#xA;   AND RCP_ID  = @rcp_id&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY RCP_VER DESC&#xD;&#xA; OFFSET (CONVERT(int, @PAGE_NO)-1) * CONVERT(int, @PAGE_SIZE) ROW FETCH NEXT CONVERT(int, @PAGE_SIZE) ROW ONLY">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="PAGE_NO" />
            <QP N="PAGE_SIZE" />
          </QY>
        </SG>
        <SG _S="4030" N="ListMasterRecipeParameter">
          <QY P="MsSql" Q="SELECT A.PARA_ID, B.PARA_DESC,&#xD;&#xA;       A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5,&#xD;&#xA;	   B.PARA_FORMAT, A.PARA_VALUE, B.MANAGE_FLAG&#xD;&#xA;  FROM QTMSMASRPR A&#xD;&#xA;  LEFT JOIN QTMSPARDEF B&#xD;&#xA;    ON A.FACTORY    = B.FACTORY&#xD;&#xA;   AND A.TYPE       = B.TYPE&#xD;&#xA;   AND A.PARA_ID    = B.PARA_ID&#xD;&#xA;   AND A.PARA_GROUP = B.PARA_GROUP&#xD;&#xA;   AND A.PARA_CAT_1 = B.PARA_CAT_1&#xD;&#xA;   AND A.PARA_CAT_2 = B.PARA_CAT_2&#xD;&#xA;   AND A.PARA_CAT_3 = B.PARA_CAT_3&#xD;&#xA;   AND A.PARA_CAT_4 = B.PARA_CAT_4&#xD;&#xA;   AND A.PARA_CAT_5 = B.PARA_CAT_5&#xD;&#xA; WHERE A.FACTORY      = @factory&#xD;&#xA;   AND A.TYPE         = @type&#xD;&#xA;   AND A.RCP_ID       = @rcp_id&#xD;&#xA;   AND A.RCP_VER      = @rcp_ver&#xD;&#xA; ORDER BY A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5, A.PARA_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="rcp_ver" />
          </QY>
        </SG>
        <SG _S="4399" N="ListMasterRecipeParameterManaged">
          <QY P="MsSql" Q="SELECT A.PARA_ID, B.PARA_DESC,&#xD;&#xA;       A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5,&#xD;&#xA;	   B.PARA_FORMAT, A.PARA_VALUE, B.MANAGE_FLAG&#xD;&#xA;  FROM QTMSMASRPR A&#xD;&#xA;  LEFT JOIN QTMSPARDEF B&#xD;&#xA;    ON A.FACTORY    = B.FACTORY&#xD;&#xA;   AND A.TYPE       = B.TYPE&#xD;&#xA;   AND A.PARA_ID    = B.PARA_ID&#xD;&#xA;   AND A.PARA_GROUP = B.PARA_GROUP&#xD;&#xA;   AND A.PARA_CAT_1 = B.PARA_CAT_1&#xD;&#xA;   AND A.PARA_CAT_2 = B.PARA_CAT_2&#xD;&#xA;   AND A.PARA_CAT_3 = B.PARA_CAT_3&#xD;&#xA;   AND A.PARA_CAT_4 = B.PARA_CAT_4&#xD;&#xA;   AND A.PARA_CAT_5 = B.PARA_CAT_5&#xD;&#xA; WHERE A.FACTORY      = @factory&#xD;&#xA;   AND A.TYPE         = @type&#xD;&#xA;   AND A.RCP_ID       = @rcp_id&#xD;&#xA;   AND A.RCP_VER      = @rcp_ver&#xD;&#xA;   AND B.MANAGE_FLAG  = 'Yes'&#xD;&#xA; ORDER BY A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5, A.PARA_ID">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="rcp_ver" />
          </QY>
        </SG>
        <SG _S="4127" N="ListMasterRecipeParameterPaging">
          <QY P="MsSql" Q="SELECT A.PARA_ID, B.PARA_DESC,&#xD;&#xA;       A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5,&#xD;&#xA;	   B.PARA_FORMAT, A.PARA_VALUE, B.MANAGE_FLAG&#xD;&#xA;  FROM QTMSMASRPR A&#xD;&#xA;  LEFT JOIN QTMSPARDEF B&#xD;&#xA;    ON A.FACTORY    = B.FACTORY&#xD;&#xA;   AND A.TYPE       = B.TYPE&#xD;&#xA;   AND A.PARA_ID    = B.PARA_ID&#xD;&#xA;   AND A.PARA_GROUP = B.PARA_GROUP&#xD;&#xA;   AND A.PARA_CAT_1 = B.PARA_CAT_1&#xD;&#xA;   AND A.PARA_CAT_2 = B.PARA_CAT_2&#xD;&#xA;   AND A.PARA_CAT_3 = B.PARA_CAT_3&#xD;&#xA;   AND A.PARA_CAT_4 = B.PARA_CAT_4&#xD;&#xA;   AND A.PARA_CAT_5 = B.PARA_CAT_5&#xD;&#xA; WHERE A.FACTORY      = @factory&#xD;&#xA;   AND A.TYPE         = @type&#xD;&#xA;   AND A.RCP_ID       = @rcp_id&#xD;&#xA;   AND A.RCP_VER      = @rcp_ver&#xD;&#xA; ORDER BY A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5, A.PARA_ID&#xD;&#xA; OFFSET (CONVERT(int, @PAGE_NO)-1) * CONVERT(int, @PAGE_SIZE) ROW FETCH NEXT CONVERT(int, @PAGE_SIZE) ROW ONLY">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="rcp_ver" />
            <QP N="PAGE_NO" />
            <QP N="PAGE_SIZE" />
          </QY>
        </SG>
        <SG _S="3503" N="ListMasterSpecVersion">
          <QY P="MsSql" Q="SELECT SPEC_VER, SPEC_VER_DESC, ACTIVE, STATUS,&#xD;&#xA;       CREATE_TIME, CREATE_USER_ID, UPDATE_TIME, UPDATE_USER_ID&#xD;&#xA;  FROM QTMSMASSVR&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE    = @type&#xD;&#xA;   AND RCP_ID  = @rcp_id&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY SPEC_VER DESC">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
          </QY>
        </SG>
        <SG _S="4124" N="ListMasterSpecVersionPaging">
          <QY P="MsSql" Q="SELECT SPEC_VER, SPEC_VER_DESC, ACTIVE, STATUS,&#xD;&#xA;       CREATE_TIME, CREATE_USER_ID, UPDATE_TIME, UPDATE_USER_ID&#xD;&#xA;  FROM QTMSMASSVR&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE    = @type&#xD;&#xA;   AND RCP_ID  = @rcp_id&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY SPEC_VER DESC&#xD;&#xA;OFFSET (CONVERT(int, @PAGE_NO)-1) * CONVERT(int, @PAGE_SIZE) ROW FETCH NEXT CONVERT(int, @PAGE_SIZE) ROW ONLY">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="PAGE_NO" />
            <QP N="PAGE_SIZE" />
          </QY>
        </SG>
        <SG _S="3534" N="ListMasterSpecParameter">
          <QY P="MsSql" Q="SELECT A.PARA_ID, B.PARA_DESC, &#xD;&#xA;       A.PARA_GROUP, A.PARA_CAT_1, A.PARA_CAT_2, A.PARA_CAT_3, A.PARA_CAT_4, A.PARA_CAT_5,&#xD;&#xA;	   B.PARA_FORMAT, A.PARA_VALUE,&#xD;&#xA;	   A.PARA_VALIDATION_RULE,&#xD;&#xA;       A.PARA_TARGET_VALUE, A.PARA_USL, A.PARA_UCL, A.PARA_LCL, A.PARA_LSL&#xD;&#xA;  FROM &#xD;&#xA;     (&#xD;&#xA;SELECT TOP 100 PERCENT&#xD;&#xA;       FACTORY, TYPE, &#xD;&#xA;       PARA_ID,&#xD;&#xA;	   PARA_VALUE,&#xD;&#xA;	   PARA_VALIDATION_RULE,&#xD;&#xA;	   PARA_GROUP, PARA_CAT_1, PARA_CAT_2, PARA_CAT_3, PARA_CAT_4, PARA_CAT_5,&#xD;&#xA;	   PARA_TARGET_VALUE, PARA_USL, PARA_UCL, PARA_LCL, PARA_LSL&#xD;&#xA;  FROM QTMSMASSVP&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TYPE        = @type&#xD;&#xA;   AND RCP_ID      = @rcp_id&#xD;&#xA;   AND SPEC_VER    = @spec_ver&#xD;&#xA; ORDER BY PARA_GROUP, PARA_CAT_1, PARA_CAT_2, PARA_CAT_3, PARA_CAT_4, PARA_CAT_5,PARA_ID   &#xD;&#xA;     ) AS A&#xD;&#xA; LEFT JOIN QTMSPARDEF B&#xD;&#xA;    ON A.FACTORY    = B.FACTORY&#xD;&#xA;   AND A.TYPE       = B.TYPE&#xD;&#xA;   AND A.PARA_ID    = B.PARA_ID&#xD;&#xA;   AND A.PARA_GROUP = B.PARA_GROUP&#xD;&#xA;   AND A.PARA_CAT_1 = B.PARA_CAT_1&#xD;&#xA;   AND A.PARA_CAT_2 = B.PARA_CAT_2&#xD;&#xA;   AND A.PARA_CAT_3 = B.PARA_CAT_3&#xD;&#xA;   AND A.PARA_CAT_4 = B.PARA_CAT_4&#xD;&#xA;   AND A.PARA_CAT_5 = B.PARA_CAT_5">
            <QP N="factory" />
            <QP N="type" />
            <QP N="rcp_id" />
            <QP N="spec_ver" />
          </QY>
