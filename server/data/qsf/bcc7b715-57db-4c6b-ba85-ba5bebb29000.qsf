    <M _S="463" N="MapLoaderTransaction">
      <F _S="465" N="MapLoaderDown">
        <SG _S="467" N="UpdateMapLoader">
          <QY P="MsSql" Q="UPDATE QWMSMLDDEF SET&#xD;&#xA;  UP_DOWN          = @up_down,  &#xD;&#xA;  LAST_EVENT_ID    = @last_event_id,&#xD;&#xA;  LAST_EVENT_TIME  = @last_event_time,&#xD;&#xA;  LAST_HIST_SEQ    = @hist_seq,&#xD;&#xA;  UPDATE_USER_ID   = @update_user_id,&#xD;&#xA;  UPDATE_TIME      = @update_time&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND MLD_NAME    = @mld_name">
            <QP N="up_down" />
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="hist_seq" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="mld_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
      </F>
      <F _S="468" N="MapLoaderUp">
        <SG _S="470" N="HasMapLoaderAtr">
          <QY P="MsSql" Q="SELECT MLD_NAME, PACKAGE, PKG_VER&#xD;&#xA;  FROM QWMSMLDATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND MLD_NAME      = @mld_name&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="mld_name" />
            <QP N="attr_category" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="471" N="UpdateMapLoader">
          <QY P="MsSql" Q="UPDATE QWMSMLDDEF SET&#xD;&#xA;  STEP             = @step,&#xD;&#xA;  UP_DOWN          = @up_down,  &#xD;&#xA;  ALARM            = @alarm,&#xD;&#xA;  NEED_ACTION      = @need_action,&#xD;&#xA;  NEXT_NEED_ACTION = @next_need_action,&#xD;&#xA;  LAST_EVENT_ID    = @last_event_id,&#xD;&#xA;  LAST_EVENT_TIME  = @last_event_time,&#xD;&#xA;  LAST_HIST_SEQ    = @hist_seq,&#xD;&#xA;  UPDATE_USER_ID   = @update_user_id,&#xD;&#xA;  UPDATE_TIME      = @update_time&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND MLD_NAME    = @mld_name">
            <QP N="step" />
            <QP N="up_down" />
            <QP N="alarm" />
            <QP N="need_action" />
            <QP N="next_need_action" />
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="hist_seq" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="mld_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="474" N="InsertMapLoaderAtr">
          <QY P="MsSql" Q="INSERT INTO QWMSMLDATR (&#xD;&#xA;   FACTORY,&#xD;&#xA;   MLD_NAME,&#xD;&#xA;   ATTR_CATEGORY,&#xD;&#xA;   PACKAGE,&#xD;&#xA;   PKG_VER,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) &#xD;&#xA;SELECT &#xD;&#xA;   FACTORY,&#xD;&#xA;   MLD_NAME,&#xD;&#xA;   @attr_category2,&#xD;&#xA;   PACKAGE,&#xD;&#xA;   PKG_VER,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;  FROM QWMSMLDATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND MLD_NAME      = @mld_name&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="attr_category2" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="mld_name" />
            <QP N="attr_category" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="475" N="DeleteMapLoaderAtr">
          <QY P="MsSql" Q="DELETE FROM QWMSMLDATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND MLD_NAME      = @mld_name&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="mld_name" />
            <QP N="attr_category" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
      </F>
    </M>
    <M _S="476" N="View">
      <F _S="477" N="MapLoaderLog">
        <SG _S="478" N="HasMapLoader">
          <QY P="MsSql" Q="SELECT MLD_NAME&#xD;&#xA;  FROM QWMSMLDDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND MLD_NAME    = @mld_name&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="mld_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
