            <QP N="bin_8_qty" />
            <QP N="bin_9_qty" />
            <QP N="bin_10_qty" />
            <QP N="bin_d_qty" />
            <QP N="create_time" />
            <QP N="create_user_id" />
          </QY>
        </SG>
        <SG _S="150" N="InsertWaferMapInfoHis">
          <QY P="MsSql" Q="INSERT INTO QWMSWAFMPH&#xD;&#xA;   FACTORY,&#xD;&#xA;   LOT_ID,&#xD;&#xA;   WAFER_ID,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   CUS_ID,&#xD;&#xA;   GOOD_QTY,&#xD;&#xA;   BAD_QTY,&#xD;&#xA;   FLAT_ZONE,&#xD;&#xA;   BIN_INFO,   &#xD;&#xA;   BIN_1_QTY,&#xD;&#xA;   BIN_2_QTY,&#xD;&#xA;   BIN_3_QTY,&#xD;&#xA;   BIN_4_QTY,&#xD;&#xA;   BIN_5_QTY,&#xD;&#xA;   BIN_6_QTY,&#xD;&#xA;   BIN_7_QTY,&#xD;&#xA;   BIN_8_QTY,&#xD;&#xA;   BIN_9_QTY,&#xD;&#xA;   BIN_10_QTY,&#xD;&#xA;   BIN_D_QTY,   &#xD;&#xA;   TRAN_USER_ID&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @lot_id,&#xD;&#xA;   @wafer_id,&#xD;&#xA;   @hist_seq,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @cus_id,&#xD;&#xA;   @good_qty,&#xD;&#xA;   @bad_qty,&#xD;&#xA;   @flat_zone,&#xD;&#xA;   @bin_1_qty,&#xD;&#xA;   @bin_2_qty,&#xD;&#xA;   @bin_3_qty,&#xD;&#xA;   @bin_4_qty,&#xD;&#xA;   @bin_5_qty,&#xD;&#xA;   @bin_6_qty,&#xD;&#xA;   @bin_7_qty,&#xD;&#xA;   @bin_8_qty,&#xD;&#xA;   @bin_9_qty,&#xD;&#xA;   @bin_10_qty,&#xD;&#xA;   @bin_d_qty,&#xD;&#xA;   @tran_user_id&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="lot_id" />
            <QP N="wafer_id" />
            <QP N="hist_seq" />
            <QP N="tran_time" />
            <QP N="cus_id" />
            <QP N="good_qty" />
            <QP N="bad_qty" />
            <QP N="flat_zone" />
            <QP N="bin_1_qty" />
            <QP N="bin_2_qty" />
            <QP N="bin_3_qty" />
            <QP N="bin_4_qty" />
            <QP N="bin_5_qty" />
            <QP N="bin_6_qty" />
            <QP N="bin_7_qty" />
            <QP N="bin_8_qty" />
            <QP N="bin_9_qty" />
            <QP N="bin_10_qty" />
            <QP N="bin_d_qty" />
            <QP N="tran_user_id" />
          </QY>
        </SG>
        <SG _S="151" N="SelectWaferBinInfoHis">
          <QY P="MsSql" Q="SELECT MAX(HIST_SEQ) AS HIST_SEQ&#xD;&#xA;  FROM QWMSWAFBNH&#xD;&#xA; WHERE WAFER_ID = @wafer_id&#xD;&#xA;   ">
            <QP N="wafer_id" />
          </QY>
        </SG>
        <SG _S="152" N="SelectWaferMapInfoHis">
          <QY P="MsSql" Q="SELECT MAX(HIST_SEQ) AS HIST_SEQ&#xD;&#xA;   FROM MTAPWAFMPH&#xD;&#xA; WHERE WAFER_ID = @wafer_id&#xD;&#xA;    AND   LOT_ID = @lot_id">
            <QP N="wafer_id" />
            <QP N="lot_id" />
          </QY>
        </SG>
        <SG _S="153" N="DeleteWaferBinInfo">
          <QY P="MsSql" Q="DELETE&#xD;&#xA;  FROM QWMSWAFBNT&#xD;&#xA; WHERE WAFER_ID    = @wafer_id">
            <QP N="wafer_id" />
          </QY>
        </SG>
        <SG _S="154" N="UpdateWaferMapInfo">
          <QY P="MsSql" Q="UPDATE QWMSWAFMAP SET &#xD;&#xA;   FACTORY              	=   @factory,&#xD;&#xA;   LOT_ID               	=   @lot_id,&#xD;&#xA;   WAFER_ID             	=   @wafer_id,&#xD;&#xA;   HIST_SEQ             	=   @hist_seq,&#xD;&#xA;   CUS_ID               	=   @cus_id,&#xD;&#xA;   GOOD_QTY             	=   @good_qty,&#xD;&#xA;   BAD_QTY              	=   @bad_qty,&#xD;&#xA;   FLAT_ZONE            	=   @flat_zone,&#xD;&#xA;   BIN_INFO             	=   @bin_1_qty,&#xD;&#xA;   BIN_1_QTY            	=   @bin_2_qty,&#xD;&#xA;   BIN_2_QTY           	=   @bin_3_qty,&#xD;&#xA;   BIN_3_QTY            	=   @bin_4_qty,&#xD;&#xA;   BIN_4_QTY            	=   @bin_5_qty,&#xD;&#xA;   BIN_5_QTY            	=   @bin_6_qty,&#xD;&#xA;   BIN_6_QTY            	=   @bin_7_qty,&#xD;&#xA;   BIN_7_QTY            	=   @bin_8_qty,&#xD;&#xA;   BIN_8_QTY            	=   @bin_9_qty,&#xD;&#xA;   BIN_9_QTY            	=   @bin_10_qty&#xD;&#xA;   BIN_10_QTY          	=   @bin_d_qty,&#xD;&#xA;   BIN_D_QTY            	=   @BIN&#xD;&#xA;   UPDATE_USER_ID   	=&#xD;&#xA;   UPDATE_TIME   	=&#xD;&#xA;">
            <QP N="factory" />
            <QP N="lot_id" />
            <QP N="wafer_id" />
            <QP N="hist_seq" />
            <QP N="cus_id" />
            <QP N="good_qty" />
            <QP N="bad_qty" />
            <QP N="flat_zone" />
            <QP N="bin_1_qty" />
            <QP N="bin_2_qty" />
            <QP N="bin_3_qty" />
            <QP N="bin_4_qty" />
            <QP N="bin_5_qty" />
            <QP N="bin_6_qty" />
            <QP N="bin_7_qty" />
            <QP N="bin_8_qty" />
            <QP N="bin_9_qty" />
            <QP N="bin_10_qty" />
            <QP N="bin_d_qty" />
            <QP N="BIN" />
          </QY>
        </SG>
      </F>
      <F _S="174" N="ApplyWaferMap">
        <SG _S="175" N="HasWaferMap">
          <QY P="MsSql" Q="SELECT LOT_ID, WAFER_ID, HIST_SEQ, CUS_ID, GOOD_QTY, BAD_QTY, FLAT_ZONE, BIN_1_QTY, BIN_2_QTY, BIN_3_QTY, BIN_4_QTY, BIN_5_QTY, BIN_6_QTY, BIN_7_QTY, BIN_8_QTY, BIN_9_QTY, BIN_10_QTY, BIN_D_QTY, CREATE_TIME, CREATE_USER_ID, UPDATE_TIME, UPDATE_USER_ID&#xD;&#xA;  FROM QWMSWAFMAP&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND WAFER_ID  = @wafer_id">
            <QP N="factory" />
            <QP N="wafer_id" />
          </QY>
        </SG>
        <SG _S="277" N="SearchTempWaferMap">
          <QY P="MsSql" Q="SELECT LOT_ID, WAFER_ID, CUS_ID, GOOD_QTY, BAD_QTY, FLAT_ZONE, &#xD;&#xA;       BIN_1_QTY, BIN_2_QTY, BIN_3_QTY, BIN_4_QTY, BIN_5_QTY, &#xD;&#xA;       BIN_6_QTY, BIN_7_QTY, BIN_8_QTY, BIN_9_QTY, BIN_10_QTY, &#xD;&#xA;       BIN_D_QTY, TRAN_USER_ID, COLS, ROWS,&#xD;&#xA;       DEVICE_ID, REFERENCE_DIE,   DIE_SIZE_X, DIE_SIZE_Y, MAP_FILE_NAME&#xD;&#xA;  FROM QWMSWAFMPT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND LOT_ID   = @lot_id&#xD;&#xA;   AND WAFER_ID = @wafer_id">
            <QP N="factory" />
            <QP N="lot_id" />
            <QP N="wafer_id" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="278" N="SearchTempWaferBin">
          <QY P="MsSql" Q="SELECT WAFER_ID, MAP_SEQ,  COLS, ROWS, BIN_INFO, &#xD;&#xA;       BIN_1_QTY, BIN_2_QTY, BIN_3_QTY, BIN_4_QTY, BIN_5_QTY, &#xD;&#xA;       BIN_6_QTY, BIN_7_QTY, BIN_8_QTY, BIN_9_QTY, BIN_10_QTY, &#xD;&#xA;       BIN_D_QTY&#xD;&#xA;  FROM QWMSWAFBNT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND WAFER_ID = @wafer_id&#xD;&#xA; ORDER BY MAP_SEQ">
            <QP N="factory" />
            <QP N="wafer_id" />
          </QY>
        </SG>
        <SG _S="291" N="SearchWaferMap">
          <QY P="MsSql" Q="SELECT A.WAFER_ID, A.LOT_ID, A.CUS_ID, A.GOOD_QTY, A.BAD_QTY, A.FLAT_ZONE,&#xD;&#xA;       B.COLS, B.ROWS, B.MAP_SEQ, B.BIN_INFO, B.BIN_1_QTY, B.BIN_2_QTY, B.BIN_3_QTY, B.BIN_4_QTY, B.BIN_5_QTY, &#xD;&#xA;       B.BIN_6_QTY, B.BIN_7_QTY, B.BIN_8_QTY, B.BIN_9_QTY, B.BIN_10_QTY, B.BIN_D_QTY&#xD;&#xA;  FROM QWMSWAFBIN B&#xD;&#xA;  LEFT JOIN QWMSWAFMAP A&#xD;&#xA;    ON A.FACTORY  = B.FACTORY&#xD;&#xA;   AND A.WAFER_ID = B.WAFER_ID&#xD;&#xA; WHERE A.FACTORY  = @factory&#xD;&#xA;   AND A.LOT_ID   = @lot_id&#xD;&#xA; ORDER BY A.WAFER_ID, B.MAP_SEQ">
            <QP N="factory" />
            <QP N="lot_id" />
          </QY>
        </SG>
        <SG _S="279" N="InsertWaferMap">
          <QY P="MsSql" Q="INSERT INTO QWMSWAFMAP (&#xD;&#xA;   FACTORY,&#xD;&#xA;   LOT_ID,&#xD;&#xA;   WAFER_ID,&#xD;&#xA;   DEVICE_ID,&#xD;&#xA;   REFERENCE_DIE,&#xD;&#xA;   DIE_SIZE_X,&#xD;&#xA;   DIE_SIZE_Y,&#xD;&#xA;   COLS,&#xD;&#xA;   ROWS,&#xD;&#xA;   MAP_FILE_NAME,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   CUS_ID,&#xD;&#xA;   GOOD_QTY,&#xD;&#xA;   BAD_QTY,&#xD;&#xA;   FLAT_ZONE,&#xD;&#xA;   BIN_1_QTY,&#xD;&#xA;   BIN_2_QTY,&#xD;&#xA;   BIN_3_QTY,&#xD;&#xA;   BIN_4_QTY,&#xD;&#xA;   BIN_5_QTY,&#xD;&#xA;   BIN_6_QTY,&#xD;&#xA;   BIN_7_QTY,&#xD;&#xA;   BIN_8_QTY,&#xD;&#xA;   BIN_9_QTY,&#xD;&#xA;   BIN_10_QTY,&#xD;&#xA;   BIN_D_QTY,   &#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   UPDATE_TIME,&#xD;&#xA;   UPDATE_USER_ID&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @lot_id,&#xD;&#xA;   @wafer_id,&#xD;&#xA;   @device_id,&#xD;&#xA;   @reference_die,&#xD;&#xA;   @die_size_x,&#xD;&#xA;   @die_size_y,&#xD;&#xA;   @cols,&#xD;&#xA;   @rows,&#xD;&#xA;   @map_file_name,&#xD;&#xA;   @hist_seq,&#xD;&#xA;   @cus_id,&#xD;&#xA;   @good_qty,&#xD;&#xA;   @bad_qty,&#xD;&#xA;   @flat_zone,&#xD;&#xA;   @bin_1_qty,&#xD;&#xA;   @bin_2_qty,&#xD;&#xA;   @bin_3_qty,&#xD;&#xA;   @bin_4_qty,&#xD;&#xA;   @bin_5_qty,&#xD;&#xA;   @bin_6_qty,&#xD;&#xA;   @bin_7_qty,&#xD;&#xA;   @bin_8_qty,&#xD;&#xA;   @bin_9_qty,&#xD;&#xA;   @bin_10_qty,&#xD;&#xA;   @bin_d_qty,&#xD;&#xA;   @create_time,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @update_time,&#xD;&#xA;   @update_user_id&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="lot_id" />
            <QP N="wafer_id" />
            <QP N="device_id" />
            <QP N="reference_die" />
            <QP N="die_size_x" />
            <QP N="die_size_y" />
            <QP N="cols" />
            <QP N="rows" />
            <QP N="map_file_name" />
            <QP N="hist_seq" />
            <QP N="cus_id" />
            <QP N="good_qty" />
            <QP N="bad_qty" />
            <QP N="flat_zone" />
            <QP N="bin_1_qty" />
            <QP N="bin_2_qty" />
            <QP N="bin_3_qty" />
            <QP N="bin_4_qty" />
            <QP N="bin_5_qty" />
            <QP N="bin_6_qty" />
            <QP N="bin_7_qty" />
            <QP N="bin_8_qty" />
            <QP N="bin_9_qty" />
            <QP N="bin_10_qty" />
            <QP N="bin_d_qty" />
            <QP N="create_time" />
            <QP N="create_user_id" />
            <QP N="update_time" />
            <QP N="update_user_id" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="281" N="InsertWaferBin">
          <QY P="MsSql" Q="INSERT INTO QWMSWAFBIN (&#xD;&#xA;   FACTORY,&#xD;&#xA;   WAFER_ID,&#xD;&#xA;   MAP_SEQ,   &#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   COLS,&#xD;&#xA;   ROWS,&#xD;&#xA;   BIN_INFO,&#xD;&#xA;   BIN_1_QTY,&#xD;&#xA;   BIN_2_QTY,&#xD;&#xA;   BIN_3_QTY,&#xD;&#xA;   BIN_4_QTY,&#xD;&#xA;   BIN_5_QTY,&#xD;&#xA;   BIN_6_QTY,&#xD;&#xA;   BIN_7_QTY,&#xD;&#xA;   BIN_8_QTY,&#xD;&#xA;   BIN_9_QTY,&#xD;&#xA;   BIN_10_QTY,&#xD;&#xA;   BIN_D_QTY,   &#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   UPDATE_TIME,&#xD;&#xA;   UPDATE_USER_ID)" />
        </SG>
        <SG _S="289" N="UpdateWaferMap">
          <QY P="MsSql" Q="UPDATE QWMSWAFMAP SET &#xD;&#xA;   LOT_ID          	= @lot_id,&#xD;&#xA;   HIST_SEQ			= @hist_seq,&#xD;&#xA;   CUS_ID 			= @cus_id,&#xD;&#xA;   GOOD_QTY        	= @good_qty,&#xD;&#xA;   BAD_QTY         	= @bad_qty,&#xD;&#xA;   FLAT_ZONE       	= @flat_zone,&#xD;&#xA;   BIN_1_QTY      	= @bin_1_qty,&#xD;&#xA;   BIN_2_QTY      	= @bin_2_qty,&#xD;&#xA;   BIN_3_QTY      	= @bin_3_qty,&#xD;&#xA;   BIN_4_QTY      	= @bin_4_qty,&#xD;&#xA;   BIN_5_QTY      	= @bin_5_qty,&#xD;&#xA;   BIN_6_QTY      	= @bin_6_qty,&#xD;&#xA;   BIN_7_QTY      	= @bin_7_qty,&#xD;&#xA;   BIN_8_QTY      	= @bin_8_qty,&#xD;&#xA;   BIN_9_QTY      	= @bin_9_qty,&#xD;&#xA;   BIN_10_QTY      	= @bin_10_qty,&#xD;&#xA;   BIN_D_QTY 	   	= @bin_d_qty,       &#xD;&#xA;   UPDATE_TIME     	= @update_time,&#xD;&#xA;   UPDATE_USER_ID  	= @update_user_id&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND WAFER_ID    	= @wafer_id">
            <QP N="lot_id" />
            <QP N="hist_seq" />
            <QP N="cus_id" />
            <QP N="good_qty" />
            <QP N="bad_qty" />
            <QP N="flat_zone" />
            <QP N="bin_1_qty" />
            <QP N="bin_2_qty" />
            <QP N="bin_3_qty" />
            <QP N="bin_4_qty" />
            <QP N="bin_5_qty" />
            <QP N="bin_6_qty" />
            <QP N="bin_7_qty" />
            <QP N="bin_8_qty" />
            <QP N="bin_9_qty" />
            <QP N="bin_10_qty" />
            <QP N="bin_d_qty" />
            <QP N="update_time" />
            <QP N="update_user_id" />
            <QP N="factory" />
            <QP N="wafer_id" />
          </QY>
        </SG>
        <SG _S="290" N="DeleteWaferBin">
          <QY P="MsSql" Q="DELETE&#xD;&#xA;  FROM QWMSWAFBIN&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND WAFER_ID  = @wafer_id">
            <QP N="factory" />
            <QP N="wafer_id" />
          </QY>
        </SG>
        <SG _S="292" N="DeleteTempWaferMap">
          <QY P="MsSql" Q="DELETE  &#xD;&#xA;  FROM QWMSWAFMPT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND LOT_ID   = @lot_id&#xD;&#xA;   AND WAFER_ID = @wafer_id">
            <QP N="factory" />
            <QP N="lot_id" />
            <QP N="wafer_id" />
          </QY>
        </SG>
        <SG _S="293" N="DeleteTempWaferBin">
          <QY P="MsSql" Q="DELETE  &#xD;&#xA;  FROM QWMSWAFBNT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND WAFER_ID = @wafer_id">
            <QP N="factory" />
            <QP N="wafer_id" />
          </QY>
        </SG>
      </F>
      <F _S="440" N="MapLoaderRelease">
        <SG _S="441" N="HasMapLoader">
          <QY P="MsSql" Q="SELECT MLD_NAME, UP_DOWN, STEP, STATUS, NEED_ACTION, NEXT_NEED_ACTION&#xD;&#xA;  FROM QWMSMLDDEF &#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND MLD_NAME     = @mld_def&#xD;&#xA;   AND DELETE_FLAG  = 'N'">
            <QP N="factory" />
            <QP N="mld_def" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
