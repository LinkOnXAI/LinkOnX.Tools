        <SG _S="267" N="ListCusMapBin">
          <QY P="MsSql" Q="SELECT A.MAP_TYPE, A.PSR_NAME, &#xD;&#xA;       ISNULL(B.CUS_BIN_CODE, ' ') AS CUS_BIN_CODE, &#xD;&#xA;	   ISNULL(B.CUS_BIN_GRADE, ' ') AS CUS_BIN_GRADE, &#xD;&#xA;	   ISNULL(B.BIN_CODE, ' ') AS BIN_CODE&#xD;&#xA;  FROM QWMSCUSMAP A&#xD;&#xA;  LEFT JOIN QWMSCUSBIN B&#xD;&#xA;    ON A.FACTORY = B.FACTORY&#xD;&#xA;   AND A.CUS_ID  = B.CUS_ID&#xD;&#xA;   AND A.MAP_TYPE = B.MAP_TYPE&#xD;&#xA; WHERE A.FACTORY  = @factory&#xD;&#xA;   AND A.CUS_ID   = @cus_id">
            <QP N="factory" />
            <QP N="cus_id" />
          </QY>
        </SG>
        <SG _S="513" N="ListSplMapBin">
          <QY P="MsSql" Q="SELECT A.MAP_TYPE, A.PSR_NAME,&#xD;&#xA;       ISNULL(B.SPL_BIN_CODE, ' ') AS CUS_BIN_CODE, &#xD;&#xA;	   ISNULL(B.SPL_BIN_GRADE, ' ') AS CUS_BIN_GRADE, &#xD;&#xA;	   ISNULL(B.BIN_CODE, ' ') AS BIN_CODE&#xD;&#xA;  FROM QWMSSPLMAP A&#xD;&#xA;  LEFT JOIN QWMSSPLBIN B&#xD;&#xA;    ON A.FACTORY = B.FACTORY&#xD;&#xA;   AND A.SPL_NAME  = B.SPL_NAME&#xD;&#xA;   AND A.MAP_TYPE = B.MAP_TYPE&#xD;&#xA; WHERE A.FACTORY  = @factory&#xD;&#xA;   AND A.SPL_NAME   = @spl_name&#xD;&#xA; ">
            <QP N="factory" />
            <QP N="spl_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
