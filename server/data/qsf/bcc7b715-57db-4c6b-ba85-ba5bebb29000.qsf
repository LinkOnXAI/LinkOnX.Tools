        </SG>
        <SG _S="56" N="SelectLinkOperation">
          <QY P="MsSql" Q="SELECT OPER, OPER_DESC, OPER_GROUP, FROM_SOURCE, FROM_REF_OPER, FROM_CONT, TO_CONT, FROM_COMMAND_TYPE,  FROM_SQL, TO_COMMAND_TYPE, TO_SQL&#xD;&#xA;  FROM QDLSOPRDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND OPER_GROUP = @oper_group&#xD;&#xA;   AND OPER = @oper">
            <QP N="factory" />
            <QP N="oper_group" />
            <QP N="oper" />
          </QY>
        </SG>
      </F>
      <F _S="57" N="LinkOperationGroup">
        <SG _S="58" N="SelectLinkOperationGroup">
          <QY P="MsSql" Q="SELECT OPER_GROUP, REPEAT_TYPE, REPEAT_VALUE&#xD;&#xA;  FROM QDLSOPGDEF&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND OPER_GROUP   = @group_name&#xD;&#xA;   AND DELETE_FLAG != 'Y'">
            <QP N="factory" />
            <QP N="group_name" />
          </QY>
        </SG>
        <SG _S="59" N="SelectLinkOperationGroupList">
          <QY P="MsSql" Q="SELECT OPER_GROUP, REPEAT_TYPE, REPEAT_VALUE&#xD;&#xA;  FROM QDLSOPGDEF&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND DELETE_FLAG != 'Y'">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="60" N="LinkConnector">
        <SG _S="61" N="SelectLinkConnector">
          <QY P="MsSql" Q="SELECT CONNECTOR, CONT_SQL_PROVIDER, CONT_STRING, CONT_PWD&#xD;&#xA;  FROM QDLSCNTDEF&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND CONNECTOR   = @connector&#xD;&#xA;   AND DELETE_FLAG != 'Y'">
            <QP N="factory" />
            <QP N="connector" />
          </QY>
        </SG>
      </F>
      <F _S="62" N="LinkDataMapping">
        <SG _S="63" N="SelectLinkDataMappingList">
          <QY P="MsSql" Q="SELECT TO_VAR, TO_TYPE, FROM_VAR, FROM_TYPE&#xD;&#xA;  FROM QDLSOPRMAP&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND OPER_GROUP = @oper_group&#xD;&#xA;   AND OPER = @oper&#xD;&#xA; ORDER BY TO_VAR">
            <QP N="factory" />
            <QP N="oper_group" />
            <QP N="oper" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="334" N="MapWatcher">
