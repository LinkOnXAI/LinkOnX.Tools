          <QY P="MsSql" Q="SELECT BIN_CODE, BIN_GRADE&#xD;&#xA;  FROM QWMSBINDEF&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND BIN_GRADE = @bin_grade">
