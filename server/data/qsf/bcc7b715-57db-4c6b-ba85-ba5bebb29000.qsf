      <F _S="201" N="EventSearch">
        <SG _S="202" N="SearchUserEvent">
          <QY P="MsSql" Q="SELECT EVENT_DESC, &#xD;&#xA;       DATA_1_PRT, DATA_2_PRT, DATA_3_PRT, DATA_4_PRT, DATA_5_PRT,&#xD;&#xA;       DATA_6_PRT, DATA_7_PRT, DATA_8_PRT, DATA_9_PRT, DATA_10_PRT,&#xD;&#xA;       DATA_11_PRT, DATA_12_PRT, DATA_13_PRT, DATA_14_PRT, DATA_15_PRT,&#xD;&#xA;       DATA_16_PRT, DATA_17_PRT, DATA_18_PRT, DATA_19_PRT, DATA_20_PRT&#xD;&#xA;  FROM QSECUSREVT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND SYSTEM   = @system&#xD;&#xA;   AND EVENT_ID = @event_id&#xD;&#xA;   AND ACTION   = @action">
            <QP N="factory" />
            <QP N="system" />
            <QP N="event_id" />
            <QP N="action" />
          </QY>
        </SG>
        <SG _S="432" N="SearchMapLoaderEvent">
          <QY P="MsSql" Q="SELECT EVENT_DESC,&#xD;&#xA;       DATA_1_PRT, DATA_2_PRT, DATA_3_PRT, DATA_4_PRT, DATA_5_PRT,&#xD;&#xA;       DATA_6_PRT, DATA_7_PRT, DATA_8_PRT, DATA_9_PRT, DATA_10_PRT,    &#xD;&#xA;       DATA_11_PRT, DATA_12_PRT, DATA_13_PRT, DATA_14_PRT, DATA_15_PRT,&#xD;&#xA;       DATA_16_PRT, DATA_17_PRT, DATA_18_PRT, DATA_19_PRT, DATA_20_PRT,&#xD;&#xA;       ALT_COMMENT&#xD;&#xA;  FROM QWMSMLDEVT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EVENT_ID = @event_id">
            <QP N="factory" />
            <QP N="event_id" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
      </F>
      <F _S="461" N="MapLoaderFilePack">
        <SG _S="462" N="HasPackageVer">
          <QY P="MsSql" Q="SELECT PKG_VER_PATH, PKG_RELEASE&#xD;&#xA;  FROM QWMSPKGVER  &#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND PACKAGE = @package&#xD;&#xA;   AND PKG_VER = @pkg_ver">
            <QP N="factory" />
            <QP N="package" />
            <QP N="pkg_ver" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
      </F>
      <F _S="303" N="WaferMap">
        <SG _S="311" N="SearchStdBinCodeList">
          <QY P="MsSql" Q="SELECT BIN_CODE, BIN_GRADE, BIN_COLOR&#xD;&#xA;  FROM QWMSBINDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY BIN_CODE">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="305" N="SearchWaferMap">
          <QY P="MsSql" Q="SELECT WAFER_ID, CUS_ID, LOT_ID, GOOD_QTY, BAD_QTY, FLAT_ZONE, &#xD;&#xA;       BIN_1_QTY, BIN_2_QTY, BIN_3_QTY, BIN_4_QTY, BIN_5_QTY, &#xD;&#xA;	   BIN_6_QTY, BIN_7_QTY, BIN_8_QTY, BIN_9_QTY, BIN_10_QTY, BIN_D_QTY,&#xD;&#xA;	   DEVICE_ID, REFERENCE_DIE,   DIE_SIZE_X, DIE_SIZE_Y, MAP_FILE_NAME&#xD;&#xA;  FROM QWMSWAFMAP&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND WAFER_ID  = @wafer_id">
            <QP N="factory" />
            <QP N="wafer_id" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="306" N="SearchWaferBin">
          <QY P="MsSql" Q="SELECT MAP_SEQ, COLS, ROWS, BIN_INFO, &#xD;&#xA;       BIN_1_QTY, BIN_2_QTY, BIN_3_QTY, BIN_4_QTY, BIN_5_QTY, &#xD;&#xA;	   BIN_6_QTY, BIN_7_QTY, BIN_8_QTY, BIN_9_QTY, BIN_10_QTY&#xD;&#xA;  FROM QWMSWAFBIN&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND WAFER_ID = @wafer_id&#xD;&#xA; ORDER BY MAP_SEQ">
            <QP N="factory" />
            <QP N="wafer_id" />
          </QY>
        </SG>
        <SG _S="307" N="SearchWaferMapHis">
          <QY P="MsSql" Q="SELECT B.WAFER_ID, B.LOT_ID, B.GOOD_QTY, B.BAD_QTY, B.FLAT_ZONE, &#xD;&#xA;       B.BIN_1_QTY, B.BIN_2_QTY, B.BIN_3_QTY, B.BIN_4_QTY, B.BIN_5_QTY, B.BIN_6_QTY, &#xD;&#xA;       B.BIN_7_QTY, B.BIN_8_QTY, B.BIN_9_QTY, B.BIN_10_QTY,	B.BIN_D_QTY, &#xD;&#xA;       A.DEVICE_ID, A.REFERENCE_DIE,   A.DIE_SIZE_X, A.DIE_SIZE_Y, A.MAP_FILE_NAME,&#xD;&#xA;       B.TRAN_TIME , B.TRAN_USER_ID      &#xD;&#xA;  FROM QWMSWAFMPH B&#xD;&#xA;  LEFT JOIN QWMSWAFMAP A&#xD;&#xA;    ON A.FACTORY  = B.FACTORY&#xD;&#xA;   AND A.WAFER_ID = B.WAFER_ID&#xD;&#xA; WHERE A.FACTORY   = @factory&#xD;&#xA;   AND A.WAFER_ID  = @wafer_id&#xD;&#xA;   AND B.HIST_SEQ  = @hist_seq">
            <QP N="factory" />
            <QP N="wafer_id" />
            <QP N="hist_seq" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="308" N="SearchWaferBinHis">
          <QY P="MsSql" Q="SELECT MAP_SEQ, COLS, ROWS, BIN_INFO, &#xD;&#xA;       BIN_1_QTY, BIN_2_QTY, BIN_3_QTY, BIN_4_QTY, BIN_5_QTY, &#xD;&#xA;	   BIN_6_QTY, BIN_7_QTY, BIN_8_QTY, BIN_9_QTY, BIN_10_QTY&#xD;&#xA;  FROM QWMSWAFBNH&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND WAFER_ID  = @wafer_id&#xD;&#xA;   AND HIST_SEQ  = @hist_seq&#xD;&#xA; ORDER BY MAP_SEQ">
            <QP N="factory" />
            <QP N="wafer_id" />
            <QP N="hist_seq" />
          </QY>
        </SG>
        <SG _S="309" N="SearchTmpWaferMap">
          <QY P="MsSql" Q="SELECT WAFER_ID, LOT_ID, GOOD_QTY, BAD_QTY, FLAT_ZONE, &#xD;&#xA;       BIN_1_QTY, BIN_2_QTY, BIN_3_QTY, BIN_4_QTY, BIN_5_QTY, &#xD;&#xA;	   BIN_6_QTY, BIN_7_QTY, BIN_8_QTY, BIN_9_QTY, BIN_10_QTY, BIN_D_QTY,&#xD;&#xA;	    DEVICE_ID, REFERENCE_DIE,   DIE_SIZE_X, DIE_SIZE_Y, MAP_FILE_NAME&#xD;&#xA;  FROM QWMSWAFMPT&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND WAFER_ID  = @wafer_id">
            <QP N="factory" />
            <QP N="wafer_id" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="310" N="SearchTmpWaferBin">
          <QY P="MsSql" Q="SELECT MAP_SEQ, COLS, ROWS, BIN_INFO, &#xD;&#xA;       BIN_1_QTY, BIN_2_QTY, BIN_3_QTY, BIN_4_QTY, BIN_5_QTY, &#xD;&#xA;	   BIN_6_QTY, BIN_7_QTY, BIN_8_QTY, BIN_9_QTY, BIN_10_QTY&#xD;&#xA;  FROM QWMSWAFBNT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND WAFER_ID = @wafer_id&#xD;&#xA; ORDER BY MAP_SEQ">
            <QP N="factory" />
            <QP N="wafer_id" />
          </QY>
        </SG>
      </F>
      <F _S="283" N="WaferMapHistory">
        <SG _S="285" N="SelectWaferMapHisSeq">
          <QY P="MsSql" Q="SELECT NEXT VALUE FOR SEQ_WMS_MAP_HIS" />
        </SG>
        <SG _S="287" N="InsertWaferMapHis">
          <QY P="MsSql" Q="INSERT INTO QWMSWAFMPH (&#xD;&#xA;   FACTORY,&#xD;&#xA;   LOT_ID,&#xD;&#xA;   WAFER_ID,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   CUS_ID,&#xD;&#xA;   GOOD_QTY,&#xD;&#xA;   BAD_QTY,&#xD;&#xA;   FLAT_ZONE,&#xD;&#xA;   BIN_1_QTY,&#xD;&#xA;   BIN_2_QTY,&#xD;&#xA;   BIN_3_QTY,&#xD;&#xA;   BIN_4_QTY,&#xD;&#xA;   BIN_5_QTY,&#xD;&#xA;   BIN_6_QTY,&#xD;&#xA;   BIN_7_QTY,&#xD;&#xA;   BIN_8_QTY,&#xD;&#xA;   BIN_9_QTY,&#xD;&#xA;   BIN_10_QTY,&#xD;&#xA;   BIN_D_QTY,   &#xD;&#xA;   TRAN_USER_ID&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @lot_id,&#xD;&#xA;   @wafer_id,&#xD;&#xA;   @hist_seq,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @cus_id,&#xD;&#xA;   @good_qty,&#xD;&#xA;   @bad_qty,&#xD;&#xA;   @flat_zone,&#xD;&#xA;   @bin_1_qty,&#xD;&#xA;   @bin_2_qty,&#xD;&#xA;   @bin_3_qty,&#xD;&#xA;   @bin_4_qty,&#xD;&#xA;   @bin_5_qty,&#xD;&#xA;   @bin_6_qty,&#xD;&#xA;   @bin_7_qty,&#xD;&#xA;   @bin_8_qty,&#xD;&#xA;   @bin_9_qty,&#xD;&#xA;   @bin_10_qty,&#xD;&#xA;   @bin_d_qty,&#xD;&#xA;   @tran_user_id&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="lot_id" />
            <QP N="wafer_id" />
            <QP N="hist_seq" />
            <QP N="tran_time" />
            <QP N="cus_id" />
            <QP N="good_qty" />
            <QP N="bad_qty" />
            <QP N="flat_zone" />
            <QP N="bin_1_qty" />
            <QP N="bin_2_qty" />
            <QP N="bin_3_qty" />
            <QP N="bin_4_qty" />
            <QP N="bin_5_qty" />
            <QP N="bin_6_qty" />
            <QP N="bin_7_qty" />
            <QP N="bin_8_qty" />
            <QP N="bin_9_qty" />
            <QP N="bin_10_qty" />
            <QP N="bin_d_qty" />
            <QP N="tran_user_id" />
          </QY>
        </SG>
      </F>
      <F _S="412" N="MapLoaderHistory">
        <SG _S="413" N="SelectMapLoaderHistorySeq">
          <QY P="MsSql" Q="SELECT NEXT VALUE FOR SEQ_MAPLOADER_HIS" />
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="414" N="SelectMapLoaderInfoForHistory">
          <QY P="MsSql" Q="SELECT FACTORY, MLD_NAME, SPL_NAME, STEP, ALARM, UP_DOWN, STATUS, NEED_ACTION, NEXT_NEED_ACTION, DELETE_FLAG   &#xD;&#xA;  FROM QWMSMLDDEF &#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND MLD_NAME = @mld_name">
            <QP N="factory" />
            <QP N="mld_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="415" N="InsertMapLoaderHistory">
          <QY P="MsSql" Q="INSERT INTO QWMSMLDHIS (&#xD;&#xA;   FACTORY,&#xD;&#xA;   MLD_NAME,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   EVENT_ID,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   STEP,&#xD;&#xA;   UP_DOWN,&#xD;&#xA;   STATUS,&#xD;&#xA;   NEED_ACTION,&#xD;&#xA;   NEXT_NEED_ACTION,&#xD;&#xA;   EVT_H_1,&#xD;&#xA;   EVT_D_1,   &#xD;&#xA;   EVT_H_2,&#xD;&#xA;   EVT_D_2,&#xD;&#xA;   EVT_H_3,&#xD;&#xA;   EVT_D_3,&#xD;&#xA;   EVT_H_4,&#xD;&#xA;   EVT_D_4,&#xD;&#xA;   EVT_H_5,&#xD;&#xA;   EVT_D_5,&#xD;&#xA;   EVT_H_6,&#xD;&#xA;   EVT_D_6,&#xD;&#xA;   EVT_H_7,&#xD;&#xA;   EVT_D_7,&#xD;&#xA;   EVT_H_8,&#xD;&#xA;   EVT_D_8,&#xD;&#xA;   EVT_H_9,&#xD;&#xA;   EVT_D_9,&#xD;&#xA;   EVT_H_10,&#xD;&#xA;   EVT_D_10,&#xD;&#xA;   EVT_H_11,&#xD;&#xA;   EVT_D_11,   &#xD;&#xA;   EVT_H_12,&#xD;&#xA;   EVT_D_12,&#xD;&#xA;   EVT_H_13,&#xD;&#xA;   EVT_D_13,&#xD;&#xA;   EVT_H_14,&#xD;&#xA;   EVT_D_14,&#xD;&#xA;   EVT_H_15,&#xD;&#xA;   EVT_D_15,&#xD;&#xA;   EVT_H_16,&#xD;&#xA;   EVT_D_16,&#xD;&#xA;   EVT_H_17,&#xD;&#xA;   EVT_D_17,&#xD;&#xA;   EVT_H_18,&#xD;&#xA;   EVT_D_18,&#xD;&#xA;   EVT_H_19,&#xD;&#xA;   EVT_D_19,&#xD;&#xA;   EVT_H_20,&#xD;&#xA;   EVT_D_20,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT      &#xD;&#xA;) &#xD;&#xA;VALUES( &#xD;&#xA;   @factory,&#xD;&#xA;   @mld_name,&#xD;&#xA;   @hist_seq,&#xD;&#xA;   @event_id,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @step,&#xD;&#xA;   @up_down,&#xD;&#xA;   @ctn_status,&#xD;&#xA;   @need_action,&#xD;&#xA;   @next_action,   &#xD;&#xA;   @evt_h_1,&#xD;&#xA;   @evt_d_1,   &#xD;&#xA;   @evt_h_2,&#xD;&#xA;   @evt_d_2,&#xD;&#xA;   @evt_h_3,&#xD;&#xA;   @evt_d_3,&#xD;&#xA;   @evt_h_4,&#xD;&#xA;   @evt_d_4,&#xD;&#xA;   @evt_h_5,&#xD;&#xA;   @evt_d_5,&#xD;&#xA;   @evt_h_6,&#xD;&#xA;   @evt_d_6,&#xD;&#xA;   @evt_h_7,&#xD;&#xA;   @evt_d_7,&#xD;&#xA;   @evt_h_8,&#xD;&#xA;   @evt_d_8,&#xD;&#xA;   @evt_h_9,&#xD;&#xA;   @evt_d_9,&#xD;&#xA;   @evt_h_10,&#xD;&#xA;   @evt_d_10,&#xD;&#xA;   @evt_h_11,&#xD;&#xA;   @evt_d_11,   &#xD;&#xA;   @evt_h_12,&#xD;&#xA;   @evt_d_12,&#xD;&#xA;   @evt_h_13,&#xD;&#xA;   @evt_d_13,&#xD;&#xA;   @evt_h_14,&#xD;&#xA;   @evt_d_14,&#xD;&#xA;   @evt_h_15,&#xD;&#xA;   @evt_d_15,&#xD;&#xA;   @evt_h_16,&#xD;&#xA;   @evt_d_16,&#xD;&#xA;   @evt_h_17,&#xD;&#xA;   @evt_d_17,&#xD;&#xA;   @evt_h_18,&#xD;&#xA;   @evt_d_18,&#xD;&#xA;   @evt_h_19,&#xD;&#xA;   @evt_d_19,&#xD;&#xA;   @evt_h_20,&#xD;&#xA;   @evt_d_20,&#xD;&#xA;   @tran_user_id,&#xD;&#xA;   @tran_comment&#xD;&#xA;);">
            <QP N="factory" />
