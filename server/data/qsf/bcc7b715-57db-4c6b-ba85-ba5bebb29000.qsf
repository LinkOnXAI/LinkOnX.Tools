        <SG _S="102" N="SelectWaferMap">
          <QY P="MsSql" Q="SELECT WAFER_ID, CUST_MAT_ID, LOT_ID, GOOD_QTY, BAD_QTY, FLAT_ZONE, QTY_1, QTY_2, QTY_3, QTY_4, QTY_5, QTY_6, QTY_7, QTY_8, QTY_9, QTY_10, WFM_CMF_11, CREATE_TIME, CREATE_USER_ID, UPDATE_TIME, UPDATE_USER_ID&#xD;&#xA;  FROM MTAPWAFMAP&#xD;&#xA; WHERE WAFER_ID  = @wafer_id&#xD;&#xA; ORDER BY WAFER_ID">
            <QP N="wafer_id" />
          </QY>
        </SG>
        <SG _S="103" N="SelectWaferBin">
