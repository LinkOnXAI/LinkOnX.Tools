    <M _S="526" N="EquipmentTranscation">
      <F _S="528" N="WaferMapDataSend">
        <SG _S="531" N="UpdateWaferMap">
          <QY P="MsSql" Q="UPDATE QWMSWAFMAP SET &#xD;&#xA;   LOT_ID          	= @lot_id,&#xD;&#xA;   HIST_SEQ			= @hist_seq,&#xD;&#xA;   CUS_ID 			= @cus_id,&#xD;&#xA;   GOOD_QTY        	= @good_qty,&#xD;&#xA;   BAD_QTY         	= @bad_qty,&#xD;&#xA;   FLAT_ZONE       	= @flat_zone,&#xD;&#xA;   BIN_1_QTY      	= @bin_1_qty,&#xD;&#xA;   BIN_2_QTY      	= @bin_2_qty,&#xD;&#xA;   BIN_3_QTY      	= @bin_3_qty,&#xD;&#xA;   BIN_4_QTY      	= @bin_4_qty,&#xD;&#xA;   BIN_5_QTY      	= @bin_5_qty,&#xD;&#xA;   BIN_6_QTY      	= @bin_6_qty,&#xD;&#xA;   BIN_7_QTY      	= @bin_7_qty,&#xD;&#xA;   BIN_8_QTY      	= @bin_8_qty,&#xD;&#xA;   BIN_9_QTY      	= @bin_9_qty,&#xD;&#xA;   BIN_10_QTY      	= @bin_10_qty,&#xD;&#xA;   BIN_D_QTY 	   	= @bin_d_qty,       &#xD;&#xA;   UPDATE_TIME     	= @update_time,&#xD;&#xA;   UPDATE_USER_ID  	= @update_user_id&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND WAFER_ID    	= @wafer_id">
            <QP N="lot_id" />
            <QP N="hist_seq" />
            <QP N="cus_id" />
            <QP N="good_qty" />
            <QP N="bad_qty" />
            <QP N="flat_zone" />
            <QP N="bin_1_qty" />
            <QP N="bin_2_qty" />
            <QP N="bin_3_qty" />
            <QP N="bin_4_qty" />
            <QP N="bin_5_qty" />
            <QP N="bin_6_qty" />
            <QP N="bin_7_qty" />
            <QP N="bin_8_qty" />
            <QP N="bin_9_qty" />
            <QP N="bin_10_qty" />
            <QP N="bin_d_qty" />
            <QP N="update_time" />
            <QP N="update_user_id" />
            <QP N="factory" />
            <QP N="wafer_id" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="532" N="DeleteWaferBin">
          <QY P="MsSql" Q="DELETE&#xD;&#xA;  FROM QWMSWAFBIN&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND WAFER_ID  = @wafer_id">
            <QP N="factory" />
            <QP N="wafer_id" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
