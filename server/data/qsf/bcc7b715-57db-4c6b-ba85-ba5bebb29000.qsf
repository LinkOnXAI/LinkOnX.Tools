            <QP N="bad_qty" />
            <QP N="flat_zone" />
            <QP N="bin_1_qty" />
            <QP N="bin_2_qty" />
            <QP N="bin_3_qty" />
            <QP N="bin_4_qty" />
            <QP N="bin_5_qty" />
            <QP N="bin_6_qty" />
            <QP N="bin_7_qty" />
            <QP N="bin_8_qty" />
            <QP N="bin_9_qty" />
            <QP N="bin_10_qty" />
