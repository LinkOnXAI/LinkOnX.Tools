        <SG _S="374" N="InsertPackageVer">
          <QY P="MsSql" Q="INSERT INTO QWMSPKGVER (&#xD;&#xA;   FACTORY,&#xD;&#xA;   PACKAGE,&#xD;&#xA;   PKG_VER,&#xD;&#xA;   PKG_VER_PATH,&#xD;&#xA;   PKG_VER_DESC,&#xD;&#xA;   PKG_COMMENT,&#xD;&#xA;   PKG_RELEASE,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @package,&#xD;&#xA;   @pkg_ver,&#xD;&#xA;   @pkg_ver_path,&#xD;&#xA;   @pkg_ver_desc,&#xD;&#xA;   @pkg_comment,&#xD;&#xA;   @release,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
