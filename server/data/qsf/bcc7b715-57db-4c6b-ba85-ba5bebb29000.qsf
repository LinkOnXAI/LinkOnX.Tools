            <QP N="factory" />
            <QP N="spl_name" />
            <QP N="map_type" />
          </QY>
          <QY P="Oracle" Q="SELECT PSR_NAME&#xD;&#xA;  FROM QWMSSPLMAP&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND SPL_NAME = @spl_name&#xD;&#xA;   AND MAP_TYPE = @map_type" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="523" N="HasParser">
          <QY P="MsSql" Q="SELECT PSR_NAME&#xD;&#xA;  FROM QWMSPSRDEF&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND PSR_NAME = @psr_name">
            <QP N="factory" />
            <QP N="psr_name" />
          </QY>
          <QY P="Oracle" Q="SELECT PSR_NAME&#xD;&#xA;  FROM QWMSPSRDEF&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND PSR_NAME = @psr_name" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="516" N="HasParserActVer">
          <QY P="MsSql" Q="SELECT PSR_NAME, PSR_VER, PSR_VER_FILE&#xD;&#xA;  FROM QWMSPSRVER&#xD;&#xA; WHERE FACTORY        = @factory&#xD;&#xA;   AND PSR_NAME       = @psr_name&#xD;&#xA;   AND PSR_VER_ACTIVE = @psr_ver_active">
            <QP N="factory" />
            <QP N="psr_name" />
            <QP N="psr_ver_active" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="517" N="HasStandardBinCode">
          <QY P="MsSql" Q="SELECT BIN_CODE, BIN_GRADE, IS_COUNTABLE&#xD;&#xA;  FROM QWMSBINDEF&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="524" N="HasSupplierBinCode">
          <QY P="MsSql" Q="SELECT SPL_BIN_CODE, SPL_BIN_GRADE, BIN_CODE&#xD;&#xA;  FROM QWMSSPLBIN&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND SPL_NAME  = @spl_name&#xD;&#xA;   AND MAP_TYPE  = @map_type">
            <QP N="factory" />
            <QP N="spl_name" />
            <QP N="map_type" />
          </QY>
          <QY P="Oracle" Q="SELECT SPL_BIN_CODE, SPL_BIN_GRADE, BIN_CODE&#xD;&#xA;  FROM QWMSSPLBIN&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND SPL_NAME  = @spl_name&#xD;&#xA;   AND MAP_TYPE  = @map_type" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="518" N="DeleteTmpWaferBin">
          <QY P="MsSql" Q="DELETE&#xD;&#xA;  FROM QWMSWAFBNT&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND WAFER_ID IN&#xD;&#xA;       (&#xD;&#xA;SELECT WAFER_ID&#xD;&#xA;  FROM QWMSWAFMPT&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND LOT_ID  = @lot_id&#xD;&#xA;       )">
            <QP N="factory" />
            <QP N="lot_id" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="519" N="DeleteTmpWaferMap">
          <QY P="MsSql" Q="DELETE&#xD;&#xA;   FROM QWMSWAFMPT&#xD;&#xA; WHERE LOT_ID = @lot_id">
            <QP N="lot_id" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="520" N="InsertTmpWaferBin">
          <QY P="MsSql" Q="INSERT INTO QWMSWAFBNT (&#xD;&#xA;   FACTORY,&#xD;&#xA;   WAFER_ID,&#xD;&#xA;   MAP_SEQ,   &#xD;&#xA;   COLS,&#xD;&#xA;   ROWS,&#xD;&#xA;   BIN_INFO,&#xD;&#xA;   BIN_1_QTY,&#xD;&#xA;   BIN_2_QTY,&#xD;&#xA;   BIN_3_QTY,&#xD;&#xA;   BIN_4_QTY,&#xD;&#xA;   BIN_5_QTY,&#xD;&#xA;   BIN_6_QTY,&#xD;&#xA;   BIN_7_QTY,&#xD;&#xA;   BIN_8_QTY,&#xD;&#xA;   BIN_9_QTY,&#xD;&#xA;   BIN_10_QTY,&#xD;&#xA;   BIN_D_QTY,   &#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   TRAN_USER_ID)" />
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="521" N="InsertTmpWaferMap">
          <QY P="MsSql" Q="INSERT INTO QWMSWAFMPT (&#xD;&#xA;   FACTORY,&#xD;&#xA;   LOT_ID,&#xD;&#xA;   WAFER_ID,   &#xD;&#xA;   DEVICE_ID,&#xD;&#xA;   REFERENCE_DIE,&#xD;&#xA;   DIE_SIZE_X,&#xD;&#xA;   DIE_SIZE_Y,&#xD;&#xA;   COLS,&#xD;&#xA;   ROWS,&#xD;&#xA;   MAP_FILE_NAME,&#xD;&#xA;   CUS_ID,&#xD;&#xA;   GOOD_QTY,&#xD;&#xA;   BAD_QTY,&#xD;&#xA;   FLAT_ZONE,  &#xD;&#xA;   BIN_1_QTY,&#xD;&#xA;   BIN_2_QTY,&#xD;&#xA;   BIN_3_QTY,&#xD;&#xA;   BIN_4_QTY,&#xD;&#xA;   BIN_5_QTY,&#xD;&#xA;   BIN_6_QTY,&#xD;&#xA;   BIN_7_QTY,&#xD;&#xA;   BIN_8_QTY,&#xD;&#xA;   BIN_9_QTY,&#xD;&#xA;   BIN_10_QTY,&#xD;&#xA;   BIN_D_QTY,   &#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   TRAN_USER_ID&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @lot_id,&#xD;&#xA;   @wafer_id,&#xD;&#xA;   @device_id,&#xD;&#xA;   @reference_die,&#xD;&#xA;   @die_size_x,&#xD;&#xA;   @die_size_y,&#xD;&#xA;   @cols,&#xD;&#xA;   @rows,&#xD;&#xA;   @map_file_name,&#xD;&#xA;   @cus_id,&#xD;&#xA;   @good_qty,&#xD;&#xA;   @bad_qty,&#xD;&#xA;   @flat_zone,&#xD;&#xA;   @bin_1_qty,&#xD;&#xA;   @bin_2_qty,&#xD;&#xA;   @bin_3_qty,&#xD;&#xA;   @bin_4_qty,&#xD;&#xA;   @bin_5_qty,&#xD;&#xA;   @bin_6_qty,&#xD;&#xA;   @bin_7_qty,&#xD;&#xA;   @bin_8_qty,&#xD;&#xA;   @bin_9_qty,&#xD;&#xA;   @bin_10_qty,&#xD;&#xA;   @bin_d_qty,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @tran_user_id&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="lot_id" />
            <QP N="wafer_id" />
            <QP N="device_id" />
            <QP N="reference_die" />
            <QP N="die_size_x" />
            <QP N="die_size_y" />
            <QP N="cols" />
            <QP N="rows" />
            <QP N="map_file_name" />
            <QP N="cus_id" />
            <QP N="good_qty" />
            <QP N="bad_qty" />
            <QP N="flat_zone" />
            <QP N="bin_1_qty" />
            <QP N="bin_2_qty" />
            <QP N="bin_3_qty" />
            <QP N="bin_4_qty" />
            <QP N="bin_5_qty" />
            <QP N="bin_6_qty" />
            <QP N="bin_7_qty" />
            <QP N="bin_8_qty" />
            <QP N="bin_9_qty" />
            <QP N="bin_10_qty" />
            <QP N="bin_d_qty" />
            <QP N="tran_time" />
            <QP N="tran_user_id" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
      </F>
      <F _S="88" N="HynixWaferMap">
        <SG _S="89" N="SelectMapParser">
          <QY P="MsSql" Q="SELECT PSR_NAME, PSR_DESC, MAP_TYPE, PSR_FILE&#xD;&#xA;  FROM QWMSPSRDEF&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND PSR_NAME = @psr_name&#xD;&#xA;">
            <QP N="factory" />
            <QP N="psr_name" />
          </QY>
        </SG>
        <SG _S="90" N="SelectStdBinCodeList">
          <QY P="MsSql" Q="SELECT BIN_CODE, BIN_GRADE, BIN_COLOR, CMF_1&#xD;&#xA;  FROM QWMSBINDEF&#xD;&#xA; WHERE FACTORY = :@actory&#xD;&#xA; ORDER BY BIN_CODE">
            <QP N="actory" />
          </QY>
        </SG>
        <SG _S="91" N="SelectMapBinCodeList">
          <QY P="MsSql" Q="SELECT MAP_BIN_CODE, MAP_BIN_GRADE, BIN_CODE&#xD;&#xA;  FROM QWMSPSRBIN&#xD;&#xA; WHERE FACTORY  = :@actory&#xD;&#xA;   AND PSR_NAME = @psr_name&#xD;&#xA; ORDER BY MAP_BIN_CODE">
            <QP N="actory" />
            <QP N="psr_name" />
          </QY>
        </SG>
        <SG _S="92" N="SelectWaferMapList">
          <QY P="MsSql" Q="SELECT LOT_ID, WAFER_ID, HIST_SEQ, CUS_ID, GOOD_QTY, BAD_QTY, FLAT_ZONE, BIN_1_QTY, BIN_2_QTY, BIN_3_QTY, BIN_4_QTY, BIN_5_QTY, BIN_6_QTY, BIN_7_QTY, BIN_8_QTY, BIN_9_QTY, BIN_10_QTY, BIN_D_QTY, CREATE_TIME, CREATE_USER_ID, UPDATE_TIME, UPDATE_USER_ID&#xD;&#xA;    	FROM QWMSWAFMAP&#xD;&#xA;    WHERE LOT_ID   = @lot_id          &#xD;&#xA;     ORDER BY WAFER_ID">
            <QP N="lot_id" />
          </QY>
        </SG>
        <SG _S="93" N="InsertWaferMapBinInfo">
          <QY P="MsSql" Q="INSERT INTO QWMSWAFBIN (&#xD;&#xA;   FACTORY,&#xD;&#xA;   WAFER_ID,&#xD;&#xA;   MAP_SEQ,   &#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   COLS,&#xD;&#xA;   ROWS,&#xD;&#xA;   BIN_INFO,&#xD;&#xA;   BIN_1_QTY,&#xD;&#xA;   BIN_2_QTY,&#xD;&#xA;   BIN_3_QTY,&#xD;&#xA;   BIN_4_QTY,&#xD;&#xA;   BIN_5_QTY,&#xD;&#xA;   BIN_6_QTY,&#xD;&#xA;   BIN_7_QTY,&#xD;&#xA;   BIN_8_QTY,&#xD;&#xA;   BIN_9_QTY,&#xD;&#xA;   BIN_10_QTY,&#xD;&#xA;   BIN_D_QTY,   &#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   CREATE_USER_ID)" />
        </SG>
        <SG _S="94" N="InsertWaferBinInfoHis">
          <QY P="MsSql" Q="INSERT INTO QWMSWAFBNH (&#xD;&#xA;   FACTORY,   &#xD;&#xA;   WAFER_ID,      &#xD;&#xA;   MAP_SEQ,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   COLS,&#xD;&#xA;   ROWS,&#xD;&#xA;   BIN_INFO,   &#xD;&#xA;   BIN_1_QTY,&#xD;&#xA;   BIN_2_QTY,&#xD;&#xA;   BIN_3_QTY,&#xD;&#xA;   BIN_4_QTY,&#xD;&#xA;   BIN_5_QTY,&#xD;&#xA;   BIN_6_QTY,&#xD;&#xA;   BIN_7_QTY,&#xD;&#xA;   BIN_8_QTY,&#xD;&#xA;   BIN_9_QTY,&#xD;&#xA;   BIN_10_QTY,&#xD;&#xA;   BIN_D_QTY,   &#xD;&#xA;   TRAN_USER_ID)" />
        </SG>
        <SG _S="95" N="InsertWaferMapInfo">
          <QY P="MsSql" Q="INSERT INTO QWMSWAFMAP&#xD;&#xA;   FACTORY,&#xD;&#xA;   LOT_ID,&#xD;&#xA;   WAFER_ID,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   CUS_ID,&#xD;&#xA;   GOOD_QTY,&#xD;&#xA;   BAD_QTY,&#xD;&#xA;   FLAT_ZONE,&#xD;&#xA;   BIN_1_QTY,&#xD;&#xA;   BIN_2_QTY,&#xD;&#xA;   BIN_3_QTY,&#xD;&#xA;   BIN_4_QTY,&#xD;&#xA;   BIN_5_QTY,&#xD;&#xA;   BIN_6_QTY,&#xD;&#xA;   BIN_7_QTY,&#xD;&#xA;   BIN_8_QTY,&#xD;&#xA;   BIN_9_QTY,&#xD;&#xA;   BIN_10_QTY,&#xD;&#xA;   BIN_D_QTY,   &#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   CREATE_USER_ID&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @lot_id,&#xD;&#xA;   @wafer_id,&#xD;&#xA;   @hist_seq,&#xD;&#xA;   @cus_id,&#xD;&#xA;   @good_qty,&#xD;&#xA;   @bad_qty,&#xD;&#xA;   @flat_zone,&#xD;&#xA;   @bin_1_qty,&#xD;&#xA;   @bin_2_qty,&#xD;&#xA;   @bin_3_qty,&#xD;&#xA;   @bin_4_qty,&#xD;&#xA;   @bin_5_qty,&#xD;&#xA;   @bin_6_qty,&#xD;&#xA;   @bin_7_qty,&#xD;&#xA;   @bin_8_qty,&#xD;&#xA;   @bin_9_qty,&#xD;&#xA;   @bin_10_qty,&#xD;&#xA;   @bin_d_qty,&#xD;&#xA;   @create_time,&#xD;&#xA;   @create_user_id&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="lot_id" />
            <QP N="wafer_id" />
            <QP N="hist_seq" />
            <QP N="cus_id" />
            <QP N="good_qty" />
            <QP N="bad_qty" />
            <QP N="flat_zone" />
            <QP N="bin_1_qty" />
            <QP N="bin_2_qty" />
            <QP N="bin_3_qty" />
            <QP N="bin_4_qty" />
            <QP N="bin_5_qty" />
            <QP N="bin_6_qty" />
            <QP N="bin_7_qty" />
            <QP N="bin_8_qty" />
            <QP N="bin_9_qty" />
            <QP N="bin_10_qty" />
            <QP N="bin_d_qty" />
            <QP N="create_time" />
            <QP N="create_user_id" />
          </QY>
        </SG>
        <SG _S="96" N="InsertWaferMapInfoHis">
          <QY P="MsSql" Q="INSERT INTO QWMSWAFMPH&#xD;&#xA;   FACTORY,&#xD;&#xA;   LOT_ID,&#xD;&#xA;   WAFER_ID,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   CUS_ID,&#xD;&#xA;   GOOD_QTY,&#xD;&#xA;   BAD_QTY,&#xD;&#xA;   FLAT_ZONE,&#xD;&#xA;   BIN_INFO,   &#xD;&#xA;   BIN_1_QTY,&#xD;&#xA;   BIN_2_QTY,&#xD;&#xA;   BIN_3_QTY,&#xD;&#xA;   BIN_4_QTY,&#xD;&#xA;   BIN_5_QTY,&#xD;&#xA;   BIN_6_QTY,&#xD;&#xA;   BIN_7_QTY,&#xD;&#xA;   BIN_8_QTY,&#xD;&#xA;   BIN_9_QTY,&#xD;&#xA;   BIN_10_QTY,&#xD;&#xA;   BIN_D_QTY,   &#xD;&#xA;   TRAN_USER_ID&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @lot_id,&#xD;&#xA;   @wafer_id,&#xD;&#xA;   @hist_seq,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @cus_id,&#xD;&#xA;   @good_qty,&#xD;&#xA;   @bad_qty,&#xD;&#xA;   @flat_zone,&#xD;&#xA;   @bin_1_qty,&#xD;&#xA;   @bin_2_qty,&#xD;&#xA;   @bin_3_qty,&#xD;&#xA;   @bin_4_qty,&#xD;&#xA;   @bin_5_qty,&#xD;&#xA;   @bin_6_qty,&#xD;&#xA;   @bin_7_qty,&#xD;&#xA;   @bin_8_qty,&#xD;&#xA;   @bin_9_qty,&#xD;&#xA;   @bin_10_qty,&#xD;&#xA;   @bin_d_qty,&#xD;&#xA;   @tran_user_id&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="lot_id" />
            <QP N="wafer_id" />
            <QP N="hist_seq" />
            <QP N="tran_time" />
            <QP N="cus_id" />
            <QP N="good_qty" />
            <QP N="bad_qty" />
            <QP N="flat_zone" />
            <QP N="bin_1_qty" />
            <QP N="bin_2_qty" />
            <QP N="bin_3_qty" />
            <QP N="bin_4_qty" />
            <QP N="bin_5_qty" />
            <QP N="bin_6_qty" />
            <QP N="bin_7_qty" />
            <QP N="bin_8_qty" />
            <QP N="bin_9_qty" />
            <QP N="bin_10_qty" />
            <QP N="bin_d_qty" />
            <QP N="tran_user_id" />
          </QY>
        </SG>
        <SG _S="97" N="SelectWaferBinInfoHis">
          <QY P="MsSql" Q="SELECT MAX(HIST_SEQ) AS HIST_SEQ&#xD;&#xA;  FROM QWMSWAFBNH&#xD;&#xA; WHERE WAFER_ID = @wafer_id">
            <QP N="wafer_id" />
          </QY>
        </SG>
        <SG _S="98" N="SelectWaferMapInfoHis">
          <QY P="MsSql" Q="SELECT MAX(HIST_SEQ) AS HIST_SEQ&#xD;&#xA;   FROM QWMSWAFMPH&#xD;&#xA;  WHERE WAFER_ID = @wafer_id&#xD;&#xA;    AND LOT_ID = @lot_id">
            <QP N="wafer_id" />
            <QP N="lot_id" />
          </QY>
        </SG>
        <SG _S="99" N="DeleteWaferBinInfo">
          <QY P="MsSql" Q="DELETE&#xD;&#xA;  FROM QWMSWAFBNH&#xD;&#xA; WHERE WAFER_ID    = @wafer_id&#xD;&#xA;   AND LOT_ID      = @lot_id">
            <QP N="wafer_id" />
            <QP N="lot_id" />
          </QY>
        </SG>
        <SG _S="100" N="UpdateWaferMapInfo">
          <QY P="MsSql" Q="UPDATE QWMSWAFMAP SET &#xD;&#xA;       LOT_ID          		= @lot_id,&#xD;&#xA;       HIST_SEQ			= @hist_seq,&#xD;&#xA;       CUS_ID 			     	= @cus_id,&#xD;&#xA;       GOOD_QTY        		= @good_qty,&#xD;&#xA;       BAD_QTY         		= @bad_qty,&#xD;&#xA;       FLAT_ZONE       		= @flat_zone,&#xD;&#xA;       BIN_1_QTY      		= @bin_1_qty,&#xD;&#xA;       BIN_2_QTY      		= @bin_2_qty,&#xD;&#xA;       BIN_3_QTY      		= @bin_3_qty,&#xD;&#xA;       BIN_4_QTY      		= @bin_4_qty,&#xD;&#xA;       BIN_5_QTY      		= @bin_5_qty,&#xD;&#xA;       BIN_6_QTY      		= @bin_6_qty,&#xD;&#xA;       BIN_7_QTY      		= @bin_7_qty,&#xD;&#xA;       BIN_8_QTY      		= @bin_8_qty,&#xD;&#xA;       BIN_9_QTY      		= @bin_9_qty,&#xD;&#xA;       BIN_10_QTY      		= @bin_10_qty,&#xD;&#xA;       BIN_D_QTY 	   		= @bin_d_qty,       &#xD;&#xA;       UPDATE_TIME     		= @update_time,&#xD;&#xA;       UPDATE_USER_ID  	= @update_user_id&#xD;&#xA;     WHERE WAFER_ID    	= @wafer_id">
            <QP N="lot_id" />
            <QP N="hist_seq" />
            <QP N="cus_id" />
            <QP N="good_qty" />
            <QP N="bad_qty" />
            <QP N="flat_zone" />
            <QP N="bin_1_qty" />
            <QP N="bin_2_qty" />
            <QP N="bin_3_qty" />
            <QP N="bin_4_qty" />
            <QP N="bin_5_qty" />
            <QP N="bin_6_qty" />
            <QP N="bin_7_qty" />
            <QP N="bin_8_qty" />
            <QP N="bin_9_qty" />
            <QP N="bin_10_qty" />
            <QP N="bin_d_qty" />
            <QP N="update_time" />
            <QP N="update_user_id" />
            <QP N="wafer_id" />
          </QY>
        </SG>
        <SG _S="101" N="SelectCurrentWaferMapByLot">
          <QY P="MsSql" Q="SELECT A.WAFER_ID, A.LOT_ID, A.CUS_ID, A.GOOD_QTY, A.BAD_QTY, A.FLAT_ZONE,&#xD;&#xA;       B.COLS, B.ROWS, B.MAP_SEQ, B.BIN_INFO, B.BIN_1_QTY, B.BIN_2_QTY, B.BIN_3_QTY, B.BIN_4_QTY, B.BIN_5_QTY, &#xD;&#xA;       B.BIN_6_QTY, B.BIN_7_QTY, B.BIN_8_QTY, B.BIN_9_QTY, B.BIN_10_QTY, B.BIN_D_QTY&#xD;&#xA;  FROM QWMSWAFBIN B&#xD;&#xA;  LEFT JOIN QWMSWAFMAP A&#xD;&#xA;    ON A.WAFER_ID = B.WAFER_ID&#xD;&#xA; WHERE A.LOT_ID   = @lot_id&#xD;&#xA; ORDER BY A.WAFER_ID, B.MAP_SEQ">
            <QP N="lot_id" />
          </QY>
        </SG>
      </F>
      <F _S="142" N="CustomerWaferMap">
        <SG _S="143" N="ValidationLotInfo">
          <QY P="MsSql" Q="SELECT LOT_ID, WAFER_ID, CUS_ID, GOOD_QTY, BAD_QTY, FLAT_ZONE, BIN_1_QTY, BIN_2_QTY, BIN_3_QTY, BIN_4_QTY, BIN_5_QTY, BIN_6_QTY, BIN_7_QTY, BIN_8_QTY, BIN_9_QTY, BIN_10_QTY, BIN_D_QTY, CREATE_TIME, CREATE_USER_ID, UPDATE_TIME, UPDATE_USER_ID&#xD;&#xA;  FROM QWMSWAFMAP&#xD;&#xA; WHERE LOT_ID   = @lot_id&#xD;&#xA; ORDER BY WAFER_ID">
            <QP N="lot_id" />
          </QY>
        </SG>
        <SG _S="144" N="SelectMapParser">
          <QY P="MsSql" Q="  SELECT PSR_NAME, PSR_VER, PSR_VER_PATH&#xD;&#xA;     FROM QWMSPSRVER A&#xD;&#xA;  WHERE A.FACTORY  = @factory&#xD;&#xA;       AND A.PSR_NAME = @psr_name&#xD;&#xA;       AND A.PSR_ACTIVE = @psr_active">
            <QP N="factory" />
            <QP N="psr_name" />
            <QP N="psr_active" />
          </QY>
        </SG>
        <SG _S="145" N="SelectStdBinCodeList">
          <QY P="MsSql" Q="SELECT BIN_CODE, BIN_GRADE, BIN_COLOR, CMF_1&#xD;&#xA;  FROM QWMSBINDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY BIN_CODE">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="146" N="SelectWaferMapList">
          <QY P="MsSql" Q="SELECT LOT_ID, WAFER_ID, CUS_ID, HIST_SEQ, GOOD_QTY, BAD_QTY, FLAT_ZONE, BIN_1_QTY, BIN_2_QTY, BIN_3_QTY, BIN_4_QTY, BIN_5_QTY, BIN_6_QTY, BIN_7_QTY, BIN_8_QTY, BIN_9_QTY, BIN_10_QTY, BIN_D_QTY, CREATE_TIME, CREATE_USER_ID, UPDATE_TIME, UPDATE_USER_ID&#xD;&#xA;  FROM QWMSWAFMAP&#xD;&#xA; WHERE LOT_ID   = @lot_id                                                   &#xD;&#xA; ORDER BY WAFER_ID&#xD;&#xA; &#xD;&#xA; ">
            <QP N="lot_id" />
          </QY>
        </SG>
        <SG _S="147" N="InsertWaferBinInfo">
          <QY P="MsSql" Q="INSERT INTO QWMSWAFBNT (&#xD;&#xA;   FACTORY_ID,&#xD;&#xA;   WAFER_ID,&#xD;&#xA;   MAP_SEQ,   &#xD;&#xA;   COLS,&#xD;&#xA;   ROWS,&#xD;&#xA;   BIN_INFO,&#xD;&#xA;   BIN_1_QTY,&#xD;&#xA;   BIN_2_QTY,&#xD;&#xA;   BIN_3_QTY,&#xD;&#xA;   BIN_4_QTY,&#xD;&#xA;   BIN_5_QTY,&#xD;&#xA;   BIN_6_QTY,&#xD;&#xA;   BIN_7_QTY,&#xD;&#xA;   BIN_8_QTY,&#xD;&#xA;   BIN_9_QTY,&#xD;&#xA;   BIN_10_QTY,&#xD;&#xA;   BIN_D_QTY,   &#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   CREATE_USER_ID)" />
        </SG>
        <SG _S="148" N="InsertWaferBinInfoHis">
          <QY P="MsSql" Q="INSERT INTO QWMSWAFBNH (&#xD;&#xA;   FACTORY,&#xD;&#xA;   WAFER_ID,      &#xD;&#xA;   MAP_SEQ,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   COLS,&#xD;&#xA;   ROWS,&#xD;&#xA;   BIN_INFO,   &#xD;&#xA;   BIN_1_QTY,&#xD;&#xA;   BIN_2_QTY,&#xD;&#xA;   BIN_3_QTY,&#xD;&#xA;   BIN_4_QTY,&#xD;&#xA;   BIN_5_QTY,&#xD;&#xA;   BIN_6_QTY,&#xD;&#xA;   BIN_7_QTY,&#xD;&#xA;   BIN_8_QTY,&#xD;&#xA;   BIN_9_QTY,&#xD;&#xA;   BIN_10_QTY,&#xD;&#xA;   BIN_D_QTY,   &#xD;&#xA;   TRAN_USER_ID)" />
        </SG>
        <SG _S="149" N="InsertWaferMapInfo">
          <QY P="MsSql" Q="INSERT INTO QWMSWAFMAP&#xD;&#xA;   FACTORY,&#xD;&#xA;   LOT_ID,&#xD;&#xA;   WAFER_ID,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   CUS_ID,&#xD;&#xA;   GOOD_QTY,&#xD;&#xA;   BAD_QTY,&#xD;&#xA;   FLAT_ZONE,&#xD;&#xA;   BIN_INFO,   &#xD;&#xA;   BIN_1_QTY,&#xD;&#xA;   BIN_2_QTY,&#xD;&#xA;   BIN_3_QTY,&#xD;&#xA;   BIN_4_QTY,&#xD;&#xA;   BIN_5_QTY,&#xD;&#xA;   BIN_6_QTY,&#xD;&#xA;   BIN_7_QTY,&#xD;&#xA;   BIN_8_QTY,&#xD;&#xA;   BIN_9_QTY,&#xD;&#xA;   BIN_10_QTY,&#xD;&#xA;   BIN_D_QTY,   &#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   CREATE_USER_ID&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @lot_id,&#xD;&#xA;   @wafer_id,&#xD;&#xA;   @hist_seq,&#xD;&#xA;   @cus_id,&#xD;&#xA;   @good_qty,&#xD;&#xA;   @bad_qty,&#xD;&#xA;   @flat_zone,&#xD;&#xA;   @bin_1_qty,&#xD;&#xA;   @bin_2_qty,&#xD;&#xA;   @bin_3_qty,&#xD;&#xA;   @bin_4_qty,&#xD;&#xA;   @bin_5_qty,&#xD;&#xA;   @bin_6_qty,&#xD;&#xA;   @bin_7_qty,&#xD;&#xA;   @bin_8_qty,&#xD;&#xA;   @bin_9_qty,&#xD;&#xA;   @bin_10_qty,&#xD;&#xA;   @bin_d_qty,&#xD;&#xA;   @create_time,&#xD;&#xA;   @create_user_id&#xD;&#xA;)">
            <QP N="factory" />
