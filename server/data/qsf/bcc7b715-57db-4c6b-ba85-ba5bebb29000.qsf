          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="533" N="InsertWaferBin">
          <QY P="MsSql" Q="INSERT INTO QWMSWAFBIN (&#xD;&#xA;   FACTORY,&#xD;&#xA;   WAFER_ID,&#xD;&#xA;   MAP_SEQ,   &#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   COLS,&#xD;&#xA;   ROWS,&#xD;&#xA;   BIN_INFO,&#xD;&#xA;   BIN_1_QTY,&#xD;&#xA;   BIN_2_QTY,&#xD;&#xA;   BIN_3_QTY,&#xD;&#xA;   BIN_4_QTY,&#xD;&#xA;   BIN_5_QTY,&#xD;&#xA;   BIN_6_QTY,&#xD;&#xA;   BIN_7_QTY,&#xD;&#xA;   BIN_8_QTY,&#xD;&#xA;   BIN_9_QTY,&#xD;&#xA;   BIN_10_QTY,&#xD;&#xA;   BIN_D_QTY,   &#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   UPDATE_TIME,&#xD;&#xA;   UPDATE_USER_ID)" />
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
