          </QY>
        </SG>
      </F>
      <F _S="324" N="StandardCellStatusSelector">
        <SG _S="325" N="ListStandardCellStatus">
          <QY P="MsSql" Q="SELECT CELL_STATUS, CELL_STATUS_DESC&#xD;&#xA;  FROM QSUBSTDSTS&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="294" N="UserSelector">
        <SG _S="295" N="SearchUserList">
          <QY P="MsSql" Q="SELECT USER_ID, USER_DESC&#xD;&#xA;  FROM QSECUSRDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY USER_ID">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="407" N="PackageVerSelector">
