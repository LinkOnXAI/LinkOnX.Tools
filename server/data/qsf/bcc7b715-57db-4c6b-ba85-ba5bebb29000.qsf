    </M>
    <M _S="107" N="Setup">
      <F _S="227" N="GcmTable">
        <SG _S="229" N="HasGcmTable">
          <QY P="MsSql" Q="SELECT TABLE_NAME &#xD;&#xA;  FROM QGCMTBLDEF&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND TABLE_NAME = @table_name">
            <QP N="factory" />
            <QP N="table_name" />
          </QY>
        </SG>
        <SG _S="230" N="ListGcmTable">
          <QY P="MsSql" Q="SELECT TABLE_NAME, TABLE_DESC&#xD;&#xA;  FROM QGCMTBLDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY TABLE_NAME">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="231" N="SearchGcmTable">
          <QY P="MsSql" Q="SELECT TABLE_NAME,  TABLE_DESC, &#xD;&#xA;       DATA_1_USE,  DATA_1_PRT,  DATA_1_FMT,  DATA_1_SIZE,  DATA_1_KEY,&#xD;&#xA;       DATA_2_USE,  DATA_2_PRT,  DATA_2_FMT,  DATA_2_SIZE,  DATA_2_KEY,&#xD;&#xA;       DATA_3_USE,  DATA_3_PRT,  DATA_3_FMT,  DATA_3_SIZE,  DATA_3_KEY,&#xD;&#xA;       DATA_4_USE,  DATA_4_PRT,  DATA_4_FMT,  DATA_4_SIZE,  DATA_4_KEY,&#xD;&#xA;       DATA_5_USE,  DATA_5_PRT,  DATA_5_FMT,  DATA_5_SIZE,  DATA_5_KEY,&#xD;&#xA;       DATA_6_USE,  DATA_6_PRT,  DATA_6_FMT,  DATA_6_SIZE,  DATA_6_KEY,&#xD;&#xA;       DATA_7_USE,  DATA_7_PRT,  DATA_7_FMT,  DATA_7_SIZE,  DATA_7_KEY,&#xD;&#xA;       DATA_8_USE,  DATA_8_PRT,  DATA_8_FMT,  DATA_8_SIZE,  DATA_8_KEY,&#xD;&#xA;       DATA_9_USE,  DATA_9_PRT,  DATA_9_FMT,  DATA_9_SIZE,  DATA_9_KEY,&#xD;&#xA;       DATA_10_USE, DATA_10_PRT, DATA_10_FMT, DATA_10_SIZE, DATA_10_KEY&#xD;&#xA;  FROM QGCMTBLDEF&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND TABLE_NAME = @table_name">
            <QP N="factory" />
            <QP N="table_name" />
          </QY>
        </SG>
        <SG _S="232" N="CountGcmData">
          <QY P="MsSql" Q="SELECT COUNT(TABLE_NAME) AS COUNT&#xD;&#xA;  FROM QGCMTBLDAT&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND TABLE_NAME = @table_name">
            <QP N="factory" />
            <QP N="table_name" />
          </QY>
        </SG>
        <SG _S="233" N="InsertGcmTable">
          <QY P="MsSql" Q="INSERT INTO QGCMTBLDEF (&#xD;&#xA;   FACTORY,&#xD;&#xA;   TABLE_NAME,&#xD;&#xA;   TABLE_DESC,&#xD;&#xA;   DATA_1_USE,  DATA_1_PRT,   DATA_1_FMT,   DATA_1_SIZE,   DATA_1_KEY,&#xD;&#xA;   DATA_2_USE,  DATA_2_PRT,   DATA_2_FMT,   DATA_2_SIZE,   DATA_2_KEY,&#xD;&#xA;   DATA_3_USE,  DATA_3_PRT,   DATA_3_FMT,   DATA_3_SIZE,   DATA_3_KEY,&#xD;&#xA;   DATA_4_USE,  DATA_4_PRT,   DATA_4_FMT,   DATA_4_SIZE,   DATA_4_KEY,&#xD;&#xA;   DATA_5_USE,  DATA_5_PRT,   DATA_5_FMT,   DATA_5_SIZE,   DATA_5_KEY,&#xD;&#xA;   DATA_6_USE,  DATA_6_PRT,   DATA_6_FMT,   DATA_6_SIZE,   DATA_6_KEY,&#xD;&#xA;   DATA_7_USE,  DATA_7_PRT,   DATA_7_FMT,   DATA_7_SIZE,   DATA_7_KEY,&#xD;&#xA;   DATA_8_USE,  DATA_8_PRT,   DATA_8_FMT,   DATA_8_SIZE,   DATA_8_KEY,&#xD;&#xA;   DATA_9_USE,  DATA_9_PRT,   DATA_9_FMT,   DATA_9_SIZE,   DATA_9_KEY,&#xD;&#xA;   DATA_10_USE, DATA_10_PRT,  DATA_10_FMT,  DATA_10_SIZE,  DATA_10_KEY,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @table_name,&#xD;&#xA;   @table_desc,&#xD;&#xA;   @data_1_use,  @data_1_prt,   @data_1_fmt,   @data_1_size,   @data_1_key,&#xD;&#xA;   @data_2_use,  @data_2_prt,   @data_2_fmt,   @data_2_size,   @data_2_key,&#xD;&#xA;   @data_3_use,  @data_3_prt,   @data_3_fmt,   @data_3_size,   @data_3_key,&#xD;&#xA;   @data_4_use,  @data_4_prt,   @data_4_fmt,   @data_4_size,   @data_4_key,&#xD;&#xA;   @data_5_use,  @data_5_prt,   @data_5_fmt,   @data_5_size,   @data_5_key,&#xD;&#xA;   @data_6_use,  @data_6_prt,   @data_6_fmt,   @data_6_size,   @data_6_key,&#xD;&#xA;   @data_7_use,  @data_7_prt,   @data_7_fmt,   @data_7_size,   @data_7_key,&#xD;&#xA;   @data_8_use,  @data_8_prt,   @data_8_fmt,   @data_8_size,   @data_8_key,&#xD;&#xA;   @data_9_use,  @data_9_prt,   @data_9_fmt,   @data_9_size,   @data_9_key,&#xD;&#xA;   @data_10_use, @data_10_prt,  @data_10_fmt,  @data_10_size,  @data_10_key,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="table_name" />
            <QP N="table_desc" />
            <QP N="data_1_use" />
            <QP N="data_1_prt" />
            <QP N="data_1_fmt" />
            <QP N="data_1_size" />
            <QP N="data_1_key" />
            <QP N="data_2_use" />
            <QP N="data_2_prt" />
            <QP N="data_2_fmt" />
            <QP N="data_2_size" />
            <QP N="data_2_key" />
            <QP N="data_3_use" />
            <QP N="data_3_prt" />
            <QP N="data_3_fmt" />
