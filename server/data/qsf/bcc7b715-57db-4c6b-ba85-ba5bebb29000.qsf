          <QY P="MsSql" Q="SELECT PSR_NAME, PSR_DESC, ACTIVE_VER, LAST_VER&#xD;&#xA;  FROM QWMSPSRDEF&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND MAP_TYPE = @map_type">
            <QP N="factory" />
            <QP N="map_type" />
          </QY>
        </SG>
      </F>
      <F _S="222" N="StandardBinCodeSelector">
