          <QY P="MsSql" Q="SELECT B.HIST_SEQ, B.WAFER_ID, B.LOT_ID, A.DEVICE_ID, A.REFERENCE_DIE,   A.DIE_SIZE_X, A.DIE_SIZE_Y,&#xD;&#xA;             B.GOOD_QTY, B.BAD_QTY, B.FLAT_ZONE, B.BIN_1_QTY, B.BIN_2_QTY, B.BIN_3_QTY, B.BIN_4_QTY, B.BIN_5_QTY, B.BIN_6_QTY, &#xD;&#xA;       B.BIN_7_QTY, B.BIN_8_QTY, B.BIN_9_QTY, B.BIN_10_QTY,      &#xD;&#xA;       B.TRAN_TIME , B.TRAN_USER_ID,A.MAP_FILE_NAME      &#xD;&#xA;  FROM QWMSWAFMPH B&#xD;&#xA;  LEFT JOIN QWMSWAFMAP A&#xD;&#xA;    ON A.FACTORY  = B.FACTORY&#xD;&#xA;   AND A.WAFER_ID = B.WAFER_ID&#xD;&#xA; WHERE A.FACTORY   = @factory&#xD;&#xA;   AND A.WAFER_ID  = @wafer_id&#xD;&#xA; ORDER BY HIST_SEQ DESC">
