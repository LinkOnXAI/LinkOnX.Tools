            <QP N="alarm" />
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="hist_seq" />
            <QP N="delete_flag" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="mld_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="396" N="UpdateContainerAtr">
          <QY P="MsSql" Q="UPDATE QWMSMLDATR SET&#xD;&#xA;  PACKAGE      	     = @package,&#xD;&#xA;  PKG_VER            = @pkg_ver,&#xD;&#xA;  UPDATE_USER_ID     = @update_user_id,&#xD;&#xA;  UPDATE_TIME        = @update_time&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND MLD_NAME      = @mld_name&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="package" />
            <QP N="pkg_ver" />
