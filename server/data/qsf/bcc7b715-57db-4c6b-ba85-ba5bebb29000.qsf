        </SG>
        <SG _S="409" N="ListPackageVer">
          <QY P="MsSql" Q="SELECT PKG_VER, PKG_VER_DESC, PKG_RELEASE, PKG_COMMENT&#xD;&#xA;  FROM QWMSPKGVER&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND PACKAGE = @package&#xD;&#xA; ORDER BY PKG_VER DESC">
            <QP N="factory" />
            <QP N="package" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
      </F>
      <F _S="410" N="SupplierSelector">
        <SG _S="411" N="ListSupplier">
          <QY P="MsSql" Q="SELECT SPL_NAME, SPL_DESC, PROP_ATTR&#xD;&#xA;  FROM QWMSSPLDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY SPL_NAME">
            <QP N="factory" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
      </F>
      <F _S="438" N="MapLoaderSelector">
        <SG _S="439" N="ListMapLoader">
          <QY P="MsSql" Q="SELECT MLD_NAME, MLD_DESC&#xD;&#xA;  FROM QWMSMLDDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY MLD_NAME">
            <QP N="factory" />
          </QY>
          <QY P="Oracle" />
