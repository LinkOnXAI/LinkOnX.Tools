          <QY P="MsSql" Q="SELECT DATA_1&#xD;&#xA;  FROM QGCMTBLDAT&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND TABLE_NAME = @table_name">
            <QP N="factory" />
            <QP N="table_name" />
          </QY>
        </SG>
      </F>
      <F _S="190" N="MapParserSelector">
