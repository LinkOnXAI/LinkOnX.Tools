          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
      </F>
      <F _S="508" N="MapLoaderViewer">
        <SG _S="510" N="ListMapLoader">
          <QY P="MsSql" Q="SELECT A.MLD_NAME, A.MLD_DESC, A.SPL_NAME, A.STEP, A.UP_DOWN, A.ALARM, A.NEED_ACTION, A.NEXT_NEED_ACTION,  &#xD;&#xA;       ISNULL(B.PACKAGE, 'N/A')  SET_PACKAGE,  ISNULL(B.PKG_VER, 0) SET_PKG_VER, &#xD;&#xA;	   ISNULL(C.PACKAGE, 'N/A') REL_PACKAGE, ISNULL(C.PKG_VER, 0) REL_PKG_VER, &#xD;&#xA;	   ISNULL(D.PACKAGE, 'N/A') APL_PACKAGE, ISNULL(D.PKG_VER, 0) APL_PKG_VER, LAST_EVENT_ID&#xD;&#xA;  FROM QWMSMLDDEF A&#xD;&#xA;  LEFT JOIN QWMSMLDATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.MLD_NAME    = B.MLD_NAME&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QWMSMLDATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.MLD_NAME    = C.MLD_NAME&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QWMSMLDATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.MLD_NAME    = D.MLD_NAME&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.SPL_NAME      = ISNULL(@spl_name, A.SPL_NAME)&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'&#xD;&#xA; ORDER BY A.MLD_NAME">
            <QP N="factory" />
            <QP N="spl_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
        <SG _S="512" N="ListSupplier">
          <QY P="MsSql" Q="SELECT SPL_NAME, SPL_DESC&#xD;&#xA;  FROM QWMSSPLDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY SPL_NAME">
            <QP N="factory" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
        </SG>
      </F>
    </M>
    <M _S="504" N="DataPusher">
      <F _S="506" N="MapLoaderDataPush">
        <SG _S="507" N="SearchMapLoader">
          <QY P="MsSql" Q="SELECT A.MLD_NAME, A.MLD_DESC, A.SPL_NAME, A.STEP, A.UP_DOWN, A.ALARM, A.NEED_ACTION, A.NEXT_NEED_ACTION,  ISNULL(B.PACKAGE, 'N/A')  SET_PACKAGE,  ISNULL(B.PKG_VER, 0) SET_PKG_VER, ISNULL(C.PACKAGE, 'N/A') REL_PACKAGE, ISNULL(C.PKG_VER, 0) REL_PKG_VER, ISNULL(D.PACKAGE, 'N/A') APL_PACKAGE, ISNULL(D.PKG_VER, 0) APL_PKG_VER, LAST_EVENT_ID&#xD;&#xA;  FROM QWMSMLDDEF A&#xD;&#xA;  LEFT JOIN QWMSMLDATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.MLD_NAME    = B.MLD_NAME&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Setup'   &#xD;&#xA;  LEFT JOIN QWMSMLDATR C &#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.MLD_NAME    = C.MLD_NAME&#xD;&#xA;   AND C.ATTR_CATEGORY = 'Released'   &#xD;&#xA;  LEFT JOIN QWMSMLDATR D &#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND A.MLD_NAME    = D.MLD_NAME&#xD;&#xA;   AND D.ATTR_CATEGORY = 'Applied'   &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.MLD_NAME      = @mld_name&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="factory" />
            <QP N="mld_name" />
          </QY>
          <QY P="Oracle" />
          <QY P="MySql" />
          <QY P="MariaDb" />
          <QY P="PostgreSql" />
          <QY P="Machbase" />
          <QY P="OleDb" />
          <QY P="Influx" />
          <QY P="SQLite" />
