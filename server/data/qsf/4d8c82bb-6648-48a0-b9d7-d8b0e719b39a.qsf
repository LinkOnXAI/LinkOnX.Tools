        <SG _S="2826" N="UserValidation" D="O">
          <QY P="MsSql" Q="SELECT USER_ID, &#13;&#10;PASSWORD, &#13;&#10;USER_NAME, &#13;&#10;USER_GRP, &#13;&#10;SYS_AUTHORITY, &#13;&#10;ISNULL(DELETE_FLAG, 'N')  DEL_FLAG, &#13;&#10;EXPIRE_DATE,&#13;&#10;CMF_10 AS IS_LS&#13;&#10;  FROM QSECUSRDEF&#13;&#10; WHERE FACTORY = @factory&#13;&#10;   AND USER_ID    = @user_id">
            <QP N="factory"/>
            <QP N="user_id"/>
          </QY>
        </SG>
        <SG _S="3192" N="LsInsertUser">
          <QY P="MsSql" Q="INSERT INTO QSECUSRDEF(&#13;&#10;   FACTORY,&#13;&#10;   USER_ID,&#13;&#10;   USER_NAME,&#13;&#10;   USER_DESC,&#13;&#10;   PASSWORD,&#13;&#10;   USER_GRP, &#13;&#10;   EXPIRE_DATE,&#13;&#10;   PHONE_OFFICE,&#13;&#10;   PHONE_MOBILE, &#13;&#10;   EMAIL_ID,&#13;&#10;   DELETE_FLAG,&#13;&#10;   CMF_10,&#13;&#10;   CREATE_USER_ID,&#13;&#10;   CREATE_TIME,&#13;&#10;   UPDATE_USER_ID,&#13;&#10;   UPDATE_TIME&#13;&#10;) VALUES (&#13;&#10;   @factory,&#13;&#10;   @user_id,&#13;&#10;   @user_name,&#13;&#10;   @user_desc,&#13;&#10;   @password,&#13;&#10;   @user_grp,&#13;&#10;   @exp_date,&#13;&#10;   @phone_office,&#13;&#10;   @phone_mobile,&#13;&#10;   @email_id,&#13;&#10;   'N',&#13;&#10;   'Y',&#13;&#10;   @create_user_id,&#13;&#10;   @create_time,&#13;&#10;   @update_user_id,&#13;&#10;   @update_time&#13;&#10;)">
            <QP N="factory"/>
            <QP N="user_id"/>
            <QP N="user_name"/>
            <QP N="user_desc"/>
            <QP N="password"/>
            <QP N="user_grp"/>
            <QP N="exp_date"/>
            <QP N="phone_office"/>
            <QP N="phone_mobile"/>
            <QP N="email_id"/>
            <QP N="create_user_id"/>
            <QP N="create_time"/>
            <QP N="update_user_id"/>
            <QP N="update_time"/>
          </QY>
        </SG>
        <SG _S="3294" N="MobisInsertUser">
          <QY P="MsSql" Q="INSERT INTO QSECUSRDEF(&#13;&#10;   FACTORY,&#13;&#10;   USER_ID,&#13;&#10;   USER_NAME,&#13;&#10;   USER_DESC,&#13;&#10;   USER_GRP, &#13;&#10;   EXPIRE_DATE,&#13;&#10;   PHONE_OFFICE,&#13;&#10;   PHONE_MOBILE, &#13;&#10;   EMAIL_ID,&#13;&#10;   DELETE_FLAG,&#13;&#10;   CREATE_USER_ID,&#13;&#10;   CREATE_TIME,&#13;&#10;   UPDATE_USER_ID,&#13;&#10;   UPDATE_TIME&#13;&#10;) VALUES (&#13;&#10;   @factory,&#13;&#10;   @user_id,&#13;&#10;   @user_name,&#13;&#10;   @user_desc,&#13;&#10;   @user_grp,&#13;&#10;   @exp_date,&#13;&#10;   @phone_office,&#13;&#10;   @phone_mobile,&#13;&#10;   @email_id,&#13;&#10;   'N',&#13;&#10;   @create_user_id,&#13;&#10;   @create_time,&#13;&#10;   @update_user_id,&#13;&#10;   @update_time&#13;&#10;)">
            <QP N="factory"/>
            <QP N="user_id"/>
            <QP N="user_name"/>
            <QP N="user_desc"/>
            <QP N="user_grp"/>
            <QP N="exp_date"/>
            <QP N="phone_office"/>
            <QP N="phone_mobile"/>
            <QP N="email_id"/>
            <QP N="create_user_id"/>
            <QP N="create_time"/>
            <QP N="update_user_id"/>
            <QP N="update_time"/>
          </QY>
        </SG>
        <SG _S="3295" N="MobisUpdateUser">
          <QY P="MsSql" Q="UPDATE QSECUSRDEF SET&#13;&#10;   USER_NAME      = @user_name,&#13;&#10;   PHONE_MOBILE   = @phone_mobile,&#13;&#10;   EMAIL_ID       = @email_id,&#13;&#10;   UPDATE_USER_ID = @update_user_id,&#13;&#10;   UPDATE_TIME    = @update_time&#13;&#10; WHERE FACTORY = @factory&#13;&#10;   AND USER_ID = @user_id">
            <QP N="user_name"/>
            <QP N="phone_mobile"/>
            <QP N="email_id"/>
            <QP N="update_user_id"/>
            <QP N="update_time"/>
            <QP N="factory"/>
            <QP N="user_id"/>
          </QY>
        </SG>
        <SG _S="3296" N="MobisUpdateUserForNew">
          <QY P="MsSql" Q="UPDATE QSECUSRDEF SET&#13;&#10;   USER_NAME      = @user_name,&#13;&#10;   USER_DESC      = @user_desc,&#13;&#10;   USER_GRP       = @user_grp,&#13;&#10;   EXPIRE_DATE = @exp_date,&#13;&#10;   PHONE_OFFICE   = @phone_office,&#13;&#10;   PHONE_MOBILE   = @phone_mobile,&#13;&#10;   EMAIL_ID       = @email_id,&#13;&#10;   DELETE_FLAG    = 'N',&#13;&#10;   UPDATE_USER_ID = @update_user_id,&#13;&#10;   UPDATE_TIME    = @update_time&#13;&#10; WHERE FACTORY = @factory&#13;&#10;   AND USER_ID = @user_id">
            <QP N="user_name"/>
