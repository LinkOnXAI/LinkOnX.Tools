      <F _S="764" N="UserHistory" D="Q">
        <SG _S="1295" N="InsertUserHistory" D="">
          <QY P="MsSql" Q="INSERT INTO QSECUSRHIS(&#13;&#10;   FACTORY,&#13;&#10;   USER_ID,&#13;&#10;   HIST_SEQ,&#13;&#10;   EVENT_ID,&#13;&#10;   ACTION,&#13;&#10;   SYSTEM,&#13;&#10;   HOST_IP,&#13;&#10;   HOST_NAME,&#13;&#10;   TRAN_TIME,&#13;&#10;   EVT_H_1,&#13;&#10;   EVT_D_1,&#13;&#10;   EVT_H_2,&#13;&#10;   EVT_D_2,&#13;&#10;   EVT_H_3,&#13;&#10;   EVT_D_3,&#13;&#10;   EVT_H_4,&#13;&#10;   EVT_D_4,&#13;&#10;   EVT_H_5,&#13;&#10;   EVT_D_5,&#13;&#10;   EVT_H_6,&#13;&#10;   EVT_D_6,&#13;&#10;   EVT_H_7,&#13;&#10;   EVT_D_7,&#13;&#10;   EVT_H_8,&#13;&#10;   EVT_D_8,&#13;&#10;   EVT_H_9,&#13;&#10;   EVT_D_9,&#13;&#10;   EVT_H_10,&#13;&#10;   EVT_D_10,    &#13;&#10;   EVT_H_11,&#13;&#10;   EVT_D_11,&#13;&#10;   EVT_H_12,&#13;&#10;   EVT_D_12,&#13;&#10;   EVT_H_13,&#13;&#10;   EVT_D_13,&#13;&#10;   EVT_H_14,&#13;&#10;   EVT_D_14,&#13;&#10;   EVT_H_15,&#13;&#10;   EVT_D_15,&#13;&#10;   EVT_H_16,&#13;&#10;   EVT_D_16,&#13;&#10;   EVT_H_17,&#13;&#10;   EVT_D_17,&#13;&#10;   EVT_H_18,&#13;&#10;   EVT_D_18,&#13;&#10;   EVT_H_19,&#13;&#10;   EVT_D_19,&#13;&#10;   EVT_H_20,&#13;&#10;   EVT_D_20,&#13;&#10;   TRAN_USER_ID,&#13;&#10;   TRAN_COMMENT&#13;&#10;) VALUES (&#13;&#10;   @factory,&#13;&#10;   @user_id,&#13;&#10;   (NEXT VALUE FOR SEQ_USR_HIS),&#13;&#10;   @event_id, &#13;&#10;   @action, &#13;&#10;   @system,&#13;&#10;   @host_ip,&#13;&#10;   @host_name,&#13;&#10;   @tran_time,&#13;&#10;   @evt_h_1,&#13;&#10;   @evt_d_1,   &#13;&#10;   @evt_h_2,&#13;&#10;   @evt_d_2,&#13;&#10;   @evt_h_3,&#13;&#10;   @evt_d_3,&#13;&#10;   @evt_h_4,&#13;&#10;   @evt_d_4,&#13;&#10;   @evt_h_5,&#13;&#10;   @evt_d_5,&#13;&#10;   @evt_h_6,&#13;&#10;   @evt_d_6,&#13;&#10;   @evt_h_7,&#13;&#10;   @evt_d_7,&#13;&#10;   @evt_h_8,&#13;&#10;   @evt_d_8,&#13;&#10;   @evt_h_9,&#13;&#10;   @evt_d_9,&#13;&#10;   @evt_h_10,&#13;&#10;   @evt_d_10,&#13;&#10;   @evt_h_11,&#13;&#10;   @evt_d_11,   &#13;&#10;   @evt_h_12,&#13;&#10;   @evt_d_12,&#13;&#10;   @evt_h_13,&#13;&#10;   @evt_d_13,&#13;&#10;   @evt_h_14,&#13;&#10;   @evt_d_14,&#13;&#10;   @evt_h_15,&#13;&#10;   @evt_d_15,&#13;&#10;   @evt_h_16,&#13;&#10;   @evt_d_16,&#13;&#10;   @evt_h_17,&#13;&#10;   @evt_d_17,&#13;&#10;   @evt_h_18,&#13;&#10;   @evt_d_18,&#13;&#10;   @evt_h_19,&#13;&#10;   @evt_d_19,&#13;&#10;   @evt_h_20,&#13;&#10;   @evt_d_20,   &#13;&#10;   @tran_user_id,&#13;&#10;   @tran_comment&#13;&#10;)">
            <QP N="factory"/>
