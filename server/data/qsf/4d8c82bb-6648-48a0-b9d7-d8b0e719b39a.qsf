          <QY P="MsSql" Q="INSERT INTO QSECUSRDEF(&#13;&#10;   FACTORY,&#13;&#10;   USER_ID,&#13;&#10;   USER_NAME,&#13;&#10;   USER_DESC,&#13;&#10;   USER_GRP, &#13;&#10;   PHONE_OFFICE,&#13;&#10;   PHONE_MOBILE, &#13;&#10;   EMAIL_ID,&#13;&#10;   DELETE_FLAG,&#13;&#10;   CREATE_USER_ID,&#13;&#10;   CREATE_TIME,&#13;&#10;   UPDATE_USER_ID,&#13;&#10;   UPDATE_TIME&#13;&#10;) VALUES (&#13;&#10;   @factory,&#13;&#10;   @user_id,&#13;&#10;   @user_name,&#13;&#10;   @user_desc,&#13;&#10;   @user_grp,&#13;&#10;   @phone_office,&#13;&#10;   @phone_mobile,&#13;&#10;   @email_id,&#13;&#10;   'N',&#13;&#10;   @create_user_id,&#13;&#10;   @create_time,&#13;&#10;   @update_user_id,&#13;&#10;   @update_time&#13;&#10;)">
