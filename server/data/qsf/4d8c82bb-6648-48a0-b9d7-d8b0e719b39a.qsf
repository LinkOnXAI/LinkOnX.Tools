    <M _S="199" N="Report">
      <F _S="811" N="UserHistory">
        <SG _S="3298" N="SearchUserHistory">
          <QY P="MsSql" Q="SELECT HIS.HIST_SEQ, HIS.TRAN_TIME, HIS.USER_ID, ISNULL(DEF.USER_NAME, ' ') AS USER_NAME,&#13;&#10;       HIS.SYSTEM, HIS.EVENT_ID, HIS.ACTION, HIS.HOST_IP, HIS.HOST_NAME,&#13;&#10;       HIS.EVT_H_1, HIS.EVT_D_1, HIS.EVT_H_2, HIS.EVT_D_2, HIS.EVT_H_3, HIS.EVT_D_3, HIS.EVT_H_4, HIS.EVT_D_4, HIS.EVT_H_5, HIS.EVT_D_5, &#13;&#10;       HIS.EVT_H_6, HIS.EVT_D_6, HIS.EVT_H_7, HIS.EVT_D_7, HIS.EVT_H_8, HIS.EVT_D_8, HIS.EVT_H_9, HIS.EVT_D_9, HIS.EVT_H_10, HIS.EVT_D_10,       &#13;&#10;       HIS.EVT_H_11, HIS.EVT_D_11, HIS.EVT_H_12, HIS.EVT_D_12, HIS.EVT_H_13, HIS.EVT_D_13, HIS.EVT_H_14, HIS.EVT_D_14, HIS.EVT_H_15, HIS.EVT_D_15, &#13;&#10;       HIS.EVT_H_16, HIS.EVT_D_16, HIS.EVT_H_17, HIS.EVT_D_17, HIS.EVT_H_18, HIS.EVT_D_18, HIS.EVT_H_19, HIS.EVT_D_19, HIS.EVT_H_20, HIS.EVT_D_20,&#13;&#10;       HIS.TRAN_COMMENT&#13;&#10;  FROM QSECUSRHIS HIS&#13;&#10;  LEFT JOIN QSECUSRDEF DEF&#13;&#10;    ON HIS.FACTORY      = DEF.FACTORY&#13;&#10;   AND HIS.USER_ID      = DEF.USER_ID&#13;&#10; WHERE HIS.FACTORY      = @factory&#13;&#10;   AND HIS.SYSTEM       = @system&#13;&#10;   AND HIS.USER_ID      = ISNULL(@user_id, HIS.USER_ID)&#13;&#10;   AND HIS.C_TRAN_TIME &gt;= CONVERT (DATETIME, (STUFF(STUFF(STUFF(STUFF(@tran_from_time, 9, 0, ' '), 12, 0, ':'), 15, 0, ':'), 18, 0, '.'))) &#13;&#10;   AND HIS.C_TRAN_TIME &lt;= CONVERT (DATETIME, (STUFF(STUFF(STUFF(STUFF(@tran_to_time, 9, 0, ' '), 12, 0, ':'), 15, 0, ':'), 18, 0, '.')))&#13;&#10; ORDER BY HIS.C_TRAN_TIME DESC">
            <QP N="factory"/>
            <QP N="system"/>
            <QP N="user_id"/>
            <QP N="tran_from_time"/>
            <QP N="tran_to_time"/>
          </QY>
        </SG>
        <SG _S="3299" N="SearchUserHistoryPaging">
          <QY P="MsSql" Q="SELECT HIS.HIST_SEQ, HIS.TRAN_TIME, HIS.USER_ID, ISNULL(DEF.USER_NAME, ' ') AS USER_NAME,&#13;&#10;       HIS.SYSTEM, HIS.EVENT_ID, HIS.ACTION, HIS.HOST_IP, HIS.HOST_NAME,&#13;&#10;       HIS.EVT_H_1, HIS.EVT_D_1, HIS.EVT_H_2, HIS.EVT_D_2, HIS.EVT_H_3, HIS.EVT_D_3, HIS.EVT_H_4, HIS.EVT_D_4, HIS.EVT_H_5, HIS.EVT_D_5, &#13;&#10;       HIS.EVT_H_6, HIS.EVT_D_6, HIS.EVT_H_7, HIS.EVT_D_7, HIS.EVT_H_8, HIS.EVT_D_8, HIS.EVT_H_9, HIS.EVT_D_9, HIS.EVT_H_10, HIS.EVT_D_10,       &#13;&#10;       HIS.EVT_H_11, HIS.EVT_D_11, HIS.EVT_H_12, HIS.EVT_D_12, HIS.EVT_H_13, HIS.EVT_D_13, HIS.EVT_H_14, HIS.EVT_D_14, HIS.EVT_H_15, HIS.EVT_D_15, &#13;&#10;       HIS.EVT_H_16, HIS.EVT_D_16, HIS.EVT_H_17, HIS.EVT_D_17, HIS.EVT_H_18, HIS.EVT_D_18, HIS.EVT_H_19, HIS.EVT_D_19, HIS.EVT_H_20, HIS.EVT_D_20,&#13;&#10;       HIS.TRAN_COMMENT&#13;&#10;  FROM QSECUSRHIS HIS&#13;&#10;  LEFT JOIN QSECUSRDEF DEF&#13;&#10;    ON HIS.FACTORY      = DEF.FACTORY&#13;&#10;   AND HIS.USER_ID      = DEF.USER_ID&#13;&#10; WHERE HIS.FACTORY      = @factory&#13;&#10;   AND HIS.SYSTEM       = @system&#13;&#10;   AND HIS.USER_ID      = ISNULL(@user_id, HIS.USER_ID)&#13;&#10;   AND HIS.C_TRAN_TIME &gt;= CONVERT (DATETIME, (STUFF(STUFF(STUFF(STUFF(@tran_from_time, 9, 0, ' '), 12, 0, ':'), 15, 0, ':'), 18, 0, '.'))) &#13;&#10;   AND HIS.C_TRAN_TIME &lt;= CONVERT (DATETIME, (STUFF(STUFF(STUFF(STUFF(@tran_to_time, 9, 0, ' '), 12, 0, ':'), 15, 0, ':'), 18, 0, '.')))&#13;&#10; ORDER BY HIS.C_TRAN_TIME DESC&#13;&#10;OFFSET (CONVERT(int, @PAGE_NO)-1) * CONVERT(int, @PAGE_SIZE) ROW FETCH NEXT CONVERT(int, @PAGE_SIZE) ROW ONLY">
            <QP N="factory"/>
            <QP N="system"/>
            <QP N="user_id"/>
            <QP N="tran_from_time"/>
            <QP N="tran_to_time"/>
            <QP N="PAGE_NO"/>
            <QP N="PAGE_SIZE"/>
          </QY>
        </SG>
        <SG _S="3300" N="SearchUserHistoryCount">
          <QY P="MsSql" Q="SELECT COUNT(*) AS CNT&#13;&#10;  FROM QSECUSRHIS&#13;&#10; WHERE FACTORY      = @factory&#13;&#10;   AND SYSTEM       = @system&#13;&#10;   AND USER_ID      = ISNULL(@user_id, USER_ID)&#13;&#10;   AND C_TRAN_TIME &gt;= CONVERT (DATETIME, (STUFF(STUFF(STUFF(STUFF(@tran_from_time, 9, 0, ' '), 12, 0, ':'), 15, 0, ':'), 18, 0, '.'))) &#13;&#10;   AND C_TRAN_TIME &lt;= CONVERT (DATETIME, (STUFF(STUFF(STUFF(STUFF(@tran_to_time, 9, 0, ' '), 12, 0, ':'), 15, 0, ':'), 18, 0, '.')))">
            <QP N="factory"/>
            <QP N="system"/>
            <QP N="user_id"/>
            <QP N="tran_from_time"/>
            <QP N="tran_to_time"/>
          </QY>
        </SG>
      </F>
    </M>
