        <SG _S="3559" N="UpdateDevice">
          <QY P="MsSql" Q="UPDATE QBWSDVCDEF SET&#xD;&#xA;   DVC_DESC       = @dvc_desc, &#xD;&#xA;   ACCOUNT_ID     = @account_id, &#xD;&#xA;   PASSWORD       = @password, &#xD;&#xA;   DOMAIN         = @domain, &#xD;&#xA;   COMPUTER_NAME  = @computer_name,&#xD;&#xA;   IP_ADDRESS     = @ip_address,&#xD;&#xA;   MAC_ADDRESS    = @mac_address,&#xD;&#xA;   OS             = @os,&#xD;&#xA;   OS_ARCH        = @os_architecture, &#xD;&#xA;   MANUFACTURER   = @manufacturer, &#xD;&#xA;   MODEL          = @model,&#xD;&#xA;   PROCESSOR      = @processor, &#xD;&#xA;   MEMORY         = @memory,&#xD;&#xA;   UPDATE_USER_ID = @update_user_id,&#xD;&#xA;   UPDATE_TIME    = @update_time&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND DVC_ID     = @dvc_id">
            <QP N="dvc_desc" />
            <QP N="account_id" />
            <QP N="password" />
            <QP N="domain" />
            <QP N="computer_name" />
            <QP N="ip_address" />
            <QP N="mac_address" />
            <QP N="os" />
            <QP N="os_architecture" />
            <QP N="manufacturer" />
            <QP N="model" />
            <QP N="processor" />
            <QP N="memory" />
            <QP N="update_user_id" />
            <QP N="update_time" />
