            <QP N="evt_h_11" />
            <QP N="evt_d_11" />
            <QP N="evt_h_12" />
            <QP N="evt_d_12" />
            <QP N="evt_h_13" />
            <QP N="evt_d_13" />
            <QP N="evt_h_14" />
            <QP N="evt_d_14" />
            <QP N="evt_h_15" />
            <QP N="evt_d_15" />
            <QP N="evt_h_16" />
            <QP N="evt_d_16" />
            <QP N="evt_h_17" />
            <QP N="evt_d_17" />
            <QP N="evt_h_18" />
            <QP N="evt_d_18" />
            <QP N="evt_h_19" />
            <QP N="evt_d_19" />
            <QP N="evt_h_20" />
            <QP N="evt_d_20" />
            <QP N="tran_user_id" />
            <QP N="tran_comment" />
          </QY>
        </SG>
        <SG _S="2348" N="UpdateEap">
          <QY P="MsSql" Q="UPDATE QRASEAPDEF SET&#xD;&#xA;  LAST_EVENT_ID    = @last_event_id,&#xD;&#xA;  LAST_EVENT_TIME  = @last_event_time,&#xD;&#xA;  LAST_HIST_SEQ    = @hist_seq,&#xD;&#xA;  UPDATE_USER_ID   = @update_user_id,&#xD;&#xA;  UPDATE_TIME      = @update_time&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND EAP     = @eap">
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="hist_seq" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="3153" N="UpdateEquipmentStatus">
          <QY P="MsSql" Q="UPDATE QRASEQPSTS SET&#xD;&#xA;   LAST_HIST_SEQ   = @last_his_seq,&#xD;&#xA;   COMM_STATE      = @comm_state,&#xD;&#xA;   CTRL_MODE       = @ctrl_mode,&#xD;&#xA;   PROC_STATE       = @proc_state,&#xD;&#xA;   LAST_EVENT_ID   = @last_event_id,&#xD;&#xA;   LAST_EVENT_TIME = @last_event_time,&#xD;&#xA;   UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;   UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EQP_NAME = @eqp_name">
            <QP N="last_his_seq" />
            <QP N="comm_state" />
            <QP N="ctrl_mode" />
            <QP N="proc_state" />
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
      </F>
      <F _S="3513" N="BranchInit">
        <SG _S="3514" N="HasEquipment">
          <QY P="MsSql" Q="SELECT EQP.EQP_NAME, EQP.EAP, EAP.SERVER, EAP.EAP_TYPE, EAP.STATUS&#xD;&#xA;  FROM QRASEQPDEF AS EQP&#xD;&#xA;   LEFT JOIN QRASEAPDEF AS EAP&#xD;&#xA;    ON EQP.FACTORY     = EAP.FACTORY&#xD;&#xA;   AND EQP.EAP         = EAP.EAP&#xD;&#xA;   AND EAP.DELETE_FLAG = 'N'&#xD;&#xA; WHERE EQP.FACTORY     = @factory&#xD;&#xA;   AND EQP.EQP_NAME    = @eqp_name&#xD;&#xA;   AND EQP.DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="3577" N="HasServer">
          <QY P="MsSql" Q="SELECT A.SVR_IP, A.UP_DOWN, A.STATUS, A.EAS_UP_DOWN,&#xD;&#xA;       A.B_SERVER, A.B_UP_DOWN, A.B_STATUS, A.B_EAS_UP_DOWN, ISNULL(B.SVR_IP, '') B_SVR_IP&#xD;&#xA;  FROM QSYSSVRDEF A&#xD;&#xA;  LEFT JOIN QSYSSVRDEF B&#xD;&#xA;    ON A.FACTORY     = B.FACTORY&#xD;&#xA;   AND A.B_SERVER    = B.SERVER&#xD;&#xA;   AND B.DELETE_FLAG = 'N'&#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.SERVER      = @server&#xD;&#xA;   AND A.DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="server" />
          </QY>
        </SG>
        <SG _S="3515" N="HasBranchEquipment">
          <QY P="MsSql" Q="SELECT IBN_NAME, ENABLE, ACTIVE_VER&#xD;&#xA;  FROM QBWSIBNEQP&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EQP_NAME    = @eqp_name">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="3516" N="HasBranch">
          <QY P="MsSql" Q="SELECT PROTOCOL, PROTOCOL_ATTR&#xD;&#xA;  FROM QBWSIBNDEF&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND IBN_NAME = @ibn_name">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
        <SG _S="3636" N="HasEap">
          <QY P="MsSql" Q="SELECT EAP&#xD;&#xA;  FROM QRASEAPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EAP         = @eap&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="3517" N="HasBranchTag">
          <QY P="MsSql" Q="WITH VersionData AS (&#xD;&#xA; SELECT V.FACTORY, V.BUILD_MDL, V.BUILD_MDL_VER, T.CNT_RK, T.CNT_NAME, T.TAG_ADDR, T.TAG_ADDR_ALIAS&#xD;&#xA;   FROM QBWSIBNVER V&#xD;&#xA;   LEFT JOIN QBWSIBNPTG T&#xD;&#xA;     ON V.FACTORY    = T.FACTORY&#xD;&#xA;    AND V.IBN_NAME   = T.IBN_NAME&#xD;&#xA;    AND V.EQP_NAME   = T.EQP_NAME&#xD;&#xA;    AND V.TAGSET_VER = T.TAGSET_VER&#xA;  WHERE V.FACTORY    = @factory&#xD;&#xA;    AND V.IBN_NAME   = @ibn_name&#xD;&#xA;    AND V.EQP_NAME   = @eqp_name&#xD;&#xA;    AND V.TAGSET_VER = @tagset_ver&#xA;)&#xD;&#xA;SELECT IBN.CNT_RK, IBN.CNT_NAME, IBN.TAG_ADDR, IBN.TAG_ADDR_ALIAS, MDL.PLC_TAG_FORMAT, MDL.TAG_FORMAT&#xD;&#xA;  FROM VersionData IBN&#xD;&#xA;  LEFT JOIN QRASMDLPTG MDL&#xD;&#xA;    ON IBN.FACTORY       = MDL.FACTORY&#xD;&#xA;   AND IBN.BUILD_MDL     = MDL.MODEL&#xD;&#xA;   AND IBN.BUILD_MDL_VER = MDL.MDL_VER&#xD;&#xA;   AND IBN.CNT_RK        = MDL.CNT_RK&#xD;&#xA;   AND IBN.TAG_ADDR      = MDL.PLC_TAG_ADDR">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
            <QP N="tagset_ver&#xA;" />
          </QY>
        </SG>
        <SG _S="3518" N="UpdateBranchEquipment">
          <QY P="MsSql" Q="UPDATE QBWSIBNEQP SET&#xD;&#xA;  APPLIED_VER    = @applied_ver,&#xD;&#xA;  UPDATE_USER_ID = @update_user_id,&#xD;&#xA;  UPDATE_TIME    = @update_time&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND IBN_NAME  = @ibn_name&#xD;&#xA;   AND EQP_NAME  = @eqp_name">
            <QP N="applied_ver" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="770" N="DataPusher">
      <F _S="3231" N="DataHoundDataPush">
        <SG _S="3232" N="SearchDataHound">
          <QY P="MsSql" Q="SELECT NAME, STATUS, SERVER_IP, SERVER_PORT, RESULT_MESSAGE&#xD;&#xA;  FROM QSYSDHDDEF  &#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND NAME = @hound">
            <QP N="factory" />
            <QP N="hound" />
          </QY>
        </SG>
      </F>
      <F _S="2435" N="EquipmentDataPush" D="cleanup needed">
        <SG _S="2436" N="SearchEquipment">
          <QY P="MsSql" Q="SELECT A.EQP_NAME, A.EQP_DESC, ISNULL(C.SERVER, 'N/A') SERVER, ISNULL(C.EAP, 'N/A') EAP, ISNULL(C.UP_DOWN, 'N/A') UP_DOWN, ISNULL(C.STATUS, 'N/A') STATUS,&#xD;&#xA;       A.TYPE, A.AREA, A.LINE, A.MDLN, A.SOFTREV, A.CTRL_MODE, A.PRI_STATE, A.STATE, A.ALARM, A.EVENT_DEFINE&#xD;&#xA;  FROM QRASEQPDEF A&#xD;&#xA;  WITH (NOLOCK)&#xD;&#xA;  LEFT JOIN QRASEQPATR B&#xD;&#xA;    ON A.FACTORY         = B.FACTORY&#xD;&#xA;   AND A.EQP_NAME        = B.EQP_NAME&#xD;&#xA;   AND B.ATTR_CATEGORY   = @attr_category&#xD;&#xA;  LEFT JOIN QRASEAPDEF C&#xD;&#xA;    ON A.FACTORY         = C.FACTORY&#xD;&#xA;   AND B.EAP             = C.EAP&#xD;&#xA; WHERE A.FACTORY         = @factory&#xD;&#xA;   AND A.EQP_NAME        = @eqp_name&#xD;&#xA;   AND A.DELETE_FLAG     = 'N'">
            <QP N="attr_category" />
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
      </F>
      <F _S="3551" N="BranchDataPush">
        <SG _S="3552" N="SearchBranch">
          <QY P="MsSql" Q="SELECT IBN_NAME, IBN_DESC, PROTOCOL, PROTOCOL_ATTR&#xD;&#xA;  FROM QBWSIBNDEF&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND IBN_NAME = @ibn_name">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
        <SG _S="3555" N="SearchBranchEquipment">
          <QY P="MsSql" Q="SELECT IBN.EQP_NAME, ISNULL(EQP.EQP_DESC, ' ') EQP_DESC, IBN.ENABLE, IBN.NEED_ACTION, IBN.ACTIVE_VER, IBN.APPLIED_VER, IBN.LAST_VER&#xD;&#xA;  FROM QBWSIBNEQP IBN&#xD;&#xA;  LEFT JOIN QRASEQPDEF EQP&#xD;&#xA;    ON IBN.FACTORY  = EQP.FACTORY&#xD;&#xA;   AND IBN.EQP_NAME =  EQP.EQP_NAME&#xD;&#xA; WHERE IBN.FACTORY  = @factory&#xD;&#xA;   AND IBN.IBN_NAME = @ibn_name&#xD;&#xA;ORDER BY IBN.EQP_NAME">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
      </F>
      <F _S="3553" N="BranchEquipmentDataPush">
        <SG _S="3554" N="SearchBranchEquipment">
          <QY P="MsSql" Q="SELECT A.EQP_NAME, ISNULL(C.EQP_DESC, ' ') EQP_DESC, B.PROTOCOL, A.ENABLE, A.NEED_ACTION, A.ACTIVE_VER, A.APPLIED_VER, A.LAST_VER&#xD;&#xA;  FROM QBWSIBNEQP A&#xD;&#xA;  LEFT JOIN QBWSIBNDEF B&#xD;&#xA;    ON A.FACTORY  = B.FACTORY&#xD;&#xA;   AND A.IBN_NAME = B.IBN_NAME&#xD;&#xA;  LEFT JOIN QRASEQPDEF C&#xD;&#xA;    ON A.FACTORY  = C.FACTORY&#xD;&#xA;   AND A.EQP_NAME = C.EQP_NAME&#xD;&#xA; WHERE A.FACTORY  = @factory&#xD;&#xA;   AND A.IBN_NAME = @ibn_name&#xD;&#xA;   AND A.EQP_NAME = @eqp_name">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="1419" N="DataPurge">
      <F _S="1420" N="DataPurge">
        <SG _S="1427" N="SearchFactory">
          <QY P="MsSql" Q="SELECT FACTORY&#xD;&#xA; FROM QSYSFACDEF" />
        </SG>
        <SG _S="1421" N="DeleteUserHistory" UMG="No">
          <QY P="MsSql" Q="WITH TMP_DELETE AS (&#xD;&#xA;	SELECT TRAN_TIME, ROW_NUMBER() OVER(ORDER BY TRAN_TIME) AS ROWNUM &#xD;&#xA;		FROM QSECUSRHIS&#xD;&#xA;		WHERE FACTORY = @factory&#xD;&#xA;		AND TRAN_TIME &lt; @tran_time&#xD;&#xA;)&#xD;&#xA;DELETE FROM TMP_DELETE WHERE ROWNUM &lt;= @delete_cnt">
            <QP N="factory" />
            <QP N="tran_time" />
            <QP N="delete_cnt" />
          </QY>
        </SG>
        <SG _S="1423" N="DeleteServerHistory" UMG="No">
          <QY P="MsSql" Q="WITH TMP_DELETE AS (&#xD;&#xA;	SELECT TRAN_TIME, ROW_NUMBER() OVER(ORDER BY TRAN_TIME) AS ROWNUM &#xD;&#xA;		FROM QSYSSVRHIS&#xD;&#xA;		WHERE FACTORY = @factory&#xD;&#xA;		AND TRAN_TIME &lt; @tran_time&#xD;&#xA;)&#xD;&#xA;DELETE FROM TMP_DELETE WHERE ROWNUM &lt;= @delete_cnt">
            <QP N="factory" />
            <QP N="tran_time" />
            <QP N="delete_cnt" />
          </QY>
        </SG>
        <SG _S="1424" N="DeleteEapHistory" UMG="No">
          <QY P="MsSql" Q="WITH TMP_DELETE AS (&#xD;&#xA;	SELECT TRAN_TIME, ROW_NUMBER() OVER(ORDER BY TRAN_TIME) AS ROWNUM &#xD;&#xA;		FROM QRASEAPHIS&#xD;&#xA;		WHERE FACTORY = @factory&#xD;&#xA;		AND TRAN_TIME &lt; @tran_time&#xD;&#xA;)&#xD;&#xA;DELETE FROM TMP_DELETE WHERE ROWNUM &lt;= @delete_cnt">
            <QP N="factory" />
            <QP N="tran_time" />
            <QP N="delete_cnt" />
          </QY>
        </SG>
        <SG _S="1505" N="DeleteEquipmentHistory" UMG="No">
          <QY P="MsSql" Q="WITH TMP_DELETE AS (&#xD;&#xA;	SELECT TRAN_TIME, ROW_NUMBER() OVER(ORDER BY TRAN_TIME) AS ROWNUM &#xD;&#xA;		FROM QRASEQPHIS&#xD;&#xA;		WHERE FACTORY = @factory&#xD;&#xA;		AND TRAN_TIME &lt; @tran_time&#xD;&#xA;)&#xD;&#xA;DELETE FROM TMP_DELETE WHERE ROWNUM &lt;= @delete_cnt">
            <QP N="factory" />
            <QP N="tran_time" />
            <QP N="delete_cnt" />
          </QY>
        </SG>
        <SG _S="2744" N="DeleteServerResourceHistory" UMG="No">
          <QY P="MsSql" Q="WITH TMP_DELETE AS (&#xD;&#xA;	SELECT TRAN_TIME, ROW_NUMBER() OVER(ORDER BY TRAN_TIME) AS ROWNUM &#xD;&#xA;		FROM QSYSSVRRHI&#xD;&#xA;		WHERE FACTORY = @factory&#xD;&#xA;		AND TRAN_TIME &lt; @tran_time&#xD;&#xA;)&#xD;&#xA;DELETE FROM TMP_DELETE WHERE ROWNUM &lt;= @delete_cnt">
            <QP N="factory" />
            <QP N="tran_time" />
            <QP N="delete_cnt" />
          </QY>
        </SG>
        <SG _S="2745" N="DeleteEapResourceHistory" UMG="No">
          <QY P="MsSql" Q="WITH TMP_DELETE AS (&#xD;&#xA;	SELECT TRAN_TIME, ROW_NUMBER() OVER(ORDER BY TRAN_TIME) AS ROWNUM&#xD;&#xA;		FROM QRASEAPRHI&#xD;&#xA;		WHERE FACTORY = @factory&#xD;&#xA;		AND TRAN_TIME &lt; @tran_time&#xD;&#xA;)&#xD;&#xA;DELETE FROM TMP_DELETE WHERE ROWNUM &lt;= @delete_cnt">
            <QP N="factory" />
            <QP N="tran_time" />
            <QP N="delete_cnt" />
          </QY>
        </SG>
      </F>
    </M>
  </S>
</Q>