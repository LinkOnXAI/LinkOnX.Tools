        </SG>
        <SG _S="2201" N="InsertEquipmentLine">
          <QY P="MsSql" Q="INSERT INTO QRASEQPLIN (&#xD;&#xA;   FACTORY,&#xD;&#xA;   LINE,&#xD;&#xA;   LINE_DESC,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @line,&#xD;&#xA;   @line_desc,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="line" />
            <QP N="line_desc" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="2202" N="UpdateEquipmentLine">
          <QY P="MsSql" Q="UPDATE QRASEQPLIN SET&#xD;&#xA;  LINE_DESC      = @line_desc,&#xD;&#xA;  UPDATE_USER_ID = @update_user_id,&#xD;&#xA;  UPDATE_TIME    = @update_time&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND LINE      = @line">
            <QP N="line_desc" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="line" />
          </QY>
        </SG>
        <SG _S="2204" N="DeleteEquipmentLine">
          <QY P="MsSql" Q="DELETE &#xD;&#xA;  FROM QRASEQPLIN&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND LINE    = @line">
            <QP N="factory" />
            <QP N="line" />
          </QY>
        </SG>
        <SG _S="2203" N="CountEquipmentLine">
          <QY P="MsSql" Q="SELECT EQP_NAME&#xD;&#xA;  FROM QRASEQPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND LINE        = @line&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="line" />
          </QY>
        </SG>
      </F>
      <F _S="2751" N="Equipment">
        <SG _S="2752" N="ListEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME, EQP_DESC, IP_ADDRESS, TYPE, LINE&#xD;&#xA;  FROM QRASEQPDEF&#xD;&#xA; WHERE FACTORY     = @factory &#xD;&#xA;   AND DELETE_FLAG = 'N'&#xD;&#xA; ORDER BY EQP_NAME">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="2753" N="SearchEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME, EQP_DESC, IP_ADDRESS, TYPE, LINE&#xD;&#xA;  FROM QRASEQPDEF&#xD;&#xA; WHERE FACTORY     = @factory &#xD;&#xA;   AND EQP_NAME    = @eqp_name&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="2812" N="HasEquipmentType">
          <QY P="MsSql" Q="SELECT TYPE&#xD;&#xA;  FROM QRASEQPTYP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TYPE    = @type">
            <QP N="factory" />
            <QP N="type" />
          </QY>
        </SG>
        <SG _S="3100" N="HasEquipmentLine">
          <QY P="MsSql" Q="SELECT LINE&#xD;&#xA;  FROM QRASEQPLIN&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND LINE    = @line">
            <QP N="factory" />
            <QP N="line" />
          </QY>
        </SG>
        <SG _S="2755" N="HasEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME, TYPE, DELETE_FLAG&#xD;&#xA;  FROM QRASEQPDEF&#xD;&#xA; WHERE FACTORY  = @factory &#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="3134" N="HasEapConfig">
          <QY P="MsSql" Q="SELECT EAP&#xD;&#xA;  FROM QRASEAPCFG&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND KEY_NAME      = @eqp_name_key&#xD;&#xA;   AND DATA          = @eqp_name">
