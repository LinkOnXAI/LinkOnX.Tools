        <SG _S="2758" N="InsertEquipment">
          <QY P="MsSql" Q="INSERT INTO QRASEQPDEF (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   EQP_DESC,&#xD;&#xA;   IP_ADDRESS,&#xD;&#xA;   EAP,&#xD;&#xA;   TYPE,&#xD;&#xA;   LINE,&#xD;&#xA;   DELETE_FLAG,   &#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @eqp_name,&#xD;&#xA;   @eqp_desc,&#xD;&#xA;   @ip_address,&#xD;&#xA;   @eap,&#xD;&#xA;   @type,&#xD;&#xA;   @line,&#xD;&#xA;   @delete_flag,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
