        <SG _S="3146" N="InsertEquipmentStatus">
          <QY P="MsSql" Q="INSERT INTO QRASEQPSTS (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   COMM_STATE,   &#xD;&#xA;   CTRL_MODE,&#xD;&#xA;   PROC_STATE,&#xD;&#xA;   LAST_EVENT_ID,&#xD;&#xA;   LAST_EVENT_TIME,&#xD;&#xA;   LAST_HIST_SEQ,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @eqp_name,&#xD;&#xA;   @comm_state,&#xD;&#xA;   @ctrl_mode,&#xD;&#xA;   @proc_state,&#xD;&#xA;   @last_event_id,&#xD;&#xA;   @last_event_time,&#xD;&#xA;   @last_hist_seq,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
