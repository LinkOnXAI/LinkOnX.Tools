          </QY>
        </SG>
        <SG _S="3654" N="ListPreset">
          <QY P="MsSql" Q="SELECT PRESET_NAME, PRESET_DESC, PRESET_CATEGORY, PRESET_PLC_MAKER, PRESET_PLC_MODEL,&#xD;&#xA;       ADDRESS_RADIX, ALLOW_EMPTY_ADDRESS, IS_ALARM&#xD;&#xA;  FROM QSYSPTMPRS&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND PRESET_GROUP = @preset_group&#xD;&#xA; ORDER BY PRESET_NAME">
            <QP N="factory" />
            <QP N="preset_group" />
          </QY>
        </SG>
        <SG _S="3656" N="ListPresetTags">
          <QY P="MsSql" Q="SELECT TAG_SEQ, TAG_NAME, TAG_DESC, TAG_REGISTER, TAG_DEC_ADDRESS, TAG_FULL_ADDRESS, &#xD;&#xA;       TAG_TYPE, TAG_FORMAT, TAG_PLC_FORMAT, TAG_LENGTH&#xD;&#xA;  FROM QSYSPTMPTG&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND PRESET_GROUP = @preset_group&#xD;&#xA;   AND PRESET_NAME  = @preset_name&#xD;&#xA; ORDER BY TAG_SEQ">
            <QP N="factory" />
            <QP N="preset_group" />
            <QP N="preset_name" />
          </QY>
        </SG>
        <SG _S="3657" N="ListPresetTagsPaging">
          <QY P="MsSql" Q="SELECT TAG_SEQ, TAG_NAME, TAG_DESC, TAG_REGISTER, TAG_DEC_ADDRESS, TAG_FULL_ADDRESS, &#xD;&#xA;       TAG_TYPE, TAG_FORMAT, TAG_PLC_FORMAT, TAG_LENGTH&#xD;&#xA;  FROM QSYSPTMPTG&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND PRESET_GROUP = @preset_group&#xD;&#xA;   AND PRESET_NAME  = @preset_name&#xD;&#xA; ORDER BY TAG_SEQ&#xD;&#xA; OFFSET (CONVERT(int, @PAGE_NO)-1) * CONVERT(int, @PAGE_SIZE) ROW FETCH NEXT CONVERT(int, @PAGE_SIZE) ROW ONLY">
            <QP N="factory" />
            <QP N="preset_group" />
            <QP N="preset_name" />
            <QP N="PAGE_NO" />
            <QP N="PAGE_SIZE" />
