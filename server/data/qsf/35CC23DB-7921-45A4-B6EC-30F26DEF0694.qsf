        <SG _S="3672" N="UpdatePreset">
          <QY P="MsSql" Q="UPDATE QSYSPTMPRS SET&#xD;&#xA;   PRESET_DESC         = @preset_desc,&#xD;&#xA;   PRESET_CATEGORY     = @preset_category,&#xD;&#xA;   PRESET_PLC_MAKER    = @preset_plc_maker,&#xD;&#xA;   PRESET_PLC_MODEL    = @preset_plc_model,&#xD;&#xA;   ADDRESS_RADIX       = @address_radix,&#xD;&#xA;   ALLOW_EMPTY_ADDRESS = @allow_empty_address,&#xD;&#xA;   IS_ALARM            = @is_alarm,&#xD;&#xA;   UPDATE_USER_ID      = @update_user_id,&#xD;&#xA;   UPDATE_TIME         = @update_time&#xD;&#xA; WHERE FACTORY         = @factory&#xD;&#xA;   AND PRESET_GROUP    = @preset_group&#xD;&#xA;   AND PRESET_NAME     = @preset_name">
