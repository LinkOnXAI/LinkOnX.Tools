          </QY>
        </SG>
        <SG _S="2760" N="UpdateEquipment">
          <QY P="MsSql" Q="UPDATE QRASEQPDEF SET&#xD;&#xA;   EQP_DESC        = @eqp_desc,&#xD;&#xA;   IP_ADDRESS      = @ip_address,&#xD;&#xA;   TYPE            = @type,&#xD;&#xA;   LINE            = @line,&#xD;&#xA;   DELETE_FLAG     = @delete_flag,&#xD;&#xA;   UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;   UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EQP_NAME    = @eqp_name">
            <QP N="eqp_desc" />
            <QP N="ip_address" />
            <QP N="type" />
            <QP N="line" />
            <QP N="delete_flag" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="3147" N="UpdateEquipmentStatus">
          <QY P="MsSql" Q="UPDATE QRASEQPSTS SET&#xD;&#xA;   LAST_EVENT_ID   = @last_event_id,&#xD;&#xA;   LAST_EVENT_TIME = @last_event_time,&#xD;&#xA;   LAST_HIST_SEQ   =@last_hist_seq,&#xD;&#xA;   UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;   UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EQP_NAME    = @eqp_name">
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="last_hist_seq" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="2761" N="UpdateEquipmentForNewEq">
          <QY P="MsSql" Q="UPDATE QRASEQPDEF SET&#xD;&#xA;   EQP_DESC        = @eqp_desc,&#xD;&#xA;   IP_ADDRESS      = @ip_address,&#xD;&#xA;   EAP             = @eap,&#xD;&#xA;   TYPE            = @type,&#xD;&#xA;   LINE            = @line, &#xD;&#xA;   DELETE_FLAG     = @delete_flag,&#xD;&#xA;   UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;   UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EQP_NAME    = @eqp_name">
            <QP N="eqp_desc" />
            <QP N="ip_address" />
            <QP N="eap" />
            <QP N="type" />
            <QP N="line" />
            <QP N="delete_flag" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="3148" N="UpdateEquipmentStatusForNewEq">
          <QY P="MsSql" Q="UPDATE QRASEQPSTS SET   &#xD;&#xA;   COMM_STATE      = @comm_state,&#xD;&#xA;   CTRL_MODE       = @ctrl_mode,&#xD;&#xA;   PROC_STATE       = @proc_state,&#xD;&#xA;   LAST_EVENT_ID   = @last_event_id,&#xD;&#xA;   LAST_EVENT_TIME = @last_event_time,&#xD;&#xA;   LAST_HIST_SEQ   = @last_his_seq,&#xD;&#xA;   UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;   UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EQP_NAME    = @eqp_name">
            <QP N="comm_state" />
            <QP N="ctrl_mode" />
            <QP N="proc_state" />
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="last_his_seq" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="2762" N="DeleteEquipment">
          <QY P="MsSql" Q="UPDATE QRASEQPDEF SET&#xD;&#xA;   DELETE_FLAG     = @delete_flag,&#xD;&#xA;   UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;   UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EQP_NAME    = @eqp_name">
            <QP N="delete_flag" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
      </F>
      <F _S="3193" N="PlcTagSetVersion">
        <SG _S="3194" N="HasPlcTagSet">
          <QY P="MsSql" Q="SELECT TAGSET_NAME, TAGSET_LAST_VER&#xD;&#xA;  FROM QSYSPTMDEF&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME  = @tagset_name">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
          </QY>
        </SG>
        <SG _S="3608" N="HasPlcTagSetGroup">
          <QY P="MsSql" Q="SELECT GROUP_NAME&#xD;&#xA;  FROM QSYSPTMGRP&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND GROUP_NAME = @tagset_group">
            <QP N="factory" />
            <QP N="tagset_group" />
          </QY>
        </SG>
        <SG _S="3195" N="HasPlcTagSetVersion">
          <QY P="MsSql" Q="SELECT TAGSET_VER&#xD;&#xA;  FROM QSYSPTMVER&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME  = @tagset_name&#xD;&#xA;   AND TAGSET_VER   = @tagset_ver&#xD;&#xA;   AND DELETE_FLAG  = 'N'">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
            <QP N="tagset_ver" />
          </QY>
        </SG>
        <SG _S="3586" N="CountPlcTagSet">
          <QY P="MsSql" Q="SELECT COUNT(*) AS CNT&#xD;&#xA;  FROM QSYSPTMDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TAGSET_GROUP = @tagset_group">
            <QP N="factory" />
            <QP N="tagset_group" />
          </QY>
        </SG>
        <SG _S="3580" N="CountPlcTagSetVersion">
          <QY P="MsSql" Q="SELECT COUNT(*) AS CNT&#xD;&#xA;  FROM QSYSPTMVER&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME = @tagset_name&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
          </QY>
        </SG>
        <SG _S="3583" N="CountPlcTagSetTags">
          <QY P="MsSql" Q="SELECT COUNT(*) AS CNT&#xD;&#xA;  FROM QSYSPTMTAG&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME = @tagset_name&#xD;&#xA;   AND TAGSET_VER = @tagset_ver">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
            <QP N="tagset_ver" />
          </QY>
        </SG>
        <SG _S="3578" N="SearchLastPlcTagSetVersion">
          <QY P="MsSql" Q="SELECT ISNULL(V.TAGSET_VER, 0) AS TAGSET_VER, &#xD;&#xA;       ISNULL(V.TAGSET_VER_DESC, ' ') AS TAGSET_VER_DESC&#xD;&#xA;  FROM &#xD;&#xA;     (&#xD;&#xA;SELECT TOP (1) TAGSET_VER, TAGSET_VER_DESC&#xD;&#xA;  FROM QSYSPTMVER&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME  = @tagset_name&#xD;&#xA;   AND DELETE_FLAG  = 'N'&#xD;&#xA; ORDER BY TAGSET_VER DESC&#xD;&#xA;     ) AS V">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
          </QY>
        </SG>
        <SG _S="3579" N="ListPlcTagSetGroup">
          <QY P="MsSql" Q="SELECT GROUP_NAME, GROUP_DESC&#xD;&#xA;  FROM QSYSPTMGRP&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3585" N="ListPlcTagSet">
          <QY P="MsSql" Q="SELECT A.TAGSET_NAME, A.TAGSET_DESC, A.TAGSET_LAST_VER, A.TAGSET_PLC_MAKER, A.TAGSET_PLC_MODEL,&#xD;&#xA;       A.CREATE_TIME, CASE WHEN USER_C.USER_NAME IS NULL THEN A.CREATE_USER_ID ELSE CONCAT(A.CREATE_USER_ID, ' [', USER_C.USER_NAME, ']') END AS CREATE_USER , &#xD;&#xA;       A.UPDATE_TIME, CASE WHEN USER_U.USER_NAME IS NULL THEN A.UPDATE_USER_ID ELSE CONCAT(A.UPDATE_USER_ID, ' [', USER_U.USER_NAME, ']') END AS UPDATE_USER&#xD;&#xA;  FROM (&#xD;&#xA;SELECT FACTORY, TAGSET_NAME, TAGSET_DESC, TAGSET_LAST_VER, TAGSET_PLC_MAKER, TAGSET_PLC_MODEL, CREATE_TIME, CREATE_USER_ID, UPDATE_TIME, UPDATE_USER_ID&#xD;&#xA;  FROM QSYSPTMDEF&#xD;&#xA; WHERE FACTORY     = @factory   &#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;       )  A&#xD;&#xA;  LEFT JOIN QSECUSRDEF USER_C&#xD;&#xA;    ON A.FACTORY        = USER_C.FACTORY&#xD;&#xA;   AND A.CREATE_USER_ID = USER_C.USER_ID&#xD;&#xA;  LEFT JOIN QSECUSRDEF USER_U&#xD;&#xA;    ON A.FACTORY        = USER_U.FACTORY&#xD;&#xA;   AND A.UPDATE_USER_ID = USER_U.USER_ID&#xD;&#xA; ORDER BY A.TAGSET_NAME">
            <QP N="factory" />
            <QP N="tagset_group" />
          </QY>
        </SG>
        <SG _S="3680" N="ListPlcPresetTags">
          <QY P="MsSql" Q="SELECT B.TAG_SEQ, A.PRESET_CATEGORY, B.TAG_NAME, B.TAG_DESC, B.TAG_REGISTER, B.TAG_DEC_ADDRESS, B.TAG_FULL_ADDRESS, B.TAG_TYPE, B.TAG_FORMAT, B.TAG_PLC_FORMAT, B.TAG_LENGTH, A.IS_ALARM  &#xD;&#xA;  FROM QSYSPTMPRS A&#xD;&#xA;  LEFT JOIN QSYSPTMPTG B&#xD;&#xA;    ON A.FACTORY      = B.FACTORY&#xD;&#xA;   AND A.PRESET_GROUP = B.PRESET_GROUP&#xD;&#xA;   AND A.PRESET_NAME  = B.PRESET_NAME&#xD;&#xA; WHERE A.FACTORY      = @factory&#xD;&#xA;   AND A.PRESET_GROUP = @preset_group&#xD;&#xA;   AND A.PRESET_NAME  = @preset_name&#xD;&#xA; ORDER BY B.TAG_SEQ">
            <QP N="factory" />
            <QP N="preset_group" />
            <QP N="preset_name" />
          </QY>
        </SG>
        <SG _S="3581" N="ListPlcTagSetVersion">
          <QY P="MsSql" Q="SELECT VER.TAGSET_VER, VER.TAGSET_VER_DESC,&#xD;&#xA;       VER.CREATE_TIME, CASE WHEN USER_C.USER_NAME IS NULL THEN VER.CREATE_USER_ID ELSE CONCAT(VER.CREATE_USER_ID, ' [', USER_C.USER_NAME, ']') END AS CREATE_USER , &#xD;&#xA;	   VER.UPDATE_TIME, CASE WHEN USER_U.USER_NAME IS NULL THEN VER.UPDATE_USER_ID ELSE CONCAT(VER.UPDATE_USER_ID, ' [', USER_U.USER_NAME, ']') END AS UPDATE_USER&#xD;&#xA;  FROM (&#xD;&#xA;SELECT FACTORY, TAGSET_VER, TAGSET_VER_DESC, CREATE_TIME, CREATE_USER_ID, UPDATE_TIME, UPDATE_USER_ID&#xD;&#xA;  FROM QSYSPTMVER&#xD;&#xA; WHERE FACTORY      = @factory   &#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME  = @tagset_name&#xD;&#xA;   AND DELETE_FLAG  = 'N'&#xD;&#xA;       ) VER&#xD;&#xA;  LEFT JOIN QSECUSRDEF USER_C&#xD;&#xA;    ON VER.FACTORY        = USER_C.FACTORY&#xD;&#xA;   AND VER.CREATE_USER_ID = USER_C.USER_ID&#xD;&#xA;  LEFT JOIN QSECUSRDEF USER_U&#xD;&#xA;    ON VER.FACTORY        = USER_U.FACTORY&#xD;&#xA;   AND VER.UPDATE_USER_ID = USER_U.USER_ID&#xD;&#xA; ORDER BY VER.TAGSET_VER DESC">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
          </QY>
        </SG>
        <SG _S="3582" N="ListPlcTagSetVersionPaging">
          <QY P="MsSql" Q="SELECT VER.TAGSET_VER, VER.TAGSET_VER_DESC,&#xD;&#xA;       VER.CREATE_TIME, CASE WHEN USER_C.USER_NAME IS NULL THEN VER.CREATE_USER_ID ELSE CONCAT(VER.CREATE_USER_ID, ' [', USER_C.USER_NAME, ']') END AS CREATE_USER , &#xD;&#xA;	   VER.UPDATE_TIME, CASE WHEN USER_U.USER_NAME IS NULL THEN VER.UPDATE_USER_ID ELSE CONCAT(VER.UPDATE_USER_ID, ' [', USER_U.USER_NAME, ']') END AS UPDATE_USER&#xD;&#xA;  FROM (&#xD;&#xA;SELECT FACTORY, TAGSET_VER, TAGSET_VER_DESC, CREATE_TIME, CREATE_USER_ID, UPDATE_TIME, UPDATE_USER_ID&#xD;&#xA;  FROM QSYSPTMVER&#xD;&#xA; WHERE FACTORY      = @factory   &#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME  = @tagset_name&#xD;&#xA;   AND DELETE_FLAG  = 'N'&#xD;&#xA;   ORDER BY TAGSET_VER DESC&#xD;&#xA;   OFFSET (CONVERT(int, @PAGE_NO)-1) * CONVERT(int, @PAGE_SIZE) ROW FETCH NEXT CONVERT(int, @PAGE_SIZE) ROW ONLY&#xD;&#xA;       ) VER&#xD;&#xA;  LEFT JOIN QSECUSRDEF USER_C&#xD;&#xA;    ON VER.FACTORY        = USER_C.FACTORY&#xD;&#xA;   AND VER.CREATE_USER_ID = USER_C.USER_ID&#xD;&#xA;  LEFT JOIN QSECUSRDEF USER_U&#xD;&#xA;    ON VER.FACTORY        = USER_U.FACTORY&#xD;&#xA;   AND VER.UPDATE_USER_ID = USER_U.USER_ID&#xD;&#xA; ORDER BY VER.TAGSET_VER DESC">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
            <QP N="PAGE_NO" />
            <QP N="PAGE_SIZE" />
          </QY>
        </SG>
        <SG _S="3196" N="SearchPlcTagSetList">
          <QY P="MsSql" Q="SELECT TAGSET_NAME, TAGSET_DESC, TAGSET_LAST_VER&#xD;&#xA; FROM QSYSPTMDEF&#xD;&#xA;WHERE FACTORY = @factory &#xD;&#xA; AND TAGSET_GROUP = @tagset_group">
            <QP N="factory" />
            <QP N="tagset_group" />
          </QY>
        </SG>
        <SG _S="3198" N="ListPlcTagSetTags">
          <QY P="MsSql" Q="SELECT TAG_SEQ, TAG_CATEGORY, TAG_NAME, TAG_DESC, TAG_REGISTER, TAG_DEC_ADDRESS, TAG_FULL_ADDRESS,	TAG_TYPE, TAG_FORMAT, TAG_PLC_FORMAT, TAG_LENGTH, TAG_ALARM&#xD;&#xA;  FROM QSYSPTMTAG&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME  = @tagset_name&#xD;&#xA;   AND TAGSET_VER   = @tagset_ver&#xD;&#xA; ORDER BY TAG_SEQ">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
            <QP N="tagset_ver" />
          </QY>
        </SG>
        <SG _S="3584" N="ListPlcTagSetTagsPaging">
          <QY P="MsSql" Q="SELECT TAG_SEQ, &#xD;&#xA;	TAG_CATEGORY, &#xD;&#xA;	TAG_NAME, &#xD;&#xA;	TAG_DESC,&#xD;&#xA;       TAG_REGISTER, 	&#xD;&#xA;	TAG_DEC_ADDRESS, &#xD;&#xA;	TAG_FULL_ADDRESS,&#xD;&#xA;	TAG_TYPE, &#xD;&#xA;	TAG_FORMAT, &#xD;&#xA;	TAG_PLC_FORMAT, &#xD;&#xA;	TAG_LENGTH,&#xD;&#xA;	TAG_ALARM&#xD;&#xA;  FROM QSYSPTMTAG&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME = @tagset_name&#xD;&#xA;   AND TAGSET_VER  = @tagset_ver&#xD;&#xA; ORDER BY TAG_SEQ&#xD;&#xA; OFFSET (CONVERT(int, @PAGE_NO)-1) * CONVERT(int, @PAGE_SIZE) ROW FETCH NEXT CONVERT(int, @PAGE_SIZE) ROW ONLY">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
            <QP N="tagset_ver" />
            <QP N="PAGE_NO" />
            <QP N="PAGE_SIZE" />
          </QY>
        </SG>
        <SG _S="3199" N="InsertPlcTagSetVersion">
          <QY P="MsSql" Q="INSERT INTO QSYSPTMVER(&#xD;&#xA;   FACTORY,   &#xD;&#xA;   TAGSET_VER,&#xD;&#xA;   TAGSET_VER_DESC,&#xD;&#xA;   TAGSET_GROUP,&#xD;&#xA;   TAGSET_NAME,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @tagset_ver,&#xD;&#xA;   @tagset_ver_desc,&#xD;&#xA;   @tagset_group,&#xD;&#xA;   @tagset_name,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;   )">
            <QP N="factory" />
            <QP N="tagset_ver" />
            <QP N="tagset_ver_desc" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="3200" N="InsertPlcTagSetTag">
          <QY P="MsSql" Q="INSERT INTO QSYSPTMTAG (&#xD;&#xA;   FACTORY,&#xD;&#xA;   TAGSET_GROUP,&#xD;&#xA;   TAGSET_NAME,&#xD;&#xA;   TAGSET_VER,&#xD;&#xA;   TAG_SEQ,&#xD;&#xA;   TAG_CATEGORY,&#xD;&#xA;   TAG_NAME,&#xD;&#xA;   TAG_DESC,&#xD;&#xA;   TAG_REGISTER,&#xD;&#xA;   TAG_DEC_ADDRESS,&#xD;&#xA;   TAG_FULL_ADDRESS,&#xD;&#xA;   TAG_TYPE,&#xD;&#xA;   TAG_FORMAT,&#xD;&#xA;   TAG_PLC_FORMAT,&#xD;&#xA;   TAG_LENGTH,&#xD;&#xA;   TAG_ALARM,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @tagset_group,&#xD;&#xA;   @tagset_name,&#xD;&#xA;   @tagset_ver,&#xD;&#xA;   @tag_seq,&#xD;&#xA;   @tag_category,&#xD;&#xA;   @tag_name,&#xD;&#xA;   @tag_desc,&#xD;&#xA;   @tag_register,&#xD;&#xA;   @tag_dec_address,&#xD;&#xA;   @tag_full_address,&#xD;&#xA;   @tag_type,&#xD;&#xA;   @tag_format,&#xD;&#xA;   @tag_plc_format,&#xD;&#xA;   @tag_length,&#xD;&#xA;   @tag_alarm,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time&#xD;&#xA;   )">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
            <QP N="tagset_ver" />
            <QP N="tag_seq" />
            <QP N="tag_category" />
            <QP N="tag_name" />
            <QP N="tag_desc" />
            <QP N="tag_register" />
            <QP N="tag_dec_address" />
            <QP N="tag_full_address" />
            <QP N="tag_type" />
            <QP N="tag_format" />
            <QP N="tag_plc_format" />
            <QP N="tag_length" />
            <QP N="tag_alarm" />
            <QP N="create_user_id" />
            <QP N="create_time" />
          </QY>
        </SG>
        <SG _S="3203" N="UpdateLastPlcTagSetVersion">
          <QY P="MsSql" Q="UPDATE QSYSPTMDEF SET&#xD;&#xA;   TAGSET_LAST_VER  = @tagset_ver&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME  = @tagset_name">
            <QP N="tagset_ver" />
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
          </QY>
        </SG>
        <SG _S="3201" N="DeletePlcTagSetVersion">
          <QY P="MsSql" Q="DELETE &#xD;&#xA;  FROM QSYSPTMVER&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME = @tagset_name&#xD;&#xA;   AND TAGSET_VER  = @tagset_ver">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
            <QP N="tagset_ver" />
          </QY>
        </SG>
        <SG _S="3202" N="DeletePlcTagSetTag">
          <QY P="MsSql" Q="DELETE &#xD;&#xA;  FROM QSYSPTMTAG&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME = @tagset_name&#xD;&#xA;   AND TAGSET_VER  = @tagset_ver">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
            <QP N="tagset_ver" />
          </QY>
        </SG>
        <SG _S="3628" N="InsertPtmHistory">
          <QY P="MsSql" Q="INSERT INTO QSYSPTMHIS (&#xD;&#xA;   FACTORY,&#xD;&#xA;   TAGSET_VER,&#xD;&#xA;   TAGSET_GROUP,	&#xD;&#xA;   TAGSET_NAME,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   EVENT_ID,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT      &#xD;&#xA;) &#xD;&#xA;VALUES( &#xD;&#xA;   @factory,&#xD;&#xA;   @tagset_ver,&#xD;&#xA;   @tagset_group,&#xD;&#xA;   @tagset_name,&#xD;&#xA;   @hist_seq,&#xD;&#xA;   @event_id,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @tran_user_id,&#xD;&#xA;   @tran_comment&#xD;&#xA;);">
            <QP N="factory" />
            <QP N="tagset_ver" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
            <QP N="hist_seq" />
            <QP N="event_id" />
            <QP N="tran_time" />
            <QP N="tran_user_id" />
            <QP N="tran_comment" />
          </QY>
        </SG>
        <SG _S="3629" N="InsertPlcTagSetTagHistory">
          <QY P="MsSql" Q="INSERT INTO QSYSPTMTHS (&#xD;&#xA;   FACTORY,&#xD;&#xA;   TAGSET_GROUP,&#xD;&#xA;   TAGSET_NAME,&#xD;&#xA;   TAGSET_VER,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   TAG_SEQ,&#xD;&#xA;   TAG_CATEGORY,&#xD;&#xA;   TAG_NAME,&#xD;&#xA;   TAG_DESC,&#xD;&#xA;   TAG_REGISTER,&#xD;&#xA;   TAG_DEC_ADDRESS,&#xD;&#xA;   TAG_FULL_ADDRESS,&#xD;&#xA;   TAG_TYPE,&#xD;&#xA;   TAG_FORMAT,&#xD;&#xA;   TAG_PLC_FORMAT,&#xD;&#xA;   TAG_LENGTH,&#xD;&#xA;   TAG_ALARM,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @tagset_group,&#xD;&#xA;   @tagset_name,&#xD;&#xA;   @tagset_ver,&#xD;&#xA;   @hist_seq,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @tag_seq,&#xD;&#xA;   @tag_category,&#xD;&#xA;   @tag_name,&#xD;&#xA;   @tag_desc,&#xD;&#xA;   @tag_register,&#xD;&#xA;   @tag_dec_address,&#xD;&#xA;   @tag_full_address,&#xD;&#xA;   @tag_type,&#xD;&#xA;   @tag_format,&#xD;&#xA;   @tag_plc_format,&#xD;&#xA;   @tag_length,&#xD;&#xA;   @tag_alarm,&#xD;&#xA;   @tran_user_id,&#xD;&#xA;   @tran_comment&#xD;&#xA;   )">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
            <QP N="tagset_ver" />
            <QP N="hist_seq" />
            <QP N="tran_time" />
            <QP N="tag_seq" />
            <QP N="tag_category" />
            <QP N="tag_name" />
            <QP N="tag_desc" />
            <QP N="tag_register" />
            <QP N="tag_dec_address" />
            <QP N="tag_full_address" />
            <QP N="tag_type" />
            <QP N="tag_format" />
            <QP N="tag_plc_format" />
            <QP N="tag_length" />
            <QP N="tag_alarm" />
            <QP N="tran_user_id" />
            <QP N="tran_comment" />
          </QY>
        </SG>
        <SG _S="3645" N="UpdatePlcTagSetVersionDeleteFlag">
          <QY P="MsSql" Q="UPDATE QSYSPTMVER SET&#xD;&#xA;   DELETE_FLAG      = 'Y',&#xD;&#xA;   UPDATE_USER_ID   = @update_user_id,&#xD;&#xA;   UPDATE_TIME      = @update_time&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME  = @tagset_name&#xD;&#xA;   AND TAGSET_VER   = @tagset_ver">
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
            <QP N="tagset_ver" />
          </QY>
        </SG>
        <SG _S="3681" N="ListPlcTagSetTagAttr">
          <QY P="MsSql" Q="SELECT TAG_NAME, ATTR_NAME, ATTR_VALUE&#xD;&#xA;  FROM QSYSPTMTAR&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME  = @tagset_name&#xD;&#xA;   AND TAGSET_VER   = @tagset_ver">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
            <QP N="tagset_ver" />
          </QY>
        </SG>
        <SG _S="3682" N="InsertPlcTagSetTagAttr">
          <QY P="MsSql" Q="INSERT INTO QSYSPTMTAR (&#xD;&#xA;   FACTORY,&#xD;&#xA;   TAGSET_GROUP,&#xD;&#xA;   TAGSET_NAME,&#xD;&#xA;   TAGSET_VER,&#xD;&#xA;   TAG_NAME,&#xD;&#xA;   ATTR_NAME,&#xD;&#xA;   ATTR_VALUE,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   CREATE_USER_ID&#xD;&#xA;   ) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @tagset_group,&#xD;&#xA;   @tagset_name,&#xD;&#xA;   @tagset_ver,&#xD;&#xA;   @tag_name,&#xD;&#xA;   @attr_name,&#xD;&#xA;   @attr_value,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time&#xD;&#xA;   )">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
            <QP N="tagset_ver" />
            <QP N="tag_name" />
            <QP N="attr_name" />
            <QP N="attr_value" />
            <QP N="create_user_id" />
            <QP N="create_time" />
          </QY>
        </SG>
      </F>
      <F _S="3305" N="CustomRemoteCommand">
        <SG _S="3306" N="HasCommand">
          <QY P="MsSql" Q="SELECT COMMAND&#xD;&#xA;  FROM QRASCUSRCM&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND COMMAND = @command">
            <QP N="factory" />
            <QP N="command" />
          </QY>
        </SG>
        <SG _S="3307" N="ListCommand">
          <QY P="MsSql" Q="SELECT COMMAND, CMD_DESC, CREATE_TIME&#xD;&#xA;  FROM QRASCUSRCM&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY COMMAND">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3308" N="SearchCommand">
          <QY P="MsSql" Q="SELECT COMMAND, CMD_DESC, &#xD;&#xA;       DATA_1_PRT, DATA_2_PRT, DATA_3_PRT, DATA_4_PRT, DATA_5_PRT, &#xD;&#xA;       DATA_6_PRT, DATA_7_PRT, DATA_8_PRT, DATA_9_PRT, DATA_10_PRT,&#xD;&#xA;       DATA_11_PRT, DATA_12_PRT, DATA_13_PRT, DATA_14_PRT, DATA_15_PRT, &#xD;&#xA;       DATA_16_PRT, DATA_17_PRT, DATA_18_PRT, DATA_19_PRT, DATA_20_PRT,&#xD;&#xA;       CREATE_TIME&#xD;&#xA;  FROM QRASCUSRCM&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND COMMAND = @command&#xD;&#xA; ORDER BY COMMAND">
            <QP N="factory" />
            <QP N="command" />
          </QY>
        </SG>
        <SG _S="3309" N="InsertCommand">
          <QY P="MsSql" Q="INSERT INTO QRASCUSRCM (&#xD;&#xA;   FACTORY,&#xD;&#xA;   COMMAND,&#xD;&#xA;   CMD_DESC,&#xD;&#xA;   DATA_1_PRT,&#xD;&#xA;   DATA_2_PRT,&#xD;&#xA;   DATA_3_PRT,&#xD;&#xA;   DATA_4_PRT,&#xD;&#xA;   DATA_5_PRT,&#xD;&#xA;   DATA_6_PRT,&#xD;&#xA;   DATA_7_PRT,&#xD;&#xA;   DATA_8_PRT,&#xD;&#xA;   DATA_9_PRT,&#xD;&#xA;   DATA_10_PRT,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @command,&#xD;&#xA;   @cmd_desc,&#xD;&#xA;   @data_1_prt,&#xD;&#xA;   @data_2_prt,&#xD;&#xA;   @data_3_prt,&#xD;&#xA;   @data_4_prt,&#xD;&#xA;   @data_5_prt,&#xD;&#xA;   @data_6_prt,&#xD;&#xA;   @data_7_prt,&#xD;&#xA;   @data_8_prt,&#xD;&#xA;   @data_9_prt,&#xD;&#xA;   @data_10_prt,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="command" />
            <QP N="cmd_desc" />
            <QP N="data_1_prt" />
            <QP N="data_2_prt" />
            <QP N="data_3_prt" />
            <QP N="data_4_prt" />
            <QP N="data_5_prt" />
            <QP N="data_6_prt" />
            <QP N="data_7_prt" />
            <QP N="data_8_prt" />
            <QP N="data_9_prt" />
            <QP N="data_10_prt" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="3310" N="UpdateCommand">
          <QY P="MsSql" Q="UPDATE QRASCUSRCM SET&#xD;&#xA;  CMD_DESC        = @cmd_desc,&#xD;&#xA;  DATA_1_PRT      = @data_1_prt,&#xD;&#xA;  DATA_2_PRT      = @data_2_prt,&#xD;&#xA;  DATA_3_PRT      = @data_3_prt,&#xD;&#xA;  DATA_4_PRT      = @data_4_prt,&#xD;&#xA;  DATA_5_PRT      = @data_5_prt,&#xD;&#xA;  DATA_6_PRT      = @data_6_prt,&#xD;&#xA;  DATA_7_PRT      = @data_7_prt,&#xD;&#xA;  DATA_8_PRT      = @data_8_prt,&#xD;&#xA;  DATA_9_PRT      = @data_9_prt,&#xD;&#xA;  DATA_10_PRT     = @data_10_prt,&#xD;&#xA;  UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;  UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND COMMAND    = @command">
            <QP N="cmd_desc" />
            <QP N="data_1_prt" />
            <QP N="data_2_prt" />
            <QP N="data_3_prt" />
            <QP N="data_4_prt" />
            <QP N="data_5_prt" />
            <QP N="data_6_prt" />
            <QP N="data_7_prt" />
            <QP N="data_8_prt" />
            <QP N="data_9_prt" />
            <QP N="data_10_prt" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="command" />
          </QY>
        </SG>
        <SG _S="3311" N="DeleteCommand">
          <QY P="MsSql" Q="DELETE &#xD;&#xA;  FROM QRASCUSRCM&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND COMMAND = @command">
            <QP N="factory" />
            <QP N="command" />
          </QY>
        </SG>
      </F>
      <F _S="3455" N="Branch">
        <SG _S="3456" N="SearchEapAppliedModel">
          <QY P="MsSql" Q="SELECT MODEL, MDL_VER&#xD;&#xA;  FROM QRASEAPATR&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EAP = &#xD;&#xA;       (&#xD;&#xA;SELECT EAP&#xD;&#xA;  FROM QRASEQPDEF&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND EQP_NAME      = @eqp_name&#xD;&#xA;   AND DELETE_FLAG   = 'N'&#xD;&#xA;       )&#xD;&#xA;   AND ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="attr_category" />
          </QY>
        </SG>
        <SG _S="3458" N="SearchEapAppliedModelTag">
          <QY P="MsSql" Q="SELECT CNT_NAME, CNT_RK, PLC_TAG_ADDR AS TAG_ADDR, TAG_NAME, TAG_DESC, PLC_TAG_TYPE, PLC_TAG_FORMAT&#xD;&#xA;  FROM QRASMDLPTG&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND MODEL    = @model&#xD;&#xA;   AND MDL_VER  = @mdl_ver&#xD;&#xA; ORDER BY CNT_NAME, PLC_TAG_ADDR">
            <QP N="factory" />
            <QP N="model" />
            <QP N="mdl_ver" />
          </QY>
        </SG>
        <SG _S="3621" N="SearchTagAlias">
          <QY P="MsSql" Q="SELECT IBN_NAME, TAG_ADDR, TAG_ADDR_ALIAS&#xD;&#xA;  FROM QBWSIBNPTA&#xD;&#xA; WHERE FACTORY  = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3457" N="SearchBranchEquipmentModel">
          <QY P="MsSql" Q="SELECT CONCAT ('Active,', TAGSET_VER, ',', BUILD_MDL, ',', BUILD_MDL_VER) AS VER_INFO&#xD;&#xA;  FROM QBWSIBNVER&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND IBN_NAME   = @ibn_name&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;   AND TAGSET_VER = &#xD;&#xA;       (&#xD;&#xA;SELECT ACTIVE_VER&#xD;&#xA;  FROM QBWSIBNEQP&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND IBN_NAME   = @ibn_name&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;       )&#xD;&#xA; UNION ALL&#xD;&#xA;SELECT CONCAT ('Last,', TAGSET_VER, ',', BUILD_MDL, ',', BUILD_MDL_VER) AS VER_INFO&#xD;&#xA;  FROM QBWSIBNVER&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND IBN_NAME   = @ibn_name&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;   AND TAGSET_VER = &#xD;&#xA;       (&#xD;&#xA;SELECT LAST_VER&#xD;&#xA;  FROM QBWSIBNEQP&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND IBN_NAME   = @ibn_name&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;       )&#xD;&#xA; UNION ALL&#xD;&#xA;SELECT CONCAT ('Applied,', TAGSET_VER, ',', BUILD_MDL, ',', BUILD_MDL_VER) AS VER_INFO&#xD;&#xA;  FROM QBWSIBNVER&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND IBN_NAME   = @ibn_name&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;   AND TAGSET_VER = &#xD;&#xA;       (&#xD;&#xA;SELECT APPLIED_VER&#xD;&#xA;  FROM QBWSIBNEQP&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND IBN_NAME   = @ibn_name&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;       )">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="3480" N="SearchBranchEquipmentModelTag">
          <QY P="MsSql" Q="SELECT IBN.CNT_NAME, IBN.CNT_RK, IBN.TAG_ADDR, IBN.TAG_ADDR_ALIAS,&#xD;&#xA;       MDL.TAG_NAME, MDL.TAG_DESC, MDL.PLC_TAG_TYPE, MDL.PLC_TAG_FORMAT&#xD;&#xA;  FROM &#xD;&#xA;     (&#xD;&#xA;SELECT VER.FACTORY, VER.BUILD_MDL, VER.BUILD_MDL_VER, TAG.CNT_RK, TAG.CNT_NAME, TAG.TAG_ADDR, TAG.TAG_ADDR_ALIAS&#xD;&#xA;  FROM QBWSIBNVER VER&#xD;&#xA;  LEFT JOIN QBWSIBNPTG TAG&#xD;&#xA;    ON VER.FACTORY    = TAG.FACTORY &#xD;&#xA;   AND VER.IBN_NAME   = TAG.IBN_NAME&#xD;&#xA;   AND VER.EQP_NAME   = TAG.EQP_NAME&#xD;&#xA;   AND VER.TAGSET_VER = TAG.TAGSET_VER&#xD;&#xA; WHERE VER.FACTORY    = @factory&#xD;&#xA;   AND VER.IBN_NAME   = @ibn_name&#xD;&#xA;   AND VER.EQP_NAME   = @eqp_name&#xD;&#xA;   AND VER.TAGSET_VER = @tagset_ver&#xD;&#xA;     ) IBN&#xD;&#xA;  LEFT JOIN QRASMDLPTG MDL&#xD;&#xA;    ON IBN.FACTORY       = MDL.FACTORY&#xD;&#xA;   AND IBN.BUILD_MDL     = MDL.MODEL&#xD;&#xA;   AND IBN.BUILD_MDL_VER = MDL.MDL_VER&#xD;&#xA;   AND IBN.CNT_RK        = MDL.CNT_RK&#xD;&#xA;   AND IBN.TAG_ADDR      = MDL.PLC_TAG_ADDR&#xD;&#xA; ORDER BY IBN.CNT_NAME, IBN.TAG_ADDR">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
            <QP N="tagset_ver" />
          </QY>
        </SG>
        <SG _S="3473" N="InsertBranch">
          <QY P="MsSql" Q="INSERT INTO QBWSIBNDEF (&#xD;&#xA;   FACTORY,&#xD;&#xA;   IBN_NAME,&#xD;&#xA;   IBN_DESC,&#xD;&#xA;   PROTOCOL,&#xD;&#xA;   PROTOCOL_ATTR,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @ibn_name,&#xD;&#xA;   @ibn_desc,&#xD;&#xA;   @protocol,&#xD;&#xA;   @protocol_attr,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="ibn_desc" />
            <QP N="protocol" />
            <QP N="protocol_attr" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="3540" N="InsertBranchEquipmentTagForClone">
          <QY P="MsSql" Q="INSERT INTO QBWSIBNPTG(&#xD;&#xA;   FACTORY,&#xD;&#xA;   IBN_NAME,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   TAGSET_VER,&#xD;&#xA;   CNT_RK,&#xD;&#xA;   CNT_NAME,&#xD;&#xA;   TAG_ADDR,&#xD;&#xA;   TAG_ADDR_ALIAS,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) &#xD;&#xA;SELECT &#xD;&#xA;   FACTORY, &#xD;&#xA;   @ibn_name,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   @tagset_ver,&#xD;&#xA;   CNT_RK,&#xD;&#xA;   CNT_NAME,&#xD;&#xA;   TAG_ADDR,&#xD;&#xA;   TAG_ADDR_ALIAS,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;  FROM QBWSIBNPTG&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND IBN_NAME   = @ref_ibn_name&#xD;&#xA;   AND EQP_NAME   = @ref_eqp_name&#xD;&#xA;   AND TAGSET_VER = @ref_tagset_ver">
            <QP N="ibn_name" />
            <QP N="tagset_ver" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="ref_ibn_name" />
            <QP N="ref_eqp_name" />
            <QP N="ref_tagset_ver" />
          </QY>
        </SG>
        <SG _S="3541" N="InsertBranchEquipmentVersionForClone">
          <QY P="MsSql" Q="INSERT INTO QBWSIBNVER(&#xD;&#xA;   FACTORY,&#xD;&#xA;   IBN_NAME,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   TAGSET_VER,&#xD;&#xA;   TAGSET_VER_DESC,&#xD;&#xA;   ACTIVE,&#xD;&#xA;   BUILD_MDL,&#xD;&#xA;   BUILD_MDL_VER,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) &#xD;&#xA;SELECT &#xD;&#xA;   FACTORY,&#xD;&#xA;   @ibn_name,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   @tagset_ver,&#xD;&#xA;   @tagset_ver_desc,&#xD;&#xA;   @active,&#xD;&#xA;   BUILD_MDL,&#xD;&#xA;   BUILD_MDL_VER,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;  FROM QBWSIBNVER&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND IBN_NAME   = @ref_ibn_name&#xD;&#xA;   AND EQP_NAME   = @ref_eqp_name&#xD;&#xA;   AND TAGSET_VER = @ref_tagset_ver">
            <QP N="ibn_name" />
            <QP N="tagset_ver" />
            <QP N="tagset_ver_desc" />
            <QP N="active" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="ref_ibn_name" />
            <QP N="ref_eqp_name" />
            <QP N="ref_tagset_ver" />
          </QY>
        </SG>
        <SG _S="3475" N="UpdateBranch">
          <QY P="MsSql" Q="UPDATE QBWSIBNDEF SET&#xD;&#xA;  IBN_DESC           = @ibn_desc,&#xD;&#xA;  PROTOCOL           = @protocol,&#xD;&#xA;  PROTOCOL_ATTR      = @protocol_attr,&#xD;&#xA;  UPDATE_USER_ID     = @update_user_id,&#xD;&#xA;  UPDATE_TIME        = @update_time&#xD;&#xA; WHERE FACTORY       = @factory&#xD;&#xA;   AND IBN_NAME      = @ibn_name">
            <QP N="ibn_desc" />
            <QP N="protocol" />
            <QP N="protocol_attr" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
        <SG _S="3478" N="ListBranchEquipmentVersion">
          <QY P="MsSql" Q="SELECT TAGSET_VER, TAGSET_VER_DESC, ACTIVE, BUILD_MDL, BUILD_MDL_VER&#xD;&#xA;  FROM QBWSIBNVER&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND IBN_NAME = @ibn_name&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA; ORDER BY TAGSET_VER DESC">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="3472" N="ListBranch">
          <QY P="MsSql" Q="SELECT IBN_NAME, IBN_DESC, PROTOCOL, PROTOCOL_ATTR&#xD;&#xA;  FROM QBWSIBNDEF&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA; ORDER BY IBN_NAME">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3537" N="SearchReferenceBranch">
          <QY P="MsSql" Q="SELECT IBN_DESC, PROTOCOL, PROTOCOL_ATTR&#xD;&#xA;  FROM QBWSIBNDEF&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND IBN_NAME  = @ibn_name">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
        <SG _S="3500" N="ListBranchEquipment">
          <QY P="MsSql" Q="SELECT IBN.EQP_NAME, ISNULL(EQP.EQP_DESC, ' ') EQP_DESC, IBN.ENABLE, IBN.NEED_ACTION, IBN.ACTIVE_VER, IBN.APPLIED_VER, IBN.LAST_VER&#xD;&#xA;  FROM QBWSIBNEQP IBN&#xD;&#xA;  LEFT JOIN QRASEQPDEF EQP&#xD;&#xA;    ON IBN.FACTORY  = EQP.FACTORY&#xD;&#xA;   AND IBN.EQP_NAME =  EQP.EQP_NAME&#xD;&#xA; WHERE IBN.FACTORY  = @factory&#xD;&#xA;   AND IBN.IBN_NAME = @ibn_name&#xD;&#xA; ORDER BY IBN.EQP_NAME">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
        <SG _S="3538" N="SearchReferenceBranchEquipment">
          <QY P="MsSql" Q="SELECT IBN.EQP_NAME, ISNULL(EQP.EQP_DESC, ' ') EQP_DESC, IBN.ACTIVE_VER, IBN.APPLIED_VER, IBN.LAST_VER&#xD;&#xA;  FROM QBWSIBNEQP IBN&#xD;&#xA;  LEFT JOIN QRASEQPDEF EQP&#xD;&#xA;    ON IBN.FACTORY  = EQP.FACTORY&#xD;&#xA;   AND IBN.EQP_NAME = EQP.EQP_NAME&#xD;&#xA; WHERE IBN.FACTORY  = @factory&#xD;&#xA;   AND IBN.IBN_NAME = @ibn_name&#xD;&#xA; ORDER BY IBN.EQP_NAME">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
        <SG _S="3471" N="ListBranchEquipmentTag">
          <QY P="MsSql" Q="SELECT IBN.CNT_NAME, IBN.CNT_RK, IBN.TAG_ADDR, IBN.TAG_ADDR_ALIAS,&#xD;&#xA;       MDL.TAG_NAME, MDL.TAG_DESC, MDL.PLC_TAG_TYPE, MDL.PLC_TAG_FORMAT&#xD;&#xA;  FROM &#xD;&#xA;     (&#xD;&#xA;SELECT VER.FACTORY, VER.BUILD_MDL, VER.BUILD_MDL_VER, TAG.CNT_RK, TAG.CNT_NAME, TAG.TAG_ADDR, TAG.TAG_ADDR_ALIAS&#xD;&#xA;  FROM QBWSIBNVER VER&#xD;&#xA;  LEFT JOIN QBWSIBNPTG TAG&#xD;&#xA;    ON VER.FACTORY    = TAG.FACTORY &#xD;&#xA;   AND VER.IBN_NAME   = TAG.IBN_NAME&#xD;&#xA;   AND VER.EQP_NAME   = TAG.EQP_NAME&#xD;&#xA;   AND VER.TAGSET_VER = TAG.TAGSET_VER&#xD;&#xA; WHERE VER.FACTORY    = @factory&#xD;&#xA;   AND VER.IBN_NAME   = @ibn_name&#xD;&#xA;   AND VER.EQP_NAME   = @eqp_name&#xD;&#xA;   AND VER.TAGSET_VER = @tagset_ver&#xD;&#xA;     ) IBN&#xD;&#xA;  LEFT JOIN QRASMDLPTG MDL&#xD;&#xA;    ON IBN.FACTORY       = MDL.FACTORY&#xD;&#xA;   AND IBN.BUILD_MDL     = MDL.MODEL&#xD;&#xA;   AND IBN.BUILD_MDL_VER = MDL.MDL_VER&#xD;&#xA;   AND IBN.CNT_RK        = MDL.CNT_RK&#xD;&#xA;   AND IBN.TAG_ADDR      = MDL.PLC_TAG_ADDR&#xD;&#xA; ORDER BY IBN.CNT_NAME, IBN.TAG_ADDR">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
            <QP N="tagset_ver" />
          </QY>
        </SG>
        <SG _S="3461" N="HasBranch">
          <QY P="MsSql" Q="SELECT IBN_NAME, IBN_DESC, PROTOCOL, PROTOCOL_ATTR&#xD;&#xA;  FROM QBWSIBNDEF&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND IBN_NAME = @ibn_name">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
        <SG _S="3539" N="HasBranchEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME, ACTIVE_VER&#xD;&#xA;  FROM QBWSIBNEQP&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND IBN_NAME = @ibn_name">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
        <SG _S="3474" N="DeleteBranch">
          <QY P="MsSql" Q="DELETE&#xD;&#xA;  FROM QBWSIBNDEF&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND IBN_NAME = @ibn_name">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
        <SG _S="3635" N="DeleteBranchPlcTagAlias">
          <QY P="MsSql" Q="DELETE&#xD;&#xA;  FROM QBWSIBNPTA&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND IBN_NAME = @ibn_name">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
        <SG _S="3476" N="UpdateEquipmentNeedAction">
          <QY P="MsSql" Q="UPDATE QBWSIBNEQP SET&#xD;&#xA;   NEED_ACTION      = @need_action,&#xD;&#xA;   UPDATE_USER_ID   = @update_user_id,&#xD;&#xA;   UPDATE_TIME      = @update_time&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND IBN_NAME     = @ibn_name&#xD;&#xA;   AND NEED_ACTION &lt;&gt; @need_action_execlude">
            <QP N="need_action" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="need_action_execlude" />
          </QY>
        </SG>
        <SG _S="3542" N="InsertBranchEquipmentForClone">
          <QY P="MsSql" Q="INSERT INTO QBWSIBNEQP(&#xD;&#xA;   FACTORY,&#xD;&#xA;   IBN_NAME,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   ENABLE,&#xD;&#xA;   NEED_ACTION,&#xD;&#xA;   APPLIED_VER,&#xD;&#xA;   ACTIVE_VER,&#xD;&#xA;   LAST_VER,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @ibn_name,&#xD;&#xA;   @eqp_name,&#xD;&#xA;   @enable,&#xD;&#xA;   @need_action,&#xD;&#xA;   @applied_ver,&#xD;&#xA;   @active_ver,&#xD;&#xA;   @last_ver,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
            <QP N="enable" />
            <QP N="need_action" />
            <QP N="applied_ver" />
            <QP N="active_ver" />
            <QP N="last_ver" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
      </F>
      <F _S="3486" N="BranchEquipment">
        <SG _S="3488" N="DeleteBranchEquipmentTag">
          <QY P="MsSql" Q="DELETE &#xD;&#xA;  FROM QBWSIBNPTG&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND IBN_NAME   = @ibn_name&#xD;&#xA;   AND EQP_NAME   = @eqp_name">
