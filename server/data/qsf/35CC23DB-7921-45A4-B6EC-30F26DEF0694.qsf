        <SG _S="3671" N="InsertPreset">
          <QY P="MsSql" Q="INSERT INTO QSYSPTMPRS (&#xD;&#xA;   FACTORY,&#xD;&#xA;   PRESET_GROUP,&#xD;&#xA;   PRESET_NAME,&#xD;&#xA;   PRESET_CATEGORY,&#xD;&#xA;   PRESET_DESC,&#xD;&#xA;   PRESET_PLC_MAKER,&#xD;&#xA;   PRESET_PLC_MODEL,&#xD;&#xA;   ADDRESS_RADIX,&#xD;&#xA;   ALLOW_EMPTY_ADDRESS,&#xD;&#xA;   IS_ALARM,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;   ) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @preset_group,&#xD;&#xA;   @preset_name,&#xD;&#xA;   @preset_desc,&#xD;&#xA;   @preset_category,&#xD;&#xA;   @preset_plc_maker,&#xD;&#xA;   @preset_plc_model,&#xD;&#xA;   @address_radix,&#xD;&#xA;   @allow_empty_address,&#xD;&#xA;   @is_alarm,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;   )">
            <QP N="factory" />
            <QP N="preset_group" />
            <QP N="preset_name" />
            <QP N="preset_desc" />
            <QP N="preset_category" />
