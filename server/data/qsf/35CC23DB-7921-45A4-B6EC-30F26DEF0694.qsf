        <SG _S="3494" N="UpdateBranchEquipmentVersionInactive">
          <QY P="MsSql" Q="UPDATE QBWSIBNVER SET&#xD;&#xA;   ACTIVE         = @active_no,&#xD;&#xA;   UPDATE_USER_ID = @update_user_id,&#xD;&#xA;   UPDATE_TIME    = @update_time&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND IBN_NAME   = @ibn_name&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;   AND ACTIVE     = @active_yes">
            <QP N="active_no" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
            <QP N="active_yes" />
          </QY>
