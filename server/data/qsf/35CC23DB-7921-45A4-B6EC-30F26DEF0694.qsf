        <SG _S="3675" N="InsertPresetTag">
          <QY P="MsSql" Q="INSERT INTO QSYSPTMPTG(&#xD;&#xA;   FACTORY,&#xD;&#xA;   PRESET_GROUP,&#xD;&#xA;   PRESET_NAME,&#xD;&#xA;   TAG_SEQ,&#xD;&#xA;   TAG_NAME,&#xD;&#xA;   TAG_DESC,&#xD;&#xA;   TAG_REGISTER,&#xD;&#xA;   TAG_DEC_ADDRESS,&#xD;&#xA;   TAG_FULL_ADDRESS,&#xD;&#xA;   TAG_TYPE,&#xD;&#xA;   TAG_FORMAT,&#xD;&#xA;   TAG_PLC_FORMAT,&#xD;&#xA;   TAG_LENGTH,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @preset_group,&#xD;&#xA;   @preset_name,&#xD;&#xA;   @tag_seq,&#xD;&#xA;   @tag_name,&#xD;&#xA;   @tag_desc,&#xD;&#xA;   @tag_register,&#xD;&#xA;   @tag_dec_address,&#xD;&#xA;   @tag_full_address,&#xD;&#xA;   @tag_type,&#xD;&#xA;   @tag_format,&#xD;&#xA;   @tag_plc_format,&#xD;&#xA;   @tag_length,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;   )">
            <QP N="factory" />
