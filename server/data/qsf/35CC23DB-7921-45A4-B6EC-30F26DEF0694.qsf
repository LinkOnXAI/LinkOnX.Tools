        </SG>
        <SG _S="3525" N="HasBranchEquipment">
          <QY P="MsSql" Q="SELECT ENABLE, ACTIVE_VER, NEED_ACTION&#xD;&#xA;  FROM QBWSIBNEQP&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND IBN_NAME    = @ibn_name&#xD;&#xA;   AND EQP_NAME    = @eqp_name">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="3526" N="HasBranchTag">
          <QY P="MsSql" Q="WITH VersionData AS (&#xD;&#xA; SELECT V.FACTORY, V.BUILD_MDL, V.BUILD_MDL_VER, T.CNT_RK, T.CNT_NAME, T.TAG_ADDR, T.TAG_ADDR_ALIAS&#xD;&#xA;   FROM QBWSIBNVER V&#xD;&#xA;   LEFT JOIN QBWSIBNPTG T&#xD;&#xA;     ON V.FACTORY    = T.FACTORY&#xD;&#xA;    AND V.IBN_NAME   = T.IBN_NAME&#xD;&#xA;    AND V.EQP_NAME   = T.EQP_NAME&#xD;&#xA;    AND V.TAGSET_VER = T.TAGSET_VER&#xA;  WHERE V.FACTORY    = @factory&#xD;&#xA;    AND V.IBN_NAME   = @ibn_name&#xD;&#xA;    AND V.EQP_NAME   = @eqp_name&#xD;&#xA;    AND V.TAGSET_VER = @tagset_ver&#xA;)&#xD;&#xA;SELECT IBN.CNT_RK, IBN.CNT_NAME, IBN.TAG_ADDR, IBN.TAG_ADDR_ALIAS, MDL.PLC_TAG_FORMAT, MDL.TAG_FORMAT&#xD;&#xA;  FROM VersionData IBN&#xD;&#xA;  LEFT JOIN QRASMDLPTG MDL&#xD;&#xA;    ON IBN.FACTORY       = MDL.FACTORY&#xD;&#xA;   AND IBN.BUILD_MDL     = MDL.MODEL&#xD;&#xA;   AND IBN.BUILD_MDL_VER = MDL.MDL_VER&#xD;&#xA;   AND IBN.CNT_RK        = MDL.CNT_RK&#xD;&#xA;   AND IBN.TAG_ADDR      = MDL.PLC_TAG_ADDR">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
            <QP N="tagset_ver&#xA;" />
          </QY>
        </SG>
        <SG _S="3527" N="HasEquipment">
          <QY P="MsSql" Q="SELECT EQP.EQP_NAME, EQP.EAP, EAP.SERVER, EAP.EAP_TYPE, EAP.STATUS&#xD;&#xA;  FROM QRASEQPDEF AS EQP&#xD;&#xA;   LEFT JOIN QRASEAPDEF AS EAP&#xD;&#xA;    ON EQP.FACTORY     = EAP.FACTORY&#xD;&#xA;   AND EQP.EAP         = EAP.EAP&#xD;&#xA;   AND EAP.DELETE_FLAG = 'N'&#xD;&#xA; WHERE EQP.FACTORY     = @factory&#xD;&#xA;   AND EQP.EQP_NAME    = @eqp_name&#xD;&#xA;   AND EQP.DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="3575" N="HasServer">
          <QY P="MsSql" Q="SELECT A.SVR_IP, A.UP_DOWN, A.STATUS, A.EAS_UP_DOWN,&#xD;&#xA;       A.B_SERVER, A.B_UP_DOWN, A.B_STATUS, A.B_EAS_UP_DOWN, ISNULL(B.SVR_IP, '') B_SVR_IP&#xD;&#xA;  FROM QSYSSVRDEF A&#xD;&#xA;  LEFT JOIN QSYSSVRDEF B&#xD;&#xA;    ON A.FACTORY     = B.FACTORY&#xD;&#xA;   AND A.B_SERVER    = B.SERVER&#xD;&#xA;   AND B.DELETE_FLAG = 'N'&#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.SERVER      = @server&#xD;&#xA;   AND A.DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="server" />
          </QY>
        </SG>
        <SG _S="3528" N="UpdateBranchEquipment">
          <QY P="MsSql" Q="UPDATE QBWSIBNEQP SET&#xD;&#xA;  ENABLE         = @enable,&#xD;&#xA;  NEED_ACTION    = @need_action,&#xD;&#xA;  APPLIED_VER    = @applied_ver,&#xD;&#xA;  UPDATE_USER_ID = @update_user_id,&#xD;&#xA;  UPDATE_TIME    = @update_time&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND IBN_NAME  = @ibn_name&#xD;&#xA;   AND EQP_NAME  = @eqp_name">
            <QP N="enable" />
            <QP N="need_action" />
            <QP N="applied_ver" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
          </QY>
        </SG>
      </F>
      <F _S="3529" N="EquipmentBranchDisable">
        <SG _S="3531" N="HasBranch">
          <QY P="MsSql" Q="SELECT IBN_NAME, PROTOCOL, PROTOCOL_ATTR&#xD;&#xA;  FROM QBWSIBNDEF&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND IBN_NAME = @ibn_name">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
        <SG _S="3532" N="HasBranchEquipment">
          <QY P="MsSql" Q="SELECT ENABLE, ACTIVE_VER&#xD;&#xA;  FROM QBWSIBNEQP&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND IBN_NAME    = @ibn_name&#xD;&#xA;   AND EQP_NAME    = @eqp_name">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="3533" N="HasBranchTag">
          <QY P="MsSql" Q="SELECT CNT_NAME, TAG_ADDR&#xD;&#xA;  FROM QBWSIBNPTG&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND IBN_NAME   = @ibn_name&#xD;&#xA;   AND EQP_NAME   = @eqp_name&#xD;&#xA;   AND TAGSET_VER = @tagset_ver">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
            <QP N="tagset_ver" />
          </QY>
        </SG>
        <SG _S="3534" N="HasEquipment">
          <QY P="MsSql" Q="SELECT EQP.EQP_NAME, EQP.EAP, EAP.SERVER, EAP.EAP_TYPE, EAP.STATUS&#xD;&#xA;  FROM QRASEQPDEF AS EQP&#xD;&#xA;   LEFT JOIN QRASEAPDEF AS EAP&#xD;&#xA;    ON EQP.FACTORY     = EAP.FACTORY&#xD;&#xA;   AND EQP.EAP         = EAP.EAP&#xD;&#xA;   AND EAP.DELETE_FLAG = 'N'&#xD;&#xA; WHERE EQP.FACTORY     = @factory&#xD;&#xA;   AND EQP.EQP_NAME    = @eqp_name&#xD;&#xA;   AND EQP.DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="3574" N="HasServer">
          <QY P="MsSql" Q="SELECT A.SVR_IP, A.UP_DOWN, A.STATUS, A.EAS_UP_DOWN,&#xD;&#xA;       A.B_SERVER, A.B_UP_DOWN, A.B_STATUS, A.B_EAS_UP_DOWN, ISNULL(B.SVR_IP, '') B_SVR_IP&#xD;&#xA;  FROM QSYSSVRDEF A&#xD;&#xA;  LEFT JOIN QSYSSVRDEF B&#xD;&#xA;    ON A.FACTORY     = B.FACTORY&#xD;&#xA;   AND A.B_SERVER    = B.SERVER&#xD;&#xA;   AND B.DELETE_FLAG = 'N'&#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.SERVER      = @server&#xD;&#xA;   AND A.DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="server" />
          </QY>
        </SG>
        <SG _S="3535" N="UpdateBranchEquipment">
          <QY P="MsSql" Q="UPDATE QBWSIBNEQP SET&#xD;&#xA;  ENABLE         = @enable,&#xD;&#xA;  APPLIED_VER    = @applied_ver,&#xD;&#xA;  UPDATE_USER_ID = @update_user_id,&#xD;&#xA;  UPDATE_TIME    = @update_time&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND IBN_NAME  = @ibn_name&#xD;&#xA;   AND EQP_NAME  = @eqp_name">
            <QP N="enable" />
            <QP N="applied_ver" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="688" N="View">
      <F _S="2594" N="EquipmentMonitor">
        <SG _S="2595" N="ListEquipmentType">
          <QY P="MsSql" Q="SELECT TYPE, TYPE_DESC&#xD;&#xA;  FROM QRASEQPTYP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY TYPE">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="2596" N="ListEquipmentArea">
          <QY P="MsSql" Q="SELECT AREA, AREA_DESC&#xD;&#xA;  FROM QRASEQPARE&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA; ORDER BY AREA">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="2597" N="ListEquipmentLine">
          <QY P="MsSql" Q="SELECT LINE, LINE_DESC&#xD;&#xA;  FROM QRASEQPLIN&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY LINE">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="2598" N="ListEquipment">
          <QY P="MsSql" Q="SELECT A.EQP_NAME, A.EQP_DESC, &#xD;&#xA;       ISNULL(C.EAP, 'N/A') EAP, ISNULL(C.SERVER, 'N/A') SERVER, ISNULL(C.UP_DOWN, 'N/A') UP_DOWN, ISNULL(C.STATUS, 'N/A') STATUS,&#xD;&#xA;       A.TYPE, A.AREA, A.LINE, A.MDLN, A.SOFTREV, A.CTRL_MODE, A.PRI_STATE, A.STATE, A.ALARM, A.EVENT_DEFINE, A.CMF_5 AS PLC_IP_ADDRESS&#xD;&#xA;  FROM QRASEQPDEF A&#xD;&#xA;  LEFT JOIN QRASEQPATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EQP_NAME      = B.EQP_NAME&#xD;&#xA;   AND B.ATTR_CATEGORY = @attr_category&#xD;&#xA;  LEFT JOIN QRASEAPDEF C&#xD;&#xA;    ON A.FACTORY = C.FACTORY&#xD;&#xA;   AND B.EAP     = C.EAP&#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.TYPE        = ISNULL(@type, A.TYPE)&#xD;&#xA;   AND A.AREA        = ISNULL(@area, A.AREA)&#xD;&#xA;   AND A.LINE        = ISNULL(@line, A.LINE)&#xD;&#xA;   AND A.DELETE_FLAG = 'N'">
            <QP N="attr_category" />
            <QP N="factory" />
            <QP N="type" />
            <QP N="area" />
            <QP N="line" />
          </QY>
        </SG>
        <SG _S="2599" N="SearchEquipment">
          <QY P="MsSql" Q="SELECT A.TYPE, A.AREA, A.LINE&#xD;&#xA;  FROM QRASEQPDEF A&#xD;&#xA;  LEFT JOIN QRASEQPATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EQP_NAME      = B.EQP_NAME&#xD;&#xA;  LEFT JOIN QRASEAPDEF C&#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND B.EAP           = C.EAP&#xD;&#xA;  LEFT JOIN QRASEAPATR D&#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND B.EAP           = D.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = D.ATTR_CATEGORY &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Applied'&#xD;&#xA;   AND A.EQP_NAME      LIKE @eqp_name&#xD;&#xA;   AND A.DELETE_FLAG   &lt;&gt; 'Y'&#xD;&#xA; ORDER BY &#xD;&#xA; (CASE @target&#xD;&#xA;  WHEN 'Type'  THEN A.TYPE&#xD;&#xA;  WHEN 'Area'  THEN A.AREA&#xD;&#xA;  WHEN 'Line'  THEN A.LINE&#xD;&#xA;   END)">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="target" />
          </QY>
        </SG>
      </F>
      <F _S="3245" N="DataHoundViewer">
        <SG _S="3246" N="ListDataHound">
          <QY P="MsSql" Q="SELECT NAME, STATUS, RESULT_MESSAGE, SERVER_IP, SERVER_PORT&#xD;&#xA;  FROM QSYSDHDDEF  &#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   ORDER BY NAME">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3271" N="HasDataHound">
          <QY P="MsSql" Q="SELECT NAME, STATUS    &#xD;&#xA;  FROM QSYSDHDDEF  &#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND NAME = @hound">
            <QP N="factory" />
            <QP N="hound" />
          </QY>
        </SG>
      </F>
      <F _S="3411" N="PlcTagViewer">
        <SG _S="3412" N="SelectPlcTagByModel">
          <QY P="MsSql" Q="SELECT FACTORY,&#xD;&#xA;MODEL,&#xD;&#xA;MDL_VER,&#xD;&#xA;CNT_NAME,&#xD;&#xA;SSN_NAME,&#xD;&#xA;TAG_NAME,&#xD;&#xA;TAG_DESC,&#xD;&#xA;TAG_FORMAT,&#xD;&#xA;PLC_TAG_ADDR,&#xD;&#xA;PLC_TAG_TYPE,&#xD;&#xA;PLC_TAG_MDL,&#xD;&#xA;PLC_TAG_AREA,&#xD;&#xA;PLC_TAG_FORMAT,&#xD;&#xA;PLC_TAG_START,&#xD;&#xA;PLC_TAG_LENGTH,&#xD;&#xA;PLC_TAG_ARRAY,&#xD;&#xA;PLC_TAG_CACHE,&#xD;&#xA;PLC_TAG_AL_EVENT,&#xD;&#xA;PLC_TAG_IG_FIRST,&#xD;&#xA;CREATE_USER_ID,&#xD;&#xA;CREATE_TIME,&#xD;&#xA;UPDATE_USER_ID,&#xD;&#xA;UPDATE_TIME &#xD;&#xA;FROM QRASMDLPTG &#xD;&#xA;WHERE FACTORY = @factory&#xD;&#xA; AND MODEL = @model&#xD;&#xA; AND MDL_VER = @model_ver &#xD;&#xA;ORDER BY PLC_TAG_ADDR">
            <QP N="factory" />
            <QP N="model" />
            <QP N="model_ver" />
          </QY>
        </SG>
        <SG _S="3413" N="SelectPlcTagByEap">
          <QY P="MsSql" Q="SELECT FACTORY,&#xD;&#xA;MODEL,&#xD;&#xA;MDL_VER,&#xD;&#xA;CNT_NAME,&#xD;&#xA;SSN_NAME,&#xD;&#xA;TAG_NAME,&#xD;&#xA;TAG_DESC,&#xD;&#xA;TAG_FORMAT,&#xD;&#xA;PLC_TAG_ADDR,&#xD;&#xA;PLC_TAG_TYPE,&#xD;&#xA;PLC_TAG_MDL,&#xD;&#xA;PLC_TAG_AREA,&#xD;&#xA;PLC_TAG_FORMAT,&#xD;&#xA;PLC_TAG_START,&#xD;&#xA;PLC_TAG_LENGTH,&#xD;&#xA;PLC_TAG_ARRAY,&#xD;&#xA;PLC_TAG_CACHE,&#xD;&#xA;PLC_TAG_AL_EVENT,&#xD;&#xA;PLC_TAG_IG_FIRST,&#xD;&#xA;CREATE_USER_ID,&#xD;&#xA;CREATE_TIME,&#xD;&#xA;UPDATE_USER_ID,&#xD;&#xA;UPDATE_TIME &#xD;&#xA;FROM QRASMDLPTG &#xD;&#xA;WHERE FACTORY = @factory&#xD;&#xA; AND MODEL = @model,&#xD;&#xA; AND MDL_VER = (&#xD;&#xA; 	SELECT ISNULL(MDL_VER, 0) APL_MDL_VER  &#xD;&#xA; 	FROM QRASEAPATR &#xD;&#xA; 	WHERE FACTORY = @factory &#xD;&#xA; 		AND EAP = @eap &#xD;&#xA; 		AND ATTR_CATEGORY = 'Applied'&#xD;&#xA; 	)&#xD;&#xA;ORDER BY PLC_TAG_ADDR">
            <QP N="factory" />
            <QP N="model" />
            <QP N="eap" />
          </QY>
        </SG>
      </F>
      <F _S="3544" N="BranchViewer">
        <SG _S="3546" N="ListBranch">
          <QY P="MsSql" Q="SELECT IBN_NAME, IBN_DESC, PROTOCOL, PROTOCOL_ATTR&#xD;&#xA;  FROM QBWSIBNDEF&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA; ORDER BY IBN_NAME">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3547" N="ListBranchEquipment">
          <QY P="MsSql" Q="SELECT A.EQP_NAME, ISNULL(C.EQP_DESC, ' ') EQP_DESC, A.IBN_NAME, B.PROTOCOL, A.ENABLE, A.NEED_ACTION, A.ACTIVE_VER, A.APPLIED_VER, A.LAST_VER&#xD;&#xA;  FROM QBWSIBNEQP A&#xD;&#xA;  LEFT JOIN QBWSIBNDEF B&#xD;&#xA;    ON A.FACTORY  = B.FACTORY&#xD;&#xA;   AND A.IBN_NAME = B.IBN_NAME&#xD;&#xA;  LEFT JOIN QRASEQPDEF C&#xD;&#xA;    ON A.FACTORY  = C.FACTORY&#xD;&#xA;   AND A.EQP_NAME = C.EQP_NAME&#xD;&#xA; WHERE A.FACTORY  = @factory&#xD;&#xA;   AND A.IBN_NAME = ISNULL(@ibn_name, A.IBN_NAME)&#xD;&#xA; ORDER BY A.EQP_NAME">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
        <SG _S="3550" N="ListBranchEquipmentAppliedTag">
          <QY P="MsSql" Q="SELECT IBN.CNT_NAME, IBN.CNT_RK, IBN.TAG_ADDR, IBN.TAG_ADDR_ALIAS,&#xD;&#xA;       MDL.TAG_NAME, MDL.TAG_DESC, MDL.PLC_TAG_TYPE, MDL.PLC_TAG_FORMAT&#xD;&#xA;  FROM &#xD;&#xA;     (&#xD;&#xA;SELECT VER.FACTORY, VER.BUILD_MDL, VER.BUILD_MDL_VER, TAG.CNT_RK, TAG.CNT_NAME, TAG.TAG_ADDR, TAG.TAG_ADDR_ALIAS&#xD;&#xA;  FROM QBWSIBNVER VER&#xD;&#xA;  LEFT JOIN QBWSIBNPTG TAG&#xD;&#xA;    ON VER.FACTORY    = TAG.FACTORY &#xD;&#xA;   AND VER.IBN_NAME   = TAG.IBN_NAME&#xD;&#xA;   AND VER.EQP_NAME   = TAG.EQP_NAME&#xD;&#xA;   AND VER.TAGSET_VER = TAG.TAGSET_VER&#xD;&#xA; WHERE VER.FACTORY    = @factory&#xD;&#xA;   AND VER.IBN_NAME   = @ibn_name&#xD;&#xA;   AND VER.EQP_NAME   = @eqp_name&#xD;&#xA;   AND VER.TAGSET_VER = @tagset_ver&#xD;&#xA;     ) IBN&#xD;&#xA;  LEFT JOIN QRASMDLPTG MDL&#xD;&#xA;    ON IBN.FACTORY       = MDL.FACTORY&#xD;&#xA;   AND IBN.BUILD_MDL     = MDL.MODEL&#xD;&#xA;   AND IBN.BUILD_MDL_VER = MDL.MDL_VER&#xD;&#xA;   AND IBN.CNT_RK        = MDL.CNT_RK&#xD;&#xA;   AND IBN.TAG_ADDR      = MDL.PLC_TAG_ADDR&#xD;&#xA; ORDER BY IBN.CNT_NAME, IBN.TAG_ADDR">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
            <QP N="tagset_ver" />
          </QY>
        </SG>
      </F>
      <F _S="3609" N="PlcTagSetCompareViewer">
        <SG _S="3610" N="ListLeftPlcTagSetTags">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;       'L' AS POSITION,&#xD;&#xA;       'N' AS COMPARE,&#xD;&#xA;       TAG_SEQ,&#xD;&#xA;	TAG_CATEGORY, 	&#xD;&#xA;	TAG_NAME, &#xD;&#xA;	TAG_FULL_ADDRESS,&#xD;&#xA;	TAG_DESC,&#xD;&#xA;       TAG_REGISTER, 	&#xD;&#xA;	TAG_DEC_ADDRESS,	&#xD;&#xA;	TAG_TYPE, &#xD;&#xA;	TAG_FORMAT, &#xD;&#xA;	TAG_PLC_FORMAT, &#xD;&#xA;	TAG_LENGTH,&#xD;&#xA;	TAG_ALARM	&#xD;&#xA;  FROM QSYSPTMTAG&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME = @tagset_name&#xD;&#xA;   AND TAGSET_VER  = @tagset_ver&#xD;&#xA; ORDER BY TAG_FULL_ADDRESS">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
            <QP N="tagset_ver" />
          </QY>
        </SG>
        <SG _S="3617" N="ListRightPlcTagSetTags">
          <QY P="MsSql" Q="SELECT &#xD;&#xA;	'R' AS POSITION,&#xD;&#xA;	'N' AS COMPARE,	&#xD;&#xA;	TAG_SEQ,&#xD;&#xA;	TAG_CATEGORY, 	&#xD;&#xA;	TAG_NAME, &#xD;&#xA;	TAG_FULL_ADDRESS,&#xD;&#xA;	TAG_DESC,&#xD;&#xA;       TAG_REGISTER, 	&#xD;&#xA;	TAG_DEC_ADDRESS,	&#xD;&#xA;	TAG_TYPE, &#xD;&#xA;	TAG_FORMAT, &#xD;&#xA;	TAG_PLC_FORMAT, &#xD;&#xA;	TAG_LENGTH,&#xD;&#xA;	TAG_ALARM	&#xD;&#xA;  FROM QSYSPTMTAG&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;      AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME = @tagset_name&#xD;&#xA;   AND TAGSET_VER  = @tagset_ver&#xD;&#xA; ORDER BY TAG_FULL_ADDRESS">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
            <QP N="tagset_ver" />
          </QY>
        </SG>
      </F>
      <F _S="3643" N="EquipmentStatus">
        <SG _S="3644" N="ListEquipment">
          <QY P="MsSql" Q="SELECT A.EQP_NAME,&#xD;&#xA;	A.EQP_DESC,&#xA;       A.EAP, &#xA;	B.COMM_STATE, &#xA;	B.CTRL_MODE, &#xA;	B.PROC_STATE,&#xD;&#xA;	ISNULL(B.LAST_EVENT_ID, ' ') AS LAST_EVENT_ID,&#xD;&#xA;	ISNULL(B.LAST_EVENT_TIME, ' ') AS LAST_EVENT_TIME&#xA;FROM QRASEQPDEF A&#xA;	LEFT JOIN QRASEQPSTS B ON &#xA;	A.FACTORY = B.FACTORY&#xA;	AND A.EQP_NAME = B.EQP_NAME&#xA;WHERE A.FACTORY = @factory&#xD;&#xA; AND A.DELETE_FLAG &lt;&gt; 'Y'">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="199" N="Report">
      <F _S="876" N="EquipmentList">
        <SG _S="882" N="ListEquipment">
          <QY P="MsSql" Q="SELECT A.EQP_NAME, A.EQP_DESC, A.TYPE, A.AREA, A.LINE,ISNULL(A.CTRL_MODE,'N/A') CTRL_MODE, ISNULL(A.PRI_STATE,'N/A') PRI_STATE, ISNULL(A.STATE,'N/A') STATE,&#xD;&#xA;       C.EAP, ISNULL(A.MDLN,'N/A') MDLN, ISNULL( A.SOFTREV,'N/A') SOFTREV, ISNULL( A.EVENT_DEFINE,'N/A') EVENT_DEFINE, A.EQP_RCP_ID,&#xD;&#xA;       C.SERVER, C.STEP, C.UP_DOWN, C.STATUS, C.RELOAD_CNT, &#xD;&#xA;       ISNULL(D.PACKAGE, 'N/A'), ISNULL(D.PKG_VER, 0),&#xD;&#xA;       ISNULL(D.MODEL, 'N/A'), ISNULL(D.MDL_VER, 0), &#xD;&#xA;       ISNULL(D.USED_COM, 'N/A'), ISNULL(D.COMPONENT, 'N/A'), ISNULL(D.COM_VER, 0), &#xD;&#xA;       C.NEED_ACTION, C.NEXT_NEED_ACTION, &#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME,&#xD;&#xA;       A.UPDATE_USER_ID, A.UPDATE_TIME,&#xD;&#xA;       A.LAST_EVENT_ID, A.LAST_EVENT_TIME &#xD;&#xA;  FROM QRASEQPDEF  A &#xD;&#xA;  LEFT JOIN  QRASEQPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EQP_NAME      = B.EQP_NAME&#xD;&#xA;   AND B.ATTR_CATEGORY = @category&#xD;&#xA;  LEFT JOIN QRASEAPDEF C&#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND B.EAP           = C.EAP&#xD;&#xA;  LEFT JOIN QRASEAPATR D&#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND B.EAP           = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = @category   &#xD;&#xA; WHERE A.FACTORY       = @factory &#xD;&#xA;   AND A.TYPE          = ISNULL(@type, A.TYPE)&#xD;&#xA;   AND A.AREA          = ISNULL(@area, A.AREA)&#xD;&#xA;   AND A.LINE          = ISNULL(@line, A.LINE)&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'&#xD;&#xA; ORDER BY A.EQP_NAME">
            <QP N="category" />
            <QP N="factory" />
            <QP N="type" />
            <QP N="area" />
            <QP N="line" />
          </QY>
        </SG>
        <SG _S="884" N="SearchEquipment">
          <QY P="MsSql" Q="SELECT A.EQP_NAME, A.EQP_DESC, A.TYPE, A.AREA, A.LINE, ISNULL(A.CTRL_MODE,'N/A'), ISNULL(A.PRI_STATE,'N/A'), ISNULL(A.STATE,'N/A'),&#xD;&#xA;       ISNULL(A.MDLN,'N/A'), ISNULL( A.SOFTREV,'N/A'), ISNULL( A.EVENT_DEFINE,'N/A'),  A.EQP_RCP_ID,&#xD;&#xA;       A.CREATE_USER_ID, A.CREATE_TIME,  &#xD;&#xA;       A.UPDATE_USER_ID, A.UPDATE_TIME, &#xD;&#xA;       A.LAST_EVENT_TIME, A.LAST_EVENT_ID,&#xD;&#xA;       C.EAP, C.EAP_DESC, C.EAP_TYPE, &#xD;&#xA;       C.SERVER, C.UP_DOWN,  C.STATUS, C.STEP, C.NEED_ACTION, C.NEXT_NEED_ACTION, &#xD;&#xA;       ISNULL(D.PACKAGE, 'N/A'), ISNULL(D.PKG_VER, 0),&#xD;&#xA;       ISNULL(D.MODEL, 'N/A'), ISNULL(D.MDL_VER, 0), &#xD;&#xA;       ISNULL(D.USED_COM, 'N/A'), ISNULL(D.COMPONENT, 'N/A'), ISNULL(D.COM_VER, 0),        &#xD;&#xA;       C.RELOAD_CNT,&#xD;&#xA;       C.CREATE_USER_ID, C.CREATE_TIME,&#xD;&#xA;       C.UPDATE_USER_ID, C.UPDATE_TIME,&#xD;&#xA;       C.LAST_EVENT_TIME, C.LAST_EVENT_ID&#xD;&#xA;  FROM QRASEQPDEF  A &#xD;&#xA;  LEFT JOIN  QRASEQPATR B &#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EQP_NAME      = B.EQP_NAME&#xD;&#xA;   AND B.ATTR_CATEGORY = @category&#xD;&#xA;  LEFT JOIN QRASEAPDEF C&#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND B.EAP           = C.EAP&#xD;&#xA;  LEFT JOIN QRASEAPATR D&#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND B.EAP           = D.EAP&#xD;&#xA;   AND D.ATTR_CATEGORY = @category   &#xD;&#xA; WHERE A.FACTORY       = @factory &#xD;&#xA;   AND A.EQP_NAME      = @eqpName&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="category" />
            <QP N="factory" />
            <QP N="eqpName" />
          </QY>
        </SG>
      </F>
      <F _S="3076" N="AlarmStatus">
        <SG _S="3077" N="SearchAlarmStatus">
          <QY P="MsSql" Q="SELECT EQP_NAME, SET_TIME, ALARM_ID, ALARM_TEXT&#xD;&#xA; FROM QRASEQPALS&#xD;&#xA;WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="2724" N="EquipmentStatus">
        <SG _S="2725" N="HasEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME &#xD;&#xA;  FROM QRASEQPDEF &#xD;&#xA; WHERE FACTORY  = @factory &#xD;&#xA;   AND EQP_NAME = @eqp_name">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="2727" N="SearchEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME, EQP_DESC, ISNULL(EQP_RCP_ID, 'N/A'),&#xD;&#xA;       TYPE, AREA, LINE, &#xD;&#xA;       ISNULL(CTRL_MODE,'N/A'), ISNULL(PRI_STATE,'N/A'), ISNULL(STATE,'N/A'),&#xD;&#xA;       ISNULL(MDLN,'N/A'), ISNULL(SOFTREV,'N/A'), ISNULL(EVENT_DEFINE,'N/A'), &#xD;&#xA;       CREATE_USER_ID, CREATE_TIME, UPDATE_USER_ID, UPDATE_TIME, &#xD;&#xA;       LAST_EVENT_TIME, LAST_EVENT_ID&#xD;&#xA;  FROM QRASEQPDEF &#xD;&#xA; WHERE FACTORY  = @factory &#xD;&#xA;   AND EQP_NAME = @eqp_name">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="2728" N="SearchEap">
          <QY P="MsSql" Q="SELECT A.EAP, B.EAP_DESC, B.EAP_TYPE,&#xD;&#xA;       B.SERVER, B.UP_DOWN, B.STATUS,&#xD;&#xA;       B.STEP, B.NEED_ACTION, B.NEXT_NEED_ACTION,&#xD;&#xA;       ISNULL(C.PACKAGE, 'N/A'), ISNULL(C.PKG_VER, 0), ISNULL(C.MODEL, 'N/A'), ISNULL(C.MDL_VER, 0), ISNULL(C.USED_COM, 'N/A'), ISNULL(C.COMPONENT, 'N/A'), ISNULL(C.COM_VER, 0),&#xD;&#xA;       B.RELOAD_CNT, B.CREATE_USER_ID, B.CREATE_TIME, B.UPDATE_USER_ID, B.UPDATE_TIME,&#xD;&#xA;       B.LAST_EVENT_TIME, B.LAST_EVENT_ID&#xD;&#xA;  FROM QRASEQPATR A&#xD;&#xA;  LEFT JOIN QRASEAPDEF B&#xD;&#xA;    ON A.FACTORY = B.FACTORY&#xD;&#xA;   AND A.EAP     = B.EAP&#xD;&#xA;  LEFT JOIN QRASEAPATR C&#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND A.EAP           = C.EAP&#xD;&#xA;   AND A.ATTR_CATEGORY = C.ATTR_CATEGORY&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.EQP_NAME      = @eqp_name&#xD;&#xA;   AND A.ATTR_CATEGORY = @attr_category">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="attr_category" />
          </QY>
        </SG>
      </F>
      <F _S="1463" N="EquipmentHistory">
        <SG _S="2822" N="SearchEquipmentHistory">
          <QY P="MsSql" Q="SELECT  TRAN_TIME, EQP_NAME, SYSTEM, EVENT_ID, EAP, COMM_STATE, CTRL_MODE, EAP_EVENT_ID, TRAN_USER_ID,&#xD;&#xA;        EVT_H_1, EVT_D_1, EVT_H_2, EVT_D_2, EVT_H_3, EVT_D_3, EVT_H_4, EVT_D_4, EVT_H_5, EVT_D_5, &#xD;&#xA;        EVT_H_6, EVT_D_6, EVT_H_7, EVT_D_7, EVT_H_8, EVT_D_8, EVT_H_9, EVT_D_9, EVT_H_10, EVT_D_10, &#xD;&#xA;        EVT_H_11, EVT_D_11, EVT_H_12, EVT_D_12, EVT_H_13, EVT_D_13, EVT_H_14, EVT_D_14, EVT_H_15, EVT_D_15, &#xD;&#xA;        EVT_H_16, EVT_D_16, EVT_H_17, EVT_D_17, EVT_H_18, EVT_D_18, EVT_H_19, EVT_D_19, EVT_H_20, EVT_D_20,&#xD;&#xA;        TRAN_COMMENT&#xD;&#xA;   FROM QRASEQPHIS&#xD;&#xA;  WHERE FACTORY      = @factory&#xD;&#xA;    AND EQP_NAME     = ISNULL(@eqp_name, EQP_NAME)&#xD;&#xA;   AND TRAN_TIME &gt;= @tran_from_time&#xD;&#xA;   AND TRAN_TIME &lt;= ISNULL(@tran_to_time, TRAN_TIME)&#xD;&#xA; ORDER BY TRAN_TIME">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
      </F>
      <F _S="811" N="UserHistory">
        <SG _S="814" N="SearchUserHistory">
          <QY P="MsSql" Q="SELECT HIS.HIST_SEQ, HIS.TRAN_TIME, HIS.USER_ID, ISNULL(DEF.USER_NAME, ' ') AS USER_NAME,&#xD;&#xA;       HIS.SYSTEM, HIS.EVENT_ID, HIS.ACTION, HIS.HOST_IP, HIS.HOST_NAME,&#xD;&#xA;       HIS.EVT_H_1, HIS.EVT_D_1, HIS.EVT_H_2, HIS.EVT_D_2, HIS.EVT_H_3, HIS.EVT_D_3, HIS.EVT_H_4, HIS.EVT_D_4, HIS.EVT_H_5, HIS.EVT_D_5, &#xD;&#xA;       HIS.EVT_H_6, HIS.EVT_D_6, HIS.EVT_H_7, HIS.EVT_D_7, HIS.EVT_H_8, HIS.EVT_D_8, HIS.EVT_H_9, HIS.EVT_D_9, HIS.EVT_H_10, HIS.EVT_D_10,       &#xD;&#xA;       HIS.EVT_H_11, HIS.EVT_D_11, HIS.EVT_H_12, HIS.EVT_D_12, HIS.EVT_H_13, HIS.EVT_D_13, HIS.EVT_H_14, HIS.EVT_D_14, HIS.EVT_H_15, HIS.EVT_D_15, &#xD;&#xA;       HIS.EVT_H_16, HIS.EVT_D_16, HIS.EVT_H_17, HIS.EVT_D_17, HIS.EVT_H_18, HIS.EVT_D_18, HIS.EVT_H_19, HIS.EVT_D_19, HIS.EVT_H_20, HIS.EVT_D_20,&#xD;&#xA;       HIS.TRAN_COMMENT&#xD;&#xA;  FROM QSECUSRHIS HIS&#xD;&#xA;  LEFT JOIN QSECUSRDEF DEF&#xD;&#xA;    ON HIS.FACTORY      = DEF.FACTORY&#xD;&#xA;   AND HIS.USER_ID      = DEF.USER_ID&#xD;&#xA; WHERE HIS.FACTORY      = @factory&#xD;&#xA;   AND HIS.SYSTEM       = @system&#xD;&#xA;   AND HIS.USER_ID      = ISNULL(@user_id, HIS.USER_ID)&#xD;&#xA;   AND HIS.C_TRAN_TIME &gt;= CONVERT (DATETIME, (STUFF(STUFF(STUFF(STUFF(@tran_from_time, 9, 0, ' '), 12, 0, ':'), 15, 0, ':'), 18, 0, '.'))) &#xD;&#xA;   AND HIS.C_TRAN_TIME &lt;= CONVERT (DATETIME, (STUFF(STUFF(STUFF(STUFF(@tran_to_time, 9, 0, ' '), 12, 0, ':'), 15, 0, ':'), 18, 0, '.')))&#xD;&#xA; ORDER BY HIS.C_TRAN_TIME DESC">
            <QP N="factory" />
            <QP N="system" />
            <QP N="user_id" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
        <SG _S="3433" N="SearchUserHistoryCount">
          <QY P="MsSql" Q="SELECT COUNT(*) AS CNT&#xD;&#xA;  FROM QSECUSRHIS&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND SYSTEM       = @system&#xD;&#xA;   AND USER_ID      = ISNULL(@user_id, USER_ID)&#xD;&#xA;   AND C_TRAN_TIME &gt;= CONVERT (DATETIME, (STUFF(STUFF(STUFF(STUFF(@tran_from_time, 9, 0, ' '), 12, 0, ':'), 15, 0, ':'), 18, 0, '.'))) &#xD;&#xA;   AND C_TRAN_TIME &lt;= CONVERT (DATETIME, (STUFF(STUFF(STUFF(STUFF(@tran_to_time, 9, 0, ' '), 12, 0, ':'), 15, 0, ':'), 18, 0, '.')))">
            <QP N="factory" />
            <QP N="system" />
            <QP N="user_id" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
        <SG _S="3434" N="SearchUserHistoryPaging">
          <QY P="MsSql" Q="SELECT HIS.HIST_SEQ, HIS.TRAN_TIME, HIS.USER_ID, ISNULL(DEF.USER_NAME, ' ') AS USER_NAME,&#xD;&#xA;       HIS.SYSTEM, HIS.EVENT_ID, HIS.ACTION, HIS.HOST_IP, HIS.HOST_NAME,&#xD;&#xA;       HIS.EVT_H_1, HIS.EVT_D_1, HIS.EVT_H_2, HIS.EVT_D_2, HIS.EVT_H_3, HIS.EVT_D_3, HIS.EVT_H_4, HIS.EVT_D_4, HIS.EVT_H_5, HIS.EVT_D_5, &#xD;&#xA;       HIS.EVT_H_6, HIS.EVT_D_6, HIS.EVT_H_7, HIS.EVT_D_7, HIS.EVT_H_8, HIS.EVT_D_8, HIS.EVT_H_9, HIS.EVT_D_9, HIS.EVT_H_10, HIS.EVT_D_10,       &#xD;&#xA;       HIS.EVT_H_11, HIS.EVT_D_11, HIS.EVT_H_12, HIS.EVT_D_12, HIS.EVT_H_13, HIS.EVT_D_13, HIS.EVT_H_14, HIS.EVT_D_14, HIS.EVT_H_15, HIS.EVT_D_15, &#xD;&#xA;       HIS.EVT_H_16, HIS.EVT_D_16, HIS.EVT_H_17, HIS.EVT_D_17, HIS.EVT_H_18, HIS.EVT_D_18, HIS.EVT_H_19, HIS.EVT_D_19, HIS.EVT_H_20, HIS.EVT_D_20,&#xD;&#xA;       HIS.TRAN_COMMENT&#xD;&#xA;  FROM QSECUSRHIS HIS&#xD;&#xA;  LEFT JOIN QSECUSRDEF DEF&#xD;&#xA;    ON HIS.FACTORY      = DEF.FACTORY&#xD;&#xA;   AND HIS.USER_ID      = DEF.USER_ID&#xD;&#xA; WHERE HIS.FACTORY      = @factory&#xD;&#xA;   AND HIS.SYSTEM       = @system&#xD;&#xA;   AND HIS.USER_ID      = ISNULL(@user_id, HIS.USER_ID)&#xD;&#xA;   AND HIS.C_TRAN_TIME &gt;= CONVERT (DATETIME, (STUFF(STUFF(STUFF(STUFF(@tran_from_time, 9, 0, ' '), 12, 0, ':'), 15, 0, ':'), 18, 0, '.'))) &#xD;&#xA;   AND HIS.C_TRAN_TIME &lt;= CONVERT (DATETIME, (STUFF(STUFF(STUFF(STUFF(@tran_to_time, 9, 0, ' '), 12, 0, ':'), 15, 0, ':'), 18, 0, '.')))&#xD;&#xA; ORDER BY HIS.C_TRAN_TIME DESC&#xD;&#xA;OFFSET (CONVERT(int, @PAGE_NO)-1) * CONVERT(int, @PAGE_SIZE) ROW FETCH NEXT CONVERT(int, @PAGE_SIZE) ROW ONLY">
            <QP N="factory" />
            <QP N="system" />
            <QP N="user_id" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
            <QP N="PAGE_NO" />
            <QP N="PAGE_SIZE" />
          </QY>
        </SG>
      </F>
      <F _S="3632" N="PlcTagSetHistory">
        <SG _S="3633" N="SearchPlcTagSetHistory">
          <QY P="MsSql" Q="SELECT TRAN_TIME, TAGSET_NAME, TAGSET_GROUP, TAGSET_VER, EVENT_ID, HIST_SEQ, TRAN_USER_ID, TRAN_COMMENT&#xD;&#xA;  FROM QSYSPTMHIS&#xD;&#xA; WHERE FACTORY      = @factory&#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME = ISNULL(@tagset_name, TAGSET_NAME)&#xD;&#xA;   AND TRAN_TIME &gt;= @tran_from_time&#xD;&#xA;   AND TRAN_TIME &lt;= ISNULL(@tran_to_time, TRAN_TIME)&#xD;&#xA; ORDER BY TRAN_TIME DESC">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="411" N="EapTransaction">
      <F _S="8095" N="EquipmentEvent">
        <SG _S="8096" N="SearchEap">
          <QY P="MsSql" Q="SELECT EAP&#xD;&#xA;  FROM QRASEAPDEF  &#xD;&#xA;  WITH (UPDLOCK)&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EAP         = @eap&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="8097" N="SearchEquipment">
          <QY P="MsSql" Q="SELECT A.EQP_NAME, B.COMM_STATE, B.CTRL_MODE&#xD;&#xA;  FROM QRASEQPDEF A&#xD;&#xA;  	LEFT JOIN QRASEQPSTS B&#xD;&#xA;  	ON A.EQP_NAME = B.EQP_NAME&#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND A.EQP_NAME = @eqp_name&#xD;&#xA;   AND A.DELETE_FLAG   = 'N'">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="8099" N="InsertEquipmentHis">
          <QY P="MsSql" Q="INSERT INTO QRASEQPHIS (&#xD;&#xA;   FACTORY,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   EVENT_ID,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   SYSTEM,&#xD;&#xA;   COMM_STATE,&#xD;&#xA;   CTRL_MODE,&#xD;&#xA;   EAP,&#xD;&#xA;   EAP_EVENT_ID,      &#xD;&#xA;   EVT_H_1,&#xD;&#xA;   EVT_D_1,   &#xD;&#xA;   EVT_H_2,&#xD;&#xA;   EVT_D_2,&#xD;&#xA;   EVT_H_3,&#xD;&#xA;   EVT_D_3,&#xD;&#xA;   EVT_H_4,&#xD;&#xA;   EVT_D_4,&#xD;&#xA;   EVT_H_5,&#xD;&#xA;   EVT_D_5,&#xD;&#xA;   EVT_H_6,&#xD;&#xA;   EVT_D_6,&#xD;&#xA;   EVT_H_7,&#xD;&#xA;   EVT_D_7,&#xD;&#xA;   EVT_H_8,&#xD;&#xA;   EVT_D_8,&#xD;&#xA;   EVT_H_9,&#xD;&#xA;   EVT_D_9,&#xD;&#xA;   EVT_H_10,&#xD;&#xA;   EVT_D_10,&#xD;&#xA;   EVT_H_11,&#xD;&#xA;   EVT_D_11,   &#xD;&#xA;   EVT_H_12,&#xD;&#xA;   EVT_D_12,&#xD;&#xA;   EVT_H_13,&#xD;&#xA;   EVT_D_13,&#xD;&#xA;   EVT_H_14,&#xD;&#xA;   EVT_D_14,&#xD;&#xA;   EVT_H_15,&#xD;&#xA;   EVT_D_15,&#xD;&#xA;   EVT_H_16,&#xD;&#xA;   EVT_D_16,&#xD;&#xA;   EVT_H_17,&#xD;&#xA;   EVT_D_17,&#xD;&#xA;   EVT_H_18,&#xD;&#xA;   EVT_D_18,&#xD;&#xA;   EVT_H_19,&#xD;&#xA;   EVT_D_19,&#xD;&#xA;   EVT_H_20,&#xD;&#xA;   EVT_D_20,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT      &#xD;&#xA;) &#xD;&#xA;VALUES( &#xD;&#xA;   @factory,&#xD;&#xA;   @eqp_name,&#xD;&#xA;   @last_his_seq,&#xD;&#xA;   @event_id,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @SYSTEM,&#xD;&#xA;   @comm_state,&#xD;&#xA;   @ctrl_mode,&#xD;&#xA;   @eap,&#xD;&#xA;   @eap_event_id,&#xD;&#xA;   @evt_h_1,&#xD;&#xA;   @evt_d_1,   &#xD;&#xA;   @evt_h_2,&#xD;&#xA;   @evt_d_2,&#xD;&#xA;   @evt_h_3,&#xD;&#xA;   @evt_d_3,&#xD;&#xA;   @evt_h_4,&#xD;&#xA;   @evt_d_4,&#xD;&#xA;   @evt_h_5,&#xD;&#xA;   @evt_d_5,&#xD;&#xA;   @evt_h_6,&#xD;&#xA;   @evt_d_6,&#xD;&#xA;   @evt_h_7,&#xD;&#xA;   @evt_d_7,&#xD;&#xA;   @evt_h_8,&#xD;&#xA;   @evt_d_8,&#xD;&#xA;   @evt_h_9,&#xD;&#xA;   @evt_d_9,&#xD;&#xA;   @evt_h_10,&#xD;&#xA;   @evt_d_10,&#xD;&#xA;   @evt_h_11,&#xD;&#xA;   @evt_d_11,   &#xD;&#xA;   @evt_h_12,&#xD;&#xA;   @evt_d_12,&#xD;&#xA;   @evt_h_13,&#xD;&#xA;   @evt_d_13,&#xD;&#xA;   @evt_h_14,&#xD;&#xA;   @evt_d_14,&#xD;&#xA;   @evt_h_15,&#xD;&#xA;   @evt_d_15,&#xD;&#xA;   @evt_h_16,&#xD;&#xA;   @evt_d_16,&#xD;&#xA;   @evt_h_17,&#xD;&#xA;   @evt_d_17,&#xD;&#xA;   @evt_h_18,&#xD;&#xA;   @evt_d_18,&#xD;&#xA;   @evt_h_19,&#xD;&#xA;   @evt_d_19,&#xD;&#xA;   @evt_h_20,&#xD;&#xA;   @evt_d_20,&#xD;&#xA;   @tran_user_id,&#xD;&#xA;   @tran_comment)">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="last_his_seq" />
            <QP N="event_id" />
            <QP N="tran_time" />
            <QP N="SYSTEM" />
            <QP N="comm_state" />
            <QP N="ctrl_mode" />
            <QP N="eap" />
            <QP N="eap_event_id" />
            <QP N="evt_h_1" />
            <QP N="evt_d_1" />
            <QP N="evt_h_2" />
            <QP N="evt_d_2" />
            <QP N="evt_h_3" />
            <QP N="evt_d_3" />
            <QP N="evt_h_4" />
            <QP N="evt_d_4" />
            <QP N="evt_h_5" />
            <QP N="evt_d_5" />
            <QP N="evt_h_6" />
            <QP N="evt_d_6" />
            <QP N="evt_h_7" />
            <QP N="evt_d_7" />
            <QP N="evt_h_8" />
            <QP N="evt_d_8" />
            <QP N="evt_h_9" />
            <QP N="evt_d_9" />
            <QP N="evt_h_10" />
            <QP N="evt_d_10" />
            <QP N="evt_h_11" />
            <QP N="evt_d_11" />
            <QP N="evt_h_12" />
            <QP N="evt_d_12" />
            <QP N="evt_h_13" />
            <QP N="evt_d_13" />
            <QP N="evt_h_14" />
            <QP N="evt_d_14" />
            <QP N="evt_h_15" />
            <QP N="evt_d_15" />
            <QP N="evt_h_16" />
            <QP N="evt_d_16" />
            <QP N="evt_h_17" />
            <QP N="evt_d_17" />
            <QP N="evt_h_18" />
            <QP N="evt_d_18" />
            <QP N="evt_h_19" />
            <QP N="evt_d_19" />
            <QP N="evt_h_20" />
            <QP N="evt_d_20" />
            <QP N="tran_user_id" />
            <QP N="tran_comment" />
          </QY>
        </SG>
        <SG _S="3178" N="UpdateEquipmentStatus">
          <QY P="MsSql" Q="UPDATE QRASEQPSTS SET&#xD;&#xA;   LAST_HIST_SEQ   = @last_his_seq,&#xD;&#xA;   LAST_EVENT_ID   = @last_event_id,&#xD;&#xA;   LAST_EVENT_TIME = @last_event_time,&#xD;&#xA;   UPDATE_USER_ID  = @update_user_id,&#xD;&#xA;   UPDATE_TIME     = @update_time&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EQP_NAME = @eqp_name">
            <QP N="last_his_seq" />
            <QP N="last_event_id" />
            <QP N="last_event_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
      </F>
      <F _S="1046" N="EquipmentControlMode">
        <SG _S="1243" N="SearchEapEquipment">
          <QY P="MsSql" Q="SELECT COMM_STATE, CTRL_MODE&#xD;&#xA;  FROM QRASEQPSTS&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EQP_NAME = @eqp_name">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
