          <QY P="MsSql" Q="SELECT USER_ID, PASSWORD, SYS_AUTHORITY&#xD;&#xA;  FROM QSECUSRDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND USER_ID = @user_id">
