      <F _S="3569" N="DeviceRestart">
        <SG _S="3571" N="HasDevice">
          <QY P="MsSql" Q="SELECT ACCOUNT_ID, PASSWORD, IP_ADDRESS, MAC_ADDRESS&#xD;&#xA;  FROM QBWSDVCDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND DVC_ID  = @dvc_id">
            <QP N="factory" />
            <QP N="dvc_id" />
          </QY>
