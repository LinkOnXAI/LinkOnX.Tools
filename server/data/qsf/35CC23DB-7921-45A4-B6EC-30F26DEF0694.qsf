        <SG _S="3660" N="InsertPresetGroup">
          <QY P="MsSql" Q="INSERT INTO QSYSPTMPRG(&#xD;&#xA;	FACTORY,&#xD;&#xA;	PRESET_GROUP,&#xD;&#xA;	PRESET_GROUP_DESC,&#xD;&#xA;	CREATE_USER_ID,&#xD;&#xA;	CREATE_TIME,&#xD;&#xA;	UPDATE_USER_ID,&#xD;&#xA;	UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;	@factory,&#xD;&#xA;	@preset_group,&#xD;&#xA;	@preset_group_desc,&#xD;&#xA;	@create_user_id,&#xD;&#xA;	@create_time,&#xD;&#xA;	@update_user_id,&#xD;&#xA;	@update_time&#xD;&#xA;)">
