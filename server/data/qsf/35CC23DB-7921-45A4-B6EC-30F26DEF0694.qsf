      <F _S="3236" N="DataHound">
        <SG _S="3238" N="HasEap">
          <QY P="MsSql" Q="SELECT EAP, EAP_TYPE, SERVER, UP_DOWN, STATUS    &#xD;&#xA;  FROM QRASEAPDEF  &#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND EAP         = @eap&#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="eap" />
          </QY>
        </SG>
        <SG _S="3239" N="HasDataHound">
          <QY P="MsSql" Q="SELECT NAME, STATUS    &#xD;&#xA;  FROM QSYSDHDDEF  &#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND NAME = @hound">
            <QP N="factory" />
            <QP N="hound" />
          </QY>
        </SG>
        <SG _S="3240" N="SearchDataHound">
          <QY P="MsSql" Q="SELECT NAME, STATUS, RESULT_MESSAGE&#xD;&#xA;  FROM QSYSDHDDEF  &#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND NAME = @hound">
            <QP N="factory" />
            <QP N="hound" />
          </QY>
        </SG>
        <SG _S="3241" N="InsertDataHound">
          <QY P="MsSql" Q="INSERT INTO QSYSDHDDEF (&#xD;&#xA;   FACTORY,&#xD;&#xA;   NAME,&#xD;&#xA;   STATUS,  &#xD;&#xA;   RESULT_MESSAGE,&#xD;&#xA;   SERVER_IP,&#xD;&#xA;   SERVER_PORT,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @hound,&#xD;&#xA;   @status,&#xD;&#xA;   @result_msg,&#xD;&#xA;   @server_ip,&#xD;&#xA;   @server_port,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="hound" />
            <QP N="status" />
            <QP N="result_msg" />
            <QP N="server_ip" />
            <QP N="server_port" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="3242" N="UpdateDataHound">
          <QY P="MsSql" Q="UPDATE QSYSDHDDEF SET&#xD;&#xA;  STATUS         = @status,&#xD;&#xA;  RESULT_MESSAGE           = @result_msg,&#xD;&#xA;  UPDATE_USER_ID   = @update_user_id,&#xD;&#xA;  UPDATE_TIME      = @update_time&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND NAME = @hound">
            <QP N="status" />
            <QP N="result_msg" />
            <QP N="update_user_id" />
            <QP N="update_time" />
            <QP N="factory" />
            <QP N="hound" />
          </QY>
        </SG>
        <SG _S="3243" N="HasServer">
          <QY P="MsSql" Q="SELECT A.SVR_IP, A.UP_DOWN, A.STATUS, A.EAS_UP_DOWN,&#xD;&#xA;       A.B_SERVER, A.B_UP_DOWN, A.B_STATUS, A.B_EAS_UP_DOWN, ISNULL(B.SVR_IP, '') B_SVR_IP&#xD;&#xA;  FROM QSYSSVRDEF A&#xD;&#xA;  LEFT JOIN QSYSSVRDEF B&#xD;&#xA;    ON A.FACTORY     = B.FACTORY&#xD;&#xA;   AND A.B_SERVER    = B.SERVER&#xD;&#xA;   AND B.DELETE_FLAG = 'N'&#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.SERVER      = @server&#xD;&#xA;   AND A.DELETE_FLAG = 'N'">
            <QP N="factory" />
            <QP N="server" />
          </QY>
        </SG>
        <SG _S="3244" N="DeleteDataHound">
          <QY P="MsSql" Q="DELETE FROM QSYSDHDDEF &#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND NAME = @hound">
            <QP N="factory" />
            <QP N="hound" />
          </QY>
        </SG>
      </F>
      <F _S="3522" N="EquipmentBranchEnable">
        <SG _S="3524" N="HasBranch">
          <QY P="MsSql" Q="SELECT IBN_NAME, PROTOCOL, PROTOCOL_ATTR&#xD;&#xA;  FROM QBWSIBNDEF&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND IBN_NAME = @ibn_name">
            <QP N="factory" />
            <QP N="ibn_name" />
