        <SG _S="3493" N="InsertBranchEquipmentVersion">
          <QY P="MsSql" Q="INSERT INTO QBWSIBNVER(&#xD;&#xA;   FACTORY,&#xD;&#xA;   IBN_NAME,&#xD;&#xA;   EQP_NAME,&#xD;&#xA;   TAGSET_VER,&#xD;&#xA;   TAGSET_VER_DESC,&#xD;&#xA;   ACTIVE,&#xD;&#xA;   BUILD_MDL,&#xD;&#xA;   BUILD_MDL_VER,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @ibn_name,&#xD;&#xA;   @eqp_name,&#xD;&#xA;   @tagset_ver,&#xD;&#xA;   @tagset_ver_desc,&#xD;&#xA;   @active,&#xD;&#xA;   @build_mdl,&#xD;&#xA;   @build_mdl_ver,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
            <QP N="tagset_ver" />
