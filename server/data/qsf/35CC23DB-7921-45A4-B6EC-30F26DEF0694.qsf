<?xml version="1.0"?>
<Q QN="QSF" QV="1.0.0.0" QC="2019.09.15 14:33:23.406" QU="2025-09-04 19:07:40.237" QD="LinkOn SQL File" QS="3683">
  <S _S="0" N="LinkOnBWService" D="LinkOn BWS" _RK="35CC23DB-7921-45A4-B6EC-30F26DEF0694">
    <M _S="100" N="Common">
      <F _S="101" N="Validation" D="Q">
        <SG _S="102" N="HasFactory" D="O">
          <QY P="MsSql" Q="SELECT FACTORY, EAP_RELOAD_LIMIT&#xD;&#xA;  FROM QSYSFACDEF&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="738" N="EventSearch" D="Q">
        <SG _S="763" N="SearchUserEvent" D="O">
          <QY P="MsSql" Q="SELECT EVENT_DESC, &#xD;&#xA;       DATA_1_PRT, DATA_2_PRT, DATA_3_PRT, DATA_4_PRT, DATA_5_PRT,&#xD;&#xA;       DATA_6_PRT, DATA_7_PRT, DATA_8_PRT, DATA_9_PRT, DATA_10_PRT,&#xD;&#xA;       DATA_11_PRT, DATA_12_PRT, DATA_13_PRT, DATA_14_PRT, DATA_15_PRT,&#xD;&#xA;       DATA_16_PRT, DATA_17_PRT, DATA_18_PRT, DATA_19_PRT, DATA_20_PRT&#xD;&#xA;  FROM QSECUSREVT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND SYSTEM   = @system&#xD;&#xA;   AND EVENT_ID = @event_id&#xD;&#xA;   AND ACTION   = @action">
            <QP N="factory" />
            <QP N="system" />
            <QP N="event_id" />
            <QP N="action" />
          </QY>
        </SG>
        <SG _S="2830" N="SearchUserEventAll" D="O">
          <QY P="MsSql" Q="SELECT EVENT_ID, EVENT_DESC, ACTION&#xD;&#xA;  FROM QSECUSREVT&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="739" N="SearchServerEvent" D="O">
          <QY P="MsSql" Q="SELECT EVENT_DESC,&#xD;&#xA;       DATA_1_PRT, DATA_2_PRT, DATA_3_PRT, DATA_4_PRT, DATA_5_PRT,&#xD;&#xA;       DATA_6_PRT, DATA_7_PRT, DATA_8_PRT, DATA_9_PRT, DATA_10_PRT,    &#xD;&#xA;       DATA_11_PRT, DATA_12_PRT, DATA_13_PRT, DATA_14_PRT, DATA_15_PRT,&#xD;&#xA;       DATA_16_PRT, DATA_17_PRT, DATA_18_PRT, DATA_19_PRT, DATA_20_PRT,&#xD;&#xA;       ALT_COMMENT&#xD;&#xA;  FROM QSYSSVREVT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EVENT_ID = @event_id">
            <QP N="factory" />
            <QP N="event_id" />
          </QY>
        </SG>
        <SG _S="2832" N="SearchServerEventAll" D="O">
          <QY P="MsSql" Q="SELECT EVENT_ID, EVENT_DESC&#xD;&#xA;  FROM QSYSSVREVT&#xD;&#xA; WHERE FACTORY  = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="816" N="SearchEapEvent" D="O">
          <QY P="MsSql" Q="SELECT EVENT_DESC,&#xD;&#xA;       DATA_1_PRT, DATA_2_PRT, DATA_3_PRT, DATA_4_PRT, DATA_5_PRT,&#xD;&#xA;       DATA_6_PRT, DATA_7_PRT, DATA_8_PRT, DATA_9_PRT, DATA_10_PRT,    &#xD;&#xA;       DATA_11_PRT, DATA_12_PRT, DATA_13_PRT, DATA_14_PRT, DATA_15_PRT,&#xD;&#xA;       DATA_16_PRT, DATA_17_PRT, DATA_18_PRT, DATA_19_PRT, DATA_20_PRT,&#xD;&#xA;       ALT_COMMENT&#xD;&#xA;  FROM QRASEAPEVT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EVENT_ID = @event_id">
            <QP N="factory" />
            <QP N="event_id" />
          </QY>
        </SG>
        <SG _S="2833" N="SearchEapEventAll" D="O">
          <QY P="MsSql" Q="SELECT EVENT_ID, EVENT_DESC&#xD;&#xA;  FROM QRASEAPEVT&#xD;&#xA; WHERE FACTORY  = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="1460" N="SearchEquipmentEvent" D="O">
          <QY P="MsSql" Q="SELECT EVENT_DESC,&#xD;&#xA;       DATA_1_PRT, DATA_2_PRT, DATA_3_PRT, DATA_4_PRT, DATA_5_PRT,&#xD;&#xA;       DATA_6_PRT, DATA_7_PRT, DATA_8_PRT, DATA_9_PRT, DATA_10_PRT,    &#xD;&#xA;       DATA_11_PRT, DATA_12_PRT, DATA_13_PRT, DATA_14_PRT, DATA_15_PRT,&#xD;&#xA;       DATA_16_PRT, DATA_17_PRT, DATA_18_PRT, DATA_19_PRT, DATA_20_PRT,&#xD;&#xA;       ALT_COMMENT&#xD;&#xA;  FROM QRASEQPEVT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EVENT_ID = @event_id">
            <QP N="factory" />
            <QP N="event_id" />
          </QY>
        </SG>
        <SG _S="2831" N="SearchEquipmentEventAll" D="Q">
          <QY P="MsSql" Q="SELECT EVENT_ID, EVENT_DESC&#xD;&#xA;  FROM QRASEQPEVT&#xD;&#xA; WHERE FACTORY  = @factory">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="764" N="UserHistory" D="Q">
        <SG _S="1295" N="InsertUserHistory" D="O">
          <QY P="MsSql" Q="INSERT INTO QSECUSRHIS(&#xD;&#xA;   FACTORY,&#xD;&#xA;   USER_ID,&#xD;&#xA;   HIST_SEQ,&#xD;&#xA;   EVENT_ID,&#xD;&#xA;   ACTION,&#xD;&#xA;   SYSTEM,&#xD;&#xA;   HOST_IP,&#xD;&#xA;   HOST_NAME,&#xD;&#xA;   TRAN_TIME,&#xD;&#xA;   EVT_H_1,&#xD;&#xA;   EVT_D_1,&#xD;&#xA;   EVT_H_2,&#xD;&#xA;   EVT_D_2,&#xD;&#xA;   EVT_H_3,&#xD;&#xA;   EVT_D_3,&#xD;&#xA;   EVT_H_4,&#xD;&#xA;   EVT_D_4,&#xD;&#xA;   EVT_H_5,&#xD;&#xA;   EVT_D_5,&#xD;&#xA;   EVT_H_6,&#xD;&#xA;   EVT_D_6,&#xD;&#xA;   EVT_H_7,&#xD;&#xA;   EVT_D_7,&#xD;&#xA;   EVT_H_8,&#xD;&#xA;   EVT_D_8,&#xD;&#xA;   EVT_H_9,&#xD;&#xA;   EVT_D_9,&#xD;&#xA;   EVT_H_10,&#xD;&#xA;   EVT_D_10,    &#xD;&#xA;   EVT_H_11,&#xD;&#xA;   EVT_D_11,&#xD;&#xA;   EVT_H_12,&#xD;&#xA;   EVT_D_12,&#xD;&#xA;   EVT_H_13,&#xD;&#xA;   EVT_D_13,&#xD;&#xA;   EVT_H_14,&#xD;&#xA;   EVT_D_14,&#xD;&#xA;   EVT_H_15,&#xD;&#xA;   EVT_D_15,&#xD;&#xA;   EVT_H_16,&#xD;&#xA;   EVT_D_16,&#xD;&#xA;   EVT_H_17,&#xD;&#xA;   EVT_D_17,&#xD;&#xA;   EVT_H_18,&#xD;&#xA;   EVT_D_18,&#xD;&#xA;   EVT_H_19,&#xD;&#xA;   EVT_D_19,&#xD;&#xA;   EVT_H_20,&#xD;&#xA;   EVT_D_20,&#xD;&#xA;   TRAN_USER_ID,&#xD;&#xA;   TRAN_COMMENT&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @user_id,&#xD;&#xA;   (NEXT VALUE FOR SEQ_USR_HIS),&#xD;&#xA;   @event_id, &#xD;&#xA;   @action, &#xD;&#xA;   @system,&#xD;&#xA;   @host_ip,&#xD;&#xA;   @host_name,&#xD;&#xA;   @tran_time,&#xD;&#xA;   @evt_h_1,&#xD;&#xA;   @evt_d_1,   &#xD;&#xA;   @evt_h_2,&#xD;&#xA;   @evt_d_2,&#xD;&#xA;   @evt_h_3,&#xD;&#xA;   @evt_d_3,&#xD;&#xA;   @evt_h_4,&#xD;&#xA;   @evt_d_4,&#xD;&#xA;   @evt_h_5,&#xD;&#xA;   @evt_d_5,&#xD;&#xA;   @evt_h_6,&#xD;&#xA;   @evt_d_6,&#xD;&#xA;   @evt_h_7,&#xD;&#xA;   @evt_d_7,&#xD;&#xA;   @evt_h_8,&#xD;&#xA;   @evt_d_8,&#xD;&#xA;   @evt_h_9,&#xD;&#xA;   @evt_d_9,&#xD;&#xA;   @evt_h_10,&#xD;&#xA;   @evt_d_10,&#xD;&#xA;   @evt_h_11,&#xD;&#xA;   @evt_d_11,   &#xD;&#xA;   @evt_h_12,&#xD;&#xA;   @evt_d_12,&#xD;&#xA;   @evt_h_13,&#xD;&#xA;   @evt_d_13,&#xD;&#xA;   @evt_h_14,&#xD;&#xA;   @evt_d_14,&#xD;&#xA;   @evt_h_15,&#xD;&#xA;   @evt_d_15,&#xD;&#xA;   @evt_h_16,&#xD;&#xA;   @evt_d_16,&#xD;&#xA;   @evt_h_17,&#xD;&#xA;   @evt_d_17,&#xD;&#xA;   @evt_h_18,&#xD;&#xA;   @evt_d_18,&#xD;&#xA;   @evt_h_19,&#xD;&#xA;   @evt_d_19,&#xD;&#xA;   @evt_h_20,&#xD;&#xA;   @evt_d_20,   &#xD;&#xA;   @tran_user_id,&#xD;&#xA;   @tran_comment&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="user_id" />
            <QP N="event_id" />
            <QP N="action" />
            <QP N="system" />
            <QP N="host_ip" />
            <QP N="host_name" />
            <QP N="tran_time" />
            <QP N="evt_h_1" />
            <QP N="evt_d_1" />
            <QP N="evt_h_2" />
            <QP N="evt_d_2" />
            <QP N="evt_h_3" />
            <QP N="evt_d_3" />
            <QP N="evt_h_4" />
            <QP N="evt_d_4" />
            <QP N="evt_h_5" />
            <QP N="evt_d_5" />
            <QP N="evt_h_6" />
            <QP N="evt_d_6" />
            <QP N="evt_h_7" />
            <QP N="evt_d_7" />
            <QP N="evt_h_8" />
            <QP N="evt_d_8" />
            <QP N="evt_h_9" />
            <QP N="evt_d_9" />
            <QP N="evt_h_10" />
            <QP N="evt_d_10" />
            <QP N="evt_h_11" />
            <QP N="evt_d_11" />
            <QP N="evt_h_12" />
            <QP N="evt_d_12" />
            <QP N="evt_h_13" />
            <QP N="evt_d_13" />
            <QP N="evt_h_14" />
            <QP N="evt_d_14" />
            <QP N="evt_h_15" />
            <QP N="evt_d_15" />
            <QP N="evt_h_16" />
            <QP N="evt_d_16" />
            <QP N="evt_h_17" />
            <QP N="evt_d_17" />
            <QP N="evt_h_18" />
            <QP N="evt_d_18" />
            <QP N="evt_h_19" />
            <QP N="evt_d_19" />
            <QP N="evt_h_20" />
            <QP N="evt_d_20" />
            <QP N="tran_user_id" />
            <QP N="tran_comment" />
          </QY>
        </SG>
      </F>
      <F _S="3182" N="Equipment">
        <SG _S="3183" N="SearchEquipmentSeq">
          <QY P="MsSql" />
        </SG>
      </F>
      <F _S="3180" N="EquipmentHistory">
        <SG _S="3181" N="SelectEquipmentHistorySeq">
          <QY P="MsSql" Q="SELECT NEXT VALUE FOR SEQ_EQP_HIS" />
        </SG>
      </F>
      <F _S="3605" N="GcmData">
        <SG _S="3606" N="SearchGcmData">
          <QY P="MsSql" Q="SELECT DATA_1, DATA_2, DATA_3, DATA_4, DATA_5, DATA_6, DATA_7, DATA_8, DATA_9, DATA_10&#xA;  FROM QGCMTBLDAT&#xA; WHERE FACTORY    = @factory&#xA;   AND TABLE_NAME = @table_name&#xD;&#xA; ORDER BY DATA_KEY">
            <QP N="factory&#xA;" />
            <QP N="table_name" />
          </QY>
        </SG>
        <SG _S="3607" N="SearchGcmTable">
          <QY P="MsSql" Q="SELECT DATA_1_USE,  DATA_1_PRT,  DATA_1_FMT,  DATA_1_SIZE,  DATA_1_KEY,&#xD;&#xA;       DATA_2_USE,  DATA_2_PRT,  DATA_2_FMT,  DATA_2_SIZE,  DATA_2_KEY,&#xD;&#xA;       DATA_3_USE,  DATA_3_PRT,  DATA_3_FMT,  DATA_3_SIZE,  DATA_3_KEY,&#xD;&#xA;       DATA_4_USE,  DATA_4_PRT,  DATA_4_FMT,  DATA_4_SIZE,  DATA_4_KEY,&#xD;&#xA;       DATA_5_USE,  DATA_5_PRT,  DATA_5_FMT,  DATA_5_SIZE,  DATA_5_KEY,&#xD;&#xA;       DATA_6_USE,  DATA_6_PRT,  DATA_6_FMT,  DATA_6_SIZE,  DATA_6_KEY,&#xD;&#xA;       DATA_7_USE,  DATA_7_PRT,  DATA_7_FMT,  DATA_7_SIZE,  DATA_7_KEY,&#xD;&#xA;       DATA_8_USE,  DATA_8_PRT,  DATA_8_FMT,  DATA_8_SIZE,  DATA_8_KEY,&#xD;&#xA;       DATA_9_USE,  DATA_9_PRT,  DATA_9_FMT,  DATA_9_SIZE,  DATA_9_KEY,&#xD;&#xA;       DATA_10_USE, DATA_10_PRT, DATA_10_FMT, DATA_10_SIZE, DATA_10_KEY&#xD;&#xA;  FROM QGCMTBLDEF&#xD;&#xA; WHERE FACTORY    = @factory&#xD;&#xA;   AND TABLE_NAME = @table_name">
            <QP N="factory" />
            <QP N="table_name" />
          </QY>
        </SG>
      </F>
      <F _S="3630" N="PTMHistory">
        <SG _S="3631" N="SelectPTMHistorySeq">
          <QY P="MsSql" Q="SELECT NEXT VALUE FOR SEQ_PTM_HIS" />
        </SG>
      </F>
      <F _S="3668" N="PTMParser">
        <SG _S="3669" N="SearchMapParser">
          <QY P="MsSql" Q="SELECT PARSER_NAME&#xD;&#xA;  FROM QSYSPTMMPS&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND PLC_MAKER = @plc_maker&#xD;&#xA;   AND PLC_MODEL = @plc_model">
            <QP N="factory" />
            <QP N="plc_maker" />
            <QP N="plc_model" />
          </QY>
        </SG>
      </F>
    </M>    
    <M _S="486" N="Dialog">
      <F _S="630" N="UserGroupSelector">
        <SG _S="633" N="ListUserGroup">
          <QY P="MsSql" Q="SELECT USER_GRP, USER_GRP_DESC&#xD;&#xA;  FROM QSECUSRGRP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY USER_GRP">
            <QP P="factory" />
          </QY>
        </SG>
      </F>
      <F _S="869" N="UserGroupFunctionSelector">
        <SG _S="870" N="ListFunction">
          <QY P="MsSql" Q="SELECT FUN, FUN_DESC, TRAN_USED&#xD;&#xA;  FROM QSECURGFUN&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND APP     = @app&#xD;&#xA; ORDER BY FUN">
            <QP P="factory" />
            <QP P="app" />
          </QY>
        </SG>
      </F>
      <F _S="871" N="UserGroupAuthoritySelector">
        <SG _S="873" N="ListUserGroup">
          <QY P="MsSql" Q="SELECT USER_GRP, USER_GRP_DESC, ALL_AUTHORITY&#xD;&#xA;  FROM QSECUSRGRP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY USER_GRP">
            <QP P="factory" />
          </QY>
        </SG>
        <SG _S="874" N="ListAuthority">
          <QY P="MsSql" Q="SELECT A.FUN, B.FUN_DESC, A.TRAN_ENABLED, B.TRAN_USED&#xD;&#xA;  FROM QSECURGAUT A&#xD;&#xA;  LEFT JOIN QSECURGFUN B&#xD;&#xA;    ON A.FACTORY  = B.FACTORY&#xD;&#xA;   AND A.APP      = B.APP&#xD;&#xA;   AND A.FUN      = B.FUN&#xD;&#xA; WHERE A.FACTORY  = @factory&#xD;&#xA;   AND A.USER_GRP = @user_grp&#xD;&#xA;   AND A.APP      = @app&#xD;&#xA; ORDER BY A.FUN">
            <QP P="factory" />
            <QP P="user_grp" />
            <QP P="app" />
          </QY>
        </SG>
      </F>
      <F _S="2808" N="SubEquipmentSelector">
        <SG _S="2809" N="ListEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME, EQP_ID, EQP_DESC &#xD;&#xA;   FROM QRASEQPDEF&#xD;&#xA;  WHERE FACTORY = @factory&#xD;&#xA;    AND EQP_CLASS = 'InlineSub'&#xD;&#xA;    AND DELETE_FLAG = 'N'&#xD;&#xA;  ORDER BY EQP_NAME">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="1767" N="EventSelector">
        <SG _S="1768" N="ListEapEvent">
          <QY P="MsSql" Q="SELECT EVENT_ID, EVENT_DESC&#xD;&#xA;  FROM QRASEAPEVT&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY EVENT_ID">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="1769" N="ListEquipmentEvent" D="ADM Only">
          <QY P="MsSql" Q="SELECT EVENT_ID, EVENT_DESC&#xD;&#xA;  FROM QRASEQPEVT&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA;   AND SYSTEM  = 'ADM'&#xD;&#xA; ORDER BY EVENT_ID">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="1770" N="ListServerEvent">
          <QY P="MsSql" Q="SELECT EVENT_ID, EVENT_DESC&#xD;&#xA;  FROM QSYSSVREVT&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY EVENT_ID">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="2213" N="EquipmentSelector_Bak">
        <SG _S="2214" N="ListEquipmentType">
          <QY P="MsSql" Q="SELECT TYPE, TYPE_DESC&#xD;&#xA;  FROM QRASEQPTYP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY TYPE">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="2216" N="ListEquipmentArea">
          <QY P="MsSql" Q="SELECT AREA, AREA_DESC&#xD;&#xA;  FROM QRASEQPARE&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA; ORDER BY AREA">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="2215" N="ListEquipmentLine">
          <QY P="MsSql" Q="SELECT LINE, LINE_DESC&#xD;&#xA;  FROM QRASEQPLIN&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY LINE">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="2220" N="ListEquipment">
          <QY P="MsSql" Q="SELECT A.EQP_NAME, B.EQP_DESC, A.CTRL_MODE, A.MDLN, A.SOFTREV,&#xD;&#xA;        ISNULL(C.EAP,'N/A'), ISNULL(C.SERVER,'N/A'), ISNULL(C.UP_DOWN,'N/A'), ISNULL(C.STATUS, 'N/A'),&#xD;&#xA;        D.PACKAGE, D.PKG_VER, D.MODEL, D.MDL_VER, D.USED_COM, D.COMPONENT, D.COM_VER, A.CMF_5 AS PLC_IP_ADDRESS&#xD;&#xA;  FROM QRASEQPDEF A&#xD;&#xA;  LEFT JOIN QRASEQPATR B&#xD;&#xA;   ON A.FACTORY  = B.FACTORY&#xD;&#xA;  AND A.EQP_NAME = B.EQP_NAME&#xD;&#xA;  AND B.ATTR_CATEGORY = 'Applied'&#xD;&#xA; LEFT JOIN QRASEAPDEF C&#xD;&#xA;   ON A.FACTORY = C.FACTORY&#xD;&#xA;  AND B.EAP     = C.EAP&#xD;&#xA; LEFT JOIN QRASEAPATR D&#xD;&#xA;   ON A.FACTORY = D.FACTORY&#xD;&#xA;  AND B.EAP     = D.EAP&#xD;&#xA;  AND D.ATTR_CATEGORY = 'Applied'&#xD;&#xA;WHERE A.FACTORY = @factory&#xD;&#xA;  AND (A.TYPE         = @type OR&#xD;&#xA;        A.AREA        = @area OR&#xD;&#xA;        A.LINE        = @line)&#xD;&#xA;  AND A.DELETE_FLAG   &lt;&gt; 'Y'&#xD;&#xA;ORDER BY A.EQP_NAME">
            <QP N="factory" />
            <QP N="type" />
            <QP N="area" />
            <QP N="line" />
          </QY>
        </SG>
        <SG _S="2856" N="ListAllEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME, EQP_DESC, CTRL_MODE, DELETE_FLAG&#xD;&#xA;  FROM QRASEQPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND DELETE_FLAG = ISNULL(@delete_flag, DELETE_FLAG)&#xD;&#xA; ORDER BY EQP_NAME">
            <QP N="factory" />
            <QP N="delete_flag" />
          </QY>
        </SG>
        <SG _S="2223" N="SearchEquipment">
          <QY P="MsSql" Q="SELECT A.TYPE, A.AREA, A.LINE&#xD;&#xA;  FROM QRASEQPDEF A&#xD;&#xA;  LEFT JOIN QRASEQPATR B&#xD;&#xA;    ON A.FACTORY       = B.FACTORY&#xD;&#xA;   AND A.EQP_NAME      = B.EQP_NAME&#xD;&#xA;  LEFT JOIN QRASEAPDEF C&#xD;&#xA;    ON A.FACTORY       = C.FACTORY&#xD;&#xA;   AND B.EAP           = C.EAP&#xD;&#xA;  LEFT JOIN QRASEAPATR D&#xD;&#xA;    ON A.FACTORY       = D.FACTORY&#xD;&#xA;   AND B.EAP           = D.EAP&#xD;&#xA;   AND B.ATTR_CATEGORY = D.ATTR_CATEGORY &#xD;&#xA; WHERE A.FACTORY       = @factory&#xD;&#xA;   AND B.ATTR_CATEGORY = 'Applied'&#xD;&#xA;   AND A.EQP_NAME      LIKE @eqpName&#xD;&#xA;   AND A.DELETE_FLAG   &lt;&gt; 'Y'&#xD;&#xA; ORDER BY &#xD;&#xA; (CASE @target&#xD;&#xA;  WHEN 'Type'  THEN A.TYPE&#xD;&#xA;  WHEN 'Area'  THEN A.AREA&#xD;&#xA;  WHEN 'Line'  THEN A.LINE&#xD;&#xA;   END)">
            <QP N="factory" />
            <QP N="eqpName" />
            <QP N="target" />
          </QY>
        </SG>
      </F>
      <F _S="3107" N="EquipmentSelector">
        <SG _S="3111" N="ListEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME, EQP_DESC, DELETE_FLAG, IP_ADDRESS&#xD;&#xA;  FROM QRASEQPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND DELETE_FLAG = ISNULL(@delete_flag, DELETE_FLAG)&#xD;&#xA; ORDER BY EQP_NAME">
            <QP N="factory" />
            <QP N="delete_flag" />
          </QY>
        </SG>
      </F>
      <F _S="3359" N="EquipmentEapSelector">
        <SG _S="3360" N="ListEquipment">
          <QY P="MsSql" Q="SELECT D.EQP_NAME, F.EAP, D.EQP_DESC, D.DELETE_FLAG&#xD;&#xA;FROM QRASEQPDEF D&#xD;&#xA;LEFT JOIN QRASEAPCFG F ON    &#xD;&#xA;	F.OBJ_TYPE = 'CONTROLLER'&#xD;&#xA;	AND F.ATTR_CATEGORY = 'Applied'&#xD;&#xA;	AND F.DATA = D.EQP_NAME&#xD;&#xA; WHERE D.FACTORY = @factory &#xD;&#xA;       AND D.DELETE_FLAG = ISNULL(@delete_flag, D.DELETE_FLAG)&#xD;&#xA;	AND F.EAP IS NOT NULL&#xD;&#xA; ORDER BY D.EQP_NAME;">
            <QP N="factory" />
            <QP N="delete_flag" />
          </QY>
        </SG>
      </F>
      <F _S="2194" N="EquipmentTypeSelector">
        <SG _S="2197" N="ListEquipmentType">
          <QY P="MsSql" Q="SELECT TYPE, TYPE_DESC&#xD;&#xA;  FROM QRASEQPTYP&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY TYPE">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="2195" N="EquipmentAreaSelector">
        <SG _S="2198" N="ListEquipmentArea">
          <QY P="MsSql" Q="SELECT AREA, AREA_DESC&#xD;&#xA;  FROM QRASEQPARE&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY AREA">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="2196" N="EquipmentLineSelector">
        <SG _S="2199" N="ListEquipmentLine">
          <QY P="MsSql" Q="SELECT LINE, LINE_DESC&#xD;&#xA;  FROM QRASEQPLIN&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY LINE">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="3206" N="EquipmentMapVersionSelector">
        <SG _S="3207" N="ListEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME, EQP_DESC&#xD;&#xA;  FROM QRASEQPDEF&#xD;&#xA; WHERE FACTORY     = @factory &#xD;&#xA;   AND DELETE_FLAG = 'N'">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3209" N="ListMapVersion">
          <QY P="MsSql" Q="SELECT MAP_VER,	MAP_VER_COMMENT&#xD;&#xA;  FROM QRASMAPVER&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EQP_NAME = @eqp_name">
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="3210" N="SearchMapData">
          <QY P="MsSql" Q="SELECT MAP_DAT_SEQ, MAP_DAT_CATEGORY, MAP_DAT_ITEM, MAP_DAT_ITEM_DESC,&#xD;&#xA;       MAP_DAT_REGISTER, MAP_DAT_ADDRESS, MAP_DAT_FULL_ADDRESS,&#xD;&#xA;	   MAP_DAT_TYPE, MAP_DAT_FORMAT, MAP_DAT_LENGTH,&#xD;&#xA;	   MAP_DAT_CONVERSION, MAP_DAT_REMARK&#xD;&#xA;  FROM QRASMAPDAT&#xD;&#xA; WHERE FACTORY  = @factory&#xD;&#xA;   AND EQP_NAME = @eqp_name&#xD;&#xA;   AND MAP_VER  = @map_ver">
            <QP N="factory" />
            <QP N="eqp_name" />
            <QP N="map_ver" />
          </QY>
        </SG>
      </F>
      <F _S="2521" N="ServerResourceHistoryViewer">
        <SG _S="2526" N="SearchManagementRate">
          <QY P="MsSql" Q="SELECT SVR_CPU_CAUTION_RATE, SVR_CPU_DANGER_RATE, &#xD;&#xA;       SVR_MEMORY_CAUTION_RATE, SVR_MEMORY_DANGER_RATE,&#xD;&#xA;       SVR_DISK_CAUTION_RATE, SVR_DISK_DANGER_RATE&#xD;&#xA;  FROM QSYSFACDEF&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="2524" N="SearchCpuHistory">
          <QY P="MsSql" Q="SELECT TRAN_TIME, CPU_USAGE&#xD;&#xA;  FROM QSYSSVRRHI&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND TRAN_TIME  &gt;= @tran_from_time&#xD;&#xA;   AND TRAN_TIME  &lt;= @tran_to_time&#xD;&#xA;   AND SERVER      = @server &#xD;&#xA; ORDER BY TRAN_TIME">
            <QP N="factory" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
            <QP N="server" />
          </QY>
        </SG>
        <SG _S="2525" N="SearchMemoryHistory">
          <QY P="MsSql" Q="SELECT A.TRAN_TIME, B.MEMORY, A.MEMORY_USAGE&#xD;&#xA;  FROM QSYSSVRRHI A &#xD;&#xA;  LEFT JOIN QSYSSVRDEF B&#xD;&#xA;    ON A.FACTORY     = B.FACTORY&#xD;&#xA;   AND A.SERVER      = B.SERVER&#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.TRAN_TIME  &gt;= @tran_from_time&#xD;&#xA;   AND A.TRAN_TIME  &lt;= @tran_to_time&#xD;&#xA;   AND A.SERVER      = @server&#xD;&#xA; ORDER BY A.TRAN_TIME">
            <QP N="factory" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
            <QP N="server" />
          </QY>
        </SG>
        <SG _S="2593" N="SearchDiskHistory">
          <QY P="MsSql" Q="SELECT A.TRAN_TIME, A.SERVER,&#xD;&#xA;       B.DISK_1, B.DISK_1_SIZE, A.DISK_1_USAGE,&#xD;&#xA;       B.DISK_2, B.DISK_2_SIZE, A.DISK_2_USAGE,&#xD;&#xA;       B.DISK_3, B.DISK_3_SIZE, A.DISK_3_USAGE,&#xD;&#xA;       B.DISK_4, B.DISK_4_SIZE, A.DISK_4_USAGE,&#xD;&#xA;       B.DISK_5, B.DISK_5_SIZE, A.DISK_5_USAGE,&#xD;&#xA;       B.DISK_6, B.DISK_6_SIZE, A.DISK_6_USAGE,&#xD;&#xA;       B.DISK_7, B.DISK_7_SIZE, A.DISK_7_USAGE,&#xD;&#xA;       B.DISK_8, B.DISK_8_SIZE, A.DISK_8_USAGE,&#xD;&#xA;       B.DISK_9, B.DISK_9_SIZE, A.DISK_9_USAGE,&#xD;&#xA;       B.DISK_10, B.DISK_10_SIZE, A.DISK_10_USAGE&#xD;&#xA;  FROM QSYSSVRRHI A &#xD;&#xA;  LEFT JOIN QSYSSVRDEF B&#xD;&#xA;    ON A.FACTORY     = B.FACTORY&#xD;&#xA;   AND A.SERVER      = B.SERVER&#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.TRAN_TIME  &gt;= @tran_from_time&#xD;&#xA;   AND A.TRAN_TIME  &lt;= @tran_to_time&#xD;&#xA;   AND A.SERVER      = @server&#xD;&#xA; ORDER BY A.TRAN_TIME">
            <QP N="factory" />
            <QP N="tran_from_time" />
            <QP N="tran_to_time" />
            <QP N="server" />
          </QY>
        </SG>
      </F>
      <F _S="2786" N="EapNameSelector">
        <SG _S="2788" N="ListEquipment">
          <QY P="MsSql" Q="SELECT EQP_NAME, EQP_DESC&#xD;&#xA;  FROM QRASEQPDEF&#xD;&#xA; WHERE FACTORY     = @factory&#xD;&#xA;   AND DELETE_FLAG = ISNULL(@delete_flag, DELETE_FLAG)&#xD;&#xA; ORDER BY EQP_NAME">
            <QP N="factory" />
            <QP N="delete_flag" />
          </QY>
        </SG>
      </F>
      <F _S="2915" N="UserSelector">
        <SG _S="2916" N="SearchUserList">
          <QY P="MsSql" Q="SELECT USER_ID, USER_DESC&#xD;&#xA;  FROM QSECUSRDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY USER_ID">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="3269" N="DataHoundSelector">
        <SG _S="3270" N="ListDataHound">
          <QY P="MsSql" Q="SELECT NAME, STATUS, RESULT_MESSAGE, SERVER_IP, SERVER_PORT&#xD;&#xA;  FROM QSYSDHDDEF  &#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; 	AND STATUS = 'SUCCESS'&#xD;&#xA;   ORDER BY NAME">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="3384" N="CustomRemoteCommandSelector">
        <SG _S="3385" N="ListCustomRemoteCommand">
          <QY P="MsSql" Q="SELECT COMMAND, CMD_DESC, CREATE_TIME&#xD;&#xA;  FROM QRASCUSRCM&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY COMMAND&#xD;&#xA;">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="3447" N="ModelPlcTagSelector">
        <SG _S="3448" N="ListModelPlcTag">
          <QY P="MsSql" Q="SELECT MODEL, MDL_VER, CNT_NAME, SSN_NAME, TAG_NAME, TAG_DESC, PLC_TAG_ADDR, PLC_TAG_TYPE, PLC_TAG_FORMAT, PLC_TAG_ARRAY, PLC_TAG_ALARM&#xD;&#xA;  FROM QRASMDLPTG&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY MODEL, MDL_VER, CNT_NAME, SSN_NAME, TAG_NAME">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="3452" N="BranchReferenceEquipmentVersionSelector">
        <SG _S="3453" N="ListEquipment">
          <QY P="MsSql" Q="SELECT A.EQP_NAME, ISNULL(B.EQP_DESC, ' ') AS EQP_DESC, A.ACTIVE_VER, A.APPLIED_VER, A.LAST_VER&#xD;&#xA;  FROM QBWSIBNEQP A&#xD;&#xA;  LEFT JOIN QRASEQPDEF B&#xD;&#xA;    ON A.FACTORY     = B.FACTORY&#xD;&#xA;   AND A.EQP_NAME    = B.EQP_NAME&#xD;&#xA;   AND B.DELETE_FLAG = 'N'&#xD;&#xA; WHERE A.FACTORY     = @factory&#xD;&#xA;   AND A.IBN_NAME    = @ibn_name&#xD;&#xA; ORDER BY A.EQP_NAME ">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
        <SG _S="3454" N="ListVersion">
          <QY P="MsSql" Q="SELECT TAGSET_VER, TAGSET_VER_DESC, ACTIVE, BUILD_MDL, BUILD_MDL_VER&#xD;&#xA;  FROM QBWSIBNVER&#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA;   AND IBN_NAME  = @ibn_name&#xD;&#xA;   AND EQP_NAME  = @eqp_name&#xD;&#xA; ORDER BY TAGSET_VER DESC">
            <QP N="factory" />
            <QP N="ibn_name" />
            <QP N="eqp_name" />
          </QY>
        </SG>
        <SG _S="3536" N="ListBranch">
          <QY P="MsSql" Q="SELECT IBN_NAME, IBN_DESC, BROKER, TOPIC&#xD;&#xA;  FROM QBWSIBNDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY IBN_NAME">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="3519" N="BranchEquipmentSelector">
        <SG _S="3520" N="ListBranch">
          <QY P="MsSql" Q="SELECT IBN_NAME, IBN_DESC&#xD;&#xA;  FROM QBWSIBNDEF &#xD;&#xA; WHERE FACTORY   = @factory&#xD;&#xA; ORDER BY IBN_NAME">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3521" N="ListEquipment">
          <QY P="MsSql" Q="SELECT IBN.EQP_NAME, ISNULL(EQP.EQP_DESC, ' ') EQP_DESC, IBN.IBN_NAME, IBN.ENABLE, IBN.NEED_ACTION, IBN.ACTIVE_VER, IBN.APPLIED_VER, IBN.LAST_VER&#xD;&#xA;  FROM QBWSIBNEQP IBN&#xD;&#xA;  LEFT JOIN QRASEQPDEF EQP&#xD;&#xA;    ON IBN.FACTORY  = EQP.FACTORY&#xD;&#xA;   AND IBN.EQP_NAME =  EQP.EQP_NAME&#xD;&#xA; WHERE IBN.FACTORY  = @factory&#xD;&#xA;   AND IBN.IBN_NAME = ISNULL(@ibn_name, IBN.IBN_NAME)&#xD;&#xA; ORDER BY IBN.EQP_NAME">
            <QP N="factory" />
            <QP N="ibn_name" />
          </QY>
        </SG>
      </F>
      <F _S="3562" N="DeviceSelector">
        <SG _S="3564" N="ListDevice">
          <QY P="MsSql" Q="SELECT DVC_ID, DVC_DESC, IP_ADDRESS, MAC_ADDRESS, DOMAIN, COMPUTER_NAME, MANUFACTURER, MODEL&#xD;&#xA;  FROM QBWSDVCDEF&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY DVC_ID">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="3611" N="PlcTagSetGroupSelector">
        <SG _S="3612" N="ListPlcTagSetGroup">
          <QY P="MsSql" Q="SELECT GROUP_NAME, GROUP_DESC&#xD;&#xA;  FROM QSYSPTMGRP&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="3613" N="PlcTagSetSelector">
        <SG _S="3614" N="ListPlcTagSet">
          <QY P="MsSql" Q="SELECT TAGSET_NAME, TAGSET_DESC&#xD;&#xA;  FROM QSYSPTMDEF&#xD;&#xA; WHERE FACTORY     = @factory   &#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA; ORDER BY TAGSET_NAME">
            <QP N="factory" />
            <QP N="tagset_group" />
          </QY>
        </SG>
      </F>
      <F _S="3615" N="PlcTagSetVerSelector">
        <SG _S="3616" N="ListPlcTagSetVer">
          <QY P="MsSql" Q="SELECT TAGSET_VER, TAGSET_VER_DESC&#xD;&#xA;  FROM QSYSPTMVER&#xD;&#xA; WHERE FACTORY     = @factory   &#xD;&#xA;   AND TAGSET_GROUP = @tagset_group&#xD;&#xA;   AND TAGSET_NAME = @tagset_name&#xD;&#xA; ORDER BY TAGSET_VER DESC">
            <QP N="factory" />
            <QP N="tagset_group" />
            <QP N="tagset_name" />
          </QY>
        </SG>
      </F>
      <F _S="3666" N="PlcModelSelector">
        <SG _S="3667" N="ListPlcModel">
          <QY P="MsSql" Q="SELECT PLC_MAKER, PLC_MODEL&#xD;&#xA;  FROM QSYSPTMMPS&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY PLC_MAKER, PLC_MODEL">
            <QP N="factory" />
          </QY>
        </SG>
      </F>
      <F _S="3677" N="PlcPresetSelector">
        <SG _S="3678" N="ListPresetGroup">
          <QY P="MsSql" Q="SELECT PRESET_GROUP, PRESET_GROUP_DESC&#xD;&#xA;  FROM QSYSPTMPRG&#xD;&#xA; WHERE FACTORY = @factory&#xD;&#xA; ORDER BY PRESET_GROUP">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="3679" N="ListPreset">
          <QY P="MsSql" Q="SELECT PRESET_GROUP, PRESET_NAME, PRESET_DESC, PRESET_PLC_MAKER, PRESET_PLC_MODEL, ADDRESS_RADIX, ALLOW_EMPTY_ADDRESS, IS_ALARM&#xD;&#xA;  FROM QSYSPTMPRS&#xD;&#xA; WHERE FACTORY          = @factory&#xD;&#xA;   AND PRESET_GROUP     = ISNULL(@preset_group, PRESET_GROUP)&#xD;&#xA;   AND PRESET_PLC_MAKER = @preset_plc_maker&#xD;&#xA;   AND PRESET_PLC_MODEL = @preset_plc_model">
            <QP N="factory" />
            <QP N="preset_group" />
            <QP N="preset_plc_maker" />
            <QP N="preset_plc_model" />
          </QY>
        </SG>
      </F>
    </M>
    <M _S="2" N="Setup">
      <F _S="3" N="Factory" D="Q">
        <SG _S="500" N="HasFactory" D="Q">
          <QY P="MsSql" Q="SELECT FACTORY&#xD;&#xA;  FROM QSYSFACDEF&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="22" N="ListFactory" D="Q">
          <QY P="MsSql" Q="SELECT FACTORY, FAC_DESC, CREATE_TIME&#xD;&#xA;  FROM QSYSFACDEF&#xD;&#xA; ORDER BY FACTORY" />
        </SG>
        <SG _S="24" N="SearchFactory" D="O">
          <QY P="MsSql" Q="SELECT FACTORY, FAC_DESC,&#xD;&#xA;       SVR_CPU_DANGER_RATE, SVR_CPU_CAUTION_RATE, SVR_MEMORY_DANGER_RATE, SVR_MEMORY_CAUTION_RATE, SVR_DISK_DANGER_RATE, SVR_DISK_CAUTION_RATE,&#xD;&#xA;       EAP_CPU_DANGER_RATE, EAP_CPU_CAUTION_RATE, EAP_MEMORY_DANGER_RATE, EAP_MEMORY_CAUTION_RATE, EAP_DISK_DANGER_RATE, EAP_DISK_CAUTION_RATE,&#xD;&#xA;       EAP_RELOAD_LIMIT&#xD;&#xA;  FROM QSYSFACDEF&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="711" N="CountUserEvent" D="Q">
          <QY P="MsSql" Q="SELECT COUNT(EVENT_ID) AS COUNT&#xD;&#xA;  FROM QSECUSREVT&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="712" N="CountServerEvent" D="Q">
          <QY P="MsSql" Q="SELECT COUNT(EVENT_ID) AS COUNT&#xD;&#xA;  FROM QSYSSVREVT&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="713" N="CountEapEvent" D="Q">
          <QY P="MsSql" Q="SELECT COUNT(EVENT_ID) AS COUNT&#xD;&#xA;  FROM QRASEAPEVT&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="2719" N="CountApplication" D="Q">
          <QY P="MsSql" Q="SELECT COUNT(APP) AS COUNT&#xD;&#xA;  FROM QSECURGAPP&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="628" N="CountServer" D="Q">
          <QY P="MsSql" Q="SELECT COUNT(SERVER) AS COUNT&#xD;&#xA;  FROM QSYSSVRDEF&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="714" N="CountPackage" D="Q">
          <QY P="MsSql" Q="SELECT COUNT(PACKAGE) AS COUNT&#xD;&#xA;  FROM QSYSPKGDEF&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="715" N="CountModel" D="Q">
          <QY P="MsSql" Q="SELECT COUNT(MODEL) AS COUNT&#xD;&#xA;  FROM QSYSMDLDEF&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="716" N="CountLibrary" D="Q">
          <QY P="MsSql" Q="SELECT COUNT(LIBRARY) AS COUNT&#xD;&#xA;  FROM QSYSLIBDEF&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="factory" />
          </QY>
        </SG>
        <SG _S="25" N="InsertFactory" D="Q">
          <QY P="MsSql" Q="INSERT INTO QSYSFACDEF (&#xD;&#xA;   FACTORY,&#xD;&#xA;   FAC_DESC,&#xD;&#xA;   SVR_CPU_DANGER_RATE,&#xD;&#xA;   SVR_CPU_CAUTION_RATE,&#xD;&#xA;   SVR_MEMORY_DANGER_RATE,&#xD;&#xA;   SVR_MEMORY_CAUTION_RATE,&#xD;&#xA;   SVR_DISK_DANGER_RATE,&#xD;&#xA;   SVR_DISK_CAUTION_RATE,   &#xD;&#xA;   EAP_CPU_DANGER_RATE,&#xD;&#xA;   EAP_CPU_CAUTION_RATE,&#xD;&#xA;   EAP_MEMORY_DANGER_RATE,&#xD;&#xA;   EAP_MEMORY_CAUTION_RATE,&#xD;&#xA;   EAP_DISK_DANGER_RATE,&#xD;&#xA;   EAP_DISK_CAUTION_RATE,&#xD;&#xA;   EAP_RELOAD_LIMIT,&#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @fac_desc,&#xD;&#xA;   @svr_cpu_danger_rate,&#xD;&#xA;   @svr_cpu_caution_rate,&#xD;&#xA;   @svr_memory_danger_rate,&#xD;&#xA;   @svr_memory_caution_rate,&#xD;&#xA;   @svr_disk_danger_rate,&#xD;&#xA;   @svr_disk_caution_rate,&#xD;&#xA;   @eap_cpu_danger_rate,&#xD;&#xA;   @eap_cpu_caution_rate,&#xD;&#xA;   @eap_memory_danger_rate,&#xD;&#xA;   @eap_memory_caution_rate,&#xD;&#xA;   @eap_disk_danger_rate,&#xD;&#xA;   @eap_disk_caution_rate,&#xD;&#xA;   @eap_reload_limit,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="fac_desc" />
            <QP N="svr_cpu_danger_rate" />
            <QP N="svr_cpu_caution_rate" />
            <QP N="svr_memory_danger_rate" />
            <QP N="svr_memory_caution_rate" />
            <QP N="svr_disk_danger_rate" />
            <QP N="svr_disk_caution_rate" />
            <QP N="eap_cpu_danger_rate" />
            <QP N="eap_cpu_caution_rate" />
            <QP N="eap_memory_danger_rate" />
            <QP N="eap_memory_caution_rate" />
            <QP N="eap_disk_danger_rate" />
            <QP N="eap_disk_caution_rate" />
            <QP N="eap_reload_limit" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="2715" N="InsertUserGroup" D="Q">
          <QY P="MsSql" Q="INSERT INTO QSECUSRGRP(&#xD;&#xA;   FACTORY,&#xD;&#xA;   USER_GRP,&#xD;&#xA;   USER_GRP_DESC,&#xD;&#xA;   ALL_AUTHORITY,   &#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @user_grp,&#xD;&#xA;   @user_grp_desc,&#xD;&#xA;   @all_authority,   &#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="user_grp" />
            <QP N="user_grp_desc" />
            <QP N="all_authority" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="2714" N="InsertUser" D="Q">
          <QY P="MsSql" Q="INSERT INTO QSECUSRDEF(&#xD;&#xA;   FACTORY,&#xD;&#xA;   USER_ID,&#xD;&#xA;   USER_DESC,&#xD;&#xA;   PASSWORD,&#xD;&#xA;   USER_GRP, &#xD;&#xA;   CREATE_USER_ID,&#xD;&#xA;   CREATE_TIME,&#xD;&#xA;   UPDATE_USER_ID,&#xD;&#xA;   UPDATE_TIME&#xD;&#xA;) VALUES (&#xD;&#xA;   @factory,&#xD;&#xA;   @user_id,&#xD;&#xA;   @user_desc,&#xD;&#xA;   @password,&#xD;&#xA;   @user_grp,&#xD;&#xA;   @create_user_id,&#xD;&#xA;   @create_time,&#xD;&#xA;   @update_user_id,&#xD;&#xA;   @update_time&#xD;&#xA;)">
            <QP N="factory" />
            <QP N="user_id" />
            <QP N="user_desc" />
            <QP N="password" />
            <QP N="user_grp" />
            <QP N="create_user_id" />
            <QP N="create_time" />
            <QP N="update_user_id" />
            <QP N="update_time" />
          </QY>
        </SG>
        <SG _S="7" N="UpdateFactory" D="Q">
          <QY P="MsSql" Q="UPDATE QSYSFACDEF SET&#xD;&#xA;  FAC_DESC                = @fac_desc,&#xD;&#xA;  SVR_CPU_DANGER_RATE     = @svr_cpu_danger_rate,&#xD;&#xA;  SVR_CPU_CAUTION_RATE    = @svr_cpu_caution_rate,&#xD;&#xA;  SVR_MEMORY_DANGER_RATE  = @svr_memory_danger_rate,&#xD;&#xA;  SVR_MEMORY_CAUTION_RATE = @svr_memory_caution_rate,&#xD;&#xA;  SVR_DISK_DANGER_RATE    = @svr_disk_danger_rate,&#xD;&#xA;  SVR_DISK_CAUTION_RATE   = @svr_disk_caution_rate,&#xD;&#xA;  EAP_CPU_DANGER_RATE     = @eap_cpu_danger_rate,&#xD;&#xA;  EAP_CPU_CAUTION_RATE    = @eap_cpu_caution_rate,&#xD;&#xA;  EAP_MEMORY_DANGER_RATE  = @eap_memory_danger_rate,&#xD;&#xA;  EAP_MEMORY_CAUTION_RATE = @eap_memory_caution_rate,&#xD;&#xA;  EAP_DISK_DANGER_RATE    = @eap_disk_danger_rate,&#xD;&#xA;  EAP_DISK_CAUTION_RATE   = @eap_disk_caution_rate,&#xD;&#xA;  EAP_RELOAD_LIMIT        = @eap_reload_limit,&#xD;&#xA;  UPDATE_USER_ID          = @update_user_id,&#xD;&#xA;  UPDATE_TIME             = @update_time&#xD;&#xA; WHERE FACTORY = @factory">
            <QP N="fac_desc" />
            <QP N="svr_cpu_danger_rate" />
            <QP N="svr_cpu_caution_rate" />
            <QP N="svr_memory_danger_rate" />
            <QP N="svr_memory_caution_rate" />
            <QP N="svr_disk_danger_rate" />
            <QP N="svr_disk_caution_rate" />
            <QP N="eap_cpu_danger_rate" />
            <QP N="eap_cpu_caution_rate" />
