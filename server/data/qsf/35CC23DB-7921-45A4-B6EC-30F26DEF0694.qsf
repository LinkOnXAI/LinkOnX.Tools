        <SG _S="3499" N="HasEquipment">
          <QY P="MsSql" Q="SELECT EQP.EQP_NAME, EQP.EAP, &#xD;&#xA;       (CASE WHEN IBN.EQP_NAME IS NOT NULL THEN 'Yes' ELSE 'No' END) AS IS_REG, ISNULL(IBN.ENABLE, 'No') AS IS_ENABLE,&#xD;&#xA;	   ISNULL(IBN.NEED_ACTION, ' ') AS NEED_ACTION,&#xD;&#xA;	   ISNULL(IBN.ACTIVE_VER, 0) AS ACTIVE_VER, ISNULL(IBN.LAST_VER, 0) AS LAST_VER, ISNULL(IBN.APPLIED_VER, 0) AS APPLIED_VER&#xD;&#xA;  FROM QRASEQPDEF EQP&#xD;&#xA;  LEFT JOIN QBWSIBNEQP IBN&#xD;&#xA;    ON EQP.FACTORY     = IBN.FACTORY&#xD;&#xA;   AND EQP.EQP_NAME    = IBN.EQP_NAME&#xD;&#xA;   AND IBN.IBN_NAME    = @ibn_name&#xD;&#xA; WHERE EQP.FACTORY     = @factory&#xD;&#xA;   AND EQP.EQP_NAME    = @eqp_name&#xD;&#xA;   AND EQP.DELETE_FLAG = 'N'">
            <QP N="ibn_name" />
            <QP N="factory" />
            <QP N="eqp_name" />
          </QY>
